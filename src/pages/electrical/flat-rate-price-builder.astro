---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/electricalTools';

const tool = getToolBySlug('flat-rate-price-builder')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is flat rate pricing in electrical work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Flat rate pricing means charging a fixed price per repair or installation regardless of how long it takes. Instead of billing hourly, you quote one price that covers parts, labor, and overhead. The customer knows the total cost upfront, which increases trust and close rates. Most successful electrical contractors use flat rate pricing for common jobs like outlet installations, breaker replacements, and ceiling fan installs."
      }
    },
    {
      "@type": "Question",
      "name": "How do I build an electrical flat rate price book?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start by listing your most common repairs and installations. For each task, calculate your actual parts cost, apply a markup (typically 150-300% depending on the part), add your labor at a billable rate that covers wages plus overhead, and include a miscellaneous materials allowance for wire nuts, tape, and connectors. Compare your prices to national averages to make sure you are competitive but profitable. Update your price book quarterly as material costs change."
      }
    },
    {
      "@type": "Question",
      "name": "Is flat rate better than time and material for electricians?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Flat rate pricing outperforms time and material billing for most electrical service companies. It eliminates the customer's fear of a runaway bill, which increases close rates by 20-40%. Electricians who work efficiently earn more per hour since the price does not decrease when they finish faster. It also simplifies dispatching and cash flow forecasting. Time and material can still make sense for complex troubleshooting or commercial work where scope is unpredictable."
      }
    },
    {
      "@type": "Question",
      "name": "What markup should electricians use for flat rate pricing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For small commodity parts like outlets, switches, and wire nuts, a 250-300% markup is standard in the electrical industry. For mid-range items like breakers and GFCI devices, 150-250% markup is typical. For major equipment like panels and sub-panels, 75-125% markup is common. Your markup needs to cover not just the part cost but also your truck stock inventory carrying cost, warranty risk, and the expertise to diagnose and install correctly per NEC code."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="flat-rate-calc">
    <!-- Input Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="repair-type">Task Type</label>
        <select id="repair-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="outlet-install">Outlet installation</option>
          <option value="switch-replace">Switch replacement</option>
          <option value="breaker-replace">Breaker replacement</option>
          <option value="gfci-install">GFCI outlet install</option>
          <option value="new-circuit">New circuit run</option>
          <option value="ceiling-fan">Ceiling fan install</option>
          <option value="dimmer-install">Dimmer switch install</option>
          <option value="sub-panel">Sub-panel install</option>
          <option value="service-upgrade">200A service upgrade</option>
          <option value="custom">Custom (enter your own)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="parts-cost">Parts Cost ($)</label>
        <input type="number" id="parts-cost" value="2" min="0" max="50000" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="parts-markup">Parts Markup (%)</label>
        <input type="number" id="parts-markup" value="250" min="0" max="1000" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="labor-hours">Estimated Labor Hours</label>
        <input type="number" id="labor-hours" value="0.75" min="0" max="40" step="0.25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="billable-rate">Billable Rate ($/hr)</label>
        <input type="number" id="billable-rate" value="115" min="0" max="500" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="misc-materials">Misc Materials ($)</label>
        <input type="number" id="misc-materials" value="12" min="0" max="500" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="loaded-wage">Your Loaded Wage ($/hr)</label>
        <input type="number" id="loaded-wage" value="32" min="0" max="200" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Electrician hourly cost including burden (taxes, insurance, benefits)</p>
      </div>
    </div>


    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Your Flat Rate Price</h3>

      <!-- Primary Result -->
      <div class="bg-bg-dark rounded-xl p-6 text-center mb-6 border border-accent/30">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Flat Rate Price</div>
        <div id="result-flat-rate" class="font-heading font-extrabold text-5xl text-accent">--</div>
        <div id="result-repair-label" class="text-text-muted text-sm mt-2">--</div>
      </div>

      <!-- National Average Comparison -->
      <div id="national-avg-section" class="mb-6">
        <div class="flex justify-between items-center mb-2">
          <span class="text-text-secondary text-sm font-medium">National Average Range</span>
          <span id="result-national-range" class="text-text-secondary text-sm font-medium">--</span>
        </div>
        <div class="relative h-8 bg-bg-dark rounded-full overflow-hidden border border-border">
          <div id="avg-range-bar" class="absolute top-0 h-full bg-[rgba(96,165,250,0.2)] rounded-full border border-[rgba(96,165,250,0.4)]"></div>
          <div id="your-price-marker" class="absolute top-1/2 -translate-y-1/2 w-4 h-4 bg-accent rounded-full border-2 border-white shadow-lg z-10" style="left: 50%"></div>
        </div>
        <div class="flex justify-between mt-1">
          <span id="bar-low" class="text-text-muted text-xs">--</span>
          <span class="text-accent text-xs font-medium">Your Price</span>
          <span id="bar-high" class="text-text-muted text-xs">--</span>
        </div>
      </div>

      <!-- Warning -->
      <div id="undercharge-warning" class="hidden mb-6 bg-[rgba(251,191,36,0.1)] border border-[rgba(251,191,36,0.3)] rounded-lg p-4">
        <p class="text-[#FBBF24] text-sm font-medium">&#9888; You may be undercharging for this task. Your price is more than 20% below the national average low end.</p>
      </div>

      <!-- Breakdown Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Parts Revenue</div>
          <div id="result-parts-rev" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Labor Revenue</div>
          <div id="result-labor-rev" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Misc</div>
          <div id="result-misc" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Your Cost</div>
          <div id="result-cost" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Profit</div>
          <div id="result-profit" class="font-heading font-extrabold text-xl text-[#34D399]">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Profit Margin</div>
          <div id="result-margin" class="font-heading font-extrabold text-xl text-[#34D399]">--</div>
        </div>
      </div>

      <p class="text-text-muted text-sm italic">Prices are estimates. Adjust parts cost and markup to match your local supplier pricing. Compare to national averages to stay competitive.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Tool</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Select the task type.</strong> Choose from the pre-built electrical task library. Parts cost and labor hours auto-fill based on industry averages. Pick "Custom" to enter your own values from scratch.</p>
          <p><strong class="text-text-primary">2. Adjust parts cost and markup.</strong> Override the default parts cost with your actual supplier pricing. Small commodity parts like outlets and switches typically carry 250% markup. Panels and sub-panels use 75-125%.</p>
          <p><strong class="text-text-primary">3. Set your labor rate and hours.</strong> Your billable rate should cover electrician wages, overhead, truck costs, and profit. Adjust labor hours based on your team's average completion time for this task.</p>
          <p><strong class="text-text-primary">4. Review your flat rate against the national average.</strong> The comparison bar shows where your price falls relative to the national range. If you are more than 20% below the low end, you are likely leaving money on the table.</p>
        </div>
      </section>

      <!-- Why Flat Rate Pricing Works -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Why Flat Rate Pricing Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>Hourly billing penalizes your best electricians. A journeyman who replaces a breaker in 30 minutes earns your company half the revenue of a slower electrician who takes an hour. Flat rate pricing flips that equation. Your price reflects the <strong class="text-text-primary">value of the work</strong>, not the speed of the electrician.</p>
          <p>Customers prefer flat rate because it eliminates uncertainty. When a homeowner hears "it'll be $115 an hour plus parts," their anxiety spikes. Every minute the electrician spends on the phone or walking to the truck feels like money burning. A flat rate quote of $150 to install a GFCI outlet removes that stress entirely. <strong class="text-text-primary">Higher close rates follow directly.</strong></p>
          <p>Flat rate also makes your business predictable. You know exactly what revenue each service call will generate before the electrician leaves the shop. That makes dispatching, payroll forecasting, and profit tracking dramatically simpler. Most electrical companies that switch from hourly to flat rate see revenue increase 15-30% within the first year with no additional marketing spend.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Building your price book from scratch.</strong> You are starting a new electrical company or transitioning from time-and-material to flat rate. Use this tool to price out every common task, compare to national averages, and build a complete price book your electricians can use in the field.</p>
          <p><strong class="text-text-primary">Quarterly price updates.</strong> Material costs change with copper prices and supply chain shifts. Run your top 10 tasks through the builder each quarter with updated supplier pricing to make sure your flat rates still hit your profit margin targets.</p>
          <p><strong class="text-text-primary">Training new electricians on pricing.</strong> Show a new hire exactly how the flat rate breaks down: parts revenue, labor revenue, cost, and profit. When electricians understand the math, they present prices with more confidence and close more jobs.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is flat rate pricing in electrical work?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Flat rate pricing means charging a fixed price per repair or installation regardless of how long it takes. Instead of billing hourly, you quote one price that covers parts, labor, and overhead. The customer knows the total cost upfront, which increases trust and close rates. Most successful electrical contractors use flat rate pricing for common jobs like outlet installations, breaker replacements, and ceiling fan installs.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I build an electrical flat rate price book?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Start by listing your most common repairs and installations. For each task, calculate your actual parts cost, apply a markup (typically 150-300% depending on the part), add your labor at a billable rate that covers wages plus overhead, and include a miscellaneous materials allowance for wire nuts, tape, and connectors. Compare your prices to national averages to make sure you are competitive but profitable. Update your price book quarterly as material costs change.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Is flat rate better than time and material for electricians?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Flat rate pricing outperforms time and material billing for most electrical service companies. It eliminates the customer's fear of a runaway bill, which increases close rates by 20-40%. Electricians who work efficiently earn more per hour since the price does not decrease when they finish faster. It also simplifies dispatching and cash flow forecasting. Time and material can still make sense for complex troubleshooting or commercial work where scope is unpredictable.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What markup should electricians use for flat rate pricing?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">For small commodity parts like outlets, switches, and wire nuts, a 250-300% markup is standard in the electrical industry. For mid-range items like breakers and GFCI devices, 150-250% markup is typical. For major equipment like panels and sub-panels, 75-125% markup is common. Your markup needs to cover not just the part cost but also your truck stock inventory carrying cost, warranty risk, and the expertise to diagnose and install correctly per NEC code.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // Task library data - electrical tasks
  const taskLibrary: Record<string, { partsCost: number; laborHours: number; markup: number; avgLow: number; avgHigh: number; label: string }> = {
    'outlet-install':   { partsCost: 2,   laborHours: 0.75, markup: 250, avgLow: 120,  avgHigh: 200,  label: 'Outlet installation' },
    'switch-replace':   { partsCost: 3,   laborHours: 0.5,  markup: 250, avgLow: 100,  avgHigh: 180,  label: 'Switch replacement' },
    'breaker-replace':  { partsCost: 8,   laborHours: 0.75, markup: 200, avgLow: 150,  avgHigh: 250,  label: 'Breaker replacement' },
    'gfci-install':     { partsCost: 12,  laborHours: 0.75, markup: 200, avgLow: 130,  avgHigh: 220,  label: 'GFCI outlet install' },
    'new-circuit':      { partsCost: 25,  laborHours: 2.5,  markup: 150, avgLow: 250,  avgHigh: 450,  label: 'New circuit run' },
    'ceiling-fan':      { partsCost: 85,  laborHours: 1.5,  markup: 100, avgLow: 180,  avgHigh: 350,  label: 'Ceiling fan install' },
    'dimmer-install':   { partsCost: 18,  laborHours: 0.5,  markup: 200, avgLow: 100,  avgHigh: 200,  label: 'Dimmer switch install' },
    'sub-panel':        { partsCost: 150, laborHours: 4,    markup: 100, avgLow: 500,  avgHigh: 800,  label: 'Sub-panel install' },
    'service-upgrade':  { partsCost: 350, laborHours: 8,    markup: 75,  avgLow: 1500, avgHigh: 3000, label: '200A service upgrade' },
    'custom':           { partsCost: 0,   laborHours: 0,    markup: 250, avgLow: 0,    avgHigh: 0,    label: 'Custom task' },
  };

  const fmt = (n: number) => '$' + n.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  const fmtDec = (n: number) => '$' + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  function onRepairTypeChange() {
    const repairType = (document.getElementById('repair-type') as HTMLSelectElement).value;
    const task = taskLibrary[repairType];
    if (!task) return;

    (document.getElementById('parts-cost') as HTMLInputElement).value = String(task.partsCost);
    (document.getElementById('parts-markup') as HTMLInputElement).value = String(task.markup);
    (document.getElementById('labor-hours') as HTMLInputElement).value = String(task.laborHours);
  }

  function calculate() {
    const repairType = (document.getElementById('repair-type') as HTMLSelectElement).value;
    const partsCost = parseFloat((document.getElementById('parts-cost') as HTMLInputElement).value) || 0;
    const partsMarkup = parseFloat((document.getElementById('parts-markup') as HTMLInputElement).value) || 0;
    const laborHours = parseFloat((document.getElementById('labor-hours') as HTMLInputElement).value) || 0;
    const billableRate = parseFloat((document.getElementById('billable-rate') as HTMLInputElement).value) || 0;
    const miscMaterials = parseFloat((document.getElementById('misc-materials') as HTMLInputElement).value) || 0;
    const loadedWage = parseFloat((document.getElementById('loaded-wage') as HTMLInputElement).value) || 0;

    const task = taskLibrary[repairType];

    // Formula: Flat_Rate = (Parts_Cost x (1 + Parts_Markup/100)) + (Labor_Hours x Billable_Rate) + Misc_Materials
    const partsRevenue = partsCost * (1 + partsMarkup / 100);
    const laborRevenue = laborHours * billableRate;
    const flatRate = partsRevenue + laborRevenue + miscMaterials;

    // Cost: actual parts + loaded wage * hours
    const totalCost = partsCost + (loadedWage * laborHours);
    const profit = flatRate - totalCost;
    const margin = flatRate > 0 ? (profit / flatRate) * 100 : 0;

    // Display primary result
    document.getElementById('result-flat-rate')!.textContent = fmt(Math.round(flatRate));
    document.getElementById('result-repair-label')!.textContent = task ? task.label : 'Custom task';

    // Breakdown
    document.getElementById('result-parts-rev')!.textContent = fmtDec(partsRevenue);
    document.getElementById('result-labor-rev')!.textContent = fmtDec(laborRevenue);
    document.getElementById('result-misc')!.textContent = fmtDec(miscMaterials);
    document.getElementById('result-cost')!.textContent = fmtDec(totalCost);
    document.getElementById('result-profit')!.textContent = fmtDec(profit);
    document.getElementById('result-margin')!.textContent = margin.toFixed(1) + '%';

    // Color profit/margin based on positive/negative
    const profitEl = document.getElementById('result-profit')!;
    const marginEl = document.getElementById('result-margin')!;
    if (profit < 0) {
      profitEl.className = 'font-heading font-extrabold text-xl text-red-400';
      marginEl.className = 'font-heading font-extrabold text-xl text-red-400';
    } else {
      profitEl.className = 'font-heading font-extrabold text-xl text-[#34D399]';
      marginEl.className = 'font-heading font-extrabold text-xl text-[#34D399]';
    }

    // National average comparison
    const avgSection = document.getElementById('national-avg-section')!;
    const warning = document.getElementById('undercharge-warning')!;

    if (task && task.avgLow > 0) {
      avgSection.classList.remove('hidden');

      const avgLow = task.avgLow;
      const avgHigh = task.avgHigh;

      document.getElementById('result-national-range')!.textContent = fmt(avgLow) + ' - ' + fmt(avgHigh);

      // Bar visualization
      const barMin = avgLow * 0.6;
      const barMax = avgHigh * 1.4;
      const barRange = barMax - barMin;

      // Position the average range band
      const rangeLeftPct = ((avgLow - barMin) / barRange) * 100;
      const rangeWidthPct = ((avgHigh - avgLow) / barRange) * 100;
      const rangeBar = document.getElementById('avg-range-bar')!;
      rangeBar.style.left = rangeLeftPct + '%';
      rangeBar.style.width = rangeWidthPct + '%';

      // Position the user's price marker
      const pricePct = Math.max(2, Math.min(98, ((flatRate - barMin) / barRange) * 100));
      const marker = document.getElementById('your-price-marker')!;
      marker.style.left = pricePct + '%';
      marker.style.transform = 'translate(-50%, -50%)';

      // Bar labels
      document.getElementById('bar-low')!.textContent = fmt(avgLow);
      document.getElementById('bar-high')!.textContent = fmt(avgHigh);

      // Undercharge warning: >20% below national avg low
      if (flatRate < avgLow * 0.8) {
        warning.classList.remove('hidden');
      } else {
        warning.classList.add('hidden');
      }
    } else {
      avgSection.classList.add('hidden');
      warning.classList.add('hidden');
    }

  }

  // Wire up event listeners
  document.getElementById('repair-type')?.addEventListener('change', () => {
    onRepairTypeChange();
    calculate();
  });


  // Auto-calculate on any input change
  document.querySelectorAll('#flat-rate-calc input, #flat-rate-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  // Calculate on load with defaults
  calculate();
</script>
