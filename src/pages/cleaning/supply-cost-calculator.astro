---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/cleaningTools';

const tool = getToolBySlug('supply-cost-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much do cleaning supplies cost per job?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most residential cleaning jobs use $5-$15 in supplies. This includes chemical cleaners ($2-$5 per job when buying concentrates), paper goods like trash bags and paper towels ($1-$3), equipment wear like microfiber cloth replacement and mop heads ($1-$3), and PPE like gloves ($0.50-$2). The exact amount depends on property size, job type, and whether you use concentrates or ready-to-use products."
      }
    },
    {
      "@type": "Question",
      "name": "What percentage of revenue should go to cleaning supplies?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cleaning supply costs should stay between 3-8% of your job revenue. If you are spending more than 8%, you may be over-applying product, using expensive ready-to-use bottles instead of concentrates, or not tracking waste. If you are under 3%, double-check that you are using enough product to deliver quality results. The sweet spot for most residential cleaning companies is 5-6%."
      }
    },
    {
      "@type": "Question",
      "name": "How do I reduce cleaning supply costs without sacrificing quality?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Buy concentrates in bulk and dilute to the manufacturer's recommended ratio instead of using ready-to-use sprays. Use microfiber cloths instead of paper towels for most surfaces. Train your team on proper product application so they are not double-spraying. Track per-clean supply usage with a cost calculator so you can spot waste early. Switch to refillable spray bottles and buy cleaning chemicals by the gallon or case."
      }
    },
    {
      "@type": "Question",
      "name": "What cleaning supplies should I stock for a residential cleaning business?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Essential supplies include all-purpose cleaner, disinfectant, glass cleaner, floor cleaner, toilet bowl cleaner, trash bags, microfiber cloths, mop heads, vacuum bags, rubber gloves, scrub sponges, and dusting spray. For deep cleans and move-outs, add oven cleaner, grout cleaner, and heavy-duty degreaser. Buy the core chemicals as concentrates and the disposables in bulk to keep your per-clean cost as low as possible."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="supply-calc">
    <!-- Revenue Input -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Job Revenue</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="avg-job-revenue">Avg Revenue per Job ($)</label>
        <input type="number" id="avg-job-revenue" value="175" min="0" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="jobs-per-week">Jobs per Week</label>
        <input type="number" id="jobs-per-week" value="15" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="weeks-per-year">Working Weeks per Year</label>
        <input type="number" id="weeks-per-year" value="50" min="1" max="52" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Supply Categories -->
    <h3 class="font-heading font-bold text-lg mb-2 text-text-primary">Supply Costs per Clean</h3>
    <p class="text-sm text-text-muted mb-4">Enter your estimated cost per cleaning job for each category. Use the quick-lookup table below for reference pricing.</p>

    <!-- Chemicals & Cleaners -->
    <div class="bg-bg-card border border-border rounded-lg p-5 mb-4">
      <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-accent mb-4">Chemicals &amp; Cleaners</h4>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-all-purpose">All-Purpose Cleaner</label>
          <input type="number" id="cost-all-purpose" value="1.50" min="0" step="0.25" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-disinfectant">Disinfectant</label>
          <input type="number" id="cost-disinfectant" value="1.25" min="0" step="0.25" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-glass-cleaner">Glass Cleaner</label>
          <input type="number" id="cost-glass-cleaner" value="0.75" min="0" step="0.25" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-floor-cleaner">Floor Cleaner</label>
          <input type="number" id="cost-floor-cleaner" value="1.00" min="0" step="0.25" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-toilet-cleaner">Toilet Bowl Cleaner</label>
          <input type="number" id="cost-toilet-cleaner" value="0.60" min="0" step="0.10" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-dusting-spray">Dusting Spray</label>
          <input type="number" id="cost-dusting-spray" value="0.50" min="0" step="0.10" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </div>

    <!-- Paper Goods -->
    <div class="bg-bg-card border border-border rounded-lg p-5 mb-4">
      <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-accent mb-4">Paper Goods &amp; Disposables</h4>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-trash-bags">Trash Bags</label>
          <input type="number" id="cost-trash-bags" value="1.50" min="0" step="0.25" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-paper-towels">Paper Towels</label>
          <input type="number" id="cost-paper-towels" value="0.75" min="0" step="0.25" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-scrub-sponges">Scrub Sponges</label>
          <input type="number" id="cost-scrub-sponges" value="0.30" min="0" step="0.10" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </div>

    <!-- Equipment Wear -->
    <div class="bg-bg-card border border-border rounded-lg p-5 mb-4">
      <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-accent mb-4">Equipment Wear</h4>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-microfiber">Microfiber Cloths (per-clean wear)</label>
          <input type="number" id="cost-microfiber" value="0.75" min="0" step="0.10" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-mop-heads">Mop Head Wear</label>
          <input type="number" id="cost-mop-heads" value="0.50" min="0" step="0.10" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-vacuum-bags">Vacuum Bags / Filters</label>
          <input type="number" id="cost-vacuum-bags" value="0.40" min="0" step="0.10" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </div>

    <!-- PPE -->
    <div class="bg-bg-card border border-border rounded-lg p-5 mb-8">
      <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-accent mb-4">PPE (Personal Protective Equipment)</h4>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-gloves">Rubber Gloves</label>
          <input type="number" id="cost-gloves" value="0.75" min="0" step="0.10" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-masks">Masks (if used)</label>
          <input type="number" id="cost-masks" value="0" min="0" step="0.10" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1" for="cost-other-ppe">Other PPE</label>
          <input type="number" id="cost-other-ppe" value="0" min="0" step="0.10" class="supply-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Per-Clean Cost Breakdown</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total per Clean</div>
          <div id="result-per-clean" class="font-heading font-extrabold text-3xl text-accent">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Chemicals</div>
          <div id="result-chemicals" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Paper Goods</div>
          <div id="result-paper" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Equipment</div>
          <div id="result-equipment" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">PPE</div>
          <div id="result-ppe" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
      </div>

      <h3 class="font-heading font-bold text-xl mb-6">Annual Projection</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Weekly Supply Cost</div>
          <div id="result-weekly" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Monthly Supply Cost</div>
          <div id="result-monthly" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Annual Supply Budget</div>
          <div id="result-annual" class="font-heading font-extrabold text-3xl text-accent">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">% of Revenue</div>
          <div id="result-pct-revenue" class="font-heading font-extrabold text-3xl">&mdash;</div>
        </div>
      </div>

      <!-- Benchmark -->
      <div class="bg-bg-dark rounded-xl p-5 mt-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Benchmark &mdash; Supply Cost as % of Revenue: 3% &ndash; 8%</h4>
        <div class="relative h-6 bg-bg-card rounded-full overflow-hidden border border-border">
          <div class="absolute inset-0 flex">
            <div class="w-[30%] bg-[rgba(251,191,36,0.1)] border-r border-border"></div>
            <div class="w-[50%] bg-[rgba(52,211,153,0.15)] border-r border-border"></div>
            <div class="w-[20%] bg-[rgba(239,68,68,0.1)]"></div>
          </div>
          <div id="benchmark-marker" class="absolute top-0 h-full w-1 bg-accent rounded transition-all" style="left: 0%"></div>
        </div>
        <div class="flex justify-between text-xs text-text-muted mt-2">
          <span>0%</span>
          <span>3%</span>
          <span>5%</span>
          <span>8%</span>
          <span>12%+</span>
        </div>
        <p id="benchmark-text" class="text-text-secondary text-sm mt-3">Your supply cost: &mdash;</p>
      </div>

      <!-- Quick Lookup -->
      <div class="bg-bg-dark rounded-xl p-5 mt-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Quick Lookup &mdash; Common Cleaning Supplies</h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">All-Purpose Cleaner (concentrate/gal)</span>
            <span class="text-text-primary font-medium">$8 &ndash; $18</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Disinfectant (concentrate/gal)</span>
            <span class="text-text-primary font-medium">$10 &ndash; $22</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Glass Cleaner (concentrate/gal)</span>
            <span class="text-text-primary font-medium">$6 &ndash; $14</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Floor Cleaner (concentrate/gal)</span>
            <span class="text-text-primary font-medium">$10 &ndash; $25</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Toilet Bowl Cleaner (per bottle)</span>
            <span class="text-text-primary font-medium">$2 &ndash; $5</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Trash Bags (per bag, 13-gal)</span>
            <span class="text-text-primary font-medium">$0.15 &ndash; $0.40</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Microfiber Cloths (each)</span>
            <span class="text-text-primary font-medium">$1 &ndash; $3</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Mop Heads (each)</span>
            <span class="text-text-primary font-medium">$5 &ndash; $12</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Vacuum Bags (each)</span>
            <span class="text-text-primary font-medium">$3 &ndash; $8</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Rubber Gloves (per pair)</span>
            <span class="text-text-primary font-medium">$0.50 &ndash; $2</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Scrub Sponges (each)</span>
            <span class="text-text-primary font-medium">$0.50 &ndash; $1.50</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Dusting Spray (per can)</span>
            <span class="text-text-primary font-medium">$3 &ndash; $7</span>
          </div>
        </div>
        <p class="text-text-muted text-xs mt-3 italic">Buying concentrates in bulk typically reduces per-clean chemical costs by 40-60% vs ready-to-use bottles.</p>
      </div>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter your revenue and volume.</strong> Set your average revenue per job, how many jobs you complete per week, and working weeks per year. This establishes the baseline for calculating supply cost as a percentage of revenue.</p>
          <p><strong class="text-text-primary">2. Fill in per-clean costs by category.</strong> For each supply item, enter your estimated cost per cleaning job. If you buy a gallon of all-purpose concentrate for $12 and it lasts 20 jobs, your per-clean cost is $0.60. Use the quick-lookup table at the bottom for reference pricing.</p>
          <p><strong class="text-text-primary">3. Review the breakdown.</strong> The calculator shows your total per-clean supply cost, broken down by category. Below that, see your weekly, monthly, and annual supply budget alongside the percentage of revenue spent on supplies.</p>
          <p><strong class="text-text-primary">4. Compare to the benchmark.</strong> The industry benchmark for cleaning supply costs is 3-8% of revenue. If you are above 8%, look for areas to cut. If below 3%, confirm you are using enough product to deliver quality results.</p>
        </div>
      </section>

      <!-- Understanding Supply Costs -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Understanding Supply Costs for Cleaning Businesses</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>Supply costs are one of the most overlooked expenses in residential cleaning businesses. Most owners know their labor cost per hour, but very few track what they spend per clean on chemicals, paper goods, equipment replacement, and PPE. The result is that supply waste silently eats into profit margins.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Per-Clean Supply Cost = Chemicals + Paper Goods + Equipment Wear + PPE</p>
            <p>Annual Supply Budget = Per-Clean Cost x Jobs/Week x Working Weeks</p>
            <p>Supply % of Revenue = (Annual Supply Budget / Annual Revenue) x 100</p>
          </div>
          <p><strong class="text-text-primary">Chemicals are the biggest variable.</strong> The difference between using ready-to-use spray bottles at $4 each versus concentrate diluted at $0.60 per clean is enormous when multiplied across hundreds of jobs per year. A cleaning company doing 15 jobs per week saves over $2,500 annually by switching from ready-to-use to concentrates.</p>
          <p><strong class="text-text-primary">Equipment wear adds up.</strong> Microfiber cloths last 200-300 washes but eventually lose effectiveness. Mop heads need replacement every 50-100 uses. Vacuum bags or filters have a per-use cost. These are easy to ignore because you pay for them infrequently, but the per-clean amortized cost should be tracked.</p>
          <p><strong class="text-text-primary">PPE is non-negotiable.</strong> Rubber gloves protect your team from chemicals and biological hazards. Even disposable gloves at $0.50 per pair per clean add up to $375 per year at 15 jobs per week. Budget for them rather than skipping them.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Setting your annual supply budget.</strong> At the start of each year or quarter, plug in your current costs and projected job volume. The annual budget number tells you exactly how much to allocate for supplies so you can plan purchasing, negotiate bulk discounts, and set aside the right amount of cash.</p>
          <p><strong class="text-text-primary">Pricing new service types.</strong> When you add deep cleans or move-out cleans to your menu, supply costs per job increase. Run those jobs through this calculator to see the actual supply cost impact and make sure your pricing covers the extra product usage.</p>
          <p><strong class="text-text-primary">Identifying waste.</strong> If your supply percentage is trending above 8% of revenue, this calculator helps you find where the money is going. Break down each category, compare to the quick-lookup ranges, and identify items where you are spending more than the market average.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much do cleaning supplies cost per job?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most residential cleaning jobs use $5-$15 in supplies. This includes chemical cleaners ($2-$5 per job when buying concentrates), paper goods like trash bags and paper towels ($1-$3), equipment wear like microfiber cloth replacement and mop heads ($1-$3), and PPE like gloves ($0.50-$2). The exact amount depends on property size, job type, and whether you use concentrates or ready-to-use products.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What percentage of revenue should go to cleaning supplies?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Cleaning supply costs should stay between 3-8% of your job revenue. If you are spending more than 8%, you may be over-applying product, using expensive ready-to-use bottles instead of concentrates, or not tracking waste. If you are under 3%, double-check that you are using enough product to deliver quality results. The sweet spot for most residential cleaning companies is 5-6%.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I reduce cleaning supply costs without sacrificing quality?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Buy concentrates in bulk and dilute to the manufacturer's recommended ratio instead of using ready-to-use sprays. Use microfiber cloths instead of paper towels for most surfaces. Train your team on proper product application so they are not double-spraying. Track per-clean supply usage with a cost calculator so you can spot waste early. Switch to refillable spray bottles and buy cleaning chemicals by the gallon or case.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What cleaning supplies should I stock for a residential cleaning business?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Essential supplies include all-purpose cleaner, disinfectant, glass cleaner, floor cleaner, toilet bowl cleaner, trash bags, microfiber cloths, mop heads, vacuum bags, rubber gloves, scrub sponges, and dusting spray. For deep cleans and move-outs, add oven cleaner, grout cleaner, and heavy-duty degreaser. Buy the core chemicals as concentrates and the disposables in bulk to keep your per-clean cost as low as possible.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    // Revenue inputs
    const avgRevenue = parseFloat((document.getElementById('avg-job-revenue') as HTMLInputElement).value) || 0;
    const jobsPerWeek = parseFloat((document.getElementById('jobs-per-week') as HTMLInputElement).value) || 0;
    const weeksPerYear = parseFloat((document.getElementById('weeks-per-year') as HTMLInputElement).value) || 0;

    // Chemicals
    const chemicals =
      (parseFloat((document.getElementById('cost-all-purpose') as HTMLInputElement).value) || 0) +
      (parseFloat((document.getElementById('cost-disinfectant') as HTMLInputElement).value) || 0) +
      (parseFloat((document.getElementById('cost-glass-cleaner') as HTMLInputElement).value) || 0) +
      (parseFloat((document.getElementById('cost-floor-cleaner') as HTMLInputElement).value) || 0) +
      (parseFloat((document.getElementById('cost-toilet-cleaner') as HTMLInputElement).value) || 0) +
      (parseFloat((document.getElementById('cost-dusting-spray') as HTMLInputElement).value) || 0);

    // Paper goods
    const paper =
      (parseFloat((document.getElementById('cost-trash-bags') as HTMLInputElement).value) || 0) +
      (parseFloat((document.getElementById('cost-paper-towels') as HTMLInputElement).value) || 0) +
      (parseFloat((document.getElementById('cost-scrub-sponges') as HTMLInputElement).value) || 0);

    // Equipment wear
    const equipment =
      (parseFloat((document.getElementById('cost-microfiber') as HTMLInputElement).value) || 0) +
      (parseFloat((document.getElementById('cost-mop-heads') as HTMLInputElement).value) || 0) +
      (parseFloat((document.getElementById('cost-vacuum-bags') as HTMLInputElement).value) || 0);

    // PPE
    const ppe =
      (parseFloat((document.getElementById('cost-gloves') as HTMLInputElement).value) || 0) +
      (parseFloat((document.getElementById('cost-masks') as HTMLInputElement).value) || 0) +
      (parseFloat((document.getElementById('cost-other-ppe') as HTMLInputElement).value) || 0);

    const perClean = chemicals + paper + equipment + ppe;
    const weeklyCost = perClean * jobsPerWeek;
    const monthlyCost = weeklyCost * (weeksPerYear / 12);
    const annualCost = perClean * jobsPerWeek * weeksPerYear;
    const annualRevenue = avgRevenue * jobsPerWeek * weeksPerYear;
    const pctRevenue = annualRevenue > 0 ? (annualCost / annualRevenue) * 100 : 0;

    // Update per-clean breakdown
    document.getElementById('result-per-clean')!.textContent = `$${perClean.toFixed(2)}`;
    document.getElementById('result-chemicals')!.textContent = `$${chemicals.toFixed(2)}`;
    document.getElementById('result-paper')!.textContent = `$${paper.toFixed(2)}`;
    document.getElementById('result-equipment')!.textContent = `$${equipment.toFixed(2)}`;
    document.getElementById('result-ppe')!.textContent = `$${ppe.toFixed(2)}`;

    // Update projections
    document.getElementById('result-weekly')!.textContent = `$${weeklyCost.toFixed(0)}`;
    document.getElementById('result-monthly')!.textContent = `$${monthlyCost.toFixed(0)}`;
    document.getElementById('result-annual')!.textContent = `$${annualCost.toFixed(0)}`;

    // Revenue percentage with color coding
    const pctEl = document.getElementById('result-pct-revenue')!;
    pctEl.textContent = `${pctRevenue.toFixed(1)}%`;
    pctEl.className = 'font-heading font-extrabold text-3xl';
    if (pctRevenue > 8) {
      pctEl.classList.add('text-red-400');
    } else if (pctRevenue > 5) {
      pctEl.classList.add('text-yellow-400');
    } else if (pctRevenue >= 3) {
      pctEl.classList.add('text-[#34D399]');
    } else if (pctRevenue > 0) {
      pctEl.classList.add('text-yellow-400');
    } else {
      pctEl.classList.add('text-text-primary');
    }

    // Benchmark bar (range 0% - 12%+)
    const maxBenchmark = 12;
    const markerPct = Math.min((pctRevenue / maxBenchmark) * 100, 100);
    const marker = document.getElementById('benchmark-marker')!;
    marker.style.left = `${markerPct}%`;

    let benchmarkNote = '';
    if (pctRevenue < 3) {
      benchmarkNote = 'Below typical range. Confirm you are using enough product for quality results.';
    } else if (pctRevenue <= 8) {
      benchmarkNote = 'Within the healthy range for cleaning businesses.';
    } else {
      benchmarkNote = 'Above average. Look for areas to reduce waste or switch to concentrates.';
    }
    document.getElementById('benchmark-text')!.textContent = `Supply cost: ${pctRevenue.toFixed(1)}% of revenue \u2014 ${benchmarkNote}`;
  }

  // Auto-calculate on any supply input change
  document.querySelectorAll('.supply-input').forEach(el => {
    el.addEventListener('input', calculate);
  });

  // Also listen to revenue inputs
  document.getElementById('avg-job-revenue')?.addEventListener('input', calculate);
  document.getElementById('jobs-per-week')?.addEventListener('input', calculate);
  document.getElementById('weeks-per-year')?.addEventListener('input', calculate);

  // Calculate on load
  calculate();
</script>
