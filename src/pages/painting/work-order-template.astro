---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/paintingTools';

const tool = getToolBySlug('work-order-template')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should be on a painting work order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A complete painting work order includes dispatch info (date, painter, priority), customer details, surface information (wall area, ceiling area, trim linear feet, window/door count), reported issue and scope, surface prep and painting work performed, materials used (paint brand, color, finish), a safety checklist, and painter signature with arrival and completion times."
      }
    },
    {
      "@type": "Question",
      "name": "Why do I need to record surface measurements?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Surface measurements like wall square footage, ceiling area, trim linear feet, and window/door count document the scope of the job. These measurements are critical for accurate paint quantity estimation, quoting future touch-ups, verifying coverage rates, and resolving billing disputes about what was painted."
      }
    },
    {
      "@type": "Question",
      "name": "Is detailed documentation required for painting jobs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Maintaining detailed service records is a best practice for every painting job. Document all surfaces prepped, coats applied, paint colors and formulas, and any issues found like moisture damage or lead paint. Thorough records protect you during disputes, support warranty claims, and provide a color history the customer will appreciate for years."
      }
    },
    {
      "@type": "Question",
      "name": "What paint information should I record on a work order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Record the paint brand, product line, color name, color code or formula number, finish (flat, eggshell, satin, semi-gloss, gloss), and number of coats applied. Also note primer used and any specialty coatings. This information is invaluable for touch-ups, warranty claims, and repainting the same property later."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="work-order-form">

    <!-- Section: Dispatch Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Dispatch Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-number">Work Order #</label>
        <input type="text" id="wo-number" value="WO-001" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-date">Date</label>
        <input type="date" id="wo-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-time">Time</label>
        <input type="time" id="wo-time" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="tech-name">Painter Name</label>
        <input type="text" id="tech-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="truck-number">Truck #</label>
        <input type="text" id="truck-number" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="priority">Priority</label>
        <select id="priority" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Routine" selected>Routine</option>
          <option value="Urgent">Urgent</option>
          <option value="Emergency">Emergency</option>
        </select>
      </div>
    </div>

    <!-- Section: Customer Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Customer Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-name">Customer Name</label>
        <input type="text" id="cust-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-address">Address</label>
        <input type="text" id="cust-address" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-phone">Phone</label>
        <input type="text" id="cust-phone" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="access-instructions">Access Instructions</label>
        <input type="text" id="access-instructions" placeholder="Gate code, lockbox, etc." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Job Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Job Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-type">Surface Type</label>
        <select id="equip-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Interior Walls">Interior Walls</option>
          <option value="Exterior Siding">Exterior Siding</option>
          <option value="Ceiling">Ceiling</option>
          <option value="Trim / Molding">Trim / Molding</option>
          <option value="Cabinets">Cabinets</option>
          <option value="Deck / Fence">Deck / Fence</option>
          <option value="Full Interior">Full Interior</option>
          <option value="Full Exterior">Full Exterior</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-make">Paint Brand</label>
        <input type="text" id="equip-make" placeholder="Sherwin-Williams, Benjamin Moore..." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-model">Color Name / Code</label>
        <input type="text" id="equip-model" placeholder="e.g., SW 7015 Repose Gray" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-serial">Formula #</label>
        <input type="text" id="equip-serial" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="install-date">Start Date</label>
        <input type="date" id="install-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="filter-size">Coats Applied</label>
        <input type="text" id="filter-size" placeholder="e.g., 2 coats" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="refrigerant-type">Finish</label>
        <select id="refrigerant-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Flat" selected>Flat</option>
          <option value="Eggshell">Eggshell</option>
          <option value="Satin">Satin</option>
          <option value="Semi-Gloss">Semi-Gloss</option>
          <option value="Gloss">Gloss</option>
          <option value="Other">Other</option>
        </select>
      </div>
    </div>

    <!-- Section: Service Details -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Service Details</h3>
    <div class="space-y-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="reported-issue">Reported Issue</label>
        <textarea id="reported-issue" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="diagnosis">Surface Assessment</label>
        <textarea id="diagnosis" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="work-performed">Work Performed</label>
        <textarea id="work-performed" rows="4" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
    </div>

    <!-- Section: Materials Used -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Materials Used</h3>
    <div class="mb-8">
      <div id="parts-table" class="space-y-3">
        <div class="grid grid-cols-[1fr_1fr_80px_40px] gap-3 items-end part-row">
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">Material Name</label>
            <input type="text" class="part-name w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">SKU / Color</label>
            <input type="text" class="part-number w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">Qty</label>
            <input type="number" value="1" min="1" class="part-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">&nbsp;</label>
            <button type="button" class="remove-part-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove material">&times;</button>
          </div>
        </div>
      </div>
      <button type="button" id="add-part-btn" class="mt-3 text-accent hover:text-accent-hover transition-colors cursor-pointer text-sm font-medium">+ Add Material</button>
    </div>

    <!-- Section: Paint Log -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Paint Log</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="ref-added">Paint Used (gallons)</label>
        <input type="number" id="ref-added" min="0" step="0.25" value="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="ref-recovered">Primer Used (gallons)</label>
        <input type="number" id="ref-recovered" min="0" step="0.25" value="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Surface Measurements -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Surface Measurements</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wall-area">Wall Area (sq ft)</label>
        <input type="number" id="wall-area" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="ceiling-area">Ceiling Area (sq ft)</label>
        <input type="number" id="ceiling-area" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="trim-lf">Trim (LF)</label>
        <input type="number" id="trim-lf" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="window-door-count">Windows / Doors</label>
        <input type="number" id="window-door-count" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cabinet-faces">Cabinet Faces</label>
        <input type="number" id="cabinet-faces" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="exterior-sqft">Exterior Siding (sq ft)</label>
        <input type="number" id="exterior-sqft" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2">Total Paintable (sq ft)</label>
        <div id="total-paintable-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="rooms-count">Number of Rooms</label>
        <input type="number" id="rooms-count" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Safety Checklist -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Safety Checklist</h3>
    <div class="space-y-3 mb-8">
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-ventilation" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-ventilation" class="text-text-primary cursor-pointer">Ventilation Adequate</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-dropcloths" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-dropcloths" class="text-text-primary cursor-pointer">Drop Cloths / Floor Protection</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-ladder" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-ladder" class="text-text-primary cursor-pointer">Ladder Safety Inspected</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-leadtest" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-leadtest" class="text-text-primary cursor-pointer">Lead Paint Test (pre-1978)</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-masking" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-masking" class="text-text-primary cursor-pointer">Masking / Taping Completed</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-cleansite" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-cleansite" class="text-text-primary cursor-pointer">Site Cleanup Completed</label>
      </div>
    </div>

    <!-- Section: Completion -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Completion</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="time-arrived">Time Arrived</label>
        <input type="time" id="time-arrived" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="time-completed">Time Completed</label>
        <input type="time" id="time-completed" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2">Total Hours</label>
        <div id="total-hours-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="tech-signature">Painter Signature</label>
        <input type="text" id="tech-signature" placeholder="Type full name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Generate Button -->
    <button id="generate-btn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
      Generate Work Order &rarr;
    </button>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Template</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Fill in dispatch and customer info.</strong> Start with the work order number, date, and painter assignment. Add the customer's name, address, phone, and any access instructions like gate codes or lockbox combos.</p>
          <p><strong class="text-text-primary">2. Describe the job.</strong> Select the surface type and enter paint details — brand, color code, finish, and number of coats. This color record is invaluable for future touch-ups.</p>
          <p><strong class="text-text-primary">3. Document the service.</strong> Write what the customer reported, your surface assessment (peeling, moisture, cracks), and exactly what prep and painting work you performed.</p>
          <p><strong class="text-text-primary">4. Record measurements and safety checks.</strong> Log wall area, ceiling area, trim linear feet, and window/door counts. Run through the safety checklist — ventilation, lead testing, ladder safety, and site protection.</p>
          <p><strong class="text-text-primary">5. Generate the work order.</strong> Hit the button to create a clean, printable work order. Have the customer review it, then use it for your records, warranty documentation, or office filing.</p>
        </div>
      </section>

      <!-- What Goes on a Work Order -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Goes on a Painting Work Order</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>A work order is the single document that proves what happened on a job. Every section exists for a reason.</p>
          <p><strong class="text-text-primary">Job identification</strong> — surface type, paint brand, color code, and finish — ties the documentation to a specific job. This information is essential for warranty claims, touch-up work, and maintaining a color history for the property.</p>
          <p><strong class="text-text-primary">Surface measurements</strong> document the scope of the painting job. Wall area, ceiling square footage, trim linear feet, and window/door counts tell the full story. If a customer questions billing or needs a touch-up quote, your measurements provide an accurate reference.</p>
          <p><strong class="text-text-primary">Material tracking</strong> is essential for every painting job. Recording gallons of paint and primer used, plus the exact color formula, protects you during billing disputes and makes future touch-ups seamless. Smart painters document every color used regardless of job size.</p>
          <p><strong class="text-text-primary">The safety checklist</strong> is your liability shield. Documenting ventilation, lead paint testing (for pre-1978 homes), ladder inspection, and site protection shows due diligence. If property damage or health claims arise, that checklist is your first line of defense.</p>
          <p><strong class="text-text-primary">Materials used</strong> with product details create a clear record for inventory management, warranty tracking, and accurate invoicing.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Interior and exterior painting jobs.</strong> Every painting job needs a work order. The painter fills it out on site — surfaces prepped, coats applied, colors used, and measurements taken. It becomes the permanent record of the visit and the basis for the invoice.</p>
          <p><strong class="text-text-primary">Touch-up and warranty work.</strong> When a customer calls back for touch-ups or reports paint failure, the original work order provides the exact color codes, surface prep details, and product used. This makes warranty claims straightforward and touch-ups accurate.</p>
          <p><strong class="text-text-primary">Multi-day projects.</strong> For large jobs spanning multiple days, each day gets its own work order documenting what rooms or surfaces were completed. This tracks progress, helps with scheduling, and provides clear documentation if there are questions about timeline or scope.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should be on a painting work order?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A complete painting work order includes dispatch info (date, painter, priority), customer details, surface information (wall area, ceiling area, trim linear feet, window/door count), reported issue and scope, surface prep and painting work performed, materials used (paint brand, color, finish), a safety checklist, and painter signature with arrival and completion times.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why do I need to record surface measurements?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Surface measurements like wall square footage, ceiling area, trim linear feet, and window/door count document the scope of the job. These measurements are critical for accurate paint quantity estimation, quoting future touch-ups, verifying coverage rates, and resolving billing disputes about what was painted.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Is detailed documentation required for painting jobs?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Yes. Maintaining detailed service records is a best practice for every painting job. Document all surfaces prepped, coats applied, paint colors and formulas, and any issues found like moisture damage or lead paint. Thorough records protect you during disputes, support warranty claims, and provide a color history the customer will appreciate for years.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What paint information should I record on a work order?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Record the paint brand, product line, color name, color code or formula number, finish (flat, eggshell, satin, semi-gloss, gloss), and number of coats applied. Also note primer used and any specialty coatings. This information is invaluable for touch-ups, warranty claims, and repainting the same property later.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // --- Default date and time ---
  const now = new Date();
  const dateInput = document.getElementById('wo-date') as HTMLInputElement;
  const timeInput = document.getElementById('wo-time') as HTMLInputElement;
  if (dateInput && !dateInput.value) {
    dateInput.value = now.toISOString().slice(0, 10);
  }
  if (timeInput && !timeInput.value) {
    timeInput.value = now.toTimeString().slice(0, 5);
  }

  // --- Total Paintable Area auto-calculation ---
  function updateTotalPaintable() {
    const wall = parseFloat((document.getElementById('wall-area') as HTMLInputElement).value) || 0;
    const ceiling = parseFloat((document.getElementById('ceiling-area') as HTMLInputElement).value) || 0;
    const exterior = parseFloat((document.getElementById('exterior-sqft') as HTMLInputElement).value) || 0;
    const display = document.getElementById('total-paintable-display')!;
    if (wall > 0 || ceiling > 0 || exterior > 0) {
      const total = wall + ceiling + exterior;
      display.textContent = total.toLocaleString() + ' sq ft';
      display.className = 'w-full bg-bg-dark border border-green-500/50 rounded-lg px-4 py-3 text-lg font-bold text-green-400';
    } else {
      display.textContent = '\u2014';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted';
    }
  }
  document.getElementById('wall-area')?.addEventListener('input', updateTotalPaintable);
  document.getElementById('ceiling-area')?.addEventListener('input', updateTotalPaintable);
  document.getElementById('exterior-sqft')?.addEventListener('input', updateTotalPaintable);

  // --- Total Hours auto-calculation ---
  function updateTotalHours() {
    const arrived = (document.getElementById('time-arrived') as HTMLInputElement).value;
    const completed = (document.getElementById('time-completed') as HTMLInputElement).value;
    const display = document.getElementById('total-hours-display')!;
    if (arrived && completed) {
      const [ah, am] = arrived.split(':').map(Number);
      const [ch, cm] = completed.split(':').map(Number);
      let totalMinutes = (ch * 60 + cm) - (ah * 60 + am);
      if (totalMinutes < 0) totalMinutes += 24 * 60;
      const hours = Math.floor(totalMinutes / 60);
      const minutes = totalMinutes % 60;
      display.textContent = hours + 'h ' + minutes + 'm';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-primary';
    } else {
      display.textContent = '\u2014';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted';
    }
  }
  document.getElementById('time-arrived')?.addEventListener('input', updateTotalHours);
  document.getElementById('time-completed')?.addEventListener('input', updateTotalHours);

  // --- Dynamic Parts Table ---
  function addPartRow() {
    const table = document.getElementById('parts-table')!;
    const row = document.createElement('div');
    row.className = 'grid grid-cols-[1fr_1fr_80px_40px] gap-3 items-end part-row';
    row.innerHTML = `
      <div>
        <input type="text" class="part-name w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <input type="text" class="part-number w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <input type="number" value="1" min="1" class="part-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <button type="button" class="remove-part-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove material">&times;</button>
      </div>
    `;
    table.appendChild(row);
  }

  document.getElementById('add-part-btn')?.addEventListener('click', addPartRow);

  document.getElementById('parts-table')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('remove-part-btn')) {
      const row = target.closest('.part-row');
      const allRows = document.querySelectorAll('.part-row');
      if (allRows.length > 1 && row) {
        row.remove();
      }
    }
  });

  // --- Generate Work Order ---
  function getVal(id: string): string {
    const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
    return el ? el.value : '';
  }
  function getChecked(id: string): boolean {
    return (document.getElementById(id) as HTMLInputElement)?.checked || false;
  }

  function generateWorkOrder() {
    const partRows = document.querySelectorAll('.part-row');
    let partsHtml = '';
    partRows.forEach(row => {
      const name = (row.querySelector('.part-name') as HTMLInputElement)?.value || '';
      const num = (row.querySelector('.part-number') as HTMLInputElement)?.value || '';
      const qty = (row.querySelector('.part-qty') as HTMLInputElement)?.value || '';
      if (name || num) {
        partsHtml += `<tr><td style="border:1px solid #ddd;padding:6px 10px;">${name}</td><td style="border:1px solid #ddd;padding:6px 10px;">${num}</td><td style="border:1px solid #ddd;padding:6px 10px;text-align:center;">${qty}</td></tr>`;
      }
    });

    // Total paintable
    const wallA = parseFloat(getVal('wall-area')) || 0;
    const ceilA = parseFloat(getVal('ceiling-area')) || 0;
    const extA = parseFloat(getVal('exterior-sqft')) || 0;
    const totalPaint = wallA + ceilA + extA;
    const totalPaintStr = totalPaint > 0 ? totalPaint.toLocaleString() + ' sq ft' : '';

    const arrived = getVal('time-arrived');
    const completed = getVal('time-completed');
    let totalHours = '';
    if (arrived && completed) {
      const [ah, am] = arrived.split(':').map(Number);
      const [ch, cm] = completed.split(':').map(Number);
      let totalMin = (ch * 60 + cm) - (ah * 60 + am);
      if (totalMin < 0) totalMin += 24 * 60;
      totalHours = Math.floor(totalMin / 60) + 'h ' + (totalMin % 60) + 'm';
    }

    const safetyItems = [
      { id: 'chk-ventilation', label: 'Ventilation Adequate', extra: '' },
      { id: 'chk-dropcloths', label: 'Drop Cloths / Floor Protection', extra: '' },
      { id: 'chk-ladder', label: 'Ladder Safety Inspected', extra: '' },
      { id: 'chk-leadtest', label: 'Lead Paint Test (pre-1978)', extra: '' },
      { id: 'chk-masking', label: 'Masking / Taping Completed', extra: '' },
      { id: 'chk-cleansite', label: 'Site Cleanup Completed', extra: '' },
    ];
    let safetyHtml = '';
    safetyItems.forEach(item => {
      const checked = getChecked(item.id);
      const mark = checked ? '&#9745;' : '&#9744;';
      safetyHtml += `<div style="margin-bottom:4px;">${mark} ${item.label}${item.extra}</div>`;
    });

    const html = `<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Work Order ${getVal('wo-number')}</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color:#1a1a1a; padding:40px; max-width:850px; margin:0 auto; font-size:14px; line-height:1.5; }
  h1 { font-size:22px; margin-bottom:4px; }
  h2 { font-size:15px; color:#333; margin:20px 0 8px; padding-bottom:4px; border-bottom:2px solid #e5e5e5; text-transform:uppercase; letter-spacing:0.5px; }
  .header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:20px; padding-bottom:16px; border-bottom:3px solid #1a1a1a; }
  .header-left { }
  .header-right { text-align:right; font-size:13px; color:#555; }
  .grid2 { display:grid; grid-template-columns:1fr 1fr; gap:4px 24px; margin-bottom:6px; }
  .grid2 .label { font-weight:600; font-size:12px; color:#666; text-transform:uppercase; letter-spacing:0.3px; }
  .grid2 .value { font-size:14px; margin-bottom:6px; }
  .text-block { margin-bottom:12px; }
  .text-block .label { font-weight:600; font-size:12px; color:#666; text-transform:uppercase; letter-spacing:0.3px; margin-bottom:2px; }
  .text-block .value { font-size:14px; white-space:pre-wrap; background:#f9f9f9; padding:8px 10px; border-radius:4px; min-height:24px; }
  table { width:100%; border-collapse:collapse; margin-bottom:8px; }
  th { background:#f0f0f0; border:1px solid #ddd; padding:6px 10px; text-align:left; font-size:12px; text-transform:uppercase; letter-spacing:0.3px; }
  td { border:1px solid #ddd; padding:6px 10px; }
  .readings-table td { text-align:center; }
  .safety { font-size:14px; }
  .signature-block { display:grid; grid-template-columns:1fr 1fr; gap:40px; margin-top:40px; padding-top:16px; }
  .sig-line { border-top:1px solid #1a1a1a; padding-top:6px; font-size:12px; color:#666; text-transform:uppercase; }
  .sig-name { font-size:16px; font-weight:600; min-height:20px; }
  .priority-badge { display:inline-block; padding:2px 10px; border-radius:4px; font-size:12px; font-weight:600; text-transform:uppercase; }
  .priority-Routine { background:#e0f2e9; color:#166534; }
  .priority-Urgent { background:#fef3c7; color:#92400e; }
  .priority-Emergency { background:#fee2e2; color:#991b1b; }
  @media print { body { padding:20px; } }
</style>
</head><body>
<div class="header">
  <div class="header-left">
    <h1>Painting Work Order</h1>
    <div style="font-size:13px;color:#555;">Service Documentation</div>
  </div>
  <div class="header-right">
    <div style="font-size:20px;font-weight:700;">\${getVal('wo-number')}</div>
    <div>\${getVal('wo-date')}</div>
    <div>\${getVal('wo-time')}</div>
    <span class="priority-badge priority-\${getVal('priority')}">\${getVal('priority')}</span>
  </div>
</div>

<h2>Dispatch</h2>
<div class="grid2">
  <div><span class="label">Painter:</span></div><div><span class="label">Truck #:</span></div>
  <div class="value">\${getVal('tech-name') || '\u2014'}</div><div class="value">\${getVal('truck-number') || '\u2014'}</div>
</div>

<h2>Customer</h2>
<div class="grid2">
  <div><span class="label">Name:</span></div><div><span class="label">Phone:</span></div>
  <div class="value">\${getVal('cust-name') || '\u2014'}</div><div class="value">\${getVal('cust-phone') || '\u2014'}</div>
  <div><span class="label">Address:</span></div><div><span class="label">Access:</span></div>
  <div class="value">\${getVal('cust-address') || '\u2014'}</div><div class="value">\${getVal('access-instructions') || '\u2014'}</div>
</div>

<h2>Job Info</h2>
<div class="grid2">
  <div><span class="label">Surface Type:</span></div><div><span class="label">Paint Brand:</span></div>
  <div class="value">\${getVal('equip-type')}</div><div class="value">\${getVal('equip-make') || '\u2014'}</div>
  <div><span class="label">Color:</span></div><div><span class="label">Formula #:</span></div>
  <div class="value">\${getVal('equip-model') || '\u2014'}</div><div class="value">\${getVal('equip-serial') || '\u2014'}</div>
  <div><span class="label">Start Date:</span></div><div><span class="label">Coats:</span></div>
  <div class="value">\${getVal('install-date') || '\u2014'}</div><div class="value">\${getVal('filter-size') || '\u2014'}</div>
  <div><span class="label">Finish:</span></div><div></div>
  <div class="value">\${getVal('refrigerant-type')}</div><div></div>
</div>

<h2>Service Details</h2>
<div class="text-block"><div class="label">Reported Issue</div><div class="value">\${getVal('reported-issue') || '\u2014'}</div></div>
<div class="text-block"><div class="label">Surface Assessment</div><div class="value">\${getVal('diagnosis') || '\u2014'}</div></div>
<div class="text-block"><div class="label">Work Performed</div><div class="value">\${getVal('work-performed') || '\u2014'}</div></div>

\${partsHtml ? \`<h2>Materials Used</h2>
<table><thead><tr><th>Material</th><th>SKU / Color</th><th style="text-align:center;">Qty</th></tr></thead><tbody>\${partsHtml}</tbody></table>\` : ''}

<h2>Paint Log</h2>
<div class="grid2">
  <div><span class="label">Paint Used:</span></div><div><span class="label">Primer Used:</span></div>
  <div class="value">\${getVal('ref-added') || '0'} gal</div><div class="value">\${getVal('ref-recovered') || '0'} gal</div>
</div>

<h2>Surface Measurements</h2>
<table class="readings-table">
  <thead><tr><th>Wall Area</th><th>Ceiling Area</th><th>Trim LF</th><th>Windows/Doors</th></tr></thead>
  <tbody><tr><td>\${getVal('wall-area') ? getVal('wall-area') + ' sq ft' : '\u2014'}</td><td>\${getVal('ceiling-area') ? getVal('ceiling-area') + ' sq ft' : '\u2014'}</td><td>\${getVal('trim-lf') ? getVal('trim-lf') + ' LF' : '\u2014'}</td><td>\${getVal('window-door-count') || '\u2014'}</td></tr></tbody>
</table>
<table class="readings-table" style="margin-top:8px;">
  <thead><tr><th>Cabinet Faces</th><th>Exterior Siding</th><th>Total Paintable</th><th>Rooms</th></tr></thead>
  <tbody><tr><td>\${getVal('cabinet-faces') || '\u2014'}</td><td>\${getVal('exterior-sqft') ? getVal('exterior-sqft') + ' sq ft' : '\u2014'}</td><td>\${totalPaintStr || '\u2014'}</td><td>\${getVal('rooms-count') || '\u2014'}</td></tr></tbody>
</table>

<h2>Safety Checklist</h2>
<div class="safety">\${safetyHtml}</div>

<h2>Completion</h2>
<div class="grid2">
  <div><span class="label">Time Arrived:</span></div><div><span class="label">Time Completed:</span></div>
  <div class="value">\${arrived || '\u2014'}</div><div class="value">\${completed || '\u2014'}</div>
  <div><span class="label">Total Hours:</span></div><div></div>
  <div class="value">\${totalHours || '\u2014'}</div><div></div>
</div>

<div class="signature-block">
  <div>
    <div class="sig-name">\${getVal('tech-signature') || ''}</div>
    <div class="sig-line">Painter Signature</div>
  </div>
  <div>
    <div class="sig-name">&nbsp;</div>
    <div class="sig-line">Customer Signature</div>
  </div>
</div>

</body></html>`;

    const printWindow = window.open('', '_blank');
    if (printWindow) {
      printWindow.document.write(html);
      printWindow.document.close();
    }
  }

  document.getElementById('generate-btn')?.addEventListener('click', generateWorkOrder);
</script>
