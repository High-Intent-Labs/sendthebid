---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/gcTools';

const tool = getToolBySlug('business-valuation-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much is a general contracting business worth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GC business values typically range from 0.5x to 2.5x annual revenue depending on size and profitability. Small GCs under $1M revenue trade at 0.5-1.0x revenue. Mid-size firms ($1M-$5M) trade at 1.0-1.5x. Large operations above $5M can command 1.5-2.5x. EBITDA multiples of 3-5x are also common. A GC with $2M revenue and $300K profit might be valued at $900K-$1.5M."
      }
    },
    {
      "@type": "Question",
      "name": "What factors increase a contracting company's value?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The biggest value drivers are recurring revenue from repeat clients, diversified customer base (no single client over 30% of revenue), strong project management systems, licensed and certified staff, clean financial records, and consistent growth above 10% per year. Owner independence is critical — if the business runs without the owner on every job, it commands a premium."
      }
    },
    {
      "@type": "Question",
      "name": "What is SDE and why does it matter for GC valuation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "SDE stands for Seller's Discretionary Earnings. It is net profit plus owner salary, personal benefits, one-time expenses, depreciation, and interest. SDE represents the true economic benefit of owning the business. Buyers use SDE to compare businesses because it normalizes for different owner compensation structures. A GC with $100K net profit but $150K owner salary has $250K+ SDE."
      }
    },
    {
      "@type": "Question",
      "name": "Should I get a professional appraisal for my GC business?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. This calculator provides a reasonable estimate for planning purposes, but a professional business appraisal accounts for local market conditions, asset values, contract backlog, bonding capacity, and intangible factors that a formula cannot capture. For any transaction over $500K, a professional appraisal typically costs $3,000-$10,000 and is well worth the investment."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="valuation-calc">
    <!-- Financial Inputs -->
    <div class="bg-bg-card border border-border rounded-lg p-5 mb-4">
      <h3 class="font-heading font-bold text-sm uppercase tracking-wider text-text-primary mb-4">Financial Information</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="annualRevenue">Annual Revenue ($)</label>
          <input type="number" id="annualRevenue" value="2000000" min="0" step="10000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="netProfit">Annual Net Profit ($)</label>
          <input type="number" id="netProfit" value="200000" min="0" step="5000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="ownerSalary">Owner Salary ($)</label>
          <input type="number" id="ownerSalary" value="120000" min="0" step="5000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="ownerBenefits">Owner Benefits / Perks ($)</label>
          <input type="number" id="ownerBenefits" value="25000" min="0" step="1000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="oneTimeExpenses">One-Time / Non-Recurring Expenses ($)</label>
          <input type="number" id="oneTimeExpenses" value="15000" min="0" step="1000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="depreciation">Depreciation ($)</label>
          <input type="number" id="depreciation" value="30000" min="0" step="1000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="interest">Interest Expense ($)</label>
          <input type="number" id="interest" value="10000" min="0" step="1000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </div>

    <!-- Business Factors -->
    <div class="bg-bg-card border border-border rounded-lg p-5 mb-8">
      <h3 class="font-heading font-bold text-sm uppercase tracking-wider text-text-primary mb-4">Business Factors</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="repeatClients">Repeat Client Revenue</label>
          <select id="repeatClients" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="0.15">Strong (40%+ repeat)</option>
            <option value="0.05" selected>Moderate (20-40% repeat)</option>
            <option value="-0.05">Low (10-20% repeat)</option>
            <option value="-0.15">Minimal (&lt;10% repeat)</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="ownerDependence">Owner Dependence</label>
          <select id="ownerDependence" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="0.10">Low (strong management team)</option>
            <option value="0.00" selected>Medium (owner manages but delegatable)</option>
            <option value="-0.10">High (owner runs most projects)</option>
            <option value="-0.20">Critical (owner IS the business)</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="equipmentCondition">Equipment &amp; Vehicle Condition</label>
          <select id="equipmentCondition" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="0.10">Excellent (under 3 years)</option>
            <option value="0.05" selected>Good (3-7 years)</option>
            <option value="0.00">Average (7-10 years)</option>
            <option value="-0.10">Poor (10+ years, needs replacement)</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="licensedStaff">Licensed / Certified Staff</label>
          <select id="licensedStaff" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="0.10">All key staff licensed</option>
            <option value="0.05" selected>Most staff licensed</option>
            <option value="0.00">Some licensed</option>
            <option value="-0.05">Owner only</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="financialRecords">Financial Records</label>
          <select id="financialRecords" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="0.10">CPA-reviewed, 3+ years</option>
            <option value="0.05" selected>Tax returns, organized books</option>
            <option value="0.00">Basic bookkeeping</option>
            <option value="-0.10">Messy or incomplete</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="growthRate">Revenue Growth (Last 3 Years)</label>
          <select id="growthRate" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="0.15">Strong (20%+ /year)</option>
            <option value="0.10">Good (10-20% /year)</option>
            <option value="0.00" selected>Flat (0-10% /year)</option>
            <option value="-0.10">Declining</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="customerConcentration">Customer Concentration</label>
          <select id="customerConcentration" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="0.05">Diversified (no client &gt;10%)</option>
            <option value="0.00" selected>Moderate (largest client 10-20%)</option>
            <option value="-0.10">Concentrated (one client 20-30%)</option>
            <option value="-0.20">Risky (one client &gt;30%)</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Estimated Business Value</h3>

      <!-- Valuation Range Bar -->
      <div class="bg-bg-dark rounded-xl p-6 mb-6">
        <div class="flex justify-between text-sm text-text-muted mb-2">
          <span>Low</span>
          <span>Mid</span>
          <span>High</span>
        </div>
        <div class="relative h-6 rounded-full overflow-hidden" style="background: linear-gradient(to right, #EF4444, #FBBF24, #34D399)">
          <div id="valuation-marker" class="absolute top-0 w-1 h-6 bg-white rounded shadow-lg transition-all duration-500" style="left: 50%"></div>
        </div>
        <div class="flex justify-between text-sm mt-2">
          <span id="val-low" class="text-text-primary font-semibold">--</span>
          <span id="val-mid" class="text-accent font-heading font-extrabold text-2xl">--</span>
          <span id="val-high" class="text-text-primary font-semibold">--</span>
        </div>
      </div>

      <!-- SDE -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">SDE (Seller's Discretionary Earnings)</div>
          <div id="result-sde" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">EBITDA</div>
          <div id="result-ebitda" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Net Profit Margin</div>
          <div id="result-margin" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
        </div>
      </div>

      <!-- Adjustment Factors -->
      <div class="bg-bg-dark rounded-xl p-6 mb-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Adjustment Factors</h4>
        <div class="space-y-2" id="adjustments-list"></div>
        <div class="mt-4 pt-4 border-t border-border flex justify-between">
          <span class="text-text-secondary font-medium">Total Adjustment</span>
          <span id="total-adjustment" class="font-heading font-bold text-text-primary">--</span>
        </div>
      </div>

      <!-- Methods Breakdown -->
      <div class="bg-bg-dark rounded-xl p-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Valuation Methods</h4>
        <div class="space-y-3">
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">Revenue Multiple Method</span>
            <span id="method-revenue" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">EBITDA Multiple Method (3-5x)</span>
            <span id="method-ebitda" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">SDE Multiple Method</span>
            <span id="method-sde" class="text-text-primary font-semibold">--</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter your financials.</strong> Input your annual revenue, net profit, owner salary, benefits, one-time expenses, depreciation, and interest. These numbers feed the SDE and EBITDA calculations that drive the valuation.</p>
          <p><strong class="text-text-primary">2. Set your business factors.</strong> Select the options that best describe your company. Repeat client revenue, owner dependence, equipment condition, staff licensing, financial records quality, growth rate, and customer concentration all affect the multiplier applied to your earnings.</p>
          <p><strong class="text-text-primary">3. Review the valuation range.</strong> The low, mid, and high estimates give you a realistic range. The mid-point is the most likely value in a fair market transaction. The adjustment factors show exactly what is helping or hurting your valuation.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How GC Business Valuation Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Revenue multiples are the starting point.</strong> Small GCs (under $1M revenue) typically sell for 0.5-1.0x annual revenue. Mid-size firms ($1M-$5M) command 1.0-1.5x. Large operations above $5M can reach 1.5-2.5x. These multiples reflect the fact that larger, more established businesses carry less risk for buyers.</p>
          <p><strong class="text-text-primary">SDE is the buyer's number.</strong> Seller's Discretionary Earnings equals net profit plus owner salary, personal benefits, one-time expenses, depreciation, and interest. It represents the total economic benefit of owning the business. Most small GC acquisitions are priced as a multiple of SDE.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>SDE = Net_Profit + Owner_Salary + Benefits + One_Time + Depreciation + Interest</p>
            <p>EBITDA = Net_Profit + Depreciation + Interest</p>
            <p>Revenue_Multiple = Based on company size (0.5x to 2.5x)</p>
            <p>Adjusted_Multiple = Base_Multiple &times; (1 + Sum_of_Adjustments)</p>
            <p>Valuation = Average of (Revenue &times; Multiple, EBITDA &times; 4, SDE &times; 2.5)</p>
          </div>
          <p><strong class="text-text-primary">Adjustments matter more than the base formula.</strong> A GC with strong repeat clients, low owner dependence, and clean books will get a premium. A business dependent on the owner with one big client will get a discount. These adjustments can swing the value by 30-40%.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Exit planning.</strong> If you are thinking about selling your GC business in the next 1-5 years, start here. The calculator shows you what drives value so you can focus on improvements that increase your sale price.</p>
          <p><strong class="text-text-primary">Partnership buyout.</strong> When a partner wants to exit or you want to buy someone out, you need a starting number. This calculator gives both parties an objective baseline for negotiation.</p>
          <p><strong class="text-text-primary">Annual benchmarking.</strong> Run this calculator once a year to track how your business value is changing. If the value is flat or declining, the adjustment factors tell you exactly what to fix.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much is a general contracting business worth?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">GC business values typically range from 0.5x to 2.5x annual revenue depending on size and profitability. Small GCs under $1M revenue trade at 0.5-1.0x revenue. Mid-size firms ($1M-$5M) trade at 1.0-1.5x. Large operations above $5M can command 1.5-2.5x. EBITDA multiples of 3-5x are also common.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What factors increase a contracting company's value?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">The biggest value drivers are recurring revenue from repeat clients, diversified customer base, strong project management systems, licensed and certified staff, clean financial records, and consistent growth. Owner independence is critical -- if the business runs without the owner on every job, it commands a premium.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is SDE and why does it matter for GC valuation?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">SDE stands for Seller's Discretionary Earnings. It is net profit plus owner salary, personal benefits, one-time expenses, depreciation, and interest. SDE represents the true economic benefit of owning the business. Buyers use SDE to compare businesses because it normalizes for different owner compensation structures.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should I get a professional appraisal for my GC business?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Yes. This calculator provides a reasonable estimate for planning purposes, but a professional business appraisal accounts for local market conditions, asset values, contract backlog, bonding capacity, and intangible factors that a formula cannot capture. For any transaction over $500K, a professional appraisal is well worth the investment.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const revenue = parseFloat((document.getElementById('annualRevenue') as HTMLInputElement).value) || 0;
    const netProfit = parseFloat((document.getElementById('netProfit') as HTMLInputElement).value) || 0;
    const ownerSalary = parseFloat((document.getElementById('ownerSalary') as HTMLInputElement).value) || 0;
    const ownerBenefits = parseFloat((document.getElementById('ownerBenefits') as HTMLInputElement).value) || 0;
    const oneTimeExpenses = parseFloat((document.getElementById('oneTimeExpenses') as HTMLInputElement).value) || 0;
    const depreciation = parseFloat((document.getElementById('depreciation') as HTMLInputElement).value) || 0;
    const interest = parseFloat((document.getElementById('interest') as HTMLInputElement).value) || 0;

    // SDE & EBITDA
    const sde = netProfit + ownerSalary + ownerBenefits + oneTimeExpenses + depreciation + interest;
    const ebitda = netProfit + depreciation + interest;
    const profitMargin = revenue > 0 ? (netProfit / revenue) * 100 : 0;

    // Revenue multiple based on size
    let revMultLow: number, revMultMid: number, revMultHigh: number;
    if (revenue < 1000000) {
      revMultLow = 0.5; revMultMid = 0.75; revMultHigh = 1.0;
    } else if (revenue < 5000000) {
      revMultLow = 1.0; revMultMid = 1.25; revMultHigh = 1.5;
    } else {
      revMultLow = 1.5; revMultMid = 2.0; revMultHigh = 2.5;
    }

    // Adjustment factors
    const factors = [
      { label: 'Repeat Client Revenue', el: 'repeatClients' },
      { label: 'Owner Dependence', el: 'ownerDependence' },
      { label: 'Equipment Condition', el: 'equipmentCondition' },
      { label: 'Licensed Staff', el: 'licensedStaff' },
      { label: 'Financial Records', el: 'financialRecords' },
      { label: 'Revenue Growth', el: 'growthRate' },
      { label: 'Customer Concentration', el: 'customerConcentration' },
    ];

    let totalAdj = 0;
    const adjListEl = document.getElementById('adjustments-list')!;
    adjListEl.innerHTML = '';
    factors.forEach(f => {
      const val = parseFloat((document.getElementById(f.el) as HTMLSelectElement).value);
      totalAdj += val;
      const color = val > 0 ? 'text-[#34D399]' : val < 0 ? 'text-[#EF4444]' : 'text-text-muted';
      const sign = val > 0 ? '+' : '';
      adjListEl.innerHTML += `<div class="flex justify-between text-sm"><span class="text-text-secondary">${f.label}</span><span class="${color} font-semibold">${sign}${(val * 100).toFixed(0)}%</span></div>`;
    });

    const adjMultiplier = 1 + totalAdj;

    // Methods
    const revenueVal = revenue * revMultMid * adjMultiplier;
    const ebitdaVal = ebitda * 4 * adjMultiplier;
    const sdeVal = sde * 2.5 * adjMultiplier;

    // Blended
    const midVal = (revenueVal + ebitdaVal + sdeVal) / 3;
    const lowVal = midVal * 0.75;
    const highVal = midVal * 1.25;

    const fmt = (n: number) => '$' + n.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });

    document.getElementById('val-low')!.textContent = fmt(lowVal);
    document.getElementById('val-mid')!.textContent = fmt(midVal);
    document.getElementById('val-high')!.textContent = fmt(highVal);
    document.getElementById('result-sde')!.textContent = fmt(sde);
    document.getElementById('result-ebitda')!.textContent = fmt(ebitda);
    document.getElementById('result-margin')!.textContent = profitMargin.toFixed(1) + '%';

    const totalAdjSign = totalAdj >= 0 ? '+' : '';
    const totalAdjEl = document.getElementById('total-adjustment')!;
    totalAdjEl.textContent = totalAdjSign + (totalAdj * 100).toFixed(0) + '%';
    totalAdjEl.classList.remove('text-[#34D399]', 'text-[#EF4444]', 'text-text-muted');
    if (totalAdj > 0) totalAdjEl.classList.add('text-[#34D399]');
    else if (totalAdj < 0) totalAdjEl.classList.add('text-[#EF4444]');
    else totalAdjEl.classList.add('text-text-muted');

    document.getElementById('method-revenue')!.textContent = fmt(revenueVal) + ` (${revMultMid}x revenue)`;
    document.getElementById('method-ebitda')!.textContent = fmt(ebitdaVal) + ' (4x EBITDA)';
    document.getElementById('method-sde')!.textContent = fmt(sdeVal) + ' (2.5x SDE)';
  }

  document.querySelectorAll('#valuation-calc input, #valuation-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
