---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/handymanTools';

const tool = getToolBySlug('overhead-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are typical handyman business overhead costs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most handyman businesses carry 20-35% overhead relative to revenue. The largest categories are usually vehicle costs (fuel, insurance, payment), general liability insurance, tools and equipment reserves, marketing, and phone/internet. A solo handyman typically runs $1,500-$3,500 per month in overhead. Multi-person operations with a vehicle and workspace can reach $4,000-$8,000 per month."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate overhead per hour for my handyman business?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Divide your total annual overhead by the total billable hours you work in a year. For example, if annual overhead is $36,000 and you bill 1,200 hours per year (about 25 hours per week), your overhead per hour is $30. This number must be built into your hourly billing rate on top of your desired income. If you want to earn $40 per hour net and overhead is $30 per hour, your minimum billing rate is $70 per hour."
      }
    },
    {
      "@type": "Question",
      "name": "What percentage of revenue should handyman overhead be?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Target 20-30% of revenue going to overhead for a healthy handyman business. Below 20% usually means a lean operation or underinvestment in growth. Above 35% signals you may be overspending or underpricing. Marketing should be 5-10% of revenue. Vehicle costs typically run 8-12%. Insurance runs 3-5%. If overhead is eating more than a third of revenue, review your largest categories for savings."
      }
    },
    {
      "@type": "Question",
      "name": "How do I reduce handyman business overhead?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start by identifying your top three overhead categories. Common wins include shopping insurance annually for better rates, optimizing routes to cut fuel costs, using free or low-cost scheduling software, maintaining tools properly to extend life, and auditing subscriptions for unused services. Do not cut marketing below 5% of revenue or you will shrink your pipeline. Focus on efficiency gains rather than blanket cuts."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="overhead-calc">
    <!-- Vehicle -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Vehicle (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="vehiclePayment">Vehicle Payment ($)</label>
          <input type="number" id="vehiclePayment" value="450" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="fuel">Fuel ($)</label>
          <input type="number" id="fuel" value="350" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="vehicleInsurance">Vehicle Insurance ($)</label>
          <input type="number" id="vehicleInsurance" value="150" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="vehicleMaint">Maintenance / Repairs ($)</label>
          <input type="number" id="vehicleMaint" value="100" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Insurance -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Insurance (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="generalLiability">General Liability ($)</label>
          <input type="number" id="generalLiability" value="150" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="workersComp">Workers Comp ($)</label>
          <input type="number" id="workersComp" value="0" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          <p class="text-text-muted text-xs mt-1">If you have employees</p>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="bonding">Bonding / E&amp;O ($)</label>
          <input type="number" id="bonding" value="50" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Tools & Equipment -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Tools &amp; Equipment (Monthly Reserve)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="toolReplace">Tool Replacement / New Tools ($)</label>
          <input type="number" id="toolReplace" value="150" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="toolMaint">Tool Maintenance / Batteries ($)</label>
          <input type="number" id="toolMaint" value="50" min="0" step="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Marketing -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Marketing (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="onlineAds">Online Ads / Lead Services ($)</label>
          <input type="number" id="onlineAds" value="300" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          <p class="text-text-muted text-xs mt-1">Google Ads, Angi, Thumbtack, etc.</p>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="website">Website / SEO ($)</label>
          <input type="number" id="website" value="50" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="printCards">Print / Business Cards ($)</label>
          <input type="number" id="printCards" value="25" min="0" step="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="referrals">Referral Incentives ($)</label>
          <input type="number" id="referrals" value="50" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Operations -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Operations (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="phone">Phone / Internet ($)</label>
          <input type="number" id="phone" value="100" min="0" step="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="accounting">Accounting / Tax Prep ($)</label>
          <input type="number" id="accounting" value="100" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="subscriptions">Software / Subscriptions ($)</label>
          <input type="number" id="subscriptions" value="75" min="0" step="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          <p class="text-text-muted text-xs mt-1">Scheduling, invoicing, CRM, etc.</p>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="licenses">Licenses / Permits ($)</label>
          <input type="number" id="licenses" value="25" min="0" step="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="workspace">Workspace / Storage Rent ($)</label>
          <input type="number" id="workspace" value="0" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          <p class="text-text-muted text-xs mt-1">If you rent a shop or storage unit</p>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="misc">Other / Misc ($)</label>
          <input type="number" id="misc" value="50" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Context -->
    <details class="mb-8 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Context (For Per-Hour &amp; Per-Job Math)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="billableHours">Billable Hours per Month</label>
          <input type="number" id="billableHours" value="100" min="1" max="250" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          <p class="text-text-muted text-xs mt-1">Hours you actually bill customers</p>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="jobsPerMonth">Jobs per Month</label>
          <input type="number" id="jobsPerMonth" value="20" min="1" max="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="annualRevenue">Annual Revenue ($)</label>
          <input type="number" id="annualRevenue" value="150000" min="0" step="10000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Results</h3>

      <!-- Primary results -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center sm:col-span-2">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Monthly Overhead</div>
          <div id="result-monthly" class="font-heading font-extrabold text-4xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center sm:col-span-2">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Annual Overhead</div>
          <div id="result-annual" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Per Billable Hour</div>
          <div id="result-per-hour" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Per Job</div>
          <div id="result-per-job" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Overhead % of Revenue</div>
          <div id="result-pct" class="font-heading font-extrabold text-2xl">--</div>
        </div>
      </div>

      <!-- Category breakdown -->
      <div class="bg-bg-dark rounded-xl p-6 mb-8">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Category Breakdown (Monthly)</h4>
        <div class="space-y-3" id="category-breakdown">
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">Vehicle</span>
            <span id="cat-vehicle" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
            <div id="bar-vehicle" class="bg-[#60A5FA] h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">Insurance</span>
            <span id="cat-insurance" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
            <div id="bar-insurance" class="bg-[#34D399] h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">Tools &amp; Equipment</span>
            <span id="cat-tools" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
            <div id="bar-tools" class="bg-[#C084FC] h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">Marketing</span>
            <span id="cat-marketing" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
            <div id="bar-marketing" class="bg-[#FBBF24] h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">Operations</span>
            <span id="cat-operations" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
            <div id="bar-operations" class="bg-[#FB923C] h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
        </div>
      </div>

      <!-- Benchmarks -->
      <div class="bg-bg-dark rounded-xl p-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Handyman Overhead Benchmarks</h4>
        <div class="space-y-3">
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Target Overhead</span>
              <span class="text-text-primary font-semibold">20 &ndash; 30% of revenue</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
              <div class="bg-[#34D399] h-2 rounded-full" style="width: 25%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Vehicle</span>
              <span class="text-text-primary font-semibold">$800 &ndash; $1,200/mo typical</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
              <div class="bg-[#60A5FA] h-2 rounded-full" style="width: 20%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Marketing</span>
              <span class="text-text-primary font-semibold">5 &ndash; 10% of revenue</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
              <div class="bg-[#FBBF24] h-2 rounded-full" style="width: 10%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Insurance</span>
              <span class="text-text-primary font-semibold">$100 &ndash; $300/mo (solo)</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
              <div class="bg-[#34D399] h-2 rounded-full" style="width: 8%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Tools Reserve</span>
              <span class="text-text-primary font-semibold">$100 &ndash; $250/mo</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
              <div class="bg-[#C084FC] h-2 rounded-full" style="width: 6%"></div>
            </div>
          </div>
          <div id="benchmark-warning" class="hidden mt-3 bg-[rgba(239,68,68,0.1)] border border-[rgba(239,68,68,0.3)] rounded-lg px-4 py-3 text-sm text-[#FCA5A5]">
            Your overhead exceeds 35% of revenue. Review your largest categories for cost reduction opportunities.
          </div>
        </div>
        <!-- Your overhead indicator -->
        <div class="mt-4 pt-4 border-t border-border">
          <div class="flex justify-between text-sm mb-1">
            <span class="text-text-secondary font-medium">Your Overhead % of Revenue</span>
            <span id="benchmark-your-pct" class="font-heading font-bold">--</span>
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2.5">
            <div id="benchmark-bar" class="h-2.5 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Fill in each overhead category.</strong> Start with the defaults and adjust to match your actual expenses. Every dollar you spend to keep the business running that is not tied to a specific job belongs here.</p>
          <p><strong class="text-text-primary">2. Enter your context numbers.</strong> Billable hours, jobs per month, and annual revenue let the calculator translate raw overhead into per-hour and per-job figures you can use for pricing.</p>
          <p><strong class="text-text-primary">3. Review your results.</strong> Check whether your overhead percentage falls within the 20-30% target range. Use the per-hour and per-job numbers to make sure your billing rates cover overhead plus profit.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How Handyman Overhead Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Overhead is every cost that keeps the business running but cannot be billed to a specific job.</strong> It includes your vehicle, insurance, tools, phone, marketing, and licenses. Unlike materials or labor on a job, overhead does not change based on how many jobs you run in a given week.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Total_Monthly = Vehicle + Insurance + Tools + Marketing + Operations</p>
            <p>Annual_Overhead = Total_Monthly x 12</p>
            <p>Per_Hour = Annual_Overhead / (Billable_Hours x 12)</p>
            <p>Per_Job = Monthly_Overhead / Jobs_Per_Month</p>
            <p>Overhead_Pct = (Annual_Overhead / Annual_Revenue) x 100</p>
          </div>
          <p><strong class="text-text-primary">The per-hour number is the most important output.</strong> It tells you exactly how much overhead you burn for every billable hour. If your overhead per hour is $20 and you bill the customer $65 per hour, you have $45 left to cover your labor and profit. Knowing this number forces you to price correctly.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Setting billing rates.</strong> Before you decide what to charge per hour, you need to know your overhead per hour. This calculator gives you that number so you can build rates that cover your costs and leave room for profit.</p>
          <p><strong class="text-text-primary">Annual budgeting.</strong> At the start of each year, plug in your expected costs to see where you will land. If overhead is creeping above 30% of projected revenue, you know you need to either cut costs or grow revenue.</p>
          <p><strong class="text-text-primary">Evaluating growth decisions.</strong> Thinking about upgrading your truck, adding a lead service, or renting workshop space? Enter the new numbers and see how they change your overhead per hour.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What are typical handyman business overhead costs?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most handyman businesses carry 20-35% overhead relative to revenue. The largest categories are usually vehicle costs, general liability insurance, tools reserves, marketing, and phone/internet. A solo handyman typically runs $1,500-$3,500 per month in overhead.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate overhead per hour?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Divide your total annual overhead by the total billable hours you work in a year. For example, if annual overhead is $36,000 and you bill 1,200 hours per year, your overhead per hour is $30. This must be built into your billing rate on top of your desired income.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What percentage of revenue should go to overhead?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Target 20-30% of revenue for a healthy handyman business. Below 20% usually means a lean operation. Above 35% signals you may be overspending or underpricing. Marketing should be 5-10% of revenue, vehicle costs 8-12%, and insurance 3-5%.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I reduce handyman business overhead?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Start by identifying your top three categories. Common wins include shopping insurance annually, optimizing routes to cut fuel, using free or low-cost software, maintaining tools to extend life, and auditing subscriptions. Do not cut marketing below 5% of revenue.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    // Vehicle
    const vehiclePayment = parseFloat((document.getElementById('vehiclePayment') as HTMLInputElement).value) || 0;
    const fuel = parseFloat((document.getElementById('fuel') as HTMLInputElement).value) || 0;
    const vehicleInsurance = parseFloat((document.getElementById('vehicleInsurance') as HTMLInputElement).value) || 0;
    const vehicleMaint = parseFloat((document.getElementById('vehicleMaint') as HTMLInputElement).value) || 0;
    const vehicleTotal = vehiclePayment + fuel + vehicleInsurance + vehicleMaint;

    // Insurance
    const generalLiability = parseFloat((document.getElementById('generalLiability') as HTMLInputElement).value) || 0;
    const workersComp = parseFloat((document.getElementById('workersComp') as HTMLInputElement).value) || 0;
    const bonding = parseFloat((document.getElementById('bonding') as HTMLInputElement).value) || 0;
    const insuranceTotal = generalLiability + workersComp + bonding;

    // Tools
    const toolReplace = parseFloat((document.getElementById('toolReplace') as HTMLInputElement).value) || 0;
    const toolMaint = parseFloat((document.getElementById('toolMaint') as HTMLInputElement).value) || 0;
    const toolsTotal = toolReplace + toolMaint;

    // Marketing
    const onlineAds = parseFloat((document.getElementById('onlineAds') as HTMLInputElement).value) || 0;
    const website = parseFloat((document.getElementById('website') as HTMLInputElement).value) || 0;
    const printCards = parseFloat((document.getElementById('printCards') as HTMLInputElement).value) || 0;
    const referrals = parseFloat((document.getElementById('referrals') as HTMLInputElement).value) || 0;
    const marketingTotal = onlineAds + website + printCards + referrals;

    // Operations
    const phone = parseFloat((document.getElementById('phone') as HTMLInputElement).value) || 0;
    const accounting = parseFloat((document.getElementById('accounting') as HTMLInputElement).value) || 0;
    const subscriptions = parseFloat((document.getElementById('subscriptions') as HTMLInputElement).value) || 0;
    const licenses = parseFloat((document.getElementById('licenses') as HTMLInputElement).value) || 0;
    const workspace = parseFloat((document.getElementById('workspace') as HTMLInputElement).value) || 0;
    const misc = parseFloat((document.getElementById('misc') as HTMLInputElement).value) || 0;
    const operationsTotal = phone + accounting + subscriptions + licenses + workspace + misc;

    // Context
    const billableHours = parseFloat((document.getElementById('billableHours') as HTMLInputElement).value) || 1;
    const jobsPerMonth = parseFloat((document.getElementById('jobsPerMonth') as HTMLInputElement).value) || 1;
    const annualRevenue = parseFloat((document.getElementById('annualRevenue') as HTMLInputElement).value) || 0;

    // Totals
    const totalMonthly = vehicleTotal + insuranceTotal + toolsTotal + marketingTotal + operationsTotal;
    const totalAnnual = totalMonthly * 12;
    const perHour = totalAnnual / (billableHours * 12);
    const perJob = totalMonthly / jobsPerMonth;
    const overheadPct = annualRevenue > 0 ? (totalAnnual / annualRevenue) * 100 : 0;

    // Format currency
    const fmt = (n: number) => '$' + n.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    const fmtDec = (n: number) => '$' + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    // Primary results
    document.getElementById('result-monthly')!.textContent = fmt(totalMonthly);
    document.getElementById('result-annual')!.textContent = fmt(totalAnnual);
    document.getElementById('result-per-hour')!.textContent = fmtDec(perHour);
    document.getElementById('result-per-job')!.textContent = fmtDec(perJob);
    document.getElementById('result-pct')!.textContent = overheadPct.toFixed(1) + '%';

    // Color overhead percentage
    const pctEl = document.getElementById('result-pct')!;
    pctEl.classList.remove('text-[#34D399]', 'text-[#FBBF24]', 'text-[#EF4444]');
    if (overheadPct <= 20) {
      pctEl.classList.add('text-[#34D399]');
    } else if (overheadPct <= 30) {
      pctEl.classList.add('text-[#FBBF24]');
    } else {
      pctEl.classList.add('text-[#EF4444]');
    }

    // Category breakdown
    const categories = [
      { id: 'vehicle', total: vehicleTotal },
      { id: 'insurance', total: insuranceTotal },
      { id: 'tools', total: toolsTotal },
      { id: 'marketing', total: marketingTotal },
      { id: 'operations', total: operationsTotal },
    ];

    categories.forEach(cat => {
      document.getElementById('cat-' + cat.id)!.textContent = fmt(cat.total);
      const barPct = totalMonthly > 0 ? (cat.total / totalMonthly) * 100 : 0;
      (document.getElementById('bar-' + cat.id) as HTMLElement).style.width = barPct + '%';
    });

    // Benchmark bar
    const clampedPct = Math.max(0, Math.min(100, overheadPct));
    const benchmarkBar = document.getElementById('benchmark-bar')!;
    benchmarkBar.style.width = Math.min(clampedPct, 60) / 60 * 100 + '%';
    benchmarkBar.classList.remove('bg-[#34D399]', 'bg-[#FBBF24]', 'bg-[#EF4444]');
    if (overheadPct <= 20) {
      benchmarkBar.classList.add('bg-[#34D399]');
    } else if (overheadPct <= 30) {
      benchmarkBar.classList.add('bg-[#FBBF24]');
    } else {
      benchmarkBar.classList.add('bg-[#EF4444]');
    }

    const yourPctEl = document.getElementById('benchmark-your-pct')!;
    yourPctEl.textContent = overheadPct.toFixed(1) + '%';
    yourPctEl.classList.remove('text-[#34D399]', 'text-[#FBBF24]', 'text-[#EF4444]');
    if (overheadPct <= 20) {
      yourPctEl.classList.add('text-[#34D399]');
    } else if (overheadPct <= 30) {
      yourPctEl.classList.add('text-[#FBBF24]');
    } else {
      yourPctEl.classList.add('text-[#EF4444]');
    }

    // Show/hide warning
    const warningEl = document.getElementById('benchmark-warning')!;
    if (overheadPct > 35) {
      warningEl.classList.remove('hidden');
    } else {
      warningEl.classList.add('hidden');
    }
  }

  // Auto-calculate on input change
  document.querySelectorAll('#overhead-calc input').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  // Calculate on load with defaults
  calculate();
</script>
