---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/gcTools';
const tool = getToolBySlug('punch-list-template')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What should a GC punch list include?", "acceptedAnswer": { "@type": "Answer", "text": "A complete GC punch list should include framing and structural items, drywall finish quality, flooring installation checks, trim and finish carpentry, paint and stain work, doors and hardware operation, window function and sealing, plumbing fixture installation, electrical fixture installation, site cleanup, and a final walkthrough with the client. Document all deficiencies with photos and assign responsibility for each correction." } },
    { "@type": "Question", "name": "How often should punch list inspections be done?", "acceptedAnswer": { "@type": "Answer", "text": "Punch list inspections should be done at each major phase completion — rough-in, drywall, trim, and final. A pre-client walkthrough punch list should happen before the owner sees the finished project. After corrections are made, a follow-up verification walkthrough confirms everything was addressed. On larger projects, weekly quality walks catch issues early before they compound." } },
    { "@type": "Question", "name": "What is the difference between a punch list and a quality checklist?", "acceptedAnswer": { "@type": "Answer", "text": "A quality checklist is used during construction to verify work meets standards as it is installed. A punch list is created near project completion to document deficiencies that need correction before final acceptance. The punch list is typically the last step before the owner signs off and final payment is released. Both are essential — quality checklists prevent punch list items from existing in the first place." } },
    { "@type": "Question", "name": "How do you prioritize punch list items?", "acceptedAnswer": { "@type": "Answer", "text": "Prioritize by impact: safety issues first (missing handrails, exposed wiring), then functional items (doors that do not latch, plumbing leaks), then cosmetic items (paint touch-ups, caulk gaps). Group items by trade so subcontractors can address all their items in one visit. Flag items that block other work — for example, a paint touch-up that must happen before final floor protection is removed." } }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="checklist-app">
    <!-- Progress Bar -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-medium text-text-secondary">Progress</span>
        <span id="progress-text" class="text-sm font-bold text-accent">0 of 0 items checked</span>
      </div>
      <div class="w-full bg-bg-dark rounded-full h-3 overflow-hidden">
        <div id="progress-bar" class="bg-accent h-3 rounded-full transition-all duration-300" style="width: 0%"></div>
      </div>
    </div>

    <!-- Tab Toggle -->
    <div class="flex gap-2 mb-8">
      <button id="tab-cooling" class="flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-accent text-white" data-tab="cooling">
        Interior Punch List
      </button>
      <button id="tab-heating" class="flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-bg-dark text-text-muted border border-border hover:border-accent hover:text-text-primary" data-tab="heating">
        Exterior &amp; Final
      </button>
    </div>

    <!-- ============ INTERIOR PUNCH LIST ============ -->
    <div id="panel-cooling">

      <!-- Framing & Structure -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Framing &amp; Structure
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Walls plumb and square</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Headers and beams properly supported</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">No visible structural cracks or deflection</span>
          </label>
        </div>
      </div>

      <!-- Drywall -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Drywall
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Seams smooth and invisible</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">No nail pops or screw dimples</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Corners and edges clean</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Proper finish level for paint type</span>
          </label>
        </div>
      </div>

      <!-- Flooring -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Flooring
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Floor level and flat (no lippage)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Transitions between materials clean</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">No scratches, chips, or damage</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Grout lines consistent and sealed</span>
          </label>
        </div>
      </div>

      <!-- Trim & Finish -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Trim &amp; Finish Carpentry
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Base trim tight to floor and walls</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Crown molding joints tight</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Casing miters tight and caulked</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Nail holes filled and sanded</span>
          </label>
        </div>
      </div>

      <!-- Paint & Stain -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Paint &amp; Stain
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Even coverage, no holidays or thin spots</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Cut lines clean at ceiling and trim</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">No drips, runs, or brush marks</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Touch-ups match surrounding areas</span>
          </label>
        </div>
      </div>

      <!-- Doors & Hardware -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Doors &amp; Hardware
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Doors swing freely, no binding</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Latches and locks operate correctly</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Even reveal around door frames</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Hinges tight, no squeaks</span>
          </label>
        </div>
      </div>

    </div>

    <!-- ============ EXTERIOR & FINAL ============ -->
    <div id="panel-heating" class="hidden">

      <!-- Windows -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Windows
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Open, close, and lock properly</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Screens installed and intact</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Weatherstripping and caulking complete</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">No glass defects or seal failures</span>
          </label>
        </div>
      </div>

      <!-- Plumbing Fixtures -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Plumbing Fixtures
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Faucets operate with no leaks</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Toilets flush and fill properly</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Drains flow freely, no standing water</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Caulking around sinks and tubs complete</span>
          </label>
        </div>
      </div>

      <!-- Electrical Fixtures -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Electrical Fixtures
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">All lights operational</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Switches and outlets work correctly</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Cover plates installed and straight</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">GFCI outlets test properly</span>
          </label>
        </div>
      </div>

      <!-- Cleanup -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Cleanup
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Construction debris removed</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Windows and surfaces cleaned</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Stickers and labels removed from fixtures</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Final vacuum and wipe-down complete</span>
          </label>
        </div>
      </div>

      <!-- Final Walkthrough -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Final Walkthrough
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">All rooms inspected with client</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Appliances demonstrated and working</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Warranty documents and manuals provided</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Client sign-off obtained</span>
          </label>
        </div>
      </div>

    </div>

    <!-- Results Summary -->
    <div id="results-summary" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Punch List Summary</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Items Checked</div>
          <div id="summary-checked" class="font-heading font-extrabold text-3xl text-accent">0 / 0</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Completion</div>
          <div id="summary-pct" class="font-heading font-extrabold text-3xl text-text-primary">0%</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Flagged Items</div>
          <div id="summary-flags" class="font-heading font-extrabold text-3xl text-text-primary">0</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Quality Grade</div>
          <div id="summary-grade" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>
      <div id="flag-list" class="hidden mb-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-3">Flagged Items</h4>
        <div id="flag-items" class="space-y-2"></div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-wrap gap-3 mt-6">
      <button id="generate-report" class="bg-accent text-white font-heading font-bold text-sm uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
        Generate Report &rarr;
      </button>
      <button id="reset-checklist" class="bg-bg-dark text-text-secondary border border-border font-heading font-bold text-sm uppercase tracking-wider px-8 py-3.5 rounded-lg hover:border-accent hover:text-text-primary transition-all cursor-pointer">
        Reset Checklist
      </button>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Checklist</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Choose your scope.</strong> Toggle between Interior and Exterior/Final tabs at the top. Each tab covers the relevant areas for that phase of the project walkthrough.</p>
          <p><strong class="text-text-primary">2. Work through each section.</strong> Check off items as you inspect them. Walk each room systematically — start at the door and work clockwise. Mark anything that needs correction.</p>
          <p><strong class="text-text-primary">3. Monitor your progress.</strong> The progress bar updates in real time. The summary section shows your completion percentage and a quality grade based on items checked and any flagged deficiencies.</p>
          <p><strong class="text-text-primary">4. Generate a report.</strong> When finished, hit Generate Report to create a printable summary of everything inspected and any items that need attention. Your progress auto-saves so you never lose work.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What a Complete GC Punch List Covers</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Framing and structure.</strong> Verify walls are plumb, floors are level, and all structural elements are properly installed. Catch framing defects before they are buried behind finishes.</p>
          <p><strong class="text-text-primary">Drywall quality.</strong> Check for smooth seams, proper finish levels, and clean corners. Drywall defects are magnified by paint — catching them now saves expensive rework later.</p>
          <p><strong class="text-text-primary">Flooring.</strong> Inspect for level installation, clean transitions, and no damage from other trades working after floor installation. Lippage and scratches are the most common punch list items.</p>
          <p><strong class="text-text-primary">Trim and finish carpentry.</strong> Tight miters, filled nail holes, and consistent reveals separate professional work from sloppy installations. These are the details clients notice most.</p>
          <p><strong class="text-text-primary">Paint and stain.</strong> Even coverage, clean cut lines, and no drips or runs. Touch-ups must match the surrounding area — mismatched touch-ups look worse than the original defect.</p>
          <p><strong class="text-text-primary">Final walkthrough.</strong> The client walkthrough is your last chance to catch issues before handover. A thorough punch list process ensures a clean handoff and protects your reputation.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Pre-client walkthrough.</strong> Walk the project before the owner sees it. Catch and fix deficiencies proactively so the client walkthrough is clean and professional.</p>
          <p><strong class="text-text-primary">Subcontractor quality checks.</strong> Use this checklist to document sub quality before releasing final payment. It creates a clear record of what needs correction and protects both parties.</p>
          <p><strong class="text-text-primary">Final project closeout.</strong> Generate the report as part of your closeout package. It demonstrates thoroughness and gives the client confidence that every detail was inspected.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should a GC punch list include?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A complete punch list should cover framing and structure, drywall finish, flooring, trim and finish carpentry, paint and stain, doors and hardware, windows, plumbing fixtures, electrical fixtures, cleanup, and a final walkthrough with the client. Document all deficiencies with photos and assign each item to the responsible sub.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How often should punch list inspections be done?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">At each major phase — rough-in, drywall, trim, and final. A pre-client walkthrough should happen before the owner sees the finished project. Weekly quality walks on larger projects catch issues early before they compound and become expensive to fix.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is the difference between a punch list and a quality checklist?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A quality checklist is used during construction to verify work meets standards as it is installed. A punch list documents deficiencies near project completion that need correction before final acceptance and payment release. Both are essential — quality checklists prevent punch list items from existing.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do you prioritize punch list items?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Safety issues first (missing handrails, exposed wiring), then functional items (doors that do not latch, plumbing leaks), then cosmetic items (paint touch-ups, caulk gaps). Group items by trade so subs can address everything in one visit. Flag items that block other work.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // ===== STATE =====
  const STORAGE_KEY = 'gc-punch-list-checklist';
  let activeTab: 'cooling' | 'heating' = 'cooling';

  interface SavedState {
    activeTab: string;
    checks: Record<string, boolean>;
    fields: Record<string, string>;
  }

  // ===== PERSISTENCE =====
  function saveState(): void {
    const checks: Record<string, boolean> = {};
    document.querySelectorAll('.cl-check').forEach((cb, i) => {
      checks[`check-${i}`] = (cb as HTMLInputElement).checked;
    });
    const fields: Record<string, string> = {};
    document.querySelectorAll('[data-field]').forEach(el => {
      const key = (el as HTMLElement).dataset.field!;
      fields[key] = (el as HTMLInputElement | HTMLSelectElement).value;
    });
    const state: SavedState = { activeTab, checks, fields };
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch {}
  }

  function loadState(): void {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const state: SavedState = JSON.parse(raw);
      if (state.activeTab === 'heating') switchTab('heating');
      if (state.checks) {
        document.querySelectorAll('.cl-check').forEach((cb, i) => {
          (cb as HTMLInputElement).checked = !!state.checks[`check-${i}`];
        });
      }
      if (state.fields) {
        document.querySelectorAll('[data-field]').forEach(el => {
          const key = (el as HTMLElement).dataset.field!;
          if (state.fields[key] !== undefined) {
            (el as HTMLInputElement | HTMLSelectElement).value = state.fields[key];
          }
        });
      }
    } catch {}
  }

  // ===== TABS =====
  function switchTab(tab: 'cooling' | 'heating'): void {
    activeTab = tab;
    const coolingPanel = document.getElementById('panel-cooling')!;
    const heatingPanel = document.getElementById('panel-heating')!;
    const coolingBtn = document.getElementById('tab-cooling')!;
    const heatingBtn = document.getElementById('tab-heating')!;

    if (tab === 'cooling') {
      coolingPanel.classList.remove('hidden');
      heatingPanel.classList.add('hidden');
      coolingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-accent text-white';
      heatingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-bg-dark text-text-muted border border-border hover:border-accent hover:text-text-primary';
    } else {
      coolingPanel.classList.add('hidden');
      heatingPanel.classList.remove('hidden');
      heatingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-accent text-white';
      coolingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-bg-dark text-text-muted border border-border hover:border-accent hover:text-text-primary';
    }
    updateProgress();
    saveState();
  }

  document.getElementById('tab-cooling')?.addEventListener('click', () => switchTab('cooling'));
  document.getElementById('tab-heating')?.addEventListener('click', () => switchTab('heating'));

  // ===== PROGRESS & SUMMARY =====
  function getActiveChecks(): NodeListOf<HTMLInputElement> {
    const panel = activeTab === 'cooling' ? '#panel-cooling' : '#panel-heating';
    return document.querySelectorAll(`${panel} .cl-check`);
  }

  function evaluateFlags(): { count: number; items: string[] } {
    const flags: string[] = [];
    // GC punch lists use checkbox-only inspection — no numeric readings to flag
    return { count: flags.length, items: flags };
  }

  function getGrade(pct: number, flagCount: number): string {
    if (pct === 0) return '--';
    const penalty = flagCount * 10;
    const score = Math.max(0, pct - penalty);
    if (score >= 90) return 'A';
    if (score >= 80) return 'B';
    if (score >= 70) return 'C';
    if (score >= 60) return 'D';
    return 'F';
  }

  function gradeColor(grade: string): string {
    if (grade === 'A') return 'text-[#34D399]';
    if (grade === 'B') return 'text-[#60A5FA]';
    if (grade === 'C') return 'text-[#FBBF24]';
    if (grade === 'D') return 'text-[#FB923C]';
    if (grade === 'F') return 'text-[#F87171]';
    return 'text-text-primary';
  }

  function updateProgress(): void {
    const checks = getActiveChecks();
    const total = checks.length;
    const checked = Array.from(checks).filter(c => c.checked).length;
    const pct = total > 0 ? Math.round((checked / total) * 100) : 0;

    document.getElementById('progress-text')!.textContent = `${checked} of ${total} items checked`;
    (document.getElementById('progress-bar') as HTMLElement).style.width = `${pct}%`;

    const flags = evaluateFlags();
    const grade = getGrade(pct, flags.count);

    document.getElementById('summary-checked')!.textContent = `${checked} / ${total}`;
    document.getElementById('summary-pct')!.textContent = `${pct}%`;
    document.getElementById('summary-flags')!.textContent = flags.count.toString();

    const gradeEl = document.getElementById('summary-grade')!;
    gradeEl.textContent = grade;
    gradeEl.className = `font-heading font-extrabold text-3xl ${gradeColor(grade)}`;

    if (flags.count > 0) {
      document.getElementById('summary-flags')!.className = 'font-heading font-extrabold text-3xl text-[#FBBF24]';
    } else {
      document.getElementById('summary-flags')!.className = 'font-heading font-extrabold text-3xl text-[#34D399]';
    }

    const flagList = document.getElementById('flag-list')!;
    const flagItems = document.getElementById('flag-items')!;
    if (flags.count > 0) {
      flagList.classList.remove('hidden');
      flagItems.innerHTML = flags.items.map(f => `<div class="bg-[rgba(251,191,36,0.1)] border border-[rgba(251,191,36,0.3)] rounded-lg px-4 py-2 text-sm text-[#FBBF24]">${f}</div>`).join('');
    } else {
      flagList.classList.add('hidden');
      flagItems.innerHTML = '';
    }
  }

  // ===== COLOR INDICATORS =====
  function updateIndicators(): void {
    // No numeric reading indicators for GC punch list
  }

  // ===== EVENT LISTENERS =====
  document.querySelectorAll('.cl-check').forEach(cb => {
    cb.addEventListener('change', () => {
      updateProgress();
      saveState();
    });
  });

  document.querySelectorAll('[data-field]').forEach(el => {
    el.addEventListener('input', () => {
      updateIndicators();
      updateProgress();
      saveState();
    });
    el.addEventListener('change', () => {
      updateIndicators();
      updateProgress();
      saveState();
    });
  });

  // ===== RESET =====
  document.getElementById('reset-checklist')?.addEventListener('click', () => {
    if (!confirm('Reset all checked items? This cannot be undone.')) return;
    document.querySelectorAll('.cl-check').forEach(cb => { (cb as HTMLInputElement).checked = false; });
    document.querySelectorAll('[data-field]').forEach(el => { (el as HTMLInputElement | HTMLSelectElement).value = ''; });
    try { localStorage.removeItem(STORAGE_KEY); } catch {}
    updateIndicators();
    updateProgress();
  });

  // ===== REPORT GENERATION =====
  document.getElementById('generate-report')?.addEventListener('click', () => {
    const seasonLabel = activeTab === 'cooling' ? 'Interior Punch List' : 'Exterior & Final';
    const panel = activeTab === 'cooling' ? '#panel-cooling' : '#panel-heating';
    const checks = document.querySelectorAll(`${panel} .cl-check`);
    const total = checks.length;
    const checked = Array.from(checks).filter(c => (c as HTMLInputElement).checked).length;
    const pct = total > 0 ? Math.round((checked / total) * 100) : 0;
    const flags = evaluateFlags();
    const grade = getGrade(pct, flags.count);
    const now = new Date();
    const dateStr = now.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    const timeStr = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });

    // Build sections from the active panel
    const sections: { title: string; items: { text: string; checked: boolean }[] }[] = [];
    const sectionEls = document.querySelectorAll(`${panel} > .mb-8`);
    sectionEls.forEach(sec => {
      const h3 = sec.querySelector('h3');
      if (!h3) return;
      const title = h3.textContent?.trim().replace(/^\u25CF\s*/, '') || '';
      const items: { text: string; checked: boolean }[] = [];
      sec.querySelectorAll('.cl-check').forEach(cb => {
        const label = (cb as HTMLElement).closest('label') || (cb as HTMLElement).closest('.flex');
        const span = label?.querySelector('span');
        const text = span?.textContent?.trim() || '';
        items.push({ text, checked: (cb as HTMLInputElement).checked });
      });
      sections.push({ title, items });
    });

    // Build HTML for print
    let html = `<!DOCTYPE html><html><head><meta charset="utf-8"><title>GC Punch List Report - ${seasonLabel}</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1a1a1a; padding: 40px; max-width: 800px; margin: 0 auto; font-size: 13px; line-height: 1.5; }
      h1 { font-size: 22px; margin-bottom: 4px; }
      h2 { font-size: 16px; margin: 20px 0 8px; border-bottom: 2px solid #e5e7eb; padding-bottom: 4px; }
      .meta { color: #6b7280; font-size: 12px; margin-bottom: 20px; }
      .summary-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px; }
      .summary-box { border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px; text-align: center; }
      .summary-box .label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280; margin-bottom: 4px; }
      .summary-box .value { font-size: 22px; font-weight: 700; }
      .grade-A { color: #10b981; } .grade-B { color: #3b82f6; } .grade-C { color: #f59e0b; } .grade-D { color: #f97316; } .grade-F { color: #ef4444; }
      .item { padding: 3px 0; display: flex; align-items: center; gap: 8px; }
      .check { width: 14px; height: 14px; border: 1.5px solid #d1d5db; border-radius: 3px; display: inline-flex; align-items: center; justify-content: center; font-size: 10px; flex-shrink: 0; }
      .check.done { background: #10b981; border-color: #10b981; color: white; }
      .flag { background: #fef3c7; border: 1px solid #f59e0b; border-radius: 6px; padding: 6px 12px; margin: 4px 0; font-size: 12px; color: #92400e; }
      @media print { body { padding: 20px; } }
    </style></head><body>`;

    html += `<h1>GC Punch List Report</h1>`;
    html += `<div class="meta">${seasonLabel} &mdash; ${dateStr} at ${timeStr}</div>`;

    html += `<div class="summary-grid">`;
    html += `<div class="summary-box"><div class="label">Checked</div><div class="value">${checked}/${total}</div></div>`;
    html += `<div class="summary-box"><div class="label">Completion</div><div class="value">${pct}%</div></div>`;
    html += `<div class="summary-box"><div class="label">Flags</div><div class="value">${flags.count}</div></div>`;
    html += `<div class="summary-box"><div class="label">Grade</div><div class="value grade-${grade}">${grade}</div></div>`;
    html += `</div>`;

    if (flags.count > 0) {
      html += `<h2>Flagged Items</h2>`;
      flags.items.forEach(f => { html += `<div class="flag">${f}</div>`; });
    }

    sections.forEach(sec => {
      html += `<h2>${sec.title}</h2>`;
      sec.items.forEach(item => {
        html += `<div class="item"><span class="check ${item.checked ? 'done' : ''}">${item.checked ? '&#10003;' : ''}</span> ${item.text}</div>`;
      });
    });

    html += `</body></html>`;

    const printWin = window.open('', '_blank');
    if (printWin) {
      printWin.document.write(html);
      printWin.document.close();
      setTimeout(() => printWin.print(), 400);
    }
  });

  // ===== INIT =====
  loadState();
  updateIndicators();
  updateProgress();
</script>
