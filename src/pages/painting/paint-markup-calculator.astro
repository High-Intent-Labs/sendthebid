---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/paintingTools';

const tool = getToolBySlug('paint-markup-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between markup and margin?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Markup is the percentage added to your wholesale cost to get the sell price. Margin is the percentage of the sell price that is profit. A 50% markup on a $40 gallon means you charge $60. The resulting margin is 33% because one-third of the sell price is profit. Markup is based on cost, margin is based on sell price."
      }
    },
    {
      "@type": "Question",
      "name": "What markup should painting companies use on paint?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most painting companies use 30-50% markup on paint products. Standard practice is 1.3 to 1.5x wholesale cost. Premium and specialty products can carry 40-60% markup. The target is a blended margin of 25-35% across all materials. Some contractors include paint in a flat job rate rather than marking up separately."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate sell price from wholesale cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Multiply the wholesale cost by (1 + markup/100). For example, a $40 gallon at 40% markup: $40 x 1.40 = $56 sell price. The profit is $16 per gallon and the margin is 28.6%."
      }
    },
    {
      "@type": "Question",
      "name": "Should painters mark up paint to customers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Paint markup covers more than the product itself. It accounts for picking up the paint, color matching, having the right products on hand, leftover product storage for touch-ups, and your expertise in selecting the right product for the surface. A 40% markup on a $40 gallon results in a $56 charge, which is still well below retail price."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="markup-calc">
    <!-- Quick Lookup -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-text-secondary mb-2" for="quick-lookup">Quick Lookup &mdash; Common Paint Products</label>
      <select id="quick-lookup" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
        <option value="">Select a product to auto-fill cost...</option>
        <option value="25">Budget Interior Latex (gal) &mdash; $25</option>
        <option value="40">Standard Interior Latex (gal) &mdash; $40</option>
        <option value="60">Premium Interior Latex (gal) &mdash; $60</option>
        <option value="35">Standard Exterior Latex (gal) &mdash; $35</option>
        <option value="55">Premium Exterior Latex (gal) &mdash; $55</option>
        <option value="75">High-End Exterior (gal) &mdash; $75</option>
        <option value="30">Primer &mdash; Standard (gal) &mdash; $30</option>
        <option value="45">Primer &mdash; Stain Blocking (gal) &mdash; $45</option>
        <option value="18">Caulk (case of 12) &mdash; $18</option>
        <option value="15">Roller Covers (6-pack) &mdash; $15</option>
        <option value="8">Blue Tape (roll) &mdash; $8</option>
        <option value="50">Wood Stain (gal) &mdash; $50</option>
        <option value="55">Polyurethane (gal) &mdash; $55</option>
        <option value="12">Drop Cloths (pack) &mdash; $12</option>
      </select>
    </div>

    <!-- Input Section -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="product-name">Product Name (optional)</label>
        <input type="text" id="product-name" placeholder="e.g. Interior Latex" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wholesale-cost">Wholesale Cost ($)</label>
        <input type="number" id="wholesale-cost" value="40" min="0.01" step="0.01" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="quantity">Quantity (gallons/units)</label>
        <input type="number" id="quantity" value="10" min="1" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <div class="mb-6">
      <label class="block text-sm font-medium text-text-secondary mb-2" for="markup-pct">Desired Markup (%)</label>
      <input type="number" id="markup-pct" value="40" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      <div class="flex flex-wrap gap-2 mt-3">
        <button class="markup-quick-btn bg-bg-dark border border-border rounded-lg px-4 py-2 text-sm text-text-secondary hover:border-accent hover:text-accent transition-colors cursor-pointer" data-markup="30">30%</button>
        <button class="markup-quick-btn bg-bg-dark border border-accent rounded-lg px-4 py-2 text-sm text-accent transition-colors cursor-pointer" data-markup="40">40%</button>
        <button class="markup-quick-btn bg-bg-dark border border-border rounded-lg px-4 py-2 text-sm text-text-secondary hover:border-accent hover:text-accent transition-colors cursor-pointer" data-markup="50">50%</button>
        <button class="markup-quick-btn bg-bg-dark border border-border rounded-lg px-4 py-2 text-sm text-text-secondary hover:border-accent hover:text-accent transition-colors cursor-pointer" data-markup="60">60%</button>
        <button class="markup-quick-btn bg-bg-dark border border-border rounded-lg px-4 py-2 text-sm text-text-secondary hover:border-accent hover:text-accent transition-colors cursor-pointer" data-markup="75">75%</button>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Results</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Sell Price/Unit</div>
          <div id="result-sell" class="font-heading font-extrabold text-3xl text-accent">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Job Cost</div>
          <div id="result-total" class="font-heading font-extrabold text-3xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Profit</div>
          <div id="result-profit" class="font-heading font-extrabold text-3xl text-[#34D399]">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Margin</div>
          <div id="result-margin" class="font-heading font-extrabold text-3xl text-text-primary">&mdash;</div>
        </div>
      </div>

      <!-- Benchmarks -->
      <div class="bg-bg-dark rounded-xl p-5 mt-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Industry Benchmarks</h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Standard paint</span>
            <span class="text-text-primary font-medium">30-50% markup &middot; 23-33% margin</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Premium/specialty paint</span>
            <span class="text-text-primary font-medium">40-60% markup &middot; 29-38% margin</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Primer &amp; prep products</span>
            <span class="text-text-primary font-medium">40-60% markup &middot; 29-38% margin</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-text-secondary">Supplies (tape, cloths, etc.)</span>
            <span class="text-text-primary font-medium">50-100% markup &middot; 33-50% margin</span>
          </div>
        </div>
        <p class="text-text-muted text-xs mt-3 italic">Target: 28-35% blended margin on all materials combined.</p>
      </div>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Pick a product or enter the cost.</strong> Use the Quick Lookup dropdown to select a common paint product and auto-fill the wholesale cost, or type your own cost directly.</p>
          <p><strong class="text-text-primary">2. Set your markup percentage.</strong> Use the quick buttons for common markup levels or type any percentage. The painting industry standard is 30-50% markup on paint products.</p>
          <p><strong class="text-text-primary">3. Enter the quantity.</strong> Set the number of gallons or units for the job. The calculator shows both per-unit and total job pricing.</p>
          <p><strong class="text-text-primary">4. Read the results.</strong> The calculator shows sell price per unit, total job material cost, total profit, and margin percentage. Compare against the benchmarks to stay competitive.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Markup vs Margin &mdash; What's the Difference</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Markup</strong> is the percentage added on top of your cost. <strong class="text-text-primary">Margin</strong> is the percentage of the final sell price that is profit. They use different denominators, which is why the numbers are always different.</p>
          <p>Here is a concrete example. You buy a gallon of paint for <strong class="text-text-primary">$40</strong> and mark it up <strong class="text-text-primary">40%</strong>.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Sell Price = $40 x (1 + 40/100) = $40 x 1.40 = <strong class="text-accent">$56</strong></p>
            <p>Profit    = $56 - $40 = <strong class="text-text-primary">$16</strong></p>
            <p>Markup %  = ($16 / $40) x 100 = <strong class="text-text-primary">40%</strong>  (profit / cost)</p>
            <p>Margin %  = ($16 / $56) x 100 = <strong class="text-text-primary">28.6%</strong> (profit / sell price)</p>
          </div>
          <p>The markup is 40% but the margin is only 28.6%. Markup will always be a larger number than margin for the same transaction. The most common mistake is confusing the two. This calculator shows both numbers so you always know exactly where you stand.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Quoting material costs for a job.</strong> You have measured the job and know you need 10 gallons. Open the calculator, select the paint quality, set your markup, and see exactly what to charge the customer for materials.</p>
          <p><strong class="text-text-primary">Setting standard material pricing.</strong> Decide on a consistent markup strategy across your product categories. Use the benchmarks as a guide: higher markup on supplies, standard markup on paint.</p>
          <p><strong class="text-text-primary">Comparing wholesale suppliers.</strong> Enter different wholesale costs from multiple suppliers to see how each affects your profit at the same sell price. Sometimes a cheaper product is not worth the quality trade-off.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is the difference between markup and margin?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Markup is the percentage added to your wholesale cost to get the sell price. Margin is the percentage of the sell price that is profit. A 50% markup on a $40 gallon means you charge $60. The margin is 33.3% because one-third of the sell price is profit.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What markup should painting companies use on paint?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most painting companies use 30-50% markup on paint products. Premium and specialty products can carry 40-60% markup. The target is a blended margin of 25-35% across all materials.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate sell price from wholesale cost?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Multiply the wholesale cost by (1 + markup/100). For example, a $40 gallon at 40% markup: $40 x 1.40 = $56 sell price. The profit is $16 per gallon and the margin is 28.6%.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should painters mark up paint to customers?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Yes. Paint markup covers more than the product itself. It accounts for picking up the paint, color matching, having the right products on hand, leftover storage for touch-ups, and your expertise in selecting the right product for the surface.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const cost = parseFloat((document.getElementById('wholesale-cost') as HTMLInputElement).value) || 0;
    const markupPct = parseFloat((document.getElementById('markup-pct') as HTMLInputElement).value) || 0;
    const quantity = parseInt((document.getElementById('quantity') as HTMLInputElement).value) || 1;

    const sellPrice = cost * (1 + markupPct / 100);
    const profitPerUnit = sellPrice - cost;
    const totalCost = sellPrice * quantity;
    const totalProfit = profitPerUnit * quantity;
    const marginPct = sellPrice > 0 ? (profitPerUnit / sellPrice) * 100 : 0;

    document.getElementById('result-sell')!.textContent = `$${sellPrice.toFixed(2)}`;
    document.getElementById('result-total')!.textContent = `$${Math.round(totalCost).toLocaleString()}`;
    document.getElementById('result-profit')!.textContent = `$${Math.round(totalProfit).toLocaleString()}`;
    document.getElementById('result-margin')!.textContent = `${marginPct.toFixed(1)}%`;
  }

  // Quick Lookup dropdown
  document.getElementById('quick-lookup')?.addEventListener('change', (e) => {
    const select = e.target as HTMLSelectElement;
    const value = select.value;
    if (value) {
      (document.getElementById('wholesale-cost') as HTMLInputElement).value = value;
      const optionText = select.options[select.selectedIndex].text;
      const productName = optionText.split(' \u2014 ')[0];
      (document.getElementById('product-name') as HTMLInputElement).value = productName;
      calculate();
    }
  });

  // Markup quick buttons
  document.querySelectorAll('.markup-quick-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const markup = target.dataset.markup;
      (document.getElementById('markup-pct') as HTMLInputElement).value = markup!;

      document.querySelectorAll('.markup-quick-btn').forEach(b => {
        b.classList.remove('text-accent', 'border-accent');
        b.classList.add('text-text-secondary');
      });
      target.classList.remove('text-text-secondary');
      target.classList.add('text-accent', 'border-accent');

      calculate();
    });
  });

  document.querySelectorAll('#markup-calc input[type="number"]').forEach(el => {
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
