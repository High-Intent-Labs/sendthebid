---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/electricalTools';
const tool = getToolBySlug('service-checklist')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What should an electrical service visit include?", "acceptedAnswer": { "@type": "Answer", "text": "A complete electrical service visit should include panel inspection, breaker torque checks, grounding and bonding verification, GFCI and AFCI testing, voltage and amperage measurements on loaded circuits, insulation resistance testing on suspect circuits, a thorough inspection of all accessible wiring and connections, testing of all safety devices, and documentation of current conditions versus previous service records. Address any code violations or safety issues found immediately or note them for follow-up." } },
    { "@type": "Question", "name": "How often should electrical systems be inspected?", "acceptedAnswer": { "@type": "Answer", "text": "Residential electrical systems should be inspected at least every 3 to 5 years, or whenever you notice flickering lights, tripped breakers, or warm outlets. Commercial properties should have annual electrical inspections. Properties with older wiring (pre-1980), aluminum wiring, or Federal Pacific or Zinsco panels should be inspected more frequently due to known safety concerns." } },
    { "@type": "Question", "name": "What are normal voltage readings for residential service?", "acceptedAnswer": { "@type": "Answer", "text": "Normal residential voltage should measure 120V line-to-neutral and 240V line-to-line at the panel, with an acceptable range of plus or minus 5 percent (114V to 126V for 120V circuits). Voltage imbalance between the two legs should be less than 3 percent. Readings outside these ranges indicate utility supply problems, loose connections, or overloaded circuits that require investigation." } },
    { "@type": "Question", "name": "What is a safe operating condition for electrical systems?", "acceptedAnswer": { "@type": "Answer", "text": "Safe electrical operating conditions require all breakers properly rated for their wire gauge, no double-tapped breakers unless listed for it, all ground and neutral connections properly separated in sub-panels, GFCI protection in wet locations (kitchens, bathrooms, garages, outdoors), AFCI protection in bedrooms and living areas per current code, and no signs of overheating such as discolored wires, melted insulation, or warm breakers." } }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="checklist-app">
    <!-- Progress Bar -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-medium text-text-secondary">Progress</span>
        <span id="progress-text" class="text-sm font-bold text-accent">0 of 0 items checked</span>
      </div>
      <div class="w-full bg-bg-dark rounded-full h-3 overflow-hidden">
        <div id="progress-bar" class="bg-accent h-3 rounded-full transition-all duration-300" style="width: 0%"></div>
      </div>
    </div>

    <!-- Tab Toggle -->
    <div class="flex gap-2 mb-8">
      <button id="tab-cooling" class="flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-accent text-white" data-tab="cooling">
        Panel &amp; Circuits
      </button>
      <button id="tab-heating" class="flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-bg-dark text-text-muted border border-border hover:border-accent hover:text-text-primary" data-tab="heating">
        Safety &amp; Testing
      </button>
    </div>

    <!-- ============ PANEL & CIRCUITS ============ -->
    <div id="panel-cooling">

      <!-- Panel Inspection -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Panel Inspection
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Panel cover secure, no damage</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">No signs of overheating or corrosion</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Bus bars clean and connections tight</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Panel brand and type noted (no recalled panels)</span>
          </label>
        </div>
      </div>

      <!-- Breaker Condition -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Breaker Condition
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">All breakers properly rated for wire gauge</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">No double-tapped breakers (unless listed)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Breakers snap firmly on and off</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">No warm breakers (infrared check)</span>
          </label>
        </div>
      </div>

      <!-- Wire Connections -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Wire Connections
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">All connections torqued to spec</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">No aluminum wiring issues (or properly remediated)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">No melted or discolored insulation</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Wire routing neat and secured</span>
          </label>
        </div>
      </div>

      <!-- Circuit Labeling -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Circuit Labeling
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Panel directory complete and accurate</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">All breakers labeled legibly</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Labels match actual circuits (verified)</span>
          </label>
        </div>
      </div>

    </div>

    <!-- ============ SAFETY & TESTING ============ -->
    <div id="panel-heating" class="hidden">

      <!-- GFCI / AFCI Testing -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> GFCI / AFCI Testing
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">All GFCI outlets trip and reset</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">GFCI protection in all required locations</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">AFCI breakers test properly</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">AFCI protection in bedrooms and living areas</span>
          </label>
        </div>
      </div>

      <!-- Grounding & Bonding -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Grounding &amp; Bonding
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Ground rod connection secure</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Water pipe bonding intact</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Ground and neutral separated in sub-panels</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Equipment grounding conductors continuous</span>
          </label>
        </div>
      </div>

      <!-- Voltage Checks -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Voltage Checks
        </h3>
        <div class="space-y-3">
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Line-to-Neutral (L1)</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <input type="number" data-field="voltage-l1n" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">V</span>
              <span class="text-xs text-text-muted ml-1">Target: 114-126V</span>
              <span id="ind-voltage-l1" class="w-3 h-3 rounded-full bg-border inline-block ml-1"></span>
            </div>
          </div>
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Line-to-Neutral (L2)</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <input type="number" data-field="voltage-l2n" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">V</span>
              <span class="text-xs text-text-muted ml-1">Target: 114-126V</span>
              <span id="ind-voltage-l2" class="w-3 h-3 rounded-full bg-border inline-block ml-1"></span>
            </div>
          </div>
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Line-to-Line</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <input type="number" data-field="voltage-ll" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">V</span>
              <span class="text-xs text-text-muted ml-1">Target: 228-252V</span>
              <span id="ind-voltage-ll" class="w-3 h-3 rounded-full bg-border inline-block ml-1"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Load Balance -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Load Balance
        </h3>
        <div class="space-y-3">
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Leg 1 amperage</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <input type="number" data-field="amps-leg1" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">A</span>
            </div>
          </div>
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Leg 2 amperage</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <input type="number" data-field="amps-leg2" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">A</span>
            </div>
          </div>
          <div class="flex flex-wrap items-center gap-3 ml-8">
            <span class="text-text-secondary text-sm">Imbalance:</span>
            <span id="load-imbalance" class="font-heading font-bold text-lg text-text-primary">--</span>
            <span class="text-xs text-text-muted">%</span>
            <span class="text-xs text-text-muted ml-1">Target: &lt; 10%</span>
            <span id="ind-imbalance" class="w-3 h-3 rounded-full bg-border inline-block ml-1"></span>
          </div>
        </div>
      </div>

    </div>

    <!-- Results Summary -->
    <div id="results-summary" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">System Health Summary</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Items Checked</div>
          <div id="summary-checked" class="font-heading font-extrabold text-3xl text-accent">0 / 0</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Completion</div>
          <div id="summary-pct" class="font-heading font-extrabold text-3xl text-text-primary">0%</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Flagged Readings</div>
          <div id="summary-flags" class="font-heading font-extrabold text-3xl text-text-primary">0</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Health Grade</div>
          <div id="summary-grade" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>
      <div id="flag-list" class="hidden mb-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-3">Flagged Items</h4>
        <div id="flag-items" class="space-y-2"></div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-wrap gap-3 mt-6">
      <button id="generate-report" class="bg-accent text-white font-heading font-bold text-sm uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
        Generate Report &rarr;
      </button>
      <button id="reset-checklist" class="bg-bg-dark text-text-secondary border border-border font-heading font-bold text-sm uppercase tracking-wider px-8 py-3.5 rounded-lg hover:border-accent hover:text-text-primary transition-all cursor-pointer">
        Reset Checklist
      </button>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Checklist</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Choose your scope.</strong> Toggle between Panel/Circuits and Safety/Testing tabs at the top. Each tab covers the relevant areas for that phase of the electrical service visit.</p>
          <p><strong class="text-text-primary">2. Work through each section.</strong> Check off items as you complete them. Enter voltage and amperage readings directly into the fields — the tool will flag anything outside normal range.</p>
          <p><strong class="text-text-primary">3. Monitor your progress.</strong> The progress bar updates in real time. The summary section shows your completion percentage and a health grade based on items checked and flagged readings.</p>
          <p><strong class="text-text-primary">4. Generate a report.</strong> When finished, hit Generate Report to create a printable summary of everything checked, every reading recorded, and any items that need attention. Your progress auto-saves so you never lose work.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What a Complete Electrical Service Visit Covers</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Panel inspection.</strong> Check the panel for signs of overheating, corrosion, or damage. Verify the panel brand is not on any recall list (Federal Pacific, Zinsco). Inspect bus bars, neutral bars, and ground bars for tight connections.</p>
          <p><strong class="text-text-primary">Breaker condition.</strong> Verify each breaker is properly rated for its wire gauge. Check for double-tapped breakers, warm breakers, and breakers that do not snap firmly. These are the most common sources of electrical failures.</p>
          <p><strong class="text-text-primary">Wire connections.</strong> Torque all connections to manufacturer specifications. Loose connections are the number one cause of electrical fires. Check for aluminum wiring, melted insulation, and improper splices.</p>
          <p><strong class="text-text-primary">GFCI and AFCI testing.</strong> Test every GFCI outlet and AFCI breaker. Verify GFCI protection exists in all required wet locations and AFCI protection covers bedrooms and living areas per current code.</p>
          <p><strong class="text-text-primary">Grounding and bonding.</strong> Verify the grounding electrode system is complete — ground rod, water pipe bond, and proper separation of grounds and neutrals in sub-panels. Poor grounding creates shock hazards and equipment damage.</p>
          <p><strong class="text-text-primary">Voltage and load balance.</strong> Measure voltage at the panel on both legs. Check load balance between legs — significant imbalance causes voltage fluctuations and premature equipment failure.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Electrical service calls.</strong> Use this as your standard process for every service visit. It ensures a thorough inspection is completed regardless of what the original call was for, and it often uncovers additional work.</p>
          <p><strong class="text-text-primary">Pre-purchase inspections.</strong> Buyers need to know the condition of the electrical system. This checklist covers every major component and produces a professional report that supports informed decisions.</p>
          <p><strong class="text-text-primary">Maintenance agreements.</strong> Offer annual electrical inspections as a service plan. The generated report shows the customer exactly what was checked and gives them peace of mind about their electrical safety.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should an electrical service visit include?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A complete visit should include panel inspection, breaker condition check, wire connection torque verification, GFCI and AFCI testing, grounding and bonding verification, voltage measurements, load balance assessment, and documentation of all findings with readings.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How often should electrical systems be inspected?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Residential systems should be inspected every 3 to 5 years. Commercial properties need annual inspections. Older homes with pre-1980 wiring, aluminum wiring, or recalled panels should be inspected more frequently. Any time you notice flickering lights or tripped breakers warrants an inspection.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What are normal voltage readings for residential service?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Normal residential voltage measures 120V line-to-neutral and 240V line-to-line at the panel, with an acceptable range of plus or minus 5 percent (114V to 126V for 120V circuits). Imbalance between legs should be less than 3 percent. Readings outside these ranges indicate utility supply issues, loose connections, or overloaded circuits.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is a safe operating condition for electrical systems?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Safe conditions require all breakers properly rated for wire gauge, no double-tapped breakers (unless listed), grounds and neutrals separated in sub-panels, GFCI protection in wet locations, AFCI protection in bedrooms and living areas, and no signs of overheating such as discolored wires, melted insulation, or warm breakers.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // ===== STATE =====
  const STORAGE_KEY = 'electrical-service-checklist';
  let activeTab: 'cooling' | 'heating' = 'cooling';

  interface SavedState {
    activeTab: string;
    checks: Record<string, boolean>;
    fields: Record<string, string>;
  }

  // ===== PERSISTENCE =====
  function saveState(): void {
    const checks: Record<string, boolean> = {};
    document.querySelectorAll('.cl-check').forEach((cb, i) => {
      checks[`check-${i}`] = (cb as HTMLInputElement).checked;
    });
    const fields: Record<string, string> = {};
    document.querySelectorAll('[data-field]').forEach(el => {
      const key = (el as HTMLElement).dataset.field!;
      fields[key] = (el as HTMLInputElement | HTMLSelectElement).value;
    });
    const state: SavedState = { activeTab, checks, fields };
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch {}
  }

  function loadState(): void {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const state: SavedState = JSON.parse(raw);
      if (state.activeTab === 'heating') switchTab('heating');
      if (state.checks) {
        document.querySelectorAll('.cl-check').forEach((cb, i) => {
          (cb as HTMLInputElement).checked = !!state.checks[`check-${i}`];
        });
      }
      if (state.fields) {
        document.querySelectorAll('[data-field]').forEach(el => {
          const key = (el as HTMLElement).dataset.field!;
          if (state.fields[key] !== undefined) {
            (el as HTMLInputElement | HTMLSelectElement).value = state.fields[key];
          }
        });
      }
    } catch {}
  }

  // ===== TABS =====
  function switchTab(tab: 'cooling' | 'heating'): void {
    activeTab = tab;
    const coolingPanel = document.getElementById('panel-cooling')!;
    const heatingPanel = document.getElementById('panel-heating')!;
    const coolingBtn = document.getElementById('tab-cooling')!;
    const heatingBtn = document.getElementById('tab-heating')!;

    if (tab === 'cooling') {
      coolingPanel.classList.remove('hidden');
      heatingPanel.classList.add('hidden');
      coolingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-accent text-white';
      heatingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-bg-dark text-text-muted border border-border hover:border-accent hover:text-text-primary';
    } else {
      coolingPanel.classList.add('hidden');
      heatingPanel.classList.remove('hidden');
      heatingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-accent text-white';
      coolingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-bg-dark text-text-muted border border-border hover:border-accent hover:text-text-primary';
    }
    updateProgress();
    saveState();
  }

  document.getElementById('tab-cooling')?.addEventListener('click', () => switchTab('cooling'));
  document.getElementById('tab-heating')?.addEventListener('click', () => switchTab('heating'));

  // ===== PROGRESS & SUMMARY =====
  function getActiveChecks(): NodeListOf<HTMLInputElement> {
    const panel = activeTab === 'cooling' ? '#panel-cooling' : '#panel-heating';
    return document.querySelectorAll(`${panel} .cl-check`);
  }

  function evaluateFlags(): { count: number; items: string[] } {
    const flags: string[] = [];
    const l1 = parseFloat((document.querySelector('[data-field="voltage-l1n"]') as HTMLInputElement)?.value);
    if (!isNaN(l1) && l1 > 0 && (l1 < 114 || l1 > 126)) flags.push(`L1-N Voltage: ${l1}V (target 114-126V)`);
    const l2 = parseFloat((document.querySelector('[data-field="voltage-l2n"]') as HTMLInputElement)?.value);
    if (!isNaN(l2) && l2 > 0 && (l2 < 114 || l2 > 126)) flags.push(`L2-N Voltage: ${l2}V (target 114-126V)`);
    const ll = parseFloat((document.querySelector('[data-field="voltage-ll"]') as HTMLInputElement)?.value);
    if (!isNaN(ll) && ll > 0 && (ll < 228 || ll > 252)) flags.push(`L-L Voltage: ${ll}V (target 228-252V)`);
    const leg1 = parseFloat((document.querySelector('[data-field="amps-leg1"]') as HTMLInputElement)?.value);
    const leg2 = parseFloat((document.querySelector('[data-field="amps-leg2"]') as HTMLInputElement)?.value);
    if (!isNaN(leg1) && !isNaN(leg2) && leg1 > 0 && leg2 > 0) {
      const avg = (leg1 + leg2) / 2;
      const imbalance = avg > 0 ? (Math.abs(leg1 - leg2) / avg) * 100 : 0;
      if (imbalance > 10) flags.push(`Load Imbalance: ${imbalance.toFixed(1)}% (target < 10%)`);
    }
    return { count: flags.length, items: flags };
  }

  function getGrade(pct: number, flagCount: number): string {
    if (pct === 0) return '--';
    const penalty = flagCount * 10;
    const score = Math.max(0, pct - penalty);
    if (score >= 90) return 'A';
    if (score >= 80) return 'B';
    if (score >= 70) return 'C';
    if (score >= 60) return 'D';
    return 'F';
  }

  function gradeColor(grade: string): string {
    if (grade === 'A') return 'text-[#34D399]';
    if (grade === 'B') return 'text-[#60A5FA]';
    if (grade === 'C') return 'text-[#FBBF24]';
    if (grade === 'D') return 'text-[#FB923C]';
    if (grade === 'F') return 'text-[#F87171]';
    return 'text-text-primary';
  }

  function updateProgress(): void {
    const checks = getActiveChecks();
    const total = checks.length;
    const checked = Array.from(checks).filter(c => c.checked).length;
    const pct = total > 0 ? Math.round((checked / total) * 100) : 0;

    document.getElementById('progress-text')!.textContent = `${checked} of ${total} items checked`;
    (document.getElementById('progress-bar') as HTMLElement).style.width = `${pct}%`;

    const flags = evaluateFlags();
    const grade = getGrade(pct, flags.count);

    document.getElementById('summary-checked')!.textContent = `${checked} / ${total}`;
    document.getElementById('summary-pct')!.textContent = `${pct}%`;
    document.getElementById('summary-flags')!.textContent = flags.count.toString();

    const gradeEl = document.getElementById('summary-grade')!;
    gradeEl.textContent = grade;
    gradeEl.className = `font-heading font-extrabold text-3xl ${gradeColor(grade)}`;

    if (flags.count > 0) {
      document.getElementById('summary-flags')!.className = 'font-heading font-extrabold text-3xl text-[#FBBF24]';
    } else {
      document.getElementById('summary-flags')!.className = 'font-heading font-extrabold text-3xl text-[#34D399]';
    }

    const flagList = document.getElementById('flag-list')!;
    const flagItems = document.getElementById('flag-items')!;
    if (flags.count > 0) {
      flagList.classList.remove('hidden');
      flagItems.innerHTML = flags.items.map(f => `<div class="bg-[rgba(251,191,36,0.1)] border border-[rgba(251,191,36,0.3)] rounded-lg px-4 py-2 text-sm text-[#FBBF24]">${f}</div>`).join('');
    } else {
      flagList.classList.add('hidden');
      flagItems.innerHTML = '';
    }
  }

  // ===== COLOR INDICATORS =====
  function updateIndicators(): void {
    const l1 = parseFloat((document.querySelector('[data-field="voltage-l1n"]') as HTMLInputElement)?.value);
    const indL1 = document.getElementById('ind-voltage-l1');
    if (indL1) {
      if (isNaN(l1) || l1 === 0) indL1.className = 'w-3 h-3 rounded-full bg-border inline-block ml-1';
      else if (l1 >= 114 && l1 <= 126) indL1.className = 'w-3 h-3 rounded-full bg-[#34D399] inline-block ml-1';
      else if (l1 >= 110 && l1 <= 130) indL1.className = 'w-3 h-3 rounded-full bg-[#FBBF24] inline-block ml-1';
      else indL1.className = 'w-3 h-3 rounded-full bg-[#F87171] inline-block ml-1';
    }

    const l2 = parseFloat((document.querySelector('[data-field="voltage-l2n"]') as HTMLInputElement)?.value);
    const indL2 = document.getElementById('ind-voltage-l2');
    if (indL2) {
      if (isNaN(l2) || l2 === 0) indL2.className = 'w-3 h-3 rounded-full bg-border inline-block ml-1';
      else if (l2 >= 114 && l2 <= 126) indL2.className = 'w-3 h-3 rounded-full bg-[#34D399] inline-block ml-1';
      else if (l2 >= 110 && l2 <= 130) indL2.className = 'w-3 h-3 rounded-full bg-[#FBBF24] inline-block ml-1';
      else indL2.className = 'w-3 h-3 rounded-full bg-[#F87171] inline-block ml-1';
    }

    const ll = parseFloat((document.querySelector('[data-field="voltage-ll"]') as HTMLInputElement)?.value);
    const indLL = document.getElementById('ind-voltage-ll');
    if (indLL) {
      if (isNaN(ll) || ll === 0) indLL.className = 'w-3 h-3 rounded-full bg-border inline-block ml-1';
      else if (ll >= 228 && ll <= 252) indLL.className = 'w-3 h-3 rounded-full bg-[#34D399] inline-block ml-1';
      else if (ll >= 220 && ll <= 260) indLL.className = 'w-3 h-3 rounded-full bg-[#FBBF24] inline-block ml-1';
      else indLL.className = 'w-3 h-3 rounded-full bg-[#F87171] inline-block ml-1';
    }

    const leg1 = parseFloat((document.querySelector('[data-field="amps-leg1"]') as HTMLInputElement)?.value);
    const leg2 = parseFloat((document.querySelector('[data-field="amps-leg2"]') as HTMLInputElement)?.value);
    const imbalanceEl = document.getElementById('load-imbalance');
    const indImbalance = document.getElementById('ind-imbalance');
    if (imbalanceEl && indImbalance) {
      if (!isNaN(leg1) && !isNaN(leg2) && leg1 > 0 && leg2 > 0) {
        const avg = (leg1 + leg2) / 2;
        const imbalance = avg > 0 ? (Math.abs(leg1 - leg2) / avg) * 100 : 0;
        imbalanceEl.textContent = imbalance.toFixed(1);
        if (imbalance <= 10) indImbalance.className = 'w-3 h-3 rounded-full bg-[#34D399] inline-block ml-1';
        else if (imbalance <= 20) indImbalance.className = 'w-3 h-3 rounded-full bg-[#FBBF24] inline-block ml-1';
        else indImbalance.className = 'w-3 h-3 rounded-full bg-[#F87171] inline-block ml-1';
      } else {
        imbalanceEl.textContent = '--';
        indImbalance.className = 'w-3 h-3 rounded-full bg-border inline-block ml-1';
      }
    }
  }

  // ===== EVENT LISTENERS =====
  document.querySelectorAll('.cl-check').forEach(cb => {
    cb.addEventListener('change', () => {
      updateProgress();
      saveState();
    });
  });

  document.querySelectorAll('[data-field]').forEach(el => {
    el.addEventListener('input', () => {
      updateIndicators();
      updateProgress();
      saveState();
    });
    el.addEventListener('change', () => {
      updateIndicators();
      updateProgress();
      saveState();
    });
  });

  // ===== RESET =====
  document.getElementById('reset-checklist')?.addEventListener('click', () => {
    if (!confirm('Reset all checked items and readings? This cannot be undone.')) return;
    document.querySelectorAll('.cl-check').forEach(cb => { (cb as HTMLInputElement).checked = false; });
    document.querySelectorAll('[data-field]').forEach(el => { (el as HTMLInputElement | HTMLSelectElement).value = ''; });
    try { localStorage.removeItem(STORAGE_KEY); } catch {}
    updateIndicators();
    updateProgress();
  });

  // ===== REPORT GENERATION =====
  document.getElementById('generate-report')?.addEventListener('click', () => {
    const seasonLabel = activeTab === 'cooling' ? 'Panel & Circuits' : 'Safety & Testing';
    const panel = activeTab === 'cooling' ? '#panel-cooling' : '#panel-heating';
    const checks = document.querySelectorAll(`${panel} .cl-check`);
    const total = checks.length;
    const checked = Array.from(checks).filter(c => (c as HTMLInputElement).checked).length;
    const pct = total > 0 ? Math.round((checked / total) * 100) : 0;
    const flags = evaluateFlags();
    const grade = getGrade(pct, flags.count);
    const now = new Date();
    const dateStr = now.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    const timeStr = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });

    // Gather field readings
    const fields: Record<string, string> = {};
    document.querySelectorAll('[data-field]').forEach(el => {
      const key = (el as HTMLElement).dataset.field!;
      const val = (el as HTMLInputElement | HTMLSelectElement).value;
      if (val) fields[key] = val;
    });

    // Build sections from the active panel
    const sections: { title: string; items: { text: string; checked: boolean }[] }[] = [];
    const sectionEls = document.querySelectorAll(`${panel} > .mb-8`);
    sectionEls.forEach(sec => {
      const h3 = sec.querySelector('h3');
      if (!h3) return;
      const title = h3.textContent?.trim().replace(/^\u25CF\s*/, '') || '';
      const items: { text: string; checked: boolean }[] = [];
      sec.querySelectorAll('.cl-check').forEach(cb => {
        const label = (cb as HTMLElement).closest('label') || (cb as HTMLElement).closest('.flex');
        const span = label?.querySelector('span');
        const text = span?.textContent?.trim() || '';
        items.push({ text, checked: (cb as HTMLInputElement).checked });
      });
      sections.push({ title, items });
    });

    // Build HTML for print
    let html = `<!DOCTYPE html><html><head><meta charset="utf-8"><title>Electrical Service Report - ${seasonLabel}</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1a1a1a; padding: 40px; max-width: 800px; margin: 0 auto; font-size: 13px; line-height: 1.5; }
      h1 { font-size: 22px; margin-bottom: 4px; }
      h2 { font-size: 16px; margin: 20px 0 8px; border-bottom: 2px solid #e5e7eb; padding-bottom: 4px; }
      .meta { color: #6b7280; font-size: 12px; margin-bottom: 20px; }
      .summary-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px; }
      .summary-box { border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px; text-align: center; }
      .summary-box .label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280; margin-bottom: 4px; }
      .summary-box .value { font-size: 22px; font-weight: 700; }
      .grade-A { color: #10b981; } .grade-B { color: #3b82f6; } .grade-C { color: #f59e0b; } .grade-D { color: #f97316; } .grade-F { color: #ef4444; }
      .item { padding: 3px 0; display: flex; align-items: center; gap: 8px; }
      .check { width: 14px; height: 14px; border: 1.5px solid #d1d5db; border-radius: 3px; display: inline-flex; align-items: center; justify-content: center; font-size: 10px; flex-shrink: 0; }
      .check.done { background: #10b981; border-color: #10b981; color: white; }
      .readings { margin: 8px 0 8px 22px; padding: 8px 12px; background: #f9fafb; border-radius: 6px; font-size: 12px; }
      .readings span { margin-right: 16px; }
      .flag { background: #fef3c7; border: 1px solid #f59e0b; border-radius: 6px; padding: 6px 12px; margin: 4px 0; font-size: 12px; color: #92400e; }
      @media print { body { padding: 20px; } }
    </style></head><body>`;

    html += `<h1>Electrical Service Report</h1>`;
    html += `<div class="meta">${seasonLabel} &mdash; ${dateStr} at ${timeStr}</div>`;

    html += `<div class="summary-grid">`;
    html += `<div class="summary-box"><div class="label">Checked</div><div class="value">${checked}/${total}</div></div>`;
    html += `<div class="summary-box"><div class="label">Completion</div><div class="value">${pct}%</div></div>`;
    html += `<div class="summary-box"><div class="label">Flags</div><div class="value">${flags.count}</div></div>`;
    html += `<div class="summary-box"><div class="label">Grade</div><div class="value grade-${grade}">${grade}</div></div>`;
    html += `</div>`;

    if (flags.count > 0) {
      html += `<h2>Flagged Readings</h2>`;
      flags.items.forEach(f => { html += `<div class="flag">${f}</div>`; });
    }

    sections.forEach(sec => {
      html += `<h2>${sec.title}</h2>`;
      sec.items.forEach(item => {
        html += `<div class="item"><span class="check ${item.checked ? 'done' : ''}">${item.checked ? '&#10003;' : ''}</span> ${item.text}</div>`;
      });
    });

    // Add readings section if any
    const readingLabels: Record<string, string> = {
      'voltage-l1n': 'L1-N Voltage (V)', 'voltage-l2n': 'L2-N Voltage (V)',
      'voltage-ll': 'L-L Voltage (V)',
      'amps-leg1': 'Leg 1 Amps (A)', 'amps-leg2': 'Leg 2 Amps (A)',
    };
    const activeFields = Object.entries(fields).filter(([_, v]) => v);
    if (activeFields.length > 0) {
      html += `<h2>Recorded Readings</h2><div class="readings">`;
      activeFields.forEach(([k, v]) => {
        const label = readingLabels[k] || k;
        html += `<span><strong>${label}:</strong> ${v}</span>`;
      });

      const leg1 = parseFloat(fields['amps-leg1']);
      const leg2 = parseFloat(fields['amps-leg2']);
      if (!isNaN(leg1) && !isNaN(leg2) && leg1 > 0 && leg2 > 0) {
        const avg = (leg1 + leg2) / 2;
        const imbalance = avg > 0 ? (Math.abs(leg1 - leg2) / avg) * 100 : 0;
        html += `<span><strong>Load Imbalance:</strong> ${imbalance.toFixed(1)}%</span>`;
      }
      html += `</div>`;
    }

    html += `</body></html>`;

    const printWin = window.open('', '_blank');
    if (printWin) {
      printWin.document.write(html);
      printWin.document.close();
      setTimeout(() => printWin.print(), 400);
    }
  });

  // ===== INIT =====
  loadState();
  updateIndicators();
  updateProgress();
</script>
