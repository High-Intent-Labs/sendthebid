---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/gcTools';

const tool = getToolBySlug('break-even-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a good profit margin for a general contractor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most general contractors target a net profit margin of 8-12% on remodeling and renovation work. Gross margins (before overhead) typically range from 25-35% depending on project type. Smaller residential remodelers often operate closer to 25% gross margin, while larger commercial GCs with efficient project management can achieve 35% or more. If your margin is consistently below 20%, you are likely underpricing your work or have cost overruns that need to be addressed."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate break-even revenue for my contracting business?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Divide your total annual fixed costs (overhead) by your average gross margin percentage expressed as a decimal. For example, if your annual overhead is $200,000 and your average gross margin is 25%, your break-even revenue is $200,000 / 0.25 = $800,000 per year or about $66,667 per month. Any revenue above that amount is net profit."
      }
    },
    {
      "@type": "Question",
      "name": "What fixed costs should a general contractor include in break-even analysis?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Fixed costs for a GC include office or shop rent, insurance premiums (general liability, workers comp, umbrella), vehicle payments, owner salary, office staff wages, software subscriptions, marketing spend, license fees, and utilities. These costs remain roughly the same regardless of how many projects you complete. Variable costs like job-site labor, materials, subcontractors, and permits scale with each project and are not included in fixed overhead."
      }
    },
    {
      "@type": "Question",
      "name": "How many projects does a general contractor need to break even?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Divide your total annual fixed costs by the average profit per project. If your overhead is $200,000 per year and each project generates $10,000 in gross profit (after subtracting job costs), you need 20 projects per year to break even. This calculation helps you set sales targets and understand the minimum volume your business requires to stay profitable."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="breakeven-calc">
    <!-- Fixed Costs Section -->
    <div class="mb-8">
      <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Monthly Fixed Costs (Overhead)</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-1" for="rent">Office / Shop Rent</label>
          <input type="number" id="rent" value="2500" min="0" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-1" for="insurance">Insurance (GL, WC, Umbrella)</label>
          <input type="number" id="insurance" value="1800" min="0" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-1" for="vehicles">Vehicles &amp; Equipment</label>
          <input type="number" id="vehicles" value="1500" min="0" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-1" for="ownerSalary">Owner Salary</label>
          <input type="number" id="ownerSalary" value="6000" min="0" step="500" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-1" for="officeStaff">Office Staff / PM Wages</label>
          <input type="number" id="officeStaff" value="3500" min="0" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-1" for="marketing">Marketing &amp; Advertising</label>
          <input type="number" id="marketing" value="1200" min="0" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-1" for="software">Software &amp; Subscriptions</label>
          <input type="number" id="software" value="400" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-1" for="otherFixed">Other Fixed Costs</label>
          <input type="number" id="otherFixed" value="600" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </div>

    <!-- Project Economics Section -->
    <div class="mb-8">
      <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Average Project Economics</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-1" for="avgProjectRevenue">Avg Project Revenue ($)</label>
          <input type="number" id="avgProjectRevenue" value="50000" min="0" step="1000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-1" for="avgGrossMargin">Avg Gross Margin (%)</label>
          <input type="number" id="avgGrossMargin" value="25" min="0" max="100" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          <p class="text-text-muted text-xs mt-1">Revenue minus direct job costs (labor, materials, subs)</p>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Break-Even Analysis</h3>

      <!-- Primary metrics -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Monthly Fixed Costs</div>
          <div id="result-monthlyFixed" class="font-heading font-extrabold text-3xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Annual Fixed Costs</div>
          <div id="result-annualFixed" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Break-Even Revenue / Year</div>
          <div id="result-beRevenue" class="font-heading font-extrabold text-3xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Break-Even Revenue / Month</div>
          <div id="result-beMonthly" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>

      <!-- Project metrics -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Gross Profit per Project</div>
          <div id="result-profitPerProject" class="font-heading font-extrabold text-2xl text-[#34D399]">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Projects to Break Even / Year</div>
          <div id="result-projectsBE" class="font-heading font-extrabold text-2xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Projects to Break Even / Month</div>
          <div id="result-projectsBEmonth" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
        </div>
      </div>

      <!-- Visual break-even bar -->
      <div class="bg-bg-dark rounded-xl p-6 mb-8">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Revenue Needed to Hit Profit Targets</h4>
        <div class="space-y-4">
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Break Even (0% net)</span>
              <span id="target-be" class="text-text-primary font-semibold">--</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
              <div class="bg-[#FBBF24] h-2 rounded-full" style="width: 60%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">5% Net Profit Target</span>
              <span id="target-5" class="text-text-primary font-semibold">--</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
              <div class="bg-[#60A5FA] h-2 rounded-full" style="width: 75%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">10% Net Profit Target</span>
              <span id="target-10" class="text-text-primary font-semibold">--</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
              <div class="bg-[#34D399] h-2 rounded-full" style="width: 90%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Benchmark -->
      <div class="bg-bg-dark rounded-xl p-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">GC Industry Benchmarks</h4>
        <div class="space-y-3">
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Typical GC Gross Margin</span>
              <span class="text-text-primary font-semibold">25 &ndash; 35%</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
              <div class="bg-[#60A5FA] h-2 rounded-full" style="width: 30%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Target Net Profit</span>
              <span class="text-text-primary font-semibold">8 &ndash; 12%</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
              <div class="bg-[#34D399] h-2 rounded-full" style="width: 10%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Typical Overhead Range</span>
              <span class="text-text-primary font-semibold">25 &ndash; 35% of revenue</span>
            </div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
              <div class="bg-[#C084FC] h-2 rounded-full" style="width: 30%"></div>
            </div>
          </div>
          <div id="benchmark-warning" class="hidden mt-3 bg-[rgba(239,68,68,0.1)] border border-[rgba(239,68,68,0.3)] rounded-lg px-4 py-3 text-sm text-[#FCA5A5]">
            Your gross margin is below 20%. You may be underpricing your work or need to reduce job costs.
          </div>
        </div>
      </div>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter your monthly fixed costs.</strong> These are expenses you pay regardless of how many projects you complete: office rent, insurance, vehicle payments, owner salary, office staff, marketing, and software. If you already used our Overhead Cost Calculator, pull those numbers directly.</p>
          <p><strong class="text-text-primary">2. Enter your average project revenue.</strong> This is the typical contract value for one project. If your projects range widely, use the median value or run the calculator multiple times with different project sizes.</p>
          <p><strong class="text-text-primary">3. Set your average gross margin.</strong> Gross margin is the percentage of project revenue left after direct job costs (field labor, materials, subcontractors, permits). Most GCs land between 25% and 35%. If you are unsure, 25% is a conservative starting point.</p>
          <p><strong class="text-text-primary">4. Review your results.</strong> The calculator shows how much total revenue you need to cover all fixed costs (break-even revenue), how many projects that translates to, and the revenue targets needed to achieve 5% and 10% net profit.</p>
        </div>
      </section>

      <!-- How It Works -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How Break-Even Analysis Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Break-even revenue is the minimum annual revenue your business needs to cover all fixed costs.</strong> Every dollar of revenue above break-even is net profit. Every dollar below means you are losing money.</p>
          <p>Here is how this calculator computes the key numbers:</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Annual_Fixed_Costs = Monthly_Fixed_Costs x 12</p>
            <p>Break_Even_Revenue = Annual_Fixed_Costs / (Gross_Margin% / 100)</p>
            <p>Gross_Profit_Per_Project = Avg_Project_Revenue x (Gross_Margin% / 100)</p>
            <p>Projects_to_Break_Even = Annual_Fixed_Costs / Gross_Profit_Per_Project</p>
          </div>
          <p><strong class="text-text-primary">Example:</strong> A GC with $17,500/month in overhead ($210,000/year) and a 25% gross margin needs $840,000 in annual revenue to break even. If the average project is $50,000, each project generates $12,500 in gross profit, meaning 17 projects per year (about 1.4 per month) are required just to cover costs.</p>
          <p>The profit-target section takes it further. To earn a 10% net profit on top of covering overhead, you need to generate even more revenue. The formula adjusts the denominator: Revenue_for_Target = Fixed_Costs / (Gross_Margin% - Target_Net%). This is the revenue level where you are not just surviving but building a sustainable business.</p>
        </div>
      </section>

      <!-- When to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When to Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Setting annual revenue goals.</strong> Break-even analysis turns vague targets like "grow the business" into a concrete revenue number. You know exactly how many projects you need per month to cover costs and hit your profit goals.</p>
          <p><strong class="text-text-primary">Deciding whether to hire.</strong> Adding a project manager or another crew increases your fixed costs. Run the new numbers through the calculator to see how much additional revenue you need to justify the hire.</p>
          <p><strong class="text-text-primary">Evaluating pricing changes.</strong> If you raise your markup from 25% to 30%, your break-even revenue drops significantly. This calculator lets you see the impact before you change your pricing.</p>
          <p><strong class="text-text-primary">Slow-season planning.</strong> Most GCs have seasonal dips. Knowing your monthly break-even number helps you decide whether to cut costs, pursue smaller projects, or dip into reserves during the off months.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is a good profit margin for a general contractor?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most general contractors target a net profit margin of 8-12% on remodeling and renovation work. Gross margins (before overhead) typically range from 25-35% depending on project type. Smaller residential remodelers often operate closer to 25% gross margin, while larger commercial GCs with efficient project management can achieve 35% or more. If your margin is consistently below 20%, you are likely underpricing your work or have cost overruns that need to be addressed.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate break-even revenue for my contracting business?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Divide your total annual fixed costs (overhead) by your average gross margin percentage expressed as a decimal. For example, if your annual overhead is $200,000 and your average gross margin is 25%, your break-even revenue is $200,000 / 0.25 = $800,000 per year or about $66,667 per month. Any revenue above that amount is net profit.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What fixed costs should a general contractor include in break-even analysis?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Fixed costs for a GC include office or shop rent, insurance premiums (general liability, workers comp, umbrella), vehicle payments, owner salary, office staff wages, software subscriptions, marketing spend, license fees, and utilities. These costs remain roughly the same regardless of how many projects you complete. Variable costs like job-site labor, materials, subcontractors, and permits scale with each project and are not included in fixed overhead.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many projects does a general contractor need to break even?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Divide your total annual fixed costs by the average profit per project. If your overhead is $200,000 per year and each project generates $10,000 in gross profit (after subtracting job costs), you need 20 projects per year to break even. This calculation helps you set sales targets and understand the minimum volume your business requires to stay profitable.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const rent = parseFloat((document.getElementById('rent') as HTMLInputElement).value) || 0;
    const insurance = parseFloat((document.getElementById('insurance') as HTMLInputElement).value) || 0;
    const vehicles = parseFloat((document.getElementById('vehicles') as HTMLInputElement).value) || 0;
    const ownerSalary = parseFloat((document.getElementById('ownerSalary') as HTMLInputElement).value) || 0;
    const officeStaff = parseFloat((document.getElementById('officeStaff') as HTMLInputElement).value) || 0;
    const marketing = parseFloat((document.getElementById('marketing') as HTMLInputElement).value) || 0;
    const software = parseFloat((document.getElementById('software') as HTMLInputElement).value) || 0;
    const otherFixed = parseFloat((document.getElementById('otherFixed') as HTMLInputElement).value) || 0;

    const avgProjectRevenue = parseFloat((document.getElementById('avgProjectRevenue') as HTMLInputElement).value) || 0;
    const avgGrossMargin = parseFloat((document.getElementById('avgGrossMargin') as HTMLInputElement).value) || 0;

    // Calculate totals
    const monthlyFixed = rent + insurance + vehicles + ownerSalary + officeStaff + marketing + software + otherFixed;
    const annualFixed = monthlyFixed * 12;

    // Break-even revenue
    const marginDecimal = avgGrossMargin / 100;
    const beRevenueAnnual = marginDecimal > 0 ? annualFixed / marginDecimal : 0;
    const beRevenueMonthly = beRevenueAnnual / 12;

    // Project-based break-even
    const grossProfitPerProject = avgProjectRevenue * marginDecimal;
    const projectsBE = grossProfitPerProject > 0 ? annualFixed / grossProfitPerProject : 0;
    const projectsBEmonth = projectsBE / 12;

    // Profit targets
    const target5margin = marginDecimal - 0.05;
    const target10margin = marginDecimal - 0.10;
    const revenue5 = target5margin > 0 ? annualFixed / target5margin : 0;
    const revenue10 = target10margin > 0 ? annualFixed / target10margin : 0;

    // Format helper
    const fmt = (n: number) => '$' + n.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });

    // Update results
    document.getElementById('result-monthlyFixed')!.textContent = fmt(monthlyFixed);
    document.getElementById('result-annualFixed')!.textContent = fmt(annualFixed);
    document.getElementById('result-beRevenue')!.textContent = marginDecimal > 0 ? fmt(beRevenueAnnual) : 'N/A';
    document.getElementById('result-beMonthly')!.textContent = marginDecimal > 0 ? fmt(beRevenueMonthly) : 'N/A';
    document.getElementById('result-profitPerProject')!.textContent = fmt(grossProfitPerProject);
    document.getElementById('result-projectsBE')!.textContent = grossProfitPerProject > 0 ? Math.ceil(projectsBE).toString() : 'N/A';
    document.getElementById('result-projectsBEmonth')!.textContent = grossProfitPerProject > 0 ? projectsBEmonth.toFixed(1) : 'N/A';

    // Profit targets
    document.getElementById('target-be')!.textContent = marginDecimal > 0 ? fmt(beRevenueAnnual) + '/yr' : 'N/A';
    document.getElementById('target-5')!.textContent = target5margin > 0 ? fmt(revenue5) + '/yr' : 'N/A';
    document.getElementById('target-10')!.textContent = target10margin > 0 ? fmt(revenue10) + '/yr' : 'N/A';

    // Dynamic bar widths based on relative scale
    const maxRevenue = Math.max(beRevenueAnnual, revenue5 || 0, revenue10 || 0);
    if (maxRevenue > 0) {
      const bars = document.querySelectorAll('#results .space-y-4 .rounded-full .rounded-full') as NodeListOf<HTMLElement>;
      if (bars.length >= 3) {
        bars[0].style.width = ((beRevenueAnnual / maxRevenue) * 100) + '%';
        bars[1].style.width = revenue5 > 0 ? ((revenue5 / maxRevenue) * 100) + '%' : '0%';
        bars[2].style.width = revenue10 > 0 ? ((revenue10 / maxRevenue) * 100) + '%' : '0%';
      }
    }

    // Benchmark warning
    const warningEl = document.getElementById('benchmark-warning')!;
    if (avgGrossMargin < 20 && avgGrossMargin > 0) {
      warningEl.classList.remove('hidden');
    } else {
      warningEl.classList.add('hidden');
    }
  }

  // Auto-calculate on input change
  document.querySelectorAll('#breakeven-calc input').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  // Calculate on load
  calculate();
</script>
