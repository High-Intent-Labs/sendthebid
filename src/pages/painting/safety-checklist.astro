---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/paintingTools';
const tool = getToolBySlug('safety-checklist')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What should a painting safety checklist cover?", "acceptedAnswer": { "@type": "Answer", "text": "A complete painting safety checklist should cover PPE requirements (respirators, goggles, gloves), ladder and scaffold safety, fall protection, ventilation for enclosed spaces, hazardous material handling (lead paint, VOCs, solvents), fire prevention, drop cloth and floor protection, electrical hazard awareness near outlets and fixtures, and proper chemical storage and disposal procedures." } },
    { "@type": "Question", "name": "What PPE is required for painting?", "acceptedAnswer": { "@type": "Answer", "text": "Required PPE depends on the job. At minimum, painters need safety glasses, nitrile or chemical-resistant gloves, and appropriate footwear. Spray painting requires a half-face respirator with organic vapor cartridges (P100/OV). Sanding and scraping require a dust mask rated N95 or higher. Lead paint abatement requires a full-face respirator, Tyvek suit, and lead-safe work area containment." } },
    { "@type": "Question", "name": "What are the OSHA requirements for painting?", "acceptedAnswer": { "@type": "Answer", "text": "OSHA requires fall protection at 6 feet for construction (including painting). Ladders must be inspected before each use and set at a 4:1 ratio. Scaffolds need guardrails, mid-rails, and toe boards. Enclosed spaces require ventilation when using solvent-based products. Lead paint disturbance requires EPA RRP certification. All hazardous chemicals need Safety Data Sheets (SDS) on site." } },
    { "@type": "Question", "name": "How do you ensure ventilation when painting indoors?", "acceptedAnswer": { "@type": "Answer", "text": "Open all windows and doors to create cross-ventilation. Use box fans to push fumes out rather than recirculate. For solvent-based paints or epoxies, set up a forced-air exhaust system. Monitor air quality if working in enclosed areas for extended periods. Take breaks in fresh air every 30-60 minutes. Never use gas-powered equipment indoors for ventilation." } }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="checklist-app">
    <!-- Progress Bar -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-medium text-text-secondary">Progress</span>
        <span id="progress-text" class="text-sm font-bold text-accent">0 of 0 items checked</span>
      </div>
      <div class="w-full bg-bg-dark rounded-full h-3 overflow-hidden">
        <div id="progress-bar" class="bg-accent h-3 rounded-full transition-all duration-300" style="width: 0%"></div>
      </div>
    </div>

    <!-- Tab Toggle -->
    <div class="flex gap-2 mb-8">
      <button id="tab-cooling" class="flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-accent text-white" data-tab="cooling">
        Interior Projects
      </button>
      <button id="tab-heating" class="flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-bg-dark text-text-muted border border-border hover:border-accent hover:text-text-primary" data-tab="heating">
        Exterior Projects
      </button>
    </div>

    <!-- ============ COOLING SEASON ============ -->
    <div id="panel-cooling">

      <!-- Controls -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Thermostat
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Test all modes (heat, cool, auto, fan)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Verify calibration (&plusmn;1&deg;F)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Check programming / schedule</span>
          </label>
        </div>
      </div>

      <!-- Air Distribution -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Air Distribution
        </h3>
        <div class="space-y-3">
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Replace / clean filter</span>
            </label>
            <div class="flex flex-wrap items-center gap-2 ml-8">
              <label class="text-xs text-text-muted">Size:</label>
              <input type="text" data-field="filter-size-cool" placeholder="e.g. 20x25x1" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-28 focus:border-accent focus:outline-none" />
              <label class="text-xs text-text-muted">Condition:</label>
              <select data-field="filter-condition-cool" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm focus:border-accent focus:outline-none">
                <option value="">Select</option>
                <option value="New">New</option>
                <option value="Clean">Clean</option>
                <option value="Dirty">Dirty</option>
                <option value="Clogged">Clogged</option>
              </select>
            </div>
          </div>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Inspect all systems for damage or issues</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Check supply and return registers (open, clean)</span>
          </label>
        </div>
      </div>

      <!-- Electrical -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Electrical
        </h3>
        <div class="space-y-3">
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Test capacitor</span>
            </label>
            <div class="flex flex-wrap items-center gap-2 ml-8">
              <label class="text-xs text-text-muted">Reading:</label>
              <input type="number" data-field="cap-reading" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">&mu;F</span>
              <label class="text-xs text-text-muted ml-2">Rated:</label>
              <input type="number" data-field="cap-rated" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">&mu;F</span>
            </div>
          </div>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Inspect contactor (pitting, arcing)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Check all electrical connections</span>
          </label>
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Measure amp draws</span>
            </label>
            <div class="flex flex-wrap items-center gap-2 ml-8">
              <label class="text-xs text-text-muted">Compressor:</label>
              <input type="number" data-field="amp-compressor" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">A</span>
              <label class="text-xs text-text-muted ml-2">Blower:</label>
              <input type="number" data-field="amp-blower" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">A</span>
              <label class="text-xs text-text-muted ml-2">Condenser fan:</label>
              <input type="number" data-field="amp-condenser" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">A</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Coating System -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Refrigerant System
        </h3>
        <div class="space-y-3">
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Suction Pressure</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <input type="number" data-field="suction-psi" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-24 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">PSI</span>
            </div>
          </div>
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Liquid / Head Pressure</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <input type="number" data-field="head-psi" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-24 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">PSI</span>
            </div>
          </div>
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Superheat</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <input type="number" data-field="superheat" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">&deg;F</span>
              <span class="text-xs text-text-muted ml-1">Target: 10-15&deg;F</span>
              <span id="ind-superheat" class="w-3 h-3 rounded-full bg-border inline-block ml-1"></span>
            </div>
          </div>
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Subcooling</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <input type="number" data-field="subcooling" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">&deg;F</span>
              <span class="text-xs text-text-muted ml-1">Target: 10-12&deg;F</span>
              <span id="ind-subcooling" class="w-3 h-3 rounded-full bg-border inline-block ml-1"></span>
            </div>
          </div>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Leak inspection performed</span>
          </label>
        </div>
      </div>

      <!-- Outdoor Unit -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Outdoor Unit
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Clean condenser coil</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Clear debris (2 ft clearance)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Level check</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Fan blade condition</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Service valves accessible</span>
          </label>
        </div>
      </div>

      <!-- Indoor Unit -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Indoor Unit
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Clean evaporator coil</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Clear condensate drain</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Test float switch</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Inspect blower wheel</span>
          </label>
        </div>
      </div>

      <!-- Performance (Cooling) -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Performance
        </h3>
        <div class="space-y-3">
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Supply Air Temp</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <input type="number" data-field="supply-temp" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">&deg;F</span>
            </div>
          </div>
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Return Air Temp</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <input type="number" data-field="return-temp" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">&deg;F</span>
            </div>
          </div>
          <div class="flex flex-wrap items-center gap-3 ml-8">
            <span class="text-text-secondary text-sm">Temperature Split:</span>
            <span id="temp-split" class="font-heading font-bold text-lg text-text-primary">--</span>
            <span class="text-xs text-text-muted">&deg;F</span>
            <span class="text-xs text-text-muted ml-1">Target: 15-20&deg;F</span>
            <span id="ind-split" class="w-3 h-3 rounded-full bg-border inline-block ml-1"></span>
          </div>
        </div>
      </div>

    </div>

    <!-- ============ HEATING SEASON ============ -->
    <div id="panel-heating" class="hidden">

      <!-- Heat Exchanger -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Heat Exchanger
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Visual inspection (cracks, rust, holes)</span>
          </label>
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">CO test</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <label class="text-xs text-text-muted">Reading:</label>
              <input type="number" data-field="co-reading" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">PPM</span>
              <span class="text-xs text-text-muted ml-1">Must be &lt; 9 PPM</span>
              <span id="ind-co" class="w-3 h-3 rounded-full bg-border inline-block ml-1"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Burner Assembly -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Burner Assembly
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Inspect burners (clean, aligned)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Clean flame sensor</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Test igniter</span>
          </label>
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Gas pressure</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <input type="number" data-field="gas-pressure" step="0.1" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">"WC</span>
              <span class="text-xs text-text-muted ml-1">Target: 3.5" WC</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Safety Controls -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
