---
import { getLiveTrades } from '../data/trades';

const year = new Date().getFullYear();
const liveTrades = getLiveTrades();
---

<footer class="border-t border-border mt-auto">
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 py-10 flex flex-col md:flex-row justify-between items-center gap-6">
    <a href="/" class="font-heading font-extrabold text-xl tracking-tight text-text-primary no-underline">
      Nail<span class="text-accent">The</span>Quote
    </a>
    <div class="flex flex-wrap gap-6">
      {liveTrades.map(trade => (
        <a href={`/${trade.slug}/`} class="text-text-muted text-sm no-underline hover:text-text-secondary transition-colors">{trade.name} Tools</a>
      ))}
      <a href="/#about" class="text-text-muted text-sm no-underline hover:text-text-secondary transition-colors">About</a>
      <a href="/dashboard/" class="text-text-muted text-sm no-underline hover:text-text-secondary transition-colors">Dashboard</a>
      <a href="/privacy/" class="text-text-muted text-sm no-underline hover:text-text-secondary transition-colors">Privacy</a>
      <a href="/terms/" class="text-text-muted text-sm no-underline hover:text-text-secondary transition-colors">Terms</a>
    </div>
    <p class="text-text-muted text-sm">&copy; {year} NailTheQuote.com</p>
  </div>
</footer>
