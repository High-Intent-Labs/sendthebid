---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/cleaningTools';

const tool = getToolBySlug('route-density-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How many cleaning jobs can I fit in a day?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The number of cleaning jobs per day depends on service type, drive time, and working hours. Most solo cleaners fit 3-5 maintenance cleans, 2-3 deep cleans, or 1-2 move-out cleans per day in an 8-hour window. The key limiting factor is drive time between stops. Reducing average drive time from 30 minutes to 15 minutes can add one full job per day, which over a year adds tens of thousands in additional revenue."
      }
    },
    {
      "@type": "Question",
      "name": "What is a good utilization rate for a cleaning business?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A good utilization rate for a cleaning business is 75-85%. Utilization measures the percentage of your working hours spent actually cleaning versus driving, waiting, or on breaks. Below 65% means too much windshield time and not enough billable work. Above 85% is excellent but hard to sustain without very tight geographic clustering. Track this metric weekly and aim to improve it by grouping jobs in the same neighborhood on the same day."
      }
    },
    {
      "@type": "Question",
      "name": "How do I optimize my cleaning route for more revenue?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cluster jobs geographically so you clean multiple homes in the same neighborhood on the same day. Schedule longer jobs like deep cleans and move-out cleans at the start or end of your day to avoid splitting your route. Book recurring clients on fixed days to build predictable route density over time. Use mapping tools to sequence stops efficiently. Even small improvements in drive time add up to thousands in extra annual revenue."
      }
    },
    {
      "@type": "Question",
      "name": "What is the average drive time between cleaning jobs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The average drive time between residential cleaning jobs is 15-30 minutes in suburban areas and 20-45 minutes in rural or spread-out metro areas. Urban cleaners with tight routes can achieve 10-15 minutes between stops. Every minute of drive time is a minute you are not earning revenue. Aim to keep average drive time under 20 minutes by clustering jobs and building route density in specific neighborhoods or zip codes."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="route-calc">
    <!-- Route Inputs -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Daily Route Settings</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="jobs-per-day">Jobs per Day</label>
        <input type="number" id="jobs-per-day" value="5" min="1" max="15" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="service-type">Primary Service Type</label>
        <select id="service-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="maintenance" selected>Maintenance Clean (1.5 hrs avg)</option>
          <option value="deep">Deep Clean (3 hrs avg)</option>
          <option value="moveout">Move-Out Clean (4 hrs avg)</option>
          <option value="custom">Custom</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="avg-service-time">Avg Service Time (hours)</label>
        <input type="number" id="avg-service-time" value="1.5" min="0.5" max="8" step="0.25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Auto-fills based on service type</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="avg-drive-time">Avg Drive Time Between Stops (min)</label>
        <input type="number" id="avg-drive-time" value="20" min="5" max="60" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="avg-revenue">Avg Revenue per Job ($)</label>
        <input type="number" id="avg-revenue" value="150" min="25" max="2000" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="working-hours">Available Working Hours / Day</label>
        <input type="number" id="working-hours" value="8" min="4" max="12" step="0.5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Work Week Settings -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Work Week</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="days-per-week">Working Days per Week</label>
        <input type="number" id="days-per-week" value="5" min="1" max="7" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="weeks-per-month">Working Weeks per Month</label>
        <input type="number" id="weeks-per-month" value="4.3" min="1" max="5" step="0.1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Daily Route Summary</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Productive Hours</div>
          <div id="result-productive-hours" class="font-heading font-extrabold text-3xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Drive Hours</div>
          <div id="result-drive-hours" class="font-heading font-extrabold text-3xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Utilization %</div>
          <div id="result-utilization" class="font-heading font-extrabold text-3xl">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Daily Revenue</div>
          <div id="result-daily-revenue" class="font-heading font-extrabold text-3xl text-accent">&mdash;</div>
        </div>
      </div>

      <!-- Feasibility Check -->
      <div id="feasibility-warning" class="hidden mb-6 bg-[rgba(251,191,36,0.1)] border border-[rgba(251,191,36,0.3)] rounded-lg p-4">
        <p class="text-[#FBBF24] text-sm font-medium" id="feasibility-text">&#9888; Warning</p>
      </div>

      <h3 class="font-heading font-bold text-xl mb-6">Revenue Projections</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Weekly Revenue</div>
          <div id="result-weekly-revenue" class="font-heading font-extrabold text-3xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Monthly Revenue</div>
          <div id="result-monthly-revenue" class="font-heading font-extrabold text-3xl text-[#34D399]">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Annual Revenue</div>
          <div id="result-annual-revenue" class="font-heading font-extrabold text-3xl text-accent">&mdash;</div>
        </div>
      </div>

      <!-- Optimization Tips -->
      <div class="bg-bg-dark rounded-xl p-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Route Optimization Impact</h4>
        <div class="space-y-3">
          <div class="flex justify-between items-center text-sm py-2 border-b border-border">
            <span class="text-text-secondary">If you reduce drive time by 5 min/stop</span>
            <div class="flex gap-6">
              <span class="text-text-muted">Saves: <span id="opt-time-saved" class="text-text-primary">0 min</span></span>
              <span class="text-text-muted">Extra/month: <span id="opt-extra-monthly" class="text-[#34D399]">$0</span></span>
            </div>
          </div>
          <div class="flex justify-between items-center text-sm py-2 border-b border-border">
            <span class="text-text-secondary">If you add 1 more job per day</span>
            <div class="flex gap-6">
              <span class="text-text-muted">Extra/month: <span id="opt-extra-job-monthly" class="text-[#34D399]">$0</span></span>
              <span class="text-text-muted">Extra/year: <span id="opt-extra-job-annual" class="text-[#34D399]">$0</span></span>
            </div>
          </div>
          <div class="flex justify-between items-center text-sm py-2">
            <span class="text-text-secondary">Max jobs at current drive time</span>
            <span class="text-accent font-medium" id="opt-max-jobs">&mdash;</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Set your daily route.</strong> Enter the number of jobs you want to fit in a day and select your primary service type. The calculator auto-fills average service time: 1.5 hours for maintenance cleans, 3 hours for deep cleans, and 4 hours for move-out cleans. Select "Custom" to enter your own average.</p>
          <p><strong class="text-text-primary">2. Enter your drive time and revenue.</strong> Set the average minutes you spend driving between stops and your average revenue per job. Be honest about drive time — most cleaners underestimate it. Include loading, unloading, and parking time in your estimate.</p>
          <p><strong class="text-text-primary">3. Review your daily results.</strong> The calculator shows your total productive hours (time spent cleaning), total drive hours, utilization percentage, and daily revenue. If your route exceeds available working hours, you will see a warning.</p>
          <p><strong class="text-text-primary">4. Check revenue projections.</strong> See your estimated weekly, monthly, and annual revenue based on your working days per week. Use the optimization section to see how reducing drive time or adding one more job impacts your bottom line.</p>
        </div>
      </section>

      <!-- Route Optimization Tips -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Optimize Your Cleaning Route</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Cluster jobs geographically.</strong> The single most impactful thing you can do is group clients by neighborhood. If you clean three homes in the same subdivision on Tuesday instead of driving across town between each one, you can cut 30-45 minutes of drive time out of your day. Over a month, that recovered time translates directly into additional billable jobs.</p>
          <p><strong class="text-text-primary">Schedule deep cleans at the start or end of your day.</strong> Deep cleans and move-out cleans take 3-4 hours and anchor your schedule. Place them first thing in the morning or as your last stop so they do not split your route and force backtracking. Fill the remaining time slots with shorter maintenance cleans that are geographically close together.</p>
          <p><strong class="text-text-primary">Build recurring density over time.</strong> When a new lead comes in, check if they are near your existing Tuesday or Wednesday route before booking them on a random day. Over months, this discipline builds tight route clusters where you clean 4-5 homes within a few miles of each other. The financial impact compounds as your utilization rate climbs toward 80% or higher.</p>
          <p><strong class="text-text-primary">Track your actual drive time.</strong> Use your phone GPS or a simple mileage tracker to log real drive times for a week. Most cleaners are surprised to find they spend 25-35% of their day driving. Once you have real data, you can identify which routes are efficient and which ones need restructuring.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Planning your weekly schedule.</strong> Before booking new clients into your calendar, run this calculator to see if another job fits in your day at the current drive time. If adding a sixth stop pushes you past 8 hours, you know you need to either tighten your route or push that client to a different day with more room.</p>
          <p><strong class="text-text-primary">Setting revenue goals.</strong> When budgeting for the quarter, use the projections to see what realistic revenue looks like based on your current job count, service mix, and drive time. This is far more accurate than guessing because it accounts for the time you actually spend driving between jobs.</p>
          <p><strong class="text-text-primary">Deciding where to market.</strong> If your current routes cluster in the north side of town, this calculator shows you what happens if you pick up clients on the south side — your drive time goes up and utilization drops. Use this to justify focusing your marketing spend on neighborhoods near your existing clients rather than chasing leads across town.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many cleaning jobs can I fit in a day?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">The number of cleaning jobs per day depends on service type, drive time, and working hours. Most solo cleaners fit 3-5 maintenance cleans, 2-3 deep cleans, or 1-2 move-out cleans per day in an 8-hour window. The key limiting factor is drive time between stops. Reducing average drive time from 30 minutes to 15 minutes can add one full job per day, which over a year adds tens of thousands in additional revenue.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is a good utilization rate for a cleaning business?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A good utilization rate for a cleaning business is 75-85%. Utilization measures the percentage of your working hours spent actually cleaning versus driving, waiting, or on breaks. Below 65% means too much windshield time and not enough billable work. Above 85% is excellent but hard to sustain without very tight geographic clustering. Track this metric weekly and aim to improve it by grouping jobs in the same neighborhood on the same day.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I optimize my cleaning route for more revenue?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Cluster jobs geographically so you clean multiple homes in the same neighborhood on the same day. Schedule longer jobs like deep cleans and move-out cleans at the start or end of your day to avoid splitting your route. Book recurring clients on fixed days to build predictable route density over time. Use mapping tools to sequence stops efficiently. Even small improvements in drive time add up to thousands in extra annual revenue.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is the average drive time between cleaning jobs?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">The average drive time between residential cleaning jobs is 15-30 minutes in suburban areas and 20-45 minutes in rural or spread-out metro areas. Urban cleaners with tight routes can achieve 10-15 minutes between stops. Every minute of drive time is a minute you are not earning revenue. Aim to keep average drive time under 20 minutes by clustering jobs and building route density in specific neighborhoods or zip codes.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // Service type average hours
  const serviceHours: Record<string, number> = {
    'maintenance': 1.5,
    'deep': 3,
    'moveout': 4,
    'custom': 1.5,
  };

  // Service type change: auto-fill hours
  document.getElementById('service-type')?.addEventListener('change', () => {
    const serviceType = (document.getElementById('service-type') as HTMLSelectElement).value;
    if (serviceType !== 'custom') {
      const hours = serviceHours[serviceType] || 1.5;
      (document.getElementById('avg-service-time') as HTMLInputElement).value = String(hours);
    }
    calculate();
  });

  function calculate() {
    const jobsPerDay = parseFloat((document.getElementById('jobs-per-day') as HTMLInputElement).value) || 0;
    const avgServiceTime = parseFloat((document.getElementById('avg-service-time') as HTMLInputElement).value) || 0;
    const avgDriveTime = parseFloat((document.getElementById('avg-drive-time') as HTMLInputElement).value) || 0;
    const avgRevenue = parseFloat((document.getElementById('avg-revenue') as HTMLInputElement).value) || 0;
    const workingHours = parseFloat((document.getElementById('working-hours') as HTMLInputElement).value) || 8;
    const daysPerWeek = parseFloat((document.getElementById('days-per-week') as HTMLInputElement).value) || 5;
    const weeksPerMonth = parseFloat((document.getElementById('weeks-per-month') as HTMLInputElement).value) || 4.3;

    // Daily calculations
    const totalProductiveHours = jobsPerDay * avgServiceTime;
    const driveSegments = jobsPerDay > 0 ? jobsPerDay - 1 : 0;
    const totalDriveMinutes = driveSegments * avgDriveTime;
    const totalDriveHours = totalDriveMinutes / 60;
    const totalHoursNeeded = totalProductiveHours + totalDriveHours;
    const utilization = totalHoursNeeded > 0 ? (totalProductiveHours / totalHoursNeeded) * 100 : 0;
    const dailyRevenue = jobsPerDay * avgRevenue;

    // Projections
    const weeklyRevenue = dailyRevenue * daysPerWeek;
    const monthlyRevenue = weeklyRevenue * weeksPerMonth;
    const annualRevenue = monthlyRevenue * 12;

    // Format helpers
    const fmt = (n: number) => '$' + Math.round(n).toLocaleString();
    const fmtDec = (n: number) => n.toFixed(1);

    // Daily results
    document.getElementById('result-productive-hours')!.textContent = fmtDec(totalProductiveHours) + ' hrs';
    document.getElementById('result-drive-hours')!.textContent = fmtDec(totalDriveHours) + ' hrs';
    document.getElementById('result-daily-revenue')!.textContent = fmt(dailyRevenue);

    // Utilization with color coding
    const utilEl = document.getElementById('result-utilization')!;
    utilEl.textContent = fmtDec(utilization) + '%';
    utilEl.className = 'font-heading font-extrabold text-3xl';
    if (utilization >= 75) {
      utilEl.classList.add('text-[#34D399]');
    } else if (utilization >= 65) {
      utilEl.classList.add('text-[#FBBF24]');
    } else {
      utilEl.classList.add('text-[#EF4444]');
    }

    // Feasibility check
    const warningEl = document.getElementById('feasibility-warning')!;
    const warningText = document.getElementById('feasibility-text')!;
    if (totalHoursNeeded > workingHours) {
      warningEl.classList.remove('hidden');
      const overBy = (totalHoursNeeded - workingHours).toFixed(1);
      warningText.textContent = `\u26A0 This route needs ${fmtDec(totalHoursNeeded)} hours but you only have ${fmtDec(workingHours)} available. You are over by ${overBy} hours. Reduce jobs, shorten drive time, or extend your work day.`;
    } else {
      warningEl.classList.add('hidden');
    }

    // Revenue projections
    document.getElementById('result-weekly-revenue')!.textContent = fmt(weeklyRevenue);
    document.getElementById('result-monthly-revenue')!.textContent = fmt(monthlyRevenue);
    document.getElementById('result-annual-revenue')!.textContent = fmt(annualRevenue);

    // Optimization calculations
    // 1. Reducing drive time by 5 min/stop
    const savedMinutes = driveSegments * 5;
    const savedMonthlyJobs = (savedMinutes / 60) / avgServiceTime * daysPerWeek * weeksPerMonth;
    const extraMonthlyFromDrive = savedMonthlyJobs * avgRevenue;
    document.getElementById('opt-time-saved')!.textContent = savedMinutes + ' min/day';
    document.getElementById('opt-extra-monthly')!.textContent = fmt(extraMonthlyFromDrive);

    // 2. Adding 1 more job per day
    const extraJobMonthly = avgRevenue * daysPerWeek * weeksPerMonth;
    const extraJobAnnual = extraJobMonthly * 12;
    document.getElementById('opt-extra-job-monthly')!.textContent = fmt(extraJobMonthly);
    document.getElementById('opt-extra-job-annual')!.textContent = fmt(extraJobAnnual);

    // 3. Max jobs at current drive time
    if (avgServiceTime > 0 && avgDriveTime >= 0) {
      // totalHours = jobs * serviceTime + (jobs - 1) * driveTime/60
      // workingHours = jobs * serviceTime + (jobs - 1) * driveTime/60
      // workingHours = jobs * (serviceTime + driveTime/60) - driveTime/60
      // jobs = (workingHours + driveTime/60) / (serviceTime + driveTime/60)
      const driveHrs = avgDriveTime / 60;
      const maxJobs = Math.floor((workingHours + driveHrs) / (avgServiceTime + driveHrs));
      document.getElementById('opt-max-jobs')!.textContent = maxJobs + ' jobs';
    } else {
      document.getElementById('opt-max-jobs')!.textContent = '--';
    }
  }

  // Auto-calculate on any input change
  document.querySelectorAll('#route-calc input[type="number"], #route-calc select').forEach(el => {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  // Initial calculation
  calculate();
</script>
