---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/paintingTools';

const tool = getToolBySlug('exterior-cost-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I price an exterior painting job?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Calculate the total exterior wall area, factor in the number of stories, siding type, and surface condition. Exterior production rates are lower than interior — typically 200-350 sq ft per hour depending on height and access. Add materials with markup, ladder or scaffold rental if needed, and target 30-45% gross margin."
      }
    },
    {
      "@type": "Question",
      "name": "How much does it cost to paint the exterior of a house?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A typical single-story home costs $2,500-4,500 for exterior painting. Two-story homes run $4,000-7,500. Three-story homes can reach $6,500-11,000 or more. These ranges assume standard paint, moderate prep, and include trim and fascia. Factors like siding type, condition, access difficulty, and paint quality shift the price."
      }
    },
    {
      "@type": "Question",
      "name": "What factors increase exterior painting costs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Multiple stories add 20-40% per additional floor due to ladder time and safety concerns. Limited access from fences or landscaping adds 10%. Scaffold rental adds $500-1,000. Poor surface condition requiring heavy scraping and priming adds 30-50% to labor. Wood siding takes longer than vinyl or fiber cement due to more prep."
      }
    },
    {
      "@type": "Question",
      "name": "How long does it take to paint the exterior of a house?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A two-person crew can paint a single-story 1,500 sq ft home exterior in 2-3 days. A two-story home takes 3-5 days. Three-story homes take 5-7 days. These estimates include prep, priming, two coats, and trim work. Weather delays can extend the timeline."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="exterior-calc">
    <!-- Project Details -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Project Details</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="total-sqft">Exterior Wall Area (sq ft)</label>
        <input type="number" id="total-sqft" value="2000" min="100" max="50000" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="num-stories">Number of Stories</label>
        <select id="num-stories" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="1" selected>1 Story</option>
          <option value="2">2 Stories</option>
          <option value="3">3+ Stories</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="siding-type">Siding Type</label>
        <select id="siding-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="vinyl">Vinyl</option>
          <option value="wood" selected>Wood (clapboard/shake)</option>
          <option value="fiber-cement">Fiber Cement (Hardie)</option>
          <option value="stucco">Stucco</option>
          <option value="brick">Brick</option>
          <option value="aluminum">Aluminum</option>
        </select>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="surface-condition">Surface Condition</label>
        <select id="surface-condition" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="good" selected>Good (light wash, minimal prep)</option>
          <option value="fair">Fair (scraping, caulking, spot prime)</option>
          <option value="poor">Poor (heavy scraping, full prime)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="ladder-access">Ladder Access</label>
        <select id="ladder-access" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="unrestricted" selected>Unrestricted ground access</option>
          <option value="limited">Limited (fences, landscaping)</option>
          <option value="scaffold">Requires scaffold/lift</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="paint-quality">Paint Quality</label>
        <select id="paint-quality" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="standard" selected>Standard (~$35/gal)</option>
          <option value="premium">Premium (~$55/gal)</option>
          <option value="high-end">High-End (~$75/gal)</option>
        </select>
      </div>
    </div>

    <!-- Additional Services -->
    <div class="bg-bg-dark border border-border rounded-lg p-4 mb-8">
      <p class="text-sm font-medium text-text-secondary mb-3">Additional Exterior Services <span class="text-text-muted">(check to include)</span></p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
        <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer hover:text-text-primary transition-colors">
          <input type="checkbox" class="addon-item accent-accent" data-hours="4" data-materials="40" checked />
          Trim, fascia &amp; soffits
        </label>
        <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer hover:text-text-primary transition-colors">
          <input type="checkbox" class="addon-item accent-accent" data-hours="3" data-materials="25" />
          Gutters &amp; downspouts
        </label>
        <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer hover:text-text-primary transition-colors">
          <input type="checkbox" class="addon-item accent-accent" data-hours="2" data-materials="20" />
          Shutters (per pair)
        </label>
        <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer hover:text-text-primary transition-colors">
          <input type="checkbox" class="addon-item accent-accent" data-hours="2" data-materials="15" />
          Exterior doors (each)
        </label>
        <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer hover:text-text-primary transition-colors">
          <input type="checkbox" class="addon-item accent-accent" data-hours="3" data-materials="30" />
          Deck/porch railing
        </label>
        <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer hover:text-text-primary transition-colors">
          <input type="checkbox" class="addon-item accent-accent" data-hours="2" data-materials="25" checked />
          Power washing
        </label>
      </div>
    </div>

    <!-- Labor & Pricing -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Labor & Pricing</h3>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="crew-size">Crew Size</label>
        <input type="number" id="crew-size" value="2" min="1" max="10" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="hourly-rate">Billable Rate ($/hr)</label>
        <input type="number" id="hourly-rate" value="60" min="10" max="200" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="materials-markup">Materials Markup (%)</label>
        <input type="number" id="materials-markup" value="40" min="0" max="200" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="scaffold-rental">Scaffold/Lift Rental ($)</label>
        <input type="number" id="scaffold-rental" value="0" min="0" max="5000" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Exterior Painting Estimate</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Suggested Price</div>
          <div id="result-total-sell" class="font-heading font-extrabold text-3xl text-accent">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Gross Profit</div>
          <div id="result-gross-profit" class="font-heading font-extrabold text-3xl text-[#34D399]">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Profit Margin</div>
          <div id="result-margin" class="font-heading font-extrabold text-3xl">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cost per Sq Ft</div>
          <div id="result-per-sqft" class="font-heading font-extrabold text-3xl text-text-primary">&mdash;</div>
        </div>
      </div>

      <!-- Breakdown -->
      <div class="bg-bg-dark rounded-xl p-6 mb-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Cost &amp; Sell Breakdown</h4>
        <div class="space-y-3">
          <div class="flex justify-between items-center text-sm py-2 border-b border-border">
            <span class="text-text-secondary">Paint &amp; Primer</span>
            <div class="flex gap-6">
              <span class="text-text-muted w-24 text-right">Cost: <span id="breakdown-paint-cost" class="text-text-primary">$0</span></span>
              <span class="text-text-muted w-24 text-right">Sell: <span id="breakdown-paint-sell" class="text-accent">$0</span></span>
            </div>
          </div>
          <div class="flex justify-between items-center text-sm py-2 border-b border-border">
            <span class="text-text-secondary">Supplies &amp; Caulk</span>
            <div class="flex gap-6">
              <span class="text-text-muted w-24 text-right">Cost: <span id="breakdown-supplies-cost" class="text-text-primary">$0</span></span>
              <span class="text-text-muted w-24 text-right">Sell: <span id="breakdown-supplies-sell" class="text-accent">$0</span></span>
            </div>
          </div>
          <div class="flex justify-between items-center text-sm py-2 border-b border-border">
            <span class="text-text-secondary">Labor</span>
            <div class="flex gap-6">
              <span class="text-text-muted w-24 text-right"><span id="breakdown-labor-hours" class="text-text-primary">0</span> hrs</span>
              <span class="text-text-muted w-24 text-right">Sell: <span id="breakdown-labor-sell" class="text-accent">$0</span></span>
            </div>
          </div>
          <div class="flex justify-between items-center text-sm py-2 border-b border-border">
            <span class="text-text-secondary">Add-Ons</span>
            <div class="flex gap-6">
              <span class="text-text-muted w-24 text-right">Cost: <span id="breakdown-addon-cost" class="text-text-primary">$0</span></span>
              <span class="text-text-muted w-24 text-right">Sell: <span id="breakdown-addon-sell" class="text-accent">$0</span></span>
            </div>
          </div>
          <div class="flex justify-between items-center text-sm py-2">
            <span class="text-text-secondary">Scaffold/Lift Rental</span>
            <div class="flex gap-6">
              <span class="text-text-muted w-24 text-right">&nbsp;</span>
              <span class="text-text-muted w-24 text-right">Cost: <span id="breakdown-scaffold" class="text-text-primary">$0</span></span>
            </div>
          </div>
        </div>
        <div class="mt-4 pt-4 border-t border-border flex justify-between items-center font-heading font-bold">
          <span class="text-text-primary">Totals</span>
          <div class="flex gap-6">
            <span class="text-text-muted w-24 text-right">Cost: <span id="breakdown-total-cost" class="text-text-primary">$0</span></span>
            <span class="text-text-muted w-24 text-right">Sell: <span id="breakdown-total-sell" class="text-accent">$0</span></span>
          </div>
        </div>
      </div>

      <!-- Timeline -->
      <div class="bg-bg-dark rounded-xl p-5">
        <p class="text-text-secondary text-sm"><strong class="text-text-primary">Estimated Timeline:</strong> <span id="timeline-estimate">--</span> &mdash; Add 1-2 buffer days for weather delays on exterior work.</p>
      </div>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter the exterior wall area.</strong> Measure or estimate the total paintable surface. A quick estimate is the home's square footage times 1.15 to account for gables and dormers. Subtract windows and doors.</p>
          <p><strong class="text-text-primary">2. Select stories, siding type, and condition.</strong> Multi-story homes cost more due to ladder time and safety requirements. Wood siding takes longer than vinyl or fiber cement. Poor condition means heavy scraping, caulking, and full priming.</p>
          <p><strong class="text-text-primary">3. Choose access and paint quality.</strong> Limited access from fences or landscaping adds time. Scaffold or lift rental is a direct cost passed to the customer. Exterior paint ranges from $35-75 per gallon.</p>
          <p><strong class="text-text-primary">4. Add exterior services.</strong> Trim, fascia, gutters, and shutters are common add-ons. Power washing is usually included in exterior bids.</p>
          <p><strong class="text-text-primary">5. Set your rate and review.</strong> The calculator builds the full estimate with materials, labor, and equipment costs.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How Exterior Cost Calculation Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Production rates drop with height.</strong> Ground-level painting runs about 300-350 sq ft per hour. Second-story work drops to 200-250 sq ft per hour due to ladder repositioning. Third-story work drops further to 175-200 sq ft per hour.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Base_Hours = Area / Production_Rate</p>
            <p>Adjusted_Hours = Base_Hours x Story_Factor x Ladder_Factor + Prep_Hours</p>
            <p>Labor_Cost = Adjusted_Hours x Hourly_Rate</p>
            <p>Total = Materials + Labor + Scaffold + Add-Ons</p>
          </div>
          <p><strong class="text-text-primary">Siding type affects production rate.</strong> Smooth vinyl is fastest to paint. Wood clapboard requires more cutting in and care. Stucco soaks up paint and needs heavier application. Brick requires special masonry primer and more coats for full coverage.</p>
          <p><strong class="text-text-primary">Exterior margins should be 30-45%.</strong> Exterior work has higher equipment costs and weather risk compared to interior. Price accordingly and always include a weather contingency clause in your contract.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Quoting whole-house exterior jobs.</strong> After measuring the home and assessing condition, plug in the details to build a professional estimate that covers all costs.</p>
          <p><strong class="text-text-primary">Comparing siding type scenarios.</strong> If a customer has mixed siding, run separate calculations and combine them for an accurate total.</p>
          <p><strong class="text-text-primary">Deciding whether to rent scaffolding.</strong> Plug in the scaffold rental cost and see how it affects margin. Sometimes the time saved with proper scaffolding pays for itself in reduced labor hours.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I price an exterior painting job?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Calculate the total exterior wall area, factor in the number of stories, siding type, and surface condition. Exterior production rates are lower than interior. Add materials with markup, ladder or scaffold rental if needed, and target 30-45% gross margin.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much does it cost to paint the exterior of a house?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A typical single-story home costs $2,500-4,500. Two-story homes run $4,000-7,500. Three-story homes can reach $6,500-11,000. These ranges assume standard paint, moderate prep, and include trim and fascia.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What factors increase exterior painting costs?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Multiple stories add 20-40% per additional floor. Limited access from fences adds 10%. Scaffold rental adds $500-1,000. Poor surface condition adds 30-50% to labor. Wood siding takes longer than vinyl or fiber cement.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How long does it take to paint the exterior of a house?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A two-person crew can paint a single-story 1,500 sq ft home exterior in 2-3 days. A two-story home takes 3-5 days. Three-story homes take 5-7 days. These include prep, priming, two coats, and trim work.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  const paintPrices: Record<string, number> = { 'standard': 35, 'premium': 55, 'high-end': 75 };
  const EXTERIOR_COVERAGE = 350;
  const PRIMER_COVERAGE = 300;
  const PRIMER_PRICE = 30;

  const sidingRates: Record<string, number> = {
    'vinyl': 350, 'wood': 275, 'fiber-cement': 300, 'stucco': 250, 'brick': 200, 'aluminum': 325
  };
  const storyFactors: Record<string, number> = { '1': 1.0, '2': 1.2, '3': 1.4 };
  const ladderFactors: Record<string, number> = { 'unrestricted': 1.0, 'limited': 1.1, 'scaffold': 1.3 };
  const conditionPrepMultipliers: Record<string, number> = { 'good': 0.1, 'fair': 0.3, 'poor': 0.5 };

  const INTERNAL_LABOR_COST = 25;
  const NUM_COATS = 2;
  const SUPPLIES_BASE = 75;

  function calculate() {
    const totalSqft = parseFloat((document.getElementById('total-sqft') as HTMLInputElement).value) || 2000;
    const numStories = (document.getElementById('num-stories') as HTMLSelectElement).value;
    const sidingType = (document.getElementById('siding-type') as HTMLSelectElement).value;
    const surfaceCondition = (document.getElementById('surface-condition') as HTMLSelectElement).value;
    const ladderAccess = (document.getElementById('ladder-access') as HTMLSelectElement).value;
    const paintQuality = (document.getElementById('paint-quality') as HTMLSelectElement).value;
    const crewSize = parseInt((document.getElementById('crew-size') as HTMLInputElement).value) || 2;
    const hourlyRate = parseFloat((document.getElementById('hourly-rate') as HTMLInputElement).value) || 60;
    const materialsMarkup = parseFloat((document.getElementById('materials-markup') as HTMLInputElement).value) || 40;
    const scaffoldRental = parseFloat((document.getElementById('scaffold-rental') as HTMLInputElement).value) || 0;

    // Paint
    const pricePerGallon = paintPrices[paintQuality] || 35;
    const paintGallons = Math.ceil((totalSqft * NUM_COATS) / EXTERIOR_COVERAGE);
    const paintCost = paintGallons * pricePerGallon;

    // Primer (always for exterior)
    const primerGallons = Math.ceil(totalSqft / PRIMER_COVERAGE);
    const primerCost = primerGallons * PRIMER_PRICE;
    const totalPaintPrimerCost = paintCost + primerCost;

    // Supplies
    const suppliesCost = SUPPLIES_BASE + (totalSqft * 0.02);

    // Labor hours
    const baseRate = sidingRates[sidingType] || 300;
    const baseHours = totalSqft / baseRate;
    const storyFactor = storyFactors[numStories] || 1.0;
    const ladderFactor = ladderFactors[ladderAccess] || 1.0;
    const prepMultiplier = conditionPrepMultipliers[surfaceCondition] || 0.1;

    const paintingHours = (baseHours * NUM_COATS) * storyFactor * ladderFactor;
    const prepHours = baseHours * prepMultiplier * storyFactor;
    const primerHours = (totalSqft / 400) * storyFactor;

    // Add-ons
    let addonHours = 0;
    let addonMaterialsCost = 0;
    document.querySelectorAll('.addon-item').forEach(cb => {
      const checkbox = cb as HTMLInputElement;
      if (checkbox.checked) {
        addonHours += parseFloat(checkbox.dataset.hours || '0');
        addonMaterialsCost += parseFloat(checkbox.dataset.materials || '0');
      }
    });
    addonHours *= storyFactor;

    const totalLaborHours = paintingHours + prepHours + primerHours + addonHours;

    // Costs
    const materialsCost = totalPaintPrimerCost + suppliesCost + addonMaterialsCost;
    const materialsSell = materialsCost * (1 + materialsMarkup / 100);
    const laborSell = totalLaborHours * hourlyRate;
    const laborCost = totalLaborHours * INTERNAL_LABOR_COST;

    const totalCost = materialsCost + laborCost + scaffoldRental;
    const totalSell = materialsSell + laborSell + scaffoldRental;
    const grossProfit = totalSell - totalCost;
    const margin = totalSell > 0 ? (grossProfit / totalSell) * 100 : 0;
    const perSqft = totalSell / totalSqft;
    const daysOnSite = Math.ceil(totalLaborHours / (crewSize * 8));

    const fmt = (n: number) => '$' + Math.round(n).toLocaleString();

    document.getElementById('result-total-sell')!.textContent = fmt(totalSell);
    document.getElementById('result-per-sqft')!.textContent = '$' + perSqft.toFixed(2);

    const profitEl = document.getElementById('result-gross-profit')!;
    profitEl.textContent = fmt(grossProfit);
    profitEl.className = 'font-heading font-extrabold text-3xl';
    profitEl.classList.add(grossProfit >= 0 ? 'text-[#34D399]' : 'text-[#EF4444]');

    const marginEl = document.getElementById('result-margin')!;
    marginEl.textContent = margin.toFixed(1) + '%';
    marginEl.className = 'font-heading font-extrabold text-3xl';
    if (margin >= 35) marginEl.classList.add('text-[#34D399]');
    else if (margin >= 25) marginEl.classList.add('text-[#FBBF24]');
    else marginEl.classList.add('text-[#EF4444]');

    document.getElementById('breakdown-paint-cost')!.textContent = fmt(totalPaintPrimerCost);
    document.getElementById('breakdown-paint-sell')!.textContent = fmt(totalPaintPrimerCost * (1 + materialsMarkup / 100));
    document.getElementById('breakdown-supplies-cost')!.textContent = fmt(suppliesCost);
    document.getElementById('breakdown-supplies-sell')!.textContent = fmt(suppliesCost * (1 + materialsMarkup / 100));
    document.getElementById('breakdown-labor-hours')!.textContent = totalLaborHours.toFixed(1);
    document.getElementById('breakdown-labor-sell')!.textContent = fmt(laborSell);
    document.getElementById('breakdown-addon-cost')!.textContent = fmt(addonMaterialsCost + (addonHours * INTERNAL_LABOR_COST));
    document.getElementById('breakdown-addon-sell')!.textContent = fmt((addonMaterialsCost * (1 + materialsMarkup / 100)) + (addonHours * hourlyRate));
    document.getElementById('breakdown-scaffold')!.textContent = fmt(scaffoldRental);
    document.getElementById('breakdown-total-cost')!.textContent = fmt(totalCost);
    document.getElementById('breakdown-total-sell')!.textContent = fmt(totalSell);
    document.getElementById('timeline-estimate')!.textContent = `${daysOnSite} working days for a ${crewSize}-person crew`;
  }

  document.querySelectorAll('#exterior-calc input[type="number"], #exterior-calc select, #exterior-calc input[type="checkbox"]').forEach(el => {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  calculate();
</script>
