---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/cleaningTools';

const tool = getToolBySlug('service-agreement-template')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should a recurring cleaning service agreement include?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A recurring cleaning service agreement should include company and customer information, the property address with size and special instructions, the service tier detailing cleaning type and frequency (biweekly standard, weekly deep, etc.), access arrangements (key, lockbox code, or garage code), pricing and payment terms, satisfaction guarantee details, cancellation policy with required notice period, and a clear scope of work describing what is included in each cleaning visit."
      }
    },
    {
      "@type": "Question",
      "name": "How much should I charge for a recurring cleaning agreement?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most cleaning companies charge between $149 and $399 per month for recurring residential agreements depending on the service tier and frequency. A basic biweekly standard clean runs $149 to $199 per month. A mid-tier plan with weekly standard cleans plus a monthly deep clean runs $249 to $299. Premium plans with weekly deep cleans and quarterly move-out level service run $349 to $449. Price to cover your labor, supplies, drive time, and overhead plus a 40-60% gross margin."
      }
    },
    {
      "@type": "Question",
      "name": "How do recurring cleaning agreements increase business value?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Recurring cleaning agreements create predictable monthly revenue that business buyers and lenders value at a higher multiple than one-time service revenue. A company with 100 active agreements at $249 per month has nearly $300,000 in predictable annual revenue. This recurring revenue stabilizes cash flow, improves customer retention since agreement clients are far less likely to shop competitors, and generates consistent route density that reduces drive time and increases daily productivity."
      }
    },
    {
      "@type": "Question",
      "name": "What cancellation policy should a cleaning agreement have?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A 30-day written notice cancellation policy is standard for residential cleaning agreements. This gives you time to fill the schedule gap and protects against last-minute cancellations. Some companies use 15-day notice for month-to-month plans and 30-day for longer commitments. Always include language about how prepaid services are handled at cancellation. Offering a satisfaction guarantee with a free re-clean within 24 hours reduces cancellations significantly because clients feel protected."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="sa-builder">
    <!-- Company Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Company Information</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="companyName">Company Name</label>
        <input type="text" id="companyName" placeholder="Your Cleaning Company" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="companyPhone">Phone</label>
        <input type="text" id="companyPhone" placeholder="(555) 123-4567" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="companyEmail">Email</label>
        <input type="email" id="companyEmail" placeholder="service@yourcleaning.com" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="companyLicense">License / Insurance #</label>
        <input type="text" id="companyLicense" placeholder="CLN-12345" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="agreementNumber">Agreement #</label>
        <input type="text" id="agreementNumber" value="SA-001" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="agreementDate">Agreement Date</label>
        <input type="date" id="agreementDate" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="agreementTerm">Term</label>
        <select id="agreementTerm" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="6">6 Months</option>
          <option value="12" selected>12 Months</option>
          <option value="24">24 Months</option>
        </select>
      </div>
    </div>

    <!-- Customer Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Customer Information</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customerName">Customer Name</label>
        <input type="text" id="customerName" placeholder="John Smith" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customerAddress">Property Address</label>
        <input type="text" id="customerAddress" placeholder="123 Main St, City, State ZIP" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customerPhone">Phone</label>
        <input type="text" id="customerPhone" placeholder="(555) 987-6543" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customerEmail">Email</label>
        <input type="email" id="customerEmail" placeholder="customer@email.com" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Property Details -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Property Details</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="propertySqft">Property Size (sq ft)</label>
        <input type="number" id="propertySqft" value="1500" min="200" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="propertyBedBath">Bed / Bath</label>
        <input type="text" id="propertyBedBath" placeholder="3 bed / 2 bath" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="accessMethod">Access Method</label>
        <select id="accessMethod" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Client home">Client home</option>
          <option value="Key provided">Key provided</option>
          <option value="Lockbox">Lockbox</option>
          <option value="Garage code">Garage code</option>
          <option value="Door code">Door code</option>
        </select>
      </div>
      <div class="md:col-span-2 lg:col-span-3">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="specialNotes">Special Instructions</label>
        <input type="text" id="specialNotes" placeholder="Pets, allergies, no-go areas, alarm codes..." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Coverage Tiers -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Service Tier</h3>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-8">
      <!-- Clean Essentials -->
      <div class="tier-card bg-bg-dark border-2 border-border rounded-xl p-5 cursor-pointer hover:border-[#3A4755] transition-all" data-tier="essentials">
        <div class="flex items-center gap-3 mb-3">
          <input type="radio" name="tier" id="tierEssentials" value="essentials" class="accent-accent w-4 h-4" />
          <label for="tierEssentials" class="font-heading font-bold text-base text-text-primary cursor-pointer">Clean Essentials</label>
        </div>
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-medium text-text-muted mb-1">Monthly Price ($)</label>
            <input type="number" id="essentialsPrice" value="149" min="0" class="tier-input w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div class="text-xs text-text-secondary space-y-1 pt-2 border-t border-border">
            <p>Biweekly standard maintenance clean</p>
            <p>Kitchen, bathrooms, floors, dusting</p>
            <p>Satisfaction guarantee (re-clean in 24 hrs)</p>
          </div>
        </div>
      </div>

      <!-- Clean Plus -->
      <div class="tier-card bg-bg-dark border-2 border-accent rounded-xl p-5 cursor-pointer transition-all relative" data-tier="plus">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-accent text-white text-[10px] font-bold uppercase tracking-wider px-3 py-0.5 rounded-full">Most Popular</div>
        <div class="flex items-center gap-3 mb-3">
          <input type="radio" name="tier" id="tierPlus" value="plus" checked class="accent-accent w-4 h-4" />
          <label for="tierPlus" class="font-heading font-bold text-base text-text-primary cursor-pointer">Clean Plus</label>
        </div>
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-medium text-text-muted mb-1">Monthly Price ($)</label>
            <input type="number" id="plusPrice" value="249" min="0" class="tier-input w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div class="text-xs text-text-secondary space-y-1 pt-2 border-t border-border">
            <p>Weekly standard maintenance clean</p>
            <p>Monthly deep clean included</p>
            <p>Inside oven and fridge monthly</p>
            <p>Priority scheduling</p>
            <p>Satisfaction guarantee (re-clean in 24 hrs)</p>
          </div>
        </div>
      </div>

      <!-- Total Clean -->
      <div class="tier-card bg-bg-dark border-2 border-border rounded-xl p-5 cursor-pointer hover:border-[#3A4755] transition-all" data-tier="total">
        <div class="flex items-center gap-3 mb-3">
          <input type="radio" name="tier" id="tierTotal" value="total" class="accent-accent w-4 h-4" />
          <label for="tierTotal" class="font-heading font-bold text-base text-text-primary cursor-pointer">Total Clean</label>
        </div>
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-medium text-text-muted mb-1">Monthly Price ($)</label>
            <input type="number" id="totalPrice" value="399" min="0" class="tier-input w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div class="text-xs text-text-secondary space-y-1 pt-2 border-t border-border">
            <p>Weekly deep clean</p>
            <p>Quarterly move-out level clean</p>
            <p>All appliances included every visit</p>
            <p>Interior windows monthly</p>
            <p>Same-day scheduling guarantee</p>
            <p>Satisfaction guarantee (re-clean in 24 hrs)</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Payment Terms -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Payment &amp; Terms</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="flex items-center gap-3 pt-2">
        <input type="checkbox" id="autoRenew" checked class="accent-accent w-5 h-5" />
        <label for="autoRenew" class="text-text-primary font-medium cursor-pointer">Auto-Renew</label>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cancelNotice">Cancellation Notice</label>
        <select id="cancelNotice" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="15">15 Days</option>
          <option value="30" selected>30 Days</option>
          <option value="60">60 Days</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="paymentMethod">Payment Method</label>
        <select id="paymentMethod" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Credit card on file">Credit card on file</option>
          <option value="ACH / Bank transfer">ACH / Bank transfer</option>
          <option value="Check">Check</option>
          <option value="Cash">Cash</option>
        </select>
      </div>
    </div>

    <!-- Profitability Calculator -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Profitability Calculator</h3>
    <div class="bg-bg-dark border border-border rounded-xl p-5 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Number of Agreements</label>
          <input type="number" id="numAgreements" value="25" min="1" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Avg Monthly Price ($)</label>
          <input type="text" id="avgPrice" value="249" readonly class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-text-muted text-sm cursor-not-allowed" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Labor Cost / Visit ($)</label>
          <input type="number" id="laborCostPerVisit" value="45" min="0" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Supply Cost / Visit ($)</label>
          <input type="number" id="supplyCostPerVisit" value="8" min="0" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-bg-card rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Monthly Revenue</div>
          <div id="profitRevenue" class="font-heading font-extrabold text-2xl text-accent">$6,225</div>
        </div>
        <div class="bg-bg-card rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Monthly Cost</div>
          <div id="profitCost" class="font-heading font-extrabold text-2xl text-text-primary">$2,650</div>
        </div>
        <div class="bg-bg-card rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Profit / Agreement</div>
          <div id="profitPerAgreement" class="font-heading font-extrabold text-2xl text-text-primary">$143</div>
        </div>
        <div class="bg-bg-card rounded-xl p-4 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Annual Profit</div>
          <div id="profitTotal" class="font-heading font-extrabold text-2xl text-[#34D399]">$42,900</div>
        </div>
      </div>
    </div>

    <!-- Generate Button -->
    <button id="generateBtn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
      Generate Service Agreement &rarr;
    </button>
    <p class="text-text-muted text-sm italic mt-3">Opens a print-ready agreement in a new window. Use your browser's print dialog to save as PDF.</p>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Template</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter your company and customer details.</strong> Fill in your company name, license or insurance number, and contact info. Then add the customer's name, property address, and contact information. The agreement number auto-generates but you can customize it to match your numbering system.</p>
          <p><strong class="text-text-primary">2. Add property details.</strong> Enter the property size, bed and bath count, and the access method your team will use (key, lockbox, garage code). Note any special instructions like pets, allergies, or areas to avoid.</p>
          <p><strong class="text-text-primary">3. Select and customize a service tier.</strong> Choose Clean Essentials, Clean Plus, or Total Clean. Each tier comes pre-loaded with competitive pricing and service descriptions. Adjust the monthly price to match what your company offers in your market.</p>
          <p><strong class="text-text-primary">4. Generate and print.</strong> Click Generate to create a professional, printable service agreement. It includes all property details, the selected service tier with scope of work, payment terms, cancellation policy, satisfaction guarantee, and signature lines for both parties.</p>
        </div>
      </section>

      <!-- Why Recurring Agreements Matter -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Why Recurring Agreements Are Essential for Cleaning</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>Recurring service agreements transform a cleaning business from a one-off gig operation into one with <strong class="text-text-primary">predictable monthly revenue</strong>. Instead of chasing new leads every week, agreements guarantee scheduled work and committed income before the month even starts.</p>
          <p><strong class="text-text-primary">Customer retention dramatically improves.</strong> A client with an active agreement is far less likely to shop competitors or cancel on short notice. They have committed to a schedule, they know your team, and they trust your work. That loyalty means fewer leads you need to buy and a lower cost of acquisition for every job.</p>
          <p><strong class="text-text-primary">Agreements increase business value.</strong> When buyers or investors evaluate a cleaning company, recurring agreement revenue is valued at a significantly higher multiple than one-time job revenue. Agreements also smooth out cash flow, making it easier to manage payroll, supplies, and growth investments month to month.</p>
          <p>Every recurring visit is also a <strong class="text-text-primary">sales opportunity</strong>. Your team can identify needs for deep cleans, window washing, carpet cleaning, or other add-ons during routine maintenance visits. Agreement customers trust your recommendations because they already have a relationship with your company, leading to higher close rates on upsells.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Launching a recurring service program.</strong> You know you need predictable revenue but have never offered formal agreements. Use this template to design your tier structure, set competitive pricing, and generate professional contracts. The profitability calculator helps you price tiers that actually make money after accounting for labor and supplies.</p>
          <p><strong class="text-text-primary">Converting one-time clients to recurring.</strong> After completing a one-time deep clean or move-out clean, present the customer with a recurring agreement before you leave. Offer a first-month discount to close them on the spot. This is the highest-conversion moment because the customer just saw the quality of your work and the home is spotless.</p>
          <p><strong class="text-text-primary">Renewing and upgrading existing clients.</strong> At renewal time, generate an updated agreement with the customer's current property details. Use the tier comparison to show clients the value of upgrading from Clean Essentials to Clean Plus or from Clean Plus to Total Clean. The incremental revenue from tier upgrades adds up fast across your entire client base.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should a recurring cleaning service agreement include?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A recurring cleaning service agreement should include company and customer information, the property address with size and special instructions, the service tier detailing cleaning type and frequency (biweekly standard, weekly deep, etc.), access arrangements (key, lockbox code, or garage code), pricing and payment terms, satisfaction guarantee details, cancellation policy with required notice period, and a clear scope of work describing what is included in each cleaning visit.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much should I charge for a recurring cleaning agreement?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most cleaning companies charge between $149 and $399 per month for recurring residential agreements depending on the service tier and frequency. A basic biweekly standard clean runs $149 to $199 per month. A mid-tier plan with weekly standard cleans plus a monthly deep clean runs $249 to $299. Premium plans with weekly deep cleans and quarterly move-out level service run $349 to $449. Price to cover your labor, supplies, drive time, and overhead plus a 40-60% gross margin.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do recurring cleaning agreements increase business value?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Recurring cleaning agreements create predictable monthly revenue that business buyers and lenders value at a higher multiple than one-time service revenue. A company with 100 active agreements at $249 per month has nearly $300,000 in predictable annual revenue. This recurring revenue stabilizes cash flow, improves customer retention since agreement clients are far less likely to shop competitors, and generates consistent route density that reduces drive time and increases daily productivity.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What cancellation policy should a cleaning agreement have?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A 30-day written notice cancellation policy is standard for residential cleaning agreements. This gives you time to fill the schedule gap and protects against last-minute cancellations. Some companies use 15-day notice for month-to-month plans and 30-day for longer commitments. Always include language about how prepaid services are handled at cancellation. Offering a satisfaction guarantee with a free re-clean within 24 hours reduces cancellations significantly because clients feel protected.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // ---- Helpers ----
  function $(id: string) { return document.getElementById(id) as HTMLInputElement; }
  function val(id: string) { return parseFloat($(id).value) || 0; }
  function checked(id: string) { return ($(id) as HTMLInputElement).checked; }
  function fmt(n: number) { return n.toLocaleString('en-US', { maximumFractionDigits: 0 }); }

  // ---- Set today's date ----
  const today = new Date().toISOString().split('T')[0];
  $('agreementDate').value = today;

  // ---- Tier card selection ----
  document.querySelectorAll('.tier-card').forEach(card => {
    card.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName === 'INPUT' || target.tagName === 'LABEL') return;
      const radio = card.querySelector('input[type="radio"]') as HTMLInputElement;
      if (radio) {
        radio.checked = true;
        radio.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  });

  function updateTierBorders() {
    const selected = (document.querySelector('input[name="tier"]:checked') as HTMLInputElement)?.value;
    document.querySelectorAll('.tier-card').forEach(card => {
      const tier = (card as HTMLElement).dataset.tier;
      if (tier === selected) {
        card.classList.remove('border-border', 'hover:border-[#3A4755]');
        card.classList.add('border-accent');
      } else {
        card.classList.remove('border-accent');
        card.classList.add('border-border', 'hover:border-[#3A4755]');
      }
    });
  }

  document.querySelectorAll('input[name="tier"]').forEach(radio => {
    radio.addEventListener('change', () => {
      updateTierBorders();
      updateProfitability();
    });
  });

  // ---- Tier configs for visits/month ----
  const tierVisits: Record<string, number> = {
    'essentials': 2,   // biweekly = 2/month
    'plus': 5,         // 4 weekly + 1 deep
    'total': 5,        // 4 weekly deep + quarterly
  };

  // ---- Profitability Calculator ----
  function getSelectedTierPrice(): number {
    const tier = (document.querySelector('input[name="tier"]:checked') as HTMLInputElement)?.value || 'plus';
    if (tier === 'essentials') return val('essentialsPrice');
    if (tier === 'total') return val('totalPrice');
    return val('plusPrice');
  }

  function getSelectedTierVisits(): number {
    const tier = (document.querySelector('input[name="tier"]:checked') as HTMLInputElement)?.value || 'plus';
    return tierVisits[tier] || 4;
  }

  function updateProfitability() {
    const monthlyPrice = getSelectedTierPrice();
    const visitsPerMonth = getSelectedTierVisits();
    const numAgreements = val('numAgreements') || 25;
    const laborCost = val('laborCostPerVisit') || 45;
    const supplyCost = val('supplyCostPerVisit') || 8;

    $('avgPrice').value = monthlyPrice.toString();

    const monthlyRevenue = numAgreements * monthlyPrice;
    const costPerVisit = laborCost + supplyCost;
    const monthlyCost = numAgreements * visitsPerMonth * costPerVisit;
    const monthlyProfit = monthlyRevenue - monthlyCost;
    const profitPerAgreement = monthlyPrice - (visitsPerMonth * costPerVisit);
    const annualProfit = monthlyProfit * 12;

    document.getElementById('profitRevenue')!.textContent = `$${fmt(monthlyRevenue)}`;
    document.getElementById('profitCost')!.textContent = `$${fmt(monthlyCost)}`;
    document.getElementById('profitPerAgreement')!.textContent = `$${fmt(profitPerAgreement)}`;
    document.getElementById('profitTotal')!.textContent = `$${fmt(annualProfit)}`;

    const profitEl = document.getElementById('profitTotal')!;
    if (annualProfit > 0) {
      profitEl.className = 'font-heading font-extrabold text-2xl text-[#34D399]';
    } else {
      profitEl.className = 'font-heading font-extrabold text-2xl text-red-400';
    }
  }

  ['numAgreements', 'laborCostPerVisit', 'supplyCostPerVisit'].forEach(id => {
    $(id)?.addEventListener('input', updateProfitability);
  });

  document.querySelectorAll('.tier-input').forEach(input => {
    input.addEventListener('input', updateProfitability);
  });

  // ---- Tier details for PDF ----
  function getSelectedTierDetails() {
    const tier = (document.querySelector('input[name="tier"]:checked') as HTMLInputElement)?.value || 'plus';
    if (tier === 'essentials') {
      return {
        name: 'Clean Essentials',
        price: val('essentialsPrice'),
        frequency: 'Biweekly',
        scope: [
          'Biweekly standard maintenance clean',
          'Kitchen: counters, sink, stovetop, exterior appliances',
          'Bathrooms: toilet, shower/tub, sink, mirror, floor',
          'All rooms: vacuum, mop hard floors, dust surfaces',
          'Trash removal from all rooms',
          'Satisfaction guarantee: free re-clean within 24 hours',
        ],
      };
    } else if (tier === 'total') {
      return {
        name: 'Total Clean',
        price: val('totalPrice'),
        frequency: 'Weekly',
        scope: [
          'Weekly deep clean',
          'All standard clean tasks plus:',
          'Baseboards, light switches, door frames every visit',
          'Inside oven, microwave, and fridge every visit',
          'Interior windows cleaned monthly',
          'Quarterly move-out level clean (walls, inside cabinets, fixtures)',
          'Same-day scheduling guarantee',
          'Satisfaction guarantee: free re-clean within 24 hours',
        ],
      };
    }
    return {
      name: 'Clean Plus',
      price: val('plusPrice'),
      frequency: 'Weekly',
      scope: [
        'Weekly standard maintenance clean',
        'Monthly deep clean included',
        'Inside oven and fridge cleaned monthly',
        'Kitchen: counters, sink, stovetop, exterior appliances, backsplash',
        'Bathrooms: toilet, shower/tub, sink, mirror, floor, fixtures',
        'All rooms: vacuum, mop, dust, cobweb removal',
        'Priority scheduling',
        'Satisfaction guarantee: free re-clean within 24 hours',
      ],
    };
  }

  // ---- Generate Agreement PDF ----
  document.getElementById('generateBtn')?.addEventListener('click', () => {
    const companyName = $('companyName').value || 'Your Cleaning Company';
    const companyPhone = $('companyPhone').value || '';
    const companyEmail = $('companyEmail').value || '';
    const companyLicense = $('companyLicense').value || '';
    const agreementNumber = $('agreementNumber').value || 'SA-001';
    const agreementDate = $('agreementDate').value || today;
    const agreementTerm = ($('agreementTerm') as HTMLSelectElement).value;
    const customerName = $('customerName').value || 'Customer';
    const customerAddress = $('customerAddress').value || '';
    const customerPhone = $('customerPhone').value || '';
    const customerEmail = $('customerEmail').value || '';
    const propertySqft = $('propertySqft').value || '';
    const propertyBedBath = $('propertyBedBath').value || '';
    const accessMethod = ($('accessMethod') as HTMLSelectElement).value;
    const specialNotes = $('specialNotes').value || '';
    const tier = getSelectedTierDetails();
    const autoRenew = checked('autoRenew');
    const cancelNotice = ($('cancelNotice') as HTMLSelectElement).value;
    const paymentMethod = ($('paymentMethod') as HTMLSelectElement).value;
    const monthlyPrice = tier.price;
    const annualPrice = monthlyPrice * 12;

    const formattedDate = new Date(agreementDate + 'T00:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    const endDate = new Date(agreementDate + 'T00:00:00');
    endDate.setMonth(endDate.getMonth() + parseInt(agreementTerm));
    const formattedEnd = endDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

    const scopeHtml = tier.scope.map(s => `<li style="margin-bottom:6px;">${s}</li>`).join('');

    const printWindow = window.open('', '_blank');
    if (!printWindow) return;

    printWindow.document.write(`
      <!DOCTYPE html>
      <html>
      <head>
        <title>Service Agreement - ${agreementNumber}</title>
        <style>
          * { margin: 0; padding: 0; box-sizing: border-box; }
          body { font-family: 'Segoe UI', Arial, sans-serif; color: #1a1a1a; max-width: 800px; margin: 0 auto; padding: 40px 30px; font-size: 13px; line-height: 1.6; }
          h1 { font-size: 22px; margin-bottom: 4px; }
          h2 { font-size: 16px; margin-top: 28px; margin-bottom: 10px; border-bottom: 2px solid #222; padding-bottom: 4px; }
          h3 { font-size: 14px; margin-top: 18px; margin-bottom: 6px; }
          table { width: 100%; border-collapse: collapse; margin: 10px 0; }
          .header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 3px solid #222; padding-bottom: 16px; margin-bottom: 20px; }
          .header-left h1 { color: #222; }
          .header-right { text-align: right; font-size: 12px; color: #555; }
          .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 16px; }
          .info-box { background: #f8f8f8; border: 1px solid #e0e0e0; border-radius: 6px; padding: 14px; }
          .info-box strong { display: block; font-size: 11px; text-transform: uppercase; color: #888; margin-bottom: 6px; letter-spacing: 0.5px; }
          .tier-banner { background: #1a1a1a; color: #fff; padding: 14px 20px; border-radius: 6px; margin: 16px 0; display: flex; justify-content: space-between; align-items: center; }
          .tier-banner .tier-name { font-size: 18px; font-weight: 700; }
          .tier-banner .tier-price { font-size: 20px; font-weight: 700; }
          .scope-list { list-style: none; padding: 0; }
          .scope-list li { padding-left: 22px; position: relative; }
          .scope-list li::before { content: "\\2713"; position: absolute; left: 0; color: #16a34a; font-weight: 700; }
          .sig-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 30px; }
          .sig-block { border-top: 1px solid #222; padding-top: 8px; margin-top: 50px; }
          .sig-label { font-size: 11px; color: #888; text-transform: uppercase; letter-spacing: 0.5px; }
          .footer { text-align: center; margin-top: 40px; padding-top: 16px; border-top: 1px solid #ddd; font-size: 11px; color: #999; }
          @media print { body { padding: 20px; } @page { margin: 0.5in; } }
        </style>
      </head>
      <body>
        <div class="header">
          <div class="header-left">
            <h1>${companyName}</h1>
            <div style="font-size:13px;color:#555;margin-top:4px;">Recurring Cleaning Service Agreement</div>
          </div>
          <div class="header-right">
            ${companyPhone ? `<div>${companyPhone}</div>` : ''}
            ${companyEmail ? `<div>${companyEmail}</div>` : ''}
            ${companyLicense ? `<div>License: ${companyLicense}</div>` : ''}
          </div>
        </div>

        <div style="display:flex;justify-content:space-between;margin-bottom:20px;font-size:13px;">
          <div><strong>Agreement #:</strong> ${agreementNumber}</div>
          <div><strong>Start:</strong> ${formattedDate}</div>
          <div><strong>Term:</strong> ${agreementTerm} months</div>
          <div><strong>Expires:</strong> ${formattedEnd}</div>
        </div>

        <div class="info-grid">
          <div class="info-box">
            <strong>Service Provider</strong>
            <div>${companyName}</div>
            ${companyPhone ? `<div>${companyPhone}</div>` : ''}
            ${companyEmail ? `<div>${companyEmail}</div>` : ''}
          </div>
          <div class="info-box">
            <strong>Customer</strong>
            <div>${customerName}</div>
            ${customerAddress ? `<div>${customerAddress}</div>` : ''}
            ${customerPhone ? `<div>${customerPhone}</div>` : ''}
            ${customerEmail ? `<div>${customerEmail}</div>` : ''}
          </div>
        </div>

        <h2>Property Details</h2>
        <table>
          <tr><td style="border:1px solid #ddd;padding:8px;width:35%;background:#f8f8f8;font-weight:600;">Address</td><td style="border:1px solid #ddd;padding:8px;">${customerAddress || 'N/A'}</td></tr>
          <tr><td style="border:1px solid #ddd;padding:8px;background:#f8f8f8;font-weight:600;">Size</td><td style="border:1px solid #ddd;padding:8px;">${propertySqft ? propertySqft + ' sq ft' : 'N/A'}${propertyBedBath ? ' &mdash; ' + propertyBedBath : ''}</td></tr>
          <tr><td style="border:1px solid #ddd;padding:8px;background:#f8f8f8;font-weight:600;">Access Method</td><td style="border:1px solid #ddd;padding:8px;">${accessMethod}</td></tr>
          ${specialNotes ? `<tr><td style="border:1px solid #ddd;padding:8px;background:#f8f8f8;font-weight:600;">Special Instructions</td><td style="border:1px solid #ddd;padding:8px;">${specialNotes}</td></tr>` : ''}
        </table>

        <div class="tier-banner">
          <div>
            <div class="tier-name">${tier.name}</div>
            <div style="font-size:12px;opacity:0.8;">${tier.frequency} Service</div>
          </div>
          <div class="tier-price">$${fmt(monthlyPrice)}<span style="font-size:12px;font-weight:400;opacity:0.8;">/month</span></div>
        </div>

        <h2>Scope of Work</h2>
        <ul class="scope-list">${scopeHtml}</ul>

        <h2>Payment Terms</h2>
        <table>
          <tr><td style="border:1px solid #ddd;padding:8px;width:35%;background:#f8f8f8;font-weight:600;">Monthly Price</td><td style="border:1px solid #ddd;padding:8px;font-weight:700;">$${fmt(monthlyPrice)}</td></tr>
          <tr><td style="border:1px solid #ddd;padding:8px;background:#f8f8f8;font-weight:600;">Annual Value</td><td style="border:1px solid #ddd;padding:8px;">$${fmt(annualPrice)}</td></tr>
          <tr><td style="border:1px solid #ddd;padding:8px;background:#f8f8f8;font-weight:600;">Payment Method</td><td style="border:1px solid #ddd;padding:8px;">${paymentMethod}</td></tr>
          <tr><td style="border:1px solid #ddd;padding:8px;background:#f8f8f8;font-weight:600;">Auto-Renewal</td><td style="border:1px solid #ddd;padding:8px;">${autoRenew ? 'Yes &mdash; agreement renews automatically unless cancelled' : 'No &mdash; customer must opt in to renew'}</td></tr>
        </table>

        <h2>Terms &amp; Conditions</h2>
        <h3>1. Scope of Service</h3>
        <p>This agreement covers recurring cleaning services for the property listed above. The Service Provider will perform cleaning visits at the frequency specified by the selected service tier. Each visit includes the tasks listed under Scope of Work.</p>

        <h3>2. Access &amp; Scheduling</h3>
        <p>The Customer agrees to provide reliable access to the property via the agreed method (${accessMethod}). If the Service Provider cannot access the property at the scheduled time, the visit will be marked as completed and the monthly rate will not be adjusted. The Customer may reschedule a visit with at least 24 hours notice.</p>

        <h3>3. Satisfaction Guarantee</h3>
        <p>If the Customer is not satisfied with any cleaning visit, the Service Provider will re-clean the specified areas at no additional charge within 24 hours of notification. The Customer must notify the Service Provider within 24 hours of the completed visit to qualify for a re-clean.</p>

        <h3>4. Supplies &amp; Equipment</h3>
        <p>The Service Provider supplies all cleaning products, tools, and equipment unless otherwise agreed. If the Customer requires specific products due to allergies or preferences, the Customer will provide those products at their own expense.</p>

        <h3>5. Cancellation</h3>
        <p>Either party may cancel this agreement with ${cancelNotice} days written notice. If the Customer cancels before the agreement term expires, no refund is due for the current month. The Service Provider reserves the right to cancel with ${cancelNotice} days notice if access or safety issues cannot be resolved.</p>

        <h3>6. Limitation of Liability</h3>
        <p>The Service Provider carries general liability insurance and is bonded. Liability for property damage is limited to the cost of repair or replacement of the damaged item. The Service Provider is not liable for pre-existing damage, normal wear and tear, or items of extraordinary value not disclosed in advance.</p>

        <div class="sig-grid">
          <div>
            <div class="sig-block">
              <div style="font-weight:600;margin-bottom:2px;">${companyName}</div>
              <div class="sig-label">Authorized Representative</div>
            </div>
            <div class="sig-block"><div class="sig-label">Date</div></div>
          </div>
          <div>
            <div class="sig-block">
              <div style="font-weight:600;margin-bottom:2px;">${customerName}</div>
              <div class="sig-label">Customer Signature</div>
            </div>
            <div class="sig-block"><div class="sig-label">Date</div></div>
          </div>
        </div>

        <div class="footer">
          ${companyName} &middot; ${companyPhone} &middot; ${companyEmail}<br/>
          ${companyLicense ? `License #${companyLicense} &middot; ` : ''}Agreement #${agreementNumber}
        </div>
      </body>
      </html>
    `);

    printWindow.document.close();
    setTimeout(() => { printWindow.print(); }, 500);
  });

  // ---- Init ----
  updateTierBorders();
  updateProfitability();
</script>
