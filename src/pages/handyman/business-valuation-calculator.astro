---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/handymanTools';

const tool = getToolBySlug('business-valuation-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much is my handyman business worth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most handyman businesses sell for 2 to 5 times their Seller's Discretionary Earnings (SDE). A solo operation doing $200K in revenue with $80K in SDE might be valued between $160K and $400K. The exact multiple depends on repeat customer rate, owner dependence, online reputation, the quality of your financial records, and whether revenue is growing year over year."
      }
    },
    {
      "@type": "Question",
      "name": "What is SDE in business valuation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "SDE stands for Seller's Discretionary Earnings. It is the total financial benefit a single owner-operator takes from the business. SDE equals net profit plus owner salary, owner benefits, one-time or non-recurring expenses, depreciation, and interest. Buyers use SDE to compare businesses on an apples-to-apples basis regardless of how the current owner chooses to pay themselves."
      }
    },
    {
      "@type": "Question",
      "name": "What drives handyman business value up or down?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The biggest value drivers for a handyman business are repeat customer rate (recurring revenue from loyal clients), owner dependence (does the business run without you), online reviews and reputation, revenue growth trajectory, and clean financial records. A business with a 60% repeat customer rate and a manager running daily operations can command a full point higher multiple than a solo owner-operator with no systems."
      }
    },
    {
      "@type": "Question",
      "name": "What multiple do handyman businesses sell for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Handyman businesses typically sell for 2 to 5 times SDE. Smaller solo operations under $200K in revenue average around 2.0 to 2.5x. Established businesses between $200K and $500K average 2.5 to 3.5x. Larger operations above $500K with employees and systems can command 3.5 to 5.0x. These multiples shift based on customer retention, owner involvement, reputation, and growth rate."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="valuation-calc">
    <!-- Financial Inputs -->
    <div class="mb-6">
      <p class="text-sm font-medium text-text-secondary mb-3">Financial Information</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="revenue">Annual Revenue ($)</label>
          <input type="number" id="revenue" value="250000" min="0" step="10000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="netProfit">Net Profit ($)</label>
          <input type="number" id="netProfit" value="45000" min="0" step="5000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="ownerSalary">Owner Salary ($)</label>
          <input type="number" id="ownerSalary" value="65000" min="0" step="5000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="ownerBenefits">Owner Benefits ($)</label>
          <input type="number" id="ownerBenefits" value="12000" min="0" step="1000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          <p class="text-text-muted text-xs mt-1">Health insurance, vehicle, phone, etc.</p>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="oneTime">One-Time / Non-Recurring Expenses ($)</label>
          <input type="number" id="oneTime" value="3000" min="0" step="1000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          <p class="text-text-muted text-xs mt-1">New tools purchase, vehicle repair, etc.</p>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="depreciation">Depreciation ($)</label>
          <input type="number" id="depreciation" value="5000" min="0" step="1000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="interest">Interest ($)</label>
          <input type="number" id="interest" value="2000" min="0" step="500" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </div>

    <!-- Business Factor Inputs -->
    <div class="mb-8">
      <p class="text-sm font-medium text-text-secondary mb-3">Business Factors</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="repeatCustomers">Repeat Customer Rate</label>
          <select id="repeatCustomers" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="-0.5">Under 20% (mostly one-time jobs)</option>
            <option value="0" selected>20 &ndash; 40% repeat</option>
            <option value="0.5">40 &ndash; 60% repeat</option>
            <option value="1.0">60%+ repeat (strong loyalty)</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="ownerDependence">Owner Dependence</label>
          <select id="ownerDependence" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="-0.5">Owner does all the work</option>
            <option value="0" selected>Owner works + manages crew</option>
            <option value="0.5">Manager runs daily ops</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="onlineReviews">Online Reviews / Reputation</label>
          <select id="onlineReviews" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="-0.25">Few reviews or below 4.0 stars</option>
            <option value="0" selected>Moderate (4.0-4.5 stars, 20+ reviews)</option>
            <option value="0.25">Strong (4.5+ stars, 50+ reviews)</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="growthRate">Revenue Growth</label>
          <select id="growthRate" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="-0.25">Declining</option>
            <option value="0" selected>Flat (0-5% YoY)</option>
            <option value="0.25">Growing (5-15% YoY)</option>
            <option value="0.5">Fast growth (15%+ YoY)</option>
          </select>
        </div>
        <div class="md:col-span-2">
          <label class="block text-xs text-text-muted mb-1" for="financialRecords">Financial Records</label>
          <select id="financialRecords" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="-0.5">Cash-heavy / poor records</option>
            <option value="0" selected>Adequate records</option>
            <option value="0.25">Clean books with CPA</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Estimated Business Value</h3>

      <!-- Valuation Range Bar -->
      <div class="bg-bg-dark rounded-xl p-6 mb-6">
        <div class="flex justify-between text-sm text-text-muted mb-2">
          <span>Conservative</span>
          <span>Mid-Range</span>
          <span>Optimistic</span>
        </div>
        <div class="relative w-full h-4 bg-[rgba(255,255,255,0.05)] rounded-full overflow-hidden">
          <div id="range-bar" class="absolute h-full rounded-full transition-all duration-500" style="left: 0%; width: 100%; background: linear-gradient(90deg, #FBBF24, #34D399, #60A5FA);"></div>
        </div>
        <div class="flex justify-between mt-3">
          <span id="result-low" class="font-heading font-extrabold text-lg text-[#FBBF24]">--</span>
          <span id="result-mid" class="font-heading font-extrabold text-2xl text-[#34D399]">--</span>
          <span id="result-high" class="font-heading font-extrabold text-lg text-[#60A5FA]">--</span>
        </div>
      </div>

      <!-- Key Metrics -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">SDE</div>
          <div id="result-sde" class="font-heading font-extrabold text-3xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Adjusted Multiple</div>
          <div id="result-multiple" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Revenue Multiple</div>
          <div id="result-revmultiple" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Base Multiple</div>
          <div id="result-basemultiple" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>

      <!-- Adjustment Factors Breakdown -->
      <div class="bg-bg-dark rounded-xl p-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Multiple Adjustment Factors</h4>
        <div class="space-y-3">
          <div class="flex justify-between items-center text-sm">
            <span class="text-text-secondary">Base Multiple (by revenue)</span>
            <span id="adj-base" class="font-heading font-bold text-text-primary">--</span>
          </div>
          <div class="border-t border-border pt-3 space-y-2">
            <div class="flex justify-between items-center text-sm">
              <span class="text-text-secondary">Repeat Customer Rate</span>
              <span id="adj-repeat" class="font-heading font-bold">--</span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-text-secondary">Owner Dependence</span>
              <span id="adj-owner" class="font-heading font-bold">--</span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-text-secondary">Online Reviews</span>
              <span id="adj-reviews" class="font-heading font-bold">--</span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-text-secondary">Revenue Growth</span>
              <span id="adj-growth" class="font-heading font-bold">--</span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-text-secondary">Financial Records</span>
              <span id="adj-records" class="font-heading font-bold">--</span>
            </div>
          </div>
          <div class="border-t border-border pt-3 flex justify-between items-center text-sm">
            <span class="text-text-primary font-medium">Adjusted Multiple</span>
            <span id="adj-total" class="font-heading font-bold text-accent">--</span>
          </div>
        </div>
      </div>

      <!-- Disclaimer -->
      <div class="mt-6 bg-[rgba(251,191,36,0.1)] border border-[rgba(251,191,36,0.3)] rounded-lg px-4 py-3 text-sm text-[#FDE68A]">
        This is a rough estimate for planning purposes. Actual business valuations vary widely based on market conditions, buyer pool, and deal structure. Consult a business broker for a professional valuation.
      </div>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter your financial numbers.</strong> Pull these from your most recent tax return or profit and loss statement. Use annual figures. Net profit is the bottom line after all expenses, including your salary.</p>
          <p><strong class="text-text-primary">2. Add owner compensation and add-backs.</strong> Include your total salary, benefits (health insurance, vehicle, phone), any one-time expenses that will not recur, depreciation, and interest. These get added back to net profit to calculate SDE.</p>
          <p><strong class="text-text-primary">3. Select your business factors.</strong> Be honest about where your business stands. Each factor shifts the valuation multiple up or down. Repeat customer rate and owner dependence have the largest impact on value.</p>
          <p><strong class="text-text-primary">4. Review the estimated value range.</strong> The calculator shows a conservative, mid-range, and optimistic estimate. Most deals close near the midpoint, but businesses with strong systems and reputation can push toward the high end.</p>
          <p><strong class="text-text-primary">5. Test different scenarios.</strong> Change the inputs to see what drives value. If you are planning to sell in 2-3 years, focus on the factors you can improve: build up repeat customers, reduce owner dependence, collect reviews, and clean up your books.</p>
        </div>
      </section>

      <!-- How It Works -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How Handyman Business Valuation Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">The SDE multiple method is the standard for valuing owner-operated service businesses.</strong> SDE (Seller's Discretionary Earnings) represents the total economic benefit available to a single owner. It starts with net profit and adds back the owner's salary, benefits, one-time expenses, depreciation, and interest.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>SDE = Net_Profit + Owner_Salary + Owner_Benefits + One_Time + Depreciation + Interest</p>
            <p>Base_Multiple = determined by annual revenue bracket</p>
            <p>Adjusted_Multiple = Base_Multiple + Sum(Factor_Adjustments)</p>
            <p>Valuation_Mid = SDE x Adjusted_Multiple</p>
            <p>Valuation_Low = SDE x (Adjusted_Multiple - 0.5)</p>
            <p>Valuation_High = SDE x (Adjusted_Multiple + 0.5)</p>
          </div>
          <p><strong class="text-text-primary">Repeat customers are the biggest value driver.</strong> A handyman business with loyal, returning clients provides predictable revenue that transfers to a new owner. A business with 60%+ repeat customers can see its multiple jump by a full point compared to one relying entirely on one-time calls from lead platforms.</p>
          <p><strong class="text-text-primary">Owner dependence is the biggest value killer.</strong> If you are personally doing all the work, answering every call, and managing every customer, a buyer sees risk. Businesses that run with a crew and systems command higher multiples because the revenue does not walk out the door with the seller.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Thinking of selling.</strong> If you are considering an exit in the next 1-5 years, run your numbers now to get a baseline. Then focus on the adjustable factors: build repeat customer relationships, hire help, collect online reviews, and get your books clean with a CPA.</p>
          <p><strong class="text-text-primary">Buying a handyman business.</strong> Before you make an offer, run the seller's numbers through this calculator. Compare the asking price to the estimated range. If the seller wants more than the high estimate, you need to understand what justifies the premium.</p>
          <p><strong class="text-text-primary">Setting long-term goals.</strong> Even if selling is years away, knowing what your business is worth today helps you make decisions. Should you invest in marketing? Hire an employee? These choices make more sense when you can see their impact on business value.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much is my handyman business worth?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most handyman businesses sell for 2 to 5 times their Seller's Discretionary Earnings (SDE). A solo operation doing $200K in revenue with $80K in SDE might be valued between $160K and $400K. The exact multiple depends on repeat customer rate, owner dependence, online reputation, financial records quality, and growth trajectory.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is SDE in business valuation?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">SDE stands for Seller's Discretionary Earnings. It is the total financial benefit a single owner-operator takes from the business. SDE equals net profit plus owner salary, owner benefits, one-time or non-recurring expenses, depreciation, and interest. Buyers use SDE to compare businesses on an apples-to-apples basis regardless of how the current owner pays themselves.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What drives handyman business value up or down?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">The biggest value drivers are repeat customer rate (recurring revenue from loyal clients), owner dependence (does the business run without you), online reviews and reputation, revenue growth trajectory, and clean financial records. A business with strong repeat clients and a manager running daily operations can command a full point higher multiple than a solo owner-operator.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What multiple do handyman businesses sell for?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Handyman businesses typically sell for 2 to 5 times SDE. Smaller solo operations under $200K in revenue average around 2.0 to 2.5x. Established businesses between $200K and $500K average 2.5 to 3.5x. Larger operations above $500K with employees and systems can command 3.5 to 5.0x.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const revenue = parseFloat((document.getElementById('revenue') as HTMLInputElement).value) || 0;
    const netProfit = parseFloat((document.getElementById('netProfit') as HTMLInputElement).value) || 0;
    const ownerSalary = parseFloat((document.getElementById('ownerSalary') as HTMLInputElement).value) || 0;
    const ownerBenefits = parseFloat((document.getElementById('ownerBenefits') as HTMLInputElement).value) || 0;
    const oneTime = parseFloat((document.getElementById('oneTime') as HTMLInputElement).value) || 0;
    const depreciation = parseFloat((document.getElementById('depreciation') as HTMLInputElement).value) || 0;
    const interest = parseFloat((document.getElementById('interest') as HTMLInputElement).value) || 0;

    const repeatAdj = parseFloat((document.getElementById('repeatCustomers') as HTMLSelectElement).value);
    const ownerAdj = parseFloat((document.getElementById('ownerDependence') as HTMLSelectElement).value);
    const reviewsAdj = parseFloat((document.getElementById('onlineReviews') as HTMLSelectElement).value);
    const growthAdj = parseFloat((document.getElementById('growthRate') as HTMLSelectElement).value);
    const recordsAdj = parseFloat((document.getElementById('financialRecords') as HTMLSelectElement).value);

    // Calculate SDE
    const sde = netProfit + ownerSalary + ownerBenefits + oneTime + depreciation + interest;

    // Determine base multiple by revenue (handyman-specific brackets)
    let baseMultiple: number;
    if (revenue < 200000) {
      baseMultiple = 2.25;
    } else if (revenue < 500000) {
      baseMultiple = 2.75;
    } else if (revenue < 1000000) {
      baseMultiple = 3.25;
    } else {
      baseMultiple = 3.75;
    }

    // Calculate adjusted multiple
    const totalAdjustment = repeatAdj + ownerAdj + reviewsAdj + growthAdj + recordsAdj;
    const adjustedMultiple = Math.max(1.5, baseMultiple + totalAdjustment);

    // Calculate valuations
    const valuationLow = sde * (adjustedMultiple - 0.5);
    const valuationMid = sde * adjustedMultiple;
    const valuationHigh = sde * (adjustedMultiple + 0.5);
    const revenueMultiple = revenue > 0 ? valuationMid / revenue : 0;

    // Format currency
    const fmt = (n: number) => {
      if (n >= 1000000) {
        return '$' + (n / 1000000).toFixed(2) + 'M';
      }
      return '$' + n.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    };

    // Format adjustment value with sign
    const fmtAdj = (val: number): string => {
      if (val > 0) return '+' + val.toFixed(2);
      if (val < 0) return val.toFixed(2);
      return '0.00';
    };

    const colorAdj = (el: HTMLElement, val: number) => {
      el.classList.remove('text-[#34D399]', 'text-[#EF4444]', 'text-text-muted');
      if (val > 0) {
        el.classList.add('text-[#34D399]');
      } else if (val < 0) {
        el.classList.add('text-[#EF4444]');
      } else {
        el.classList.add('text-text-muted');
      }
    };

    // Update valuation range
    document.getElementById('result-low')!.textContent = fmt(valuationLow);
    document.getElementById('result-mid')!.textContent = fmt(valuationMid);
    document.getElementById('result-high')!.textContent = fmt(valuationHigh);

    // Update key metrics
    document.getElementById('result-sde')!.textContent = fmt(sde);
    document.getElementById('result-multiple')!.textContent = adjustedMultiple.toFixed(2) + 'x';
    document.getElementById('result-revmultiple')!.textContent = revenueMultiple.toFixed(2) + 'x';
    document.getElementById('result-basemultiple')!.textContent = baseMultiple.toFixed(2) + 'x';

    // Update adjustment breakdown
    document.getElementById('adj-base')!.textContent = baseMultiple.toFixed(2) + 'x';

    const adjRepeatEl = document.getElementById('adj-repeat')!;
    adjRepeatEl.textContent = fmtAdj(repeatAdj);
    colorAdj(adjRepeatEl, repeatAdj);

    const adjOwnerEl = document.getElementById('adj-owner')!;
    adjOwnerEl.textContent = fmtAdj(ownerAdj);
    colorAdj(adjOwnerEl, ownerAdj);

    const adjReviewsEl = document.getElementById('adj-reviews')!;
    adjReviewsEl.textContent = fmtAdj(reviewsAdj);
    colorAdj(adjReviewsEl, reviewsAdj);

    const adjGrowthEl = document.getElementById('adj-growth')!;
    adjGrowthEl.textContent = fmtAdj(growthAdj);
    colorAdj(adjGrowthEl, growthAdj);

    const adjRecordsEl = document.getElementById('adj-records')!;
    adjRecordsEl.textContent = fmtAdj(recordsAdj);
    colorAdj(adjRecordsEl, recordsAdj);

    document.getElementById('adj-total')!.textContent = adjustedMultiple.toFixed(2) + 'x';
  }

  // Auto-calculate on input change
  document.querySelectorAll('#valuation-calc input, #valuation-calc select').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  // Calculate on load with defaults
  calculate();
</script>
