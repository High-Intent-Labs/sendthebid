---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { gcTools, getToolsByCategory } from '../../data/gcTools';
import { categoryColors } from '../../data/types';

const technical = getToolsByCategory('technical');
const business = getToolsByCategory('business');
const templates = getToolsByCategory('template');
const sales = getToolsByCategory('sales');

const sections = [
  { title: 'Technical Calculators', subtitle: 'Concrete, lumber, framing, and materials estimating', tools: technical, id: 'technical' },
  { title: 'Business & Pricing', subtitle: 'Margins, rates, budgets, and job costing', tools: business, id: 'business' },
  { title: 'Templates & Documents', subtitle: 'Invoices, estimates, change orders, and agreements', tools: templates, id: 'templates' },
  { title: 'Sales Tools', subtitle: 'Customer-facing ROI and valuation calculators', tools: sales, id: 'sales' },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://nailthequote.com/" },
    { "@type": "ListItem", "position": 2, "name": "General Contractor Tools" }
  ]
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Free General Contractor Calculators & Templates",
  "numberOfItems": 24,
  "itemListElement": gcTools.map((tool, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://nailthequote.com/gc/${tool.slug}`,
    "name": tool.name
  }))
};
---

<BaseLayout
  title="Free General Contractor Tools — Calculators, Templates & Pricing | NailTheQuote"
  description="24 free tools for general contractors. Concrete calculators, profit margin tools, invoice generators, and more. Built with real GC terminology and benchmarks."
  currentPath="/gc/"
  schema={[breadcrumbSchema, itemListSchema]}
>
  <!-- Hero -->
  <section class="max-w-[1080px] mx-auto px-6 md:px-12 pt-8 pb-10">
    <nav class="text-sm text-text-muted mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-text-secondary no-underline transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-text-secondary">General Contractor Tools</span>
    </nav>

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
      <div>
        <h1 class="font-heading font-extrabold text-4xl md:text-5xl tracking-tight mb-3">
          General Contractor <span class="text-accent">Tools</span>
        </h1>
        <p class="text-text-secondary text-lg max-w-xl">
          24 free tools built for your trade. Real terminology, real benchmarks, real formulas.
        </p>
      </div>
      <div class="flex gap-2 flex-wrap">
        {sections.map(s => (
          <a href={`#${s.id}`} class="text-xs font-semibold px-3 py-1.5 rounded-full border border-border text-text-secondary hover:border-accent hover:text-accent no-underline transition-all">
            {s.title}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Tool Sections -->
  {sections.map(section => (
    <section id={section.id} class="max-w-[1080px] mx-auto px-6 md:px-12 mb-14 scroll-mt-20">
      <div class="mb-5">
        <h2 class="font-heading font-bold text-2xl">{section.title}</h2>
        <p class="text-text-muted text-sm mt-1">{section.subtitle}</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {section.tools.map(tool => {
          const cc = categoryColors[tool.category];
          return (
            <a href={`/gc/${tool.slug}`} class="bg-bg-card border border-border rounded-xl p-5 no-underline hover:border-[#3A4755] hover:bg-bg-card-hover hover:-translate-y-0.5 transition-all group">
              <div class="flex items-center justify-between mb-3">
                <span class:list={["text-[11px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded", cc.text, cc.bg]}>
                  {cc.label}
                </span>
                <span class="text-text-muted text-xs">{tool.id}</span>
              </div>
              <h3 class="font-heading font-bold text-base text-text-primary mb-1.5 group-hover:text-accent transition-colors">{tool.shortName}</h3>
              <p class="text-text-secondary text-[13px] leading-relaxed">{tool.shortDescription}</p>
            </a>
          );
        })}
      </div>
    </section>
  ))}

  <!-- Bottom CTA -->
  <section class="text-center py-16 border-t border-border max-w-[1080px] mx-auto">
    <p class="text-text-muted text-sm mb-2">All 24 tools are 100% free.</p>
    <p class="text-text-secondary text-base">Pick a tool above and get to work.</p>
  </section>
</BaseLayout>
