---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/paintingTools';

const tool = getToolBySlug('completion-report-template')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should a painting completion report include?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A professional painting completion report should include property and client information, a room-by-room breakdown of surfaces painted, paint products used (brand, color, finish, number of coats), surface preparation details, before and after photos, any issues encountered during the project, a punch list of remaining touch-ups, warranty information, and your company credentials with license number."
      }
    },
    {
      "@type": "Question",
      "name": "Why should painters use a completion report?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A completion report protects you and satisfies the customer. It documents exactly what was done, which paints were used (so the client can touch up later), and creates a written record for warranty claims. It also serves as a professional walk-through document that gets the customer to sign off on the finished work, reducing callbacks and disputes."
      }
    },
    {
      "@type": "Question",
      "name": "What details should be recorded for each room?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For each room or area, record the surfaces painted (walls, ceiling, trim, doors), the paint brand and color code, the finish type (flat, eggshell, satin, semi-gloss, gloss), number of coats applied, any surface prep work done (scraping, sanding, priming, patching), and a condition rating. Note any areas that need monitoring or future attention."
      }
    },
    {
      "@type": "Question",
      "name": "How do I write a professional painting completion report?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start with complete property and client information. List every room or area painted with specific paint details. Rate each area using a standardized scale (Excellent, Good, Needs Touch-Up). Document all surface prep work performed. Include a punch list of any remaining items. Add paint care and maintenance instructions for the client. Always include a signature line for client sign-off and your warranty terms."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="inspection-report-form">

    <!-- Section: Header / Company Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Inspector &amp; Company Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="company-name">Company Name</label>
        <input type="text" id="company-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="inspector-name">Inspector Name</label>
        <input type="text" id="inspector-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="inspector-phone">Phone</label>
        <input type="text" id="inspector-phone" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="license-number">License #</label>
        <input type="text" id="license-number" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="inspection-date">Inspection Date</label>
        <input type="date" id="inspection-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="report-number">Report #</label>
        <input type="text" id="report-number" value="IR-001" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="property-address">Property Address</label>
        <input type="text" id="property-address" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="inspection-reason">Reason for Inspection</label>
        <select id="inspection-reason" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Pre-Purchase">Pre-Purchase</option>
          <option value="Annual Inspection" selected>Annual Inspection</option>
          <option value="Insurance">Insurance</option>
          <option value="Warranty Claim">Warranty Claim</option>
          <option value="Complaint Investigation">Complaint Investigation</option>
        </select>
      </div>
    </div>

    <!-- Section: Project Scope -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Project Scope</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-type">Surface Type</label>
        <select id="equip-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Interior Wall">Interior Wall</option>
          <option value="Exterior Siding">Exterior Siding</option>
          <option value="Ceiling">Ceiling</option>
          <option value="Cabinet">Cabinet</option>
          <option value="Trim Work">Trim Work</option>
          <option value="Deck/Fence">Deck/Fence</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-make">Paint Brand</label>
        <input type="text" id="equip-make" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-model">Color Name</label>
        <input type="text" id="equip-model" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-serial">Color Code</label>
        <input type="text" id="equip-serial" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="install-date">Project Start Date</label>
        <input type="date" id="install-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2">Project Duration</label>
        <div id="equip-age-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="remaining-life">Warranty Period (years)</label>
        <input type="number" id="remaining-life" min="0" max="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="overall-condition">Overall Condition</label>
        <select id="overall-condition" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Excellent">Excellent</option>
          <option value="Good" selected>Good</option>
          <option value="Fair">Fair</option>
          <option value="Poor">Poor</option>
          <option value="Failed">Failed</option>
        </select>
      </div>
    </div>

    <!-- Section: Component Ratings -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Component Ratings</h3>
    <div class="space-y-4 mb-8">
      <!-- Surface Preparation -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Surface Preparation</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="heat-exchanger">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="heat-exchanger"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="heat-exchanger" rows="2" placeholder="Notes..."></textarea>
      </div>
      <!-- Paint System -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Paint System</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="electrical">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="electrical"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="electrical" rows="2" placeholder="Notes..."></textarea>
      </div>
      <!-- Coating System -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Coating Adhesion</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="refrigerant">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="refrigerant"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="refrigerant" rows="2" placeholder="Notes..."></textarea>
      </div>
      <!-- Trim & Detail Work -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Trim &amp; Detail Work</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="ductwork">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="ductwork"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="ductwork" rows="2" placeholder="Notes..."></textarea>
      </div>
      <!-- Color & Finish -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Color &amp; Finish</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="thermostat">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="thermostat"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="thermostat" rows="2" placeholder="Notes..."></textarea>
      </div>
      <!-- Coverage & Uniformity -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Coverage &amp; Uniformity</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="filtration">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="filtration"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="filtration" rows="2" placeholder="Notes..."></textarea>
      </div>
      <!-- Masking & Protection -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Masking &amp; Protection</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="safety">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="safety"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="safety" rows="2" placeholder="Notes..."></textarea>
      </div>
      <!-- Cleanup & Final Inspection -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Cleanup &amp; Final Inspection</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="drainage">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="drainage"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="drainage" rows="2" placeholder="Notes..."></textarea>
      </div>
    </div>

    <!-- Section: Paint Details -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Paint Details</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="paint-brand">Paint Brand</label>
        <input type="text" id="paint-brand" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="paint-color">Color Name / Code</label>
        <input type="text" id="paint-color" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="paint-finish">Finish Type</label>
        <select id="paint-finish" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Flat">Flat</option>
          <option value="Matte">Matte</option>
          <option value="Eggshell" selected>Eggshell</option>
          <option value="Satin">Satin</option>
          <option value="Semi-Gloss">Semi-Gloss</option>
          <option value="Gloss">Gloss</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="num-coats">Number of Coats</label>
        <input type="number" id="num-coats" min="1" max="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="primer-used">Primer Used</label>
        <input type="text" id="primer-used" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" placeholder="Brand and type" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="total-sqft">Total Sq Ft Painted</label>
        <input type="number" id="total-sqft" min="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="gallons-used">Gallons Used</label>
        <input type="number" id="gallons-used" min="0" step="0.5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Findings -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Findings</h3>
    <div class="mb-8">
      <div id="findings-table" class="space-y-3">
        <div class="finding-row bg-bg-dark border border-border rounded-lg p-4">
          <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr_120px_140px_40px] gap-3 items-end">
            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">Description</label>
              <input type="text" class="finding-desc w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">Recommended Action</label>
              <input type="text" class="finding-action w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">Est. Cost ($)</label>
              <input type="number" min="0" step="1" class="finding-cost w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">Priority</label>
              <select class="finding-priority w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
                <option value="Immediate/Safety">Immediate / Safety</option>
                <option value="High">High</option>
                <option value="Medium" selected>Medium</option>
                <option value="Low">Low</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">&nbsp;</label>
              <button type="button" class="remove-finding-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove finding">&times;</button>
            </div>
          </div>
        </div>
      </div>
      <button type="button" id="add-finding-btn" class="mt-3 text-accent hover:text-accent-hover transition-colors cursor-pointer text-sm font-medium">+ Add Finding</button>
    </div>

    <!-- Section: Summary -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Summary</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
      <div class="bg-bg-dark rounded-xl p-5 text-center">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Good Condition</div>
        <div id="summary-good" class="font-heading font-extrabold text-3xl text-green-400">0</div>
      </div>
      <div class="bg-bg-dark rounded-xl p-5 text-center">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Needs Attention</div>
        <div id="summary-attention" class="font-heading font-extrabold text-3xl text-yellow-400">0</div>
      </div>
      <div class="bg-bg-dark rounded-xl p-5 text-center">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Repair Cost</div>
        <div id="summary-cost" class="font-heading font-extrabold text-3xl text-accent">$0</div>
      </div>
      <div class="bg-bg-dark rounded-xl p-5 text-center">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Overall Assessment</div>
        <div id="summary-assessment-display" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="overall-assessment">Overall Assessment</label>
        <select id="overall-assessment" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Pass">Pass</option>
          <option value="Conditional Pass" selected>Conditional Pass</option>
          <option value="Fail">Fail</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="additional-notes">Additional Notes</label>
        <textarea id="additional-notes" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
    </div>

    <!-- Generate Button -->
    <button id="generate-btn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
      Generate Inspection Report &rarr;
    </button>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Template</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Fill in your company and project details.</strong> Enter your company name, license number, and the property address. The report number auto-generates as IR-001 — change it to match your numbering system. Select the project type so the report context is clear from the start.</p>
          <p><strong class="text-text-primary">2. Document each room or area painted.</strong> Record the surfaces completed (walls, ceilings, trim, doors), the paint products used (brand, color name, color code, finish), and the number of coats applied. Rate each area's finish quality and note any areas that need monitoring or touch-up.</p>
          <p><strong class="text-text-primary">3. Record surface prep and document findings.</strong> For each area, note the prep work performed — scraping, sanding, patching, priming, caulking. If you found issues during prep (rot, water damage, mold), add a finding row with a description, recommended action, and priority level. The summary section auto-calculates totals as you go.</p>
          <p><strong class="text-text-primary">4. Generate the printable report.</strong> Select your overall assessment, add any punch list items or maintenance notes for the customer, and hit Generate. The report opens in a new tab with professional formatting, color-coded quality ratings, a findings table, and a signature line — ready to print or save as PDF for the customer walk-through.</p>
        </div>
      </section>

      <!-- What Makes a Professional Report -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Makes a Professional Painting Completion Report</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>A professional completion report does more than list what was painted. Every section serves a specific purpose in communicating the scope of work to the property owner and creating a permanent record of the project.</p>
          <p><strong class="text-text-primary">Paint specifications</strong> are the most valuable part of the report for the customer. Brand, color name, color code, and finish type for every surface means they can touch up years later without guessing. This single detail generates more referrals than anything else you can do — customers remember the painter who left them a complete paint schedule.</p>
          <p><strong class="text-text-primary">Surface preparation details</strong> document the work the customer cannot see. Scraping, sanding, patching, priming, and caulking are what separate a paint job that lasts from one that peels. Recording prep work justifies your pricing and protects you if adhesion issues arise later — you can point to exactly what was done.</p>
          <p><strong class="text-text-primary">Quality ratings</strong> using a standardized scale (Excellent, Good, Needs Touch-Up) give the customer a clear picture of the finished result. Walk through each area together, agree on the rating, and note any items for the punch list. This structured approach eliminates ambiguity during the final walk-through.</p>
          <p><strong class="text-text-primary">Punch list items</strong> show professionalism and honesty. Every paint job has small touch-ups. Documenting them proactively — rather than waiting for the customer to find them — builds trust and sets the expectation that you will come back to finish the details.</p>
          <p><strong class="text-text-primary">Documentation matters</strong> because completion reports become reference documents. They protect you from warranty disputes, help property managers track maintenance history, and give real estate agents confidence when selling a recently painted home. A thorough report separates professional painters from handyman-level work.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">End of every project.</strong> Use this template at the completion of every painting job, no matter the size. A completion report turns a finished project into a professional deliverable. The customer walk-through becomes structured and efficient, and you leave behind a document that markets your business every time the homeowner opens a drawer looking for their paint colors.</p>
          <p><strong class="text-text-primary">Commercial and property management work.</strong> Property managers require documentation for every service performed on their properties. A completion report with room-by-room paint specs, prep details, and before/after ratings gives them exactly what they need for their records. This level of documentation is often the difference between getting a single job and landing an ongoing contract.</p>
          <p><strong class="text-text-primary">Warranty and callback protection.</strong> When a customer calls six months later about peeling paint, your completion report documents exactly what prep was done, what products were used, and what the surface condition was at completion. This protects you from claims related to substrate failure, moisture problems, or other issues outside your control.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should a painting completion report include?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A professional painting completion report should include property and client information, a room-by-room breakdown of surfaces painted, paint products used (brand, color, finish, number of coats), surface preparation details, any issues encountered during the project, a punch list of remaining touch-ups, warranty information, and your company credentials with license number.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why should painters use a completion report?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A completion report protects you and satisfies the customer. It documents exactly what was done, which paints were used (so the client can touch up later), and creates a written record for warranty claims. It also serves as a professional walk-through document that gets the customer to sign off on the finished work, reducing callbacks and disputes.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What details should be recorded for each room?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">For each room or area, record the surfaces painted (walls, ceiling, trim, doors), the paint brand and color code, the finish type (flat, eggshell, satin, semi-gloss, gloss), number of coats applied, any surface prep work done (scraping, sanding, priming, patching), and a condition rating. Note any areas that need monitoring or future attention.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I write a professional painting completion report?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Start with complete property and client information. List every room or area painted with specific paint details. Rate each area using a standardized scale (Excellent, Good, Needs Touch-Up). Document all surface prep work performed. Include a punch list of any remaining items. Add paint care and maintenance instructions for the client. Always include a signature line for client sign-off and your warranty terms.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // --- Default date ---
  const now = new Date();
  const dateInput = document.getElementById('inspection-date') as HTMLInputElement;
  if (dateInput && !dateInput.value) {
    dateInput.value = now.toISOString().slice(0, 10);
  }

  // --- Equipment Age auto-calculation ---
  function updateEquipAge() {
    const installDate = (document.getElementById('install-date') as HTMLInputElement).value;
    const display = document.getElementById('equip-age-display')!;
    if (installDate) {
      const install = new Date(installDate);
      const today = new Date();
      let years = today.getFullYear() - install.getFullYear();
      const monthDiff = today.getMonth() - install.getMonth();
      if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < install.getDate())) {
        years--;
      }
      display.textContent = years + (years === 1 ? ' year' : ' years');
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-primary';
    } else {
      display.textContent = '\u2014';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted';
    }
  }
  document.getElementById('install-date')?.addEventListener('input', updateEquipAge);

  // --- Overall Condition color coding ---
  function updateConditionColor() {
    const select = document.getElementById('overall-condition') as HTMLSelectElement;
    const val = select.value;
    select.classList.remove('text-green-400', 'text-yellow-400', 'text-red-400', 'text-text-primary');
    if (val === 'Excellent' || val === 'Good') {
      select.classList.add('text-green-400');
    } else if (val === 'Fair') {
      select.classList.add('text-yellow-400');
    } else if (val === 'Poor' || val === 'Failed') {
      select.classList.add('text-red-400');
    }
  }
  document.getElementById('overall-condition')?.addEventListener('change', updateConditionColor);
  updateConditionColor();

  // --- Component Rating color indicators ---
  function updateRatingIndicators() {
    document.querySelectorAll('.component-rating').forEach(sel => {
      const select = sel as HTMLSelectElement;
      const component = select.dataset.component;
      const indicator = document.querySelector(`.rating-indicator[data-for="${component}"]`) as HTMLElement;
      if (!indicator) return;
      indicator.classList.remove('bg-green-500', 'bg-yellow-500', 'bg-red-500');
      if (select.value === 'Pass') {
        indicator.classList.add('bg-green-500');
      } else if (select.value === 'Monitor') {
        indicator.classList.add('bg-yellow-500');
      } else {
        indicator.classList.add('bg-red-500');
      }
    });
    updateSummary();
  }
  document.querySelectorAll('.component-rating').forEach(el => {
    el.addEventListener('change', updateRatingIndicators);
  });

  // No HVAC-specific temperature or CO calculations needed for painting completion reports

  // --- Dynamic Findings Table ---
  function addFindingRow() {
    const table = document.getElementById('findings-table')!;
    const row = document.createElement('div');
    row.className = 'finding-row bg-bg-dark border border-border rounded-lg p-4';
    row.innerHTML = `
      <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr_120px_140px_40px] gap-3 items-end">
        <div>
          <input type="text" class="finding-desc w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <input type="text" class="finding-action w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <input type="number" min="0" step="1" class="finding-cost w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <select class="finding-priority w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="Immediate/Safety">Immediate / Safety</option>
            <option value="High">High</option>
            <option value="Medium" selected>Medium</option>
            <option value="Low">Low</option>
          </select>
        </div>
        <div>
          <button type="button" class="remove-finding-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove finding">&times;</button>
        </div>
      </div>
    `;
    table.appendChild(row);
    attachFindingListeners();
  }

  document.getElementById('add-finding-btn')?.addEventListener('click', addFindingRow);

  document.getElementById('findings-table')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('remove-finding-btn')) {
      const row = target.closest('.finding-row');
      const allRows = document.querySelectorAll('.finding-row');
      if (allRows.length > 1 && row) {
        row.remove();
        updateSummary();
      }
    }
  });

  function attachFindingListeners() {
    document.querySelectorAll('.finding-cost').forEach(el => {
      el.removeEventListener('input', updateSummary);
      el.addEventListener('input', updateSummary);
    });
  }
  attachFindingListeners();

  // --- Summary auto-calculation ---
  function updateSummary() {
    // Count component ratings
    let good = 0;
    let attention = 0;
    document.querySelectorAll('.component-rating').forEach(sel => {
      const val = (sel as HTMLSelectElement).value;
      if (val === 'Pass') good++;
      else attention++;
    });
    document.getElementById('summary-good')!.textContent = String(good);
    document.getElementById('summary-attention')!.textContent = String(attention);

    // Sum finding costs
    let totalCost = 0;
    document.querySelectorAll('.finding-cost').forEach(el => {
      const val = parseFloat((el as HTMLInputElement).value);
      if (!isNaN(val)) totalCost += val;
    });
    document.getElementById('summary-cost')!.textContent = '$' + totalCost.toLocaleString();

    // Overall assessment display
    const assessment = (document.getElementById('overall-assessment') as HTMLSelectElement).value;
    const assessDisplay = document.getElementById('summary-assessment-display')!;
    assessDisplay.textContent = assessment;
    assessDisplay.classList.remove('text-green-400', 'text-yellow-400', 'text-red-400', 'text-text-primary');
    if (assessment === 'Pass') {
      assessDisplay.classList.add('text-green-400');
    } else if (assessment === 'Conditional Pass') {
      assessDisplay.classList.add('text-yellow-400');
    } else {
      assessDisplay.classList.add('text-red-400');
    }
  }
  document.getElementById('overall-assessment')?.addEventListener('change', updateSummary);
  updateSummary();

  // --- Helper ---
  function getVal(id: string): string {
    const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
    return el ? el.value : '';
  }

  // --- Generate Inspection Report ---
  function generateReport() {
    // Collect component ratings
    const components = [
      { key: 'heat-exchanger', label: 'Surface Preparation' },
      { key: 'electrical', label: 'Paint System' },
      { key: 'refrigerant', label: 'Coating Adhesion' },
      { key: 'ductwork', label: 'Trim & Detail Work' },
      { key: 'thermostat', label: 'Color & Finish' },
      { key: 'filtration', label: 'Coverage & Uniformity' },
      { key: 'safety', label: 'Masking & Protection' },
      { key: 'drainage', label: 'Cleanup & Final Inspection' },
    ];

    let ratingsHtml = '';
    let greenCount = 0;
    let yellowCount = 0;
    let redCount = 0;
    components.forEach(comp => {
      const rating = (document.querySelector(`.component-rating[data-component="${comp.key}"]`) as HTMLSelectElement)?.value || 'Pass';
      const notes = (document.querySelector(`.component-notes[data-component="${comp.key}"]`) as HTMLTextAreaElement)?.value || '';
      let color = '#16a34a';
      let bg = '#dcfce7';
      let label = 'PASS';
      if (rating === 'Monitor') {
        color = '#ca8a04'; bg = '#fef9c3'; label = 'MONITOR'; yellowCount++;
      } else if (rating === 'Fail') {
        color = '#dc2626'; bg = '#fee2e2'; label = 'FAIL'; redCount++;
      } else {
        greenCount++;
      }
      ratingsHtml += `<tr>
        <td style="border:1px solid #ddd;padding:8px 12px;font-weight:600;">${comp.label}</td>
        <td style="border:1px solid #ddd;padding:8px 12px;text-align:center;"><span style="display:inline-block;padding:2px 12px;border-radius:4px;background:${bg};color:${color};font-weight:700;font-size:12px;text-transform:uppercase;">${label}</span></td>
        <td style="border:1px solid #ddd;padding:8px 12px;font-size:13px;color:#555;">${notes || '\u2014'}</td>
      </tr>`;
    });

    // Equipment age
    const installDate = getVal('install-date');
    let equipAge = '\u2014';
    if (installDate) {
      const install = new Date(installDate);
      const today = new Date();
      let years = today.getFullYear() - install.getFullYear();
      const md = today.getMonth() - install.getMonth();
      if (md < 0 || (md === 0 && today.getDate() < install.getDate())) years--;
      equipAge = years + (years === 1 ? ' year' : ' years');
    }

    // Paint details for report (no HVAC measurements)

    // Findings
    const findingRows = document.querySelectorAll('.finding-row');
    let findingsHtml = '';
    let totalCost = 0;
    findingRows.forEach(row => {
      const desc = (row.querySelector('.finding-desc') as HTMLInputElement)?.value || '';
      const action = (row.querySelector('.finding-action') as HTMLInputElement)?.value || '';
      const cost = parseFloat((row.querySelector('.finding-cost') as HTMLInputElement)?.value) || 0;
      const priority = (row.querySelector('.finding-priority') as HTMLSelectElement)?.value || 'Medium';
      if (desc || action) {
        totalCost += cost;
        let priBg = '#e0f2e9'; let priColor = '#166534';
        if (priority === 'Immediate/Safety') { priBg = '#fee2e2'; priColor = '#991b1b'; }
        else if (priority === 'High') { priBg = '#fef3c7'; priColor = '#92400e'; }
        else if (priority === 'Medium') { priBg = '#dbeafe'; priColor = '#1e40af'; }
        findingsHtml += `<tr>
          <td style="border:1px solid #ddd;padding:8px 12px;">${desc}</td>
          <td style="border:1px solid #ddd;padding:8px 12px;">${action}</td>
          <td style="border:1px solid #ddd;padding:8px 12px;text-align:right;">$${cost.toLocaleString()}</td>
          <td style="border:1px solid #ddd;padding:8px 12px;text-align:center;"><span style="display:inline-block;padding:2px 10px;border-radius:4px;background:${priBg};color:${priColor};font-weight:600;font-size:11px;text-transform:uppercase;">${priority}</span></td>
        </tr>`;
      }
    });

    // Overall condition color
    const condition = getVal('overall-condition');
    let condColor = '#16a34a';
    if (condition === 'Fair') condColor = '#ca8a04';
    else if (condition === 'Poor' || condition === 'Failed') condColor = '#dc2626';

    // Overall assessment color
    const assessment = getVal('overall-assessment');
    let assessColor = '#16a34a';
    let assessBg = '#dcfce7';
    if (assessment === 'Conditional Pass') { assessColor = '#ca8a04'; assessBg = '#fef9c3'; }
    else if (assessment === 'Fail') { assessColor = '#dc2626'; assessBg = '#fee2e2'; }

    const html = `<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Painting Completion Report ${getVal('report-number')}</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
