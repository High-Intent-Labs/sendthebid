---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/gcTools';

const tool = getToolBySlug('invoice-generator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should be included on a general contractor invoice?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A professional GC invoice should include your company name, address, phone, and contractor license number. It should list the customer name, project address, project type, and permit number if applicable. Itemize all labor, materials, subcontractor charges, and any markups. Include payment terms, warranty language, and the invoice date and number."
      }
    },
    {
      "@type": "Question",
      "name": "How do I create a professional contractor invoice?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Use a contractor-specific invoice generator that includes fields for project details, permit numbers, and itemized line items for labor, materials, and subcontractor work. Fill in your company details, customer and project info, add each charge as a separate line item with quantities and prices, set your tax rate and payment terms, and generate a PDF."
      }
    },
    {
      "@type": "Question",
      "name": "Should a general contractor charge tax on labor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tax rules vary by state and municipality. In most states, materials are taxable but labor is not when billed separately. However, some states tax the entire invoice including labor when it is part of a construction contract. Check your state department of revenue guidelines or consult your accountant."
      }
    },
    {
      "@type": "Question",
      "name": "What payment terms are standard for general contractors?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For smaller projects under $10,000, Due on Completion or Net 15 is common. For larger remodeling and renovation projects, most GCs use a progress payment schedule: 30-50% deposit, progress payments at milestones, and a final payment on completion. Commercial work typically uses Net 30."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="invoice-gen">
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Company Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="companyName">Company Name</label>
        <input type="text" id="companyName" placeholder="Your Construction Company" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="companyPhone">Phone</label>
        <input type="text" id="companyPhone" placeholder="(555) 123-4567" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="companyEmail">Email</label>
        <input type="text" id="companyEmail" placeholder="office@yourcompany.com" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="licenseNum">GC License #</label>
        <input type="text" id="licenseNum" placeholder="GC-123456" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="invoiceNum">Invoice #</label>
        <input type="text" id="invoiceNum" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-2" for="invoiceDate">Invoice Date</label>
          <input type="date" id="invoiceDate" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-2" for="dueDate">Due Date</label>
          <input type="date" id="dueDate" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Customer Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customerName">Customer Name</label>
        <input type="text" id="customerName" placeholder="John Smith" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customerPhone">Customer Phone</label>
        <input type="text" id="customerPhone" placeholder="(555) 987-6543" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customerAddress">Customer Address</label>
        <input type="text" id="customerAddress" placeholder="123 Main St, Anytown, ST 12345" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Project Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="projectType">Project Type</label>
        <select id="projectType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Kitchen Remodel">Kitchen Remodel</option>
          <option value="Bathroom Remodel">Bathroom Remodel</option>
          <option value="Room Addition">Room Addition</option>
          <option value="Whole-House Renovation">Whole-House Renovation</option>
          <option value="Deck / Patio">Deck / Patio</option>
          <option value="Basement Finish">Basement Finish</option>
          <option value="Siding / Exterior">Siding / Exterior</option>
          <option value="Roofing">Roofing</option>
          <option value="New Construction">New Construction</option>
          <option value="Commercial Buildout">Commercial Buildout</option>
          <option value="Other">Other</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="permitNum">Permit #</label>
        <input type="text" id="permitNum" placeholder="BP-2024-12345" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="projectAddress">Project Address (if different)</label>
        <input type="text" id="projectAddress" placeholder="456 Oak Ave, Anytown, ST 12345" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Line Items</h3>
    <div class="mb-3">
      <div class="hidden md:grid grid-cols-[1fr_80px_120px_120px_40px] gap-3 mb-2 px-1">
        <span class="text-text-muted text-xs font-medium uppercase tracking-wider">Description</span>
        <span class="text-text-muted text-xs font-medium uppercase tracking-wider">Qty</span>
        <span class="text-text-muted text-xs font-medium uppercase tracking-wider">Unit Price</span>
        <span class="text-text-muted text-xs font-medium uppercase tracking-wider">Total</span>
        <span></span>
      </div>
      <div id="line-items" class="space-y-3"></div>
    </div>
    <div class="flex flex-wrap gap-3 mb-8">
      <button id="add-line-btn" class="bg-bg-dark border border-border text-text-primary text-sm font-medium px-4 py-2 rounded-lg hover:border-accent hover:text-accent transition-colors cursor-pointer">+ Add Line Item</button>
      <span class="text-text-muted text-xs self-center">Quick add:</span>
      <button data-quick="Demolition" data-price="0" class="quick-add-btn bg-bg-dark border border-border text-text-secondary text-xs px-3 py-2 rounded-lg hover:border-accent hover:text-accent transition-colors cursor-pointer">Demolition</button>
      <button data-quick="Framing Labor" data-price="0" class="quick-add-btn bg-bg-dark border border-border text-text-secondary text-xs px-3 py-2 rounded-lg hover:border-accent hover:text-accent transition-colors cursor-pointer">Framing</button>
      <button data-quick="Drywall Install &amp; Finish" data-price="0" class="quick-add-btn bg-bg-dark border border-border text-text-secondary text-xs px-3 py-2 rounded-lg hover:border-accent hover:text-accent transition-colors cursor-pointer">Drywall</button>
      <button data-quick="Lumber &amp; Materials" data-price="0" class="quick-add-btn bg-bg-dark border border-border text-text-secondary text-xs px-3 py-2 rounded-lg hover:border-accent hover:text-accent transition-colors cursor-pointer">Lumber</button>
      <button data-quick="Permit Fee" data-price="0" class="quick-add-btn bg-bg-dark border border-border text-text-secondary text-xs px-3 py-2 rounded-lg hover:border-accent hover:text-accent transition-colors cursor-pointer">Permit Fee</button>
      <button data-quick="Sub - Electrical" data-price="0" class="quick-add-btn bg-bg-dark border border-border text-text-secondary text-xs px-3 py-2 rounded-lg hover:border-accent hover:text-accent transition-colors cursor-pointer">Sub - Electrical</button>
      <button data-quick="Sub - Plumbing" data-price="0" class="quick-add-btn bg-bg-dark border border-border text-text-secondary text-xs px-3 py-2 rounded-lg hover:border-accent hover:text-accent transition-colors cursor-pointer">Sub - Plumbing</button>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Invoice Settings</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="taxRate">Tax Rate (%)</label>
        <input type="number" id="taxRate" value="0" min="0" max="20" step="0.1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="paymentTerms">Payment Terms</label>
        <select id="paymentTerms" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Due on Completion">Due on Completion</option>
          <option value="Net 15">Net 15</option>
          <option value="Net 30" selected>Net 30</option>
          <option value="50% Deposit / 50% on Completion">50/50 Split</option>
          <option value="Progress Billing">Progress Billing</option>
        </select>
      </div>
      <div></div>
      <div class="md:col-span-3">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="notes">Notes / Warranty</label>
        <textarea id="notes" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">1-year workmanship warranty on all labor. Materials covered by manufacturer warranty. All work per approved plans and local building code.</textarea>
      </div>
    </div>

    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Invoice Totals</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Subtotal</div>
          <div id="result-subtotal" class="font-heading font-extrabold text-3xl text-text-primary">$0.00</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Tax</div>
          <div id="result-tax" class="font-heading font-extrabold text-3xl text-text-primary">$0.00</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Due</div>
          <div id="result-total" class="font-heading font-extrabold text-3xl text-accent">$0.00</div>
        </div>
      </div>
      <button id="generate-pdf-btn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">Generate PDF &rarr;</button>
      <p class="text-text-muted text-sm italic mt-3">Opens a print-ready invoice in a new window. Use your browser's print dialog to save as PDF.</p>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Generator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter your company details.</strong> Fill in your company name, phone, email, and GC license number. These appear in the invoice header and build credibility with clients.</p>
          <p><strong class="text-text-primary">2. Add customer and project info.</strong> Enter the client name, address, and phone. Then fill in the project type, permit number, and project address so the invoice ties directly to the job.</p>
          <p><strong class="text-text-primary">3. Build your line items.</strong> Add each charge as a separate line item: labor, materials, subcontractor costs, permit fees, and any markups. Use the quick-add buttons for common GC line items, or add custom entries.</p>
          <p><strong class="text-text-primary">4. Set tax and payment terms.</strong> Enter your local tax rate, choose payment terms, and add warranty language or project notes in the notes field.</p>
          <p><strong class="text-text-primary">5. Generate the PDF.</strong> Click "Generate PDF" to open a clean, print-ready invoice. Use your browser's print function to save as PDF.</p>
        </div>
      </section>
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Makes a Professional Contractor Invoice</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>A professional contractor invoice documents the work performed, protects both parties, and supports your lien rights in many states. Include your company name, GC license number, and full contact information at the top.</p>
          <p>The project section separates a contractor invoice from a generic template. Recording the project type, address, and permit number creates a paper trail for inspections, warranty claims, and potential disputes.</p>
          <p>Itemized line items with clear descriptions prevent payment disputes. Break work into demolition, framing, plumbing rough-in, tile, fixtures, and so on. Clients respect transparency, and it makes change orders easier to justify.</p>
          <p>Warranty terms on the invoice are legally important. A common setup is a 1-year workmanship warranty with materials covered by manufacturer warranties.</p>
        </div>
      </section>
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Progress billing on active projects.</strong> Send invoices at each milestone: after demo, after framing, after rough-ins pass inspection, and at completion. This tool generates a professional invoice in minutes.</p>
          <p><strong class="text-text-primary">Small projects and handyman work.</strong> For jobs under $5,000, this invoice serves as both the bill and the record. Fill in the project details, itemize the work, and hand the client a clean document.</p>
          <p><strong class="text-text-primary">Backup when your system is down.</strong> If your project management software crashes or internet goes out on a job site, this tool works in your browser. Generate a clean invoice, save the PDF, and enter it into your system later.</p>
        </div>
      </section>
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should be included on a general contractor invoice?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A professional GC invoice should include your company name, address, phone, and contractor license number. It should list the customer name, project address, project type, and permit number. Itemize all labor, materials, subcontractor charges, and any markups. Include payment terms, warranty language, and the invoice date and number.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I create a professional contractor invoice?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Use a contractor-specific invoice generator with fields for project details, permit numbers, and itemized line items. Fill in your company details, customer and project info, add each charge as a line item, set tax rate and payment terms, and generate a PDF.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should a general contractor charge tax on labor?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Tax rules vary by state. In most states, materials are taxable but labor is not when billed separately. Some states tax the entire invoice when labor is part of a construction contract. Check your state department of revenue guidelines or consult your accountant.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What payment terms are standard for general contractors?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">For projects under $10,000, Due on Completion or Net 15 is common. For larger projects, most GCs use progress payments: 30-50% deposit, payments at milestones, and final payment on completion. Commercial work typically uses Net 30.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function initDefaults() {
    const today = new Date();
    const todayStr = today.toISOString().split('T')[0];
    const due = new Date(today);
    due.setDate(due.getDate() + 30);
    const dueStr = due.toISOString().split('T')[0];
    (document.getElementById('invoiceDate') as HTMLInputElement).value = todayStr;
    (document.getElementById('dueDate') as HTMLInputElement).value = dueStr;
    (document.getElementById('invoiceNum') as HTMLInputElement).value = 'INV-' + String(Math.floor(Math.random() * 9000) + 1000);
  }

  interface LineItem { id: number; description: string; qty: number; price: number; }
  let lineItems: LineItem[] = [{ id: 1, description: '', qty: 1, price: 0 }];
  let nextId = 2;

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function renderLineItems() {
    const container = document.getElementById('line-items')!;
    container.innerHTML = '';
    lineItems.forEach((item) => {
      const row = document.createElement('div');
      row.className = 'grid grid-cols-1 md:grid-cols-[1fr_80px_120px_120px_40px] gap-3 items-center bg-bg-dark rounded-lg p-3 md:p-0 md:bg-transparent md:rounded-none';
      const total = (item.qty * item.price).toFixed(2);
      row.innerHTML = `
        <div><label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Description</label><input type="text" data-id="${item.id}" data-field="description" value="${escapeHtml(item.description)}" placeholder="Description" class="line-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" /></div>
        <div><label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Qty</label><input type="number" data-id="${item.id}" data-field="qty" value="${item.qty}" min="1" class="line-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2 text-text-primary text-sm text-center focus:border-accent focus:outline-none transition-colors" /></div>
        <div><label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Unit Price</label><input type="number" data-id="${item.id}" data-field="price" value="${item.price}" min="0" step="0.01" class="line-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2 text-text-primary text-sm text-right focus:border-accent focus:outline-none transition-colors" /></div>
        <div><label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Total</label><div class="text-text-primary text-sm font-medium text-right px-3 py-2">$${total}</div></div>
        <div class="flex justify-end">${lineItems.length > 1 ? `<button data-remove="${item.id}" class="remove-line-btn text-text-muted hover:text-red-400 transition-colors cursor-pointer text-lg leading-none" title="Remove">&times;</button>` : '<span></span>'}</div>`;
      container.appendChild(row);
    });
    container.querySelectorAll('.line-input').forEach(input => { input.addEventListener('input', handleLineInput); });
    container.querySelectorAll('.remove-line-btn').forEach(btn => { btn.addEventListener('click', handleRemoveLine); });
    recalculate();
  }

  function handleLineInput(e: Event) {
    const input = e.target as HTMLInputElement;
    const id = parseInt(input.dataset.id!);
    const field = input.dataset.field!;
    const item = lineItems.find(i => i.id === id);
    if (!item) return;
    if (field === 'description') item.description = input.value;
    else if (field === 'qty') item.qty = parseFloat(input.value) || 0;
    else if (field === 'price') item.price = parseFloat(input.value) || 0;
    const row = input.closest('.grid')!;
    const totalEl = row.querySelector('div:nth-child(4) div') as HTMLElement;
    if (totalEl) totalEl.textContent = '$' + (item.qty * item.price).toFixed(2);
    recalculate();
  }

  function handleRemoveLine(e: Event) {
    const btn = e.currentTarget as HTMLElement;
    const id = parseInt(btn.dataset.remove!);
    lineItems = lineItems.filter(i => i.id !== id);
    renderLineItems();
  }

  function addLineItem(description = '', price = 0) {
    lineItems.push({ id: nextId++, description, qty: 1, price });
    renderLineItems();
  }

  function recalculate() {
    const subtotal = lineItems.reduce((sum, item) => sum + (item.qty * item.price), 0);
    const taxRate = parseFloat((document.getElementById('taxRate') as HTMLInputElement).value) || 0;
    const tax = subtotal * (taxRate / 100);
    const total = subtotal + tax;
    document.getElementById('result-subtotal')!.textContent = '$' + subtotal.toFixed(2);
    document.getElementById('result-tax')!.textContent = '$' + tax.toFixed(2);
    document.getElementById('result-total')!.textContent = '$' + total.toFixed(2);
  }

  function generatePDF() {
    const companyName = (document.getElementById('companyName') as HTMLInputElement).value || 'Construction Company';
    const companyPhone = (document.getElementById('companyPhone') as HTMLInputElement).value;
    const companyEmail = (document.getElementById('companyEmail') as HTMLInputElement).value;
    const licenseNum = (document.getElementById('licenseNum') as HTMLInputElement).value;
    const invoiceNum = (document.getElementById('invoiceNum') as HTMLInputElement).value;
    const invoiceDate = (document.getElementById('invoiceDate') as HTMLInputElement).value;
    const dueDate = (document.getElementById('dueDate') as HTMLInputElement).value;
    const customerName = (document.getElementById('customerName') as HTMLInputElement).value || 'Customer';
    const customerAddress = (document.getElementById('customerAddress') as HTMLInputElement).value;
    const customerPhone = (document.getElementById('customerPhone') as HTMLInputElement).value;
    const projectType = (document.getElementById('projectType') as HTMLSelectElement).value;
    const permitNum = (document.getElementById('permitNum') as HTMLInputElement).value;
    const projectAddress = (document.getElementById('projectAddress') as HTMLInputElement).value;
    const taxRate = parseFloat((document.getElementById('taxRate') as HTMLInputElement).value) || 0;
    const paymentTerms = (document.getElementById('paymentTerms') as HTMLSelectElement).value;
    const notes = (document.getElementById('notes') as HTMLTextAreaElement).value;
    const subtotal = lineItems.reduce((sum, item) => sum + (item.qty * item.price), 0);
    const tax = subtotal * (taxRate / 100);
    const total = subtotal + tax;

    function formatDate(dateStr: string): string {
      if (!dateStr) return '';
      const d = new Date(dateStr + 'T00:00:00');
      return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    }

    const lineItemsHtml = lineItems.filter(item => item.description || item.price > 0).map(item => `<tr><td style="padding:10px 12px;border-bottom:1px solid #eee;text-align:left;">${escapeHtml(item.description)}</td><td style="padding:10px 12px;border-bottom:1px solid #eee;text-align:center;">${item.qty}</td><td style="padding:10px 12px;border-bottom:1px solid #eee;text-align:right;">$${item.price.toFixed(2)}</td><td style="padding:10px 12px;border-bottom:1px solid #eee;text-align:right;font-weight:600;">$${(item.qty * item.price).toFixed(2)}</td></tr>`).join('');

    const projectInfoHtml = (projectType || permitNum || projectAddress) ? `<div style="margin-bottom:30px;padding:15px;background:#f8f9fa;border-radius:6px;"><div style="font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:0.05em;color:#666;margin-bottom:8px;">Project Information</div><div style="display:flex;flex-wrap:wrap;gap:20px;font-size:14px;color:#333;">${projectType ? `<div><span style="color:#888;">Type:</span> ${escapeHtml(projectType)}</div>` : ''}${permitNum ? `<div><span style="color:#888;">Permit #:</span> ${escapeHtml(permitNum)}</div>` : ''}${projectAddress ? `<div><span style="color:#888;">Job Site:</span> ${escapeHtml(projectAddress)}</div>` : ''}</div></div>` : '';

    const html = `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><title>Invoice ${escapeHtml(invoiceNum)}</title><style>@media print{body{margin:0}.no-print{display:none}}*{box-sizing:border-box;margin:0;padding:0}body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:#333;background:#fff;padding:40px;max-width:800px;margin:0 auto}</style></head><body><div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:40px;padding-bottom:20px;border-bottom:3px solid #333;"><div><div style="font-size:28px;font-weight:800;color:#111;margin-bottom:4px;">${escapeHtml(companyName)}</div>${companyPhone ? `<div style="font-size:14px;color:#555;">${escapeHtml(companyPhone)}</div>` : ''}${companyEmail ? `<div style="font-size:14px;color:#555;">${escapeHtml(companyEmail)}</div>` : ''}${licenseNum ? `<div style="font-size:13px;color:#888;margin-top:4px;">GC License: ${escapeHtml(licenseNum)}</div>` : ''}</div><div style="text-align:right;"><div style="font-size:36px;font-weight:800;color:#111;letter-spacing:0.04em;">INVOICE</div><div style="font-size:14px;color:#555;margin-top:4px;">${escapeHtml(invoiceNum)}</div></div></div><div style="display:flex;justify-content:space-between;margin-bottom:30px;"><div><div style="font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:0.05em;color:#888;margin-bottom:6px;">Bill To</div><div style="font-size:16px;font-weight:600;color:#111;">${escapeHtml(customerName)}</div>${customerAddress ? `<div style="font-size:14px;color:#555;margin-top:2px;">${escapeHtml(customerAddress)}</div>` : ''}${customerPhone ? `<div style="font-size:14px;color:#555;margin-top:2px;">${escapeHtml(customerPhone)}</div>` : ''}</div><div style="text-align:right;"><div style="font-size:14px;color:#555;margin-bottom:4px;"><span style="color:#888;">Date:</span> ${formatDate(invoiceDate)}</div><div style="font-size:14px;color:#555;margin-bottom:4px;"><span style="color:#888;">Due:</span> ${formatDate(dueDate)}</div><div style="font-size:14px;color:#555;"><span style="color:#888;">Terms:</span> ${escapeHtml(paymentTerms)}</div></div></div>${projectInfoHtml}<table style="width:100%;border-collapse:collapse;margin-bottom:30px;"><thead><tr style="background:#333;color:#fff;"><th style="padding:12px;text-align:left;font-size:12px;text-transform:uppercase;letter-spacing:0.05em;font-weight:600;">Description</th><th style="padding:12px;text-align:center;font-size:12px;text-transform:uppercase;letter-spacing:0.05em;font-weight:600;width:70px;">Qty</th><th style="padding:12px;text-align:right;font-size:12px;text-transform:uppercase;letter-spacing:0.05em;font-weight:600;width:110px;">Unit Price</th><th style="padding:12px;text-align:right;font-size:12px;text-transform:uppercase;letter-spacing:0.05em;font-weight:600;width:110px;">Total</th></tr></thead><tbody>${lineItemsHtml}</tbody></table><div style="display:flex;justify-content:flex-end;margin-bottom:40px;"><div style="width:280px;"><div style="display:flex;justify-content:space-between;padding:8px 0;font-size:14px;color:#555;"><span>Subtotal</span><span>$${subtotal.toFixed(2)}</span></div>${taxRate > 0 ? `<div style="display:flex;justify-content:space-between;padding:8px 0;font-size:14px;color:#555;border-bottom:1px solid #eee;"><span>Tax (${taxRate}%)</span><span>$${tax.toFixed(2)}</span></div>` : ''}<div style="display:flex;justify-content:space-between;padding:12px 0;font-size:20px;font-weight:800;color:#111;border-top:2px solid #333;"><span>Total Due</span><span>$${total.toFixed(2)}</span></div></div></div>${notes ? `<div style="padding:20px;background:#f8f9fa;border-radius:6px;border-left:4px solid #333;"><div style="font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:0.05em;color:#888;margin-bottom:6px;">Notes & Warranty</div><div style="font-size:13px;color:#555;line-height:1.6;white-space:pre-wrap;">${escapeHtml(notes)}</div></div>` : ''}<div style="text-align:center;margin-top:50px;padding-top:20px;border-top:1px solid #eee;font-size:12px;color:#aaa;">Thank you for your business.</div><script>window.onload=function(){window.print();}<\/script></body></html>`;

    const printWindow = window.open('', '_blank');
    if (printWindow) { printWindow.document.write(html); printWindow.document.close(); }
  }

  initDefaults();
  renderLineItems();
  document.getElementById('add-line-btn')?.addEventListener('click', () => addLineItem());
  document.querySelectorAll('.quick-add-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      addLineItem(el.dataset.quick || '', parseFloat(el.dataset.price || '0'));
    });
  });
  document.getElementById('taxRate')?.addEventListener('input', recalculate);
  document.getElementById('generate-pdf-btn')?.addEventListener('click', generatePDF);
</script>
