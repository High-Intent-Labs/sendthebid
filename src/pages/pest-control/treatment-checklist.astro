            </label>
            <div class="flex items-center gap-2 ml-8">
              <input type="number" data-field="temp-rise" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" /> <span class="text-xs text-text-muted">&deg;F</span>
              <span class="text-xs text-text-muted ml-1 italic">Check nameplate for range</span>
