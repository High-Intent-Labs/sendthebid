---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/hvacTools';

const tool = getToolBySlug('btu-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I calculate BTU for a room?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Multiply the room's square footage by 20 BTU per square foot as a baseline. Then adjust for ceiling height, insulation quality, sun exposure, and number of occupants. A 300 sq ft room with average conditions needs approximately 6,000 BTU."
      }
    },
    {
      "@type": "Question",
      "name": "What size mini-split do I need?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Calculate your room's BTU requirement, then match to the nearest mini-split size: 9,000 BTU (0.75 ton), 12,000 BTU (1 ton), 18,000 BTU (1.5 ton), 24,000 BTU (2 ton), or 36,000 BTU (3 ton). Always round up to the next available size."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between BTU calculator and Manual J?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A BTU calculator provides a quick room-level estimate using simplified factors. Manual J is a comprehensive whole-house load calculation considering wall construction, window orientation, duct losses, and more. Use a BTU calculator for single-room sizing and Manual J for full system design."
      }
    },
    {
      "@type": "Question",
      "name": "How many BTU per square foot for HVAC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The standard rule of thumb is 20 BTU per square foot for cooling. This baseline gets adjusted up or down based on insulation (poor insulation adds 15%), sun exposure (heavy sun adds 10%), ceiling height, and occupancy. Well-insulated rooms may need only 18 BTU/sq ft."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="btu-calc">
    <!-- Input Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="sqft">Room Square Footage</label>
        <input type="number" id="sqft" value="300" min="50" max="10000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="ceiling">Ceiling Height (ft)</label>
        <input type="number" id="ceiling" value="8" min="6" max="30" step="0.5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="insulation">Insulation Quality</label>
        <select id="insulation" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="1.15">Poor — Older home, single-pane windows</option>
          <option value="1.0" selected>Average — Standard construction</option>
          <option value="0.9">Good — Modern build, double-pane</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="sun">Sun Exposure</label>
        <select id="sun" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="1.1">Heavy — South/west facing, lots of glass</option>
          <option value="1.0" selected>Moderate — Mixed exposure</option>
          <option value="0.9">Shaded — North facing, tree cover</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="occupants">Number of Occupants</label>
        <input type="number" id="occupants" value="2" min="1" max="20" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="kitchen">Kitchen?</label>
        <select id="kitchen" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="0" selected>No</option>
          <option value="4000">Yes</option>
        </select>
      </div>
    </div>


    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Results</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Required BTU</div>
          <div id="result-btu" class="font-heading font-extrabold text-3xl text-accent">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Recommended Unit</div>
          <div id="result-unit" class="font-heading font-extrabold text-xl text-text-primary">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Tonnage</div>
          <div id="result-tons" class="font-heading font-extrabold text-3xl text-text-primary">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">BTU/sq ft</div>
          <div id="result-persqft" class="font-heading font-extrabold text-3xl text-text-primary">—</div>
        </div>
      </div>
      <p class="text-text-muted text-sm italic">This is a room-level estimate. For whole-house sizing, use the <a href="/hvac/load-calculator" class="text-accent hover:underline">HVAC Load Calculator</a>. A Manual J calculation is required for final equipment selection.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter the room's square footage.</strong> Measure length times width. If the room is L-shaped, break it into rectangles and add them up.</p>
          <p><strong class="text-text-primary">2. Set the ceiling height.</strong> Standard is 8 ft. Vaulted or cathedral ceilings need more cooling capacity — the calculator adjusts automatically.</p>
          <p><strong class="text-text-primary">3. Rate the insulation.</strong> Older homes with single-pane windows are "Poor." Modern builds with double-pane Low-E glass are "Good."</p>
          <p><strong class="text-text-primary">4. Choose sun exposure.</strong> South and west-facing rooms with large windows get more solar heat gain. North-facing or shaded rooms need less cooling.</p>
          <p><strong class="text-text-primary">5. Add occupants and kitchen.</strong> Each person beyond 2 adds 600 BTU. Kitchens generate significant heat from cooking and appliances.</p>
        </div>
      </section>

      <!-- How It Works -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How the BTU Formula Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>The calculator starts with a baseline of <strong class="text-text-primary">20 BTU per square foot</strong> — the industry standard for residential cooling. This is more conservative than the 25 BTU/sq ft some competitors use, which tends to oversize systems.</p>
          <p>From the baseline, five adjustment factors fine-tune the result:</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm">
            <p>Room_BTU = (Sqft × 20) × Ceiling_Factor × Insulation_Factor × Sun_Factor + Occupant_BTU + Kitchen_BTU</p>
          </div>
          <p>Ceiling factor scales linearly: a 10-foot ceiling is 1.25× (10/8). Insulation ranges from 1.15× for poor to 0.9× for good. Sun exposure adds or removes 10%. Each person beyond two adds 600 BTU of body heat. Kitchens add a flat 4,000 BTU for cooking and appliance heat.</p>
          <p>The calculator then matches the result to standard mini-split and window unit sizes (9K, 12K, 18K, 24K, 36K, 48K BTU) and shows the recommended tonnage.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Mini-split sizing on site.</strong> You're at a customer's home and need to quickly recommend a ductless unit size for a sunroom, garage conversion, or bonus room. Pull this up on your phone, enter the room dimensions, and give the customer a confident answer.</p>
          <p><strong class="text-text-primary">Window unit recommendations.</strong> When a customer calls asking what size window AC they need, walk them through the inputs over the phone and give them a specific BTU number instead of guessing.</p>
          <p><strong class="text-text-primary">Quick sanity check.</strong> Before running a full Manual J, use this as a gut-check on individual rooms. If your Manual J says a 200 sq ft bedroom needs 12,000 BTU, something's off.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate BTU for a room?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Multiply the room's square footage by 20 BTU per square foot as a baseline. Then adjust for ceiling height, insulation quality, sun exposure, and number of occupants. A 300 sq ft room with average conditions needs approximately 6,000 BTU.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What size mini-split do I need?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Calculate your room's BTU requirement, then match to the nearest mini-split size: 9,000 BTU (0.75 ton), 12,000 BTU (1 ton), 18,000 BTU (1.5 ton), 24,000 BTU (2 ton), or 36,000 BTU (3 ton). Always round up to the next available size.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is the difference between a BTU calculator and Manual J?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A BTU calculator provides a quick room-level estimate using simplified factors. Manual J is a comprehensive whole-house load calculation considering wall construction, window orientation, duct losses, and more. Use a BTU calculator for single-room sizing and Manual J for full system design.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How many BTU per square foot for HVAC?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">The standard rule of thumb is 20 BTU per square foot for cooling. This baseline gets adjusted based on insulation, sun exposure, ceiling height, and occupancy. Well-insulated rooms may need as low as 18 BTU/sq ft, while poorly insulated sun-facing rooms can need 25+ BTU/sq ft.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const sqft = parseFloat((document.getElementById('sqft') as HTMLInputElement).value) || 300;
    const ceiling = parseFloat((document.getElementById('ceiling') as HTMLInputElement).value) || 8;
    const insulation = parseFloat((document.getElementById('insulation') as HTMLSelectElement).value);
    const sun = parseFloat((document.getElementById('sun') as HTMLSelectElement).value);
    const occupants = parseInt((document.getElementById('occupants') as HTMLInputElement).value) || 2;
    const kitchen = parseInt((document.getElementById('kitchen') as HTMLSelectElement).value);

    const baseBtu = sqft * 20;
    const ceilingFactor = ceiling > 8 ? ceiling / 8 : 1;
    const occupantBtu = occupants > 2 ? (occupants - 2) * 600 : 0;

    const totalBtu = Math.round(baseBtu * ceilingFactor * insulation * sun + occupantBtu + kitchen);

    // Match to standard unit sizes
    let unitSize: string;
    if (totalBtu <= 9000) unitSize = '9,000 BTU (0.75 ton)';
    else if (totalBtu <= 12000) unitSize = '12,000 BTU (1 ton)';
    else if (totalBtu <= 18000) unitSize = '18,000 BTU (1.5 ton)';
    else if (totalBtu <= 24000) unitSize = '24,000 BTU (2 ton)';
    else if (totalBtu <= 36000) unitSize = '36,000 BTU (3 ton)';
    else if (totalBtu <= 48000) unitSize = '48,000 BTU (4 ton)';
    else unitSize = 'Multiple units or central system recommended';

    const tonnage = (totalBtu / 12000).toFixed(1);
    const perSqft = (totalBtu / sqft).toFixed(0);

    document.getElementById('result-btu')!.textContent = totalBtu.toLocaleString();
    document.getElementById('result-unit')!.textContent = unitSize;
    document.getElementById('result-tons')!.textContent = `${tonnage} ton`;
    document.getElementById('result-persqft')!.textContent = perSqft;
  }


  // Auto-calculate on input change
  document.querySelectorAll('#btu-calc input, #btu-calc select').forEach(el => {
    el.addEventListener('change', calculate);
  });

  // Calculate on load with defaults
  calculate();
</script>
