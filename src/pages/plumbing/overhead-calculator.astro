---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/plumbingTools';

const tool = getToolBySlug('overhead-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are typical plumbing business overhead costs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most plumbing businesses carry 25-35% overhead relative to revenue. The largest categories are usually fleet costs (fuel, insurance, payments at $1,000-$1,800 per van per month), payroll for non-tech staff (office, dispatch, owner salary), insurance (general liability, workers comp at 4-6% of payroll), and marketing. A three-van shop with an office typically runs $18,000-$26,000 per month in overhead before any plumber labor or job materials."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate overhead per hour for plumbing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Divide your total annual overhead by the total billable hours your plumbers produce in a year. For example, if annual overhead is $280,000 and you have 3 plumbers each billing 768 hours per year (64 hours per month), your total billable hours are 2,304. Overhead per hour is $280,000 / 2,304 = $121.53. This number must be built into your hourly billing rate on top of labor cost and profit margin."
      }
    },
    {
      "@type": "Question",
      "name": "What percentage of revenue should go to overhead in plumbing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The target range for plumbing companies is 25-35% of revenue going to overhead. Below 25% usually means a lean operation or underinvestment in growth. Above 35% signals you may be overspending or underpricing. Marketing alone should be 6-8% of revenue for a stable business and 10-15% if you are actively growing. Fleet costs typically run 8-12% and insurance 4-6%."
      }
    },
    {
      "@type": "Question",
      "name": "How do I reduce plumbing business overhead?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start by identifying your top three overhead categories. Common wins include renegotiating insurance annually, optimizing truck routes to cut fuel costs, switching to cloud-based dispatch software, cross-training office staff to eliminate redundant positions, and auditing subscriptions for unused services. Do not cut marketing below 6% of revenue or you will shrink your pipeline. Focus on efficiency gains rather than blanket cuts."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="overhead-calc">
    <!-- Facility -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Facility (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="shopRent">Shop Rent ($)</label>
          <input type="number" id="shopRent" value="1800" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="utilities">Utilities ($)</label>
          <input type="number" id="utilities" value="350" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Fleet -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Fleet (Per Van)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="sm:col-span-2 lg:col-span-3">
          <label class="block text-xs text-text-muted mb-1" for="numTrucks">Number of Vans</label>
          <input type="number" id="numTrucks" value="3" min="1" max="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="fuelPerTruck">Fuel per Van ($)</label>
          <input type="number" id="fuelPerTruck" value="650" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="insurancePerTruck">Insurance per Van ($)</label>
          <input type="number" id="insurancePerTruck" value="275" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="maintPerTruck">Maintenance per Van ($)</label>
          <input type="number" id="maintPerTruck" value="225" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="paymentPerTruck">Payment per Van ($)</label>
          <input type="number" id="paymentPerTruck" value="500" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Insurance -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Insurance (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="generalLiability">General Liability ($)</label>
          <input type="number" id="generalLiability" value="600" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="workersComp">Workers Comp ($)</label>
          <input type="number" id="workersComp" value="900" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="umbrella">Umbrella ($)</label>
          <input type="number" id="umbrella" value="200" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- People -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">People (Monthly, Non-Plumber)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="officeStaff">Office Staff ($)</label>
          <input type="number" id="officeStaff" value="3500" min="0" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="dispatcher">Dispatcher ($)</label>
          <input type="number" id="dispatcher" value="3000" min="0" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="ownerSalary">Owner Salary ($)</label>
          <input type="number" id="ownerSalary" value="9000" min="0" step="500" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="bookkeeper">Bookkeeper ($)</label>
          <input type="number" id="bookkeeper" value="500" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Operations -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Operations (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="softwareDispatch">Software/Dispatch ($)</label>
          <input type="number" id="softwareDispatch" value="400" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="answeringService">Answering Service ($)</label>
          <input type="number" id="answeringService" value="300" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="phoneInternet">Phone/Internet ($)</label>
          <input type="number" id="phoneInternet" value="250" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="toolsEquipment">Camera/Locator/Press Tool ($)</label>
          <input type="number" id="toolsEquipment" value="300" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          <p class="text-text-muted text-xs mt-1">$200-400/mo per plumber (lease or amortize)</p>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="uniforms">Uniforms ($)</label>
          <input type="number" id="uniforms" value="100" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Compliance -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Compliance (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="plumbingLicense">Plumbing License ($)</label>
          <input type="number" id="plumbingLicense" value="75" min="0" step="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="businessLicenses">Business Licenses ($)</label>
          <input type="number" id="businessLicenses" value="75" min="0" step="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="backflowCerts">Backflow Certs/Training ($)</label>
          <input type="number" id="backflowCerts" value="100" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Marketing -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Marketing (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="onlineAds">Online Ads ($)</label>
          <input type="number" id="onlineAds" value="1500" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="seoWebsite">SEO/Website ($)</label>
          <input type="number" id="seoWebsite" value="500" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="printMail">Print/Mail ($)</label>
          <input type="number" id="printMail" value="200" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="referralPrograms">Referral Programs ($)</label>
          <input type="number" id="referralPrograms" value="300" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Other -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Other (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="accountingLegal">Accounting/Legal ($)</label>
          <input type="number" id="accountingLegal" value="400" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="badDebt">Bad Debt Allowance ($)</label>
          <input type="number" id="badDebt" value="200" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="misc">Misc ($)</label>
          <input type="number" id="misc" value="300" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Context -->
    <details class="mb-8 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Context (For Per-Hour &amp; Per-Call Math)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="numTechs">Number of Plumbers</label>
          <input type="number" id="numTechs" value="3" min="1" max="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="billableHours">Billable Hours/Month per Plumber</label>
          <input type="number" id="billableHours" value="64" min="1" max="200" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="annualRevenue">Annual Revenue ($)</label>
          <input type="number" id="annualRevenue" value="1200000" min="0" step="10000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="callsPerDay">Avg Service Calls per Day</label>
          <input type="number" id="callsPerDay" value="6" min="1" max="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="workingDays">Working Days per Month</label>
          <input type="number" id="workingDays" value="22" min="1" max="31" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>


    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Results</h3>

      <!-- Primary results -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center sm:col-span-2">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Monthly Overhead</div>
          <div id="result-monthly" class="font-heading font-extrabold text-4xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center sm:col-span-2">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Annual Overhead</div>
          <div id="result-annual" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Per Plumber (Annual)</div>
          <div id="result-per-tech" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Per Billable Hour</div>
          <div id="result-per-hour" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Per Service Call</div>
          <div id="result-per-call" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Overhead % of Revenue</div>
          <div id="result-pct" class="font-heading font-extrabold text-2xl">--</div>
        </div>
      </div>

      <!-- Category breakdown -->
      <div class="bg-bg-dark rounded-xl p-6 mb-8">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Category Breakdown (Monthly)</h4>
        <div class="space-y-3" id="category-breakdown">
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">Facility</span>
            <span id="cat-facility" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
            <div id="bar-facility" class="bg-[#60A5FA] h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">Fleet</span>
            <span id="cat-fleet" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
            <div id="bar-fleet" class="bg-[#34D399] h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">Insurance</span>
            <span id="cat-insurance" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
            <div id="bar-insurance" class="bg-[#C084FC] h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">People</span>
            <span id="cat-people" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
            <div id="bar-people" class="bg-[#FBBF24] h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">Operations</span>
            <span id="cat-operations" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
            <div id="bar-operations" class="bg-[#F472B6] h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">Compliance</span>
            <span id="cat-compliance" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
            <div id="bar-compliance" class="bg-[#A78BFA] h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">Marketing</span>
            <span id="cat-marketing" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
            <div id="bar-marketing" class="bg-[#FB923C] h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-text-secondary">Other</span>
            <span id="cat-other" class="text-text-primary font-semibold">--</span>
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2">
            <div id="bar-other" class="bg-[#94A3B8] h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
