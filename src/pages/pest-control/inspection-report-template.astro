---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/pestControlTools';

const tool = getToolBySlug('inspection-report-template')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should a pest control inspection report include?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A professional pest control inspection report should include property identification and access points, pest species identified (with evidence type: live insects, droppings, damage, nesting), severity ratings for each area (None, Low, Moderate, Severe), conducive conditions found (moisture, food sources, entry points, harborage), a diagram or map of activity zones, recommended treatment plan with products and methods, and technician credentials with license number."
      }
    },
    {
      "@type": "Question",
      "name": "How much does a pest control inspection cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A standard pest control inspection costs $75 to $150 for general pest assessment. Termite inspections (WDI/WDO reports) for real estate transactions typically run $75 to $250 depending on property size and state requirements. Many pest control companies offer free inspections as a lead-generation tool, with the understanding that treatment services will follow. Annual inspection contracts for commercial properties range from $200 to $1,000 per year."
      }
    },
    {
      "@type": "Question",
      "name": "What is checked during a pest control inspection?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A thorough pest inspection covers the interior (kitchen, bathrooms, basements, attics, utility rooms), exterior (foundation, eaves, soffits, landscaping, drainage), structural elements (crawl spaces, wall voids, roof line), and environmental factors (moisture levels, sanitation, food storage, waste management). The technician looks for live pests, droppings, gnaw marks, mud tubes, wood damage, nesting materials, and conditions that attract or harbor pest activity."
      }
    },
    {
      "@type": "Question",
      "name": "How do I write a professional pest inspection report?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start with complete property details and inspection scope. Document each area inspected with specific findings and evidence type. Use severity ratings (None, Low, Moderate, Severe) so the client understands the urgency. Include photos of evidence and conducive conditions. List every finding with a recommended treatment, estimated cost, and priority level. Add a property diagram marking activity zones. Always include your license number, the inspection date, and a follow-up recommendation."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="inspection-report-form">

    <!-- Section: Header / Company Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Inspector &amp; Company Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="company-name">Company Name</label>
        <input type="text" id="company-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="inspector-name">Inspector Name</label>
        <input type="text" id="inspector-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="inspector-phone">Phone</label>
        <input type="text" id="inspector-phone" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="license-number">License #</label>
        <input type="text" id="license-number" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="inspection-date">Inspection Date</label>
        <input type="date" id="inspection-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="report-number">Report #</label>
        <input type="text" id="report-number" value="IR-001" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="property-address">Property Address</label>
        <input type="text" id="property-address" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="inspection-reason">Reason for Inspection</label>
        <select id="inspection-reason" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Pre-Purchase">Pre-Purchase</option>
          <option value="Annual Inspection" selected>Annual Inspection</option>
          <option value="Insurance">Insurance</option>
          <option value="Warranty Claim">Warranty Claim</option>
          <option value="Complaint Investigation">Complaint Investigation</option>
        </select>
      </div>
    </div>

    <!-- Section: Property Details -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Property Details</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-type">Property Type</label>
        <select id="equip-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Single Family">Single Family</option>
          <option value="Multi-Family">Multi-Family</option>
          <option value="Commercial" selected>Commercial</option>
          <option value="Restaurant/Food Service">Restaurant/Food Service</option>
          <option value="Warehouse">Warehouse</option>
          <option value="Healthcare">Healthcare</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-make">Target Pest(s)</label>
        <input type="text" id="equip-make" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-model">Evidence Type</label>
        <input type="text" id="equip-model" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-serial">Severity Level</label>
        <input type="text" id="equip-serial" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="install-date">Last Service Date</label>
        <input type="date" id="install-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2">Time Since Last Service</label>
        <div id="equip-age-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="remaining-life">Recommended Service Interval (months)</label>
        <input type="number" id="remaining-life" min="0" max="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="overall-condition">Overall Condition</label>
        <select id="overall-condition" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Excellent">Excellent</option>
          <option value="Good" selected>Good</option>
          <option value="Fair">Fair</option>
          <option value="Poor">Poor</option>
          <option value="Failed">Failed</option>
        </select>
      </div>
    </div>

    <!-- Section: Component Ratings -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Component Ratings</h3>
    <div class="space-y-4 mb-8">
      <!-- Interior Areas -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Interior Areas</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="interior-areas">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="interior-areas"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="interior-areas" rows="2" placeholder="Notes..."></textarea>
      </div>
      <!-- Exterior Perimeter -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Exterior Perimeter</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="electrical">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="electrical"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="electrical" rows="2" placeholder="Notes..."></textarea>
      </div>
      <!-- Treatment Areas -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Treatment Areas</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="treatment-areas">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="treatment-areas"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="treatment-areas" rows="2" placeholder="Notes..."></textarea>
      </div>
      <!-- Entry Points -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Entry Points</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="entry-points">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="entry-points"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="entry-points" rows="2" placeholder="Notes..."></textarea>
      </div>
      <!-- Monitoring Stations -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Monitoring Stations</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="monitoring-stations">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="monitoring-stations"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="monitoring-stations" rows="2" placeholder="Notes..."></textarea>
      </div>
      <!-- Sanitation Conditions -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Sanitation Conditions</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="filtration">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="filtration"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="filtration" rows="2" placeholder="Notes..."></textarea>
      </div>
      <!-- Conducive Conditions -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Conducive Conditions</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="safety">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="safety"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="safety" rows="2" placeholder="Notes..."></textarea>
      </div>
      <!-- Moisture &amp; Drainage -->
      <div class="bg-bg-dark border border-border rounded-lg p-4">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
          <span class="font-medium text-text-primary w-48 shrink-0">Moisture &amp; Drainage</span>
          <select class="component-rating bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary focus:border-accent focus:outline-none transition-colors" data-component="drainage">
            <option value="Pass">Pass (Green)</option>
            <option value="Monitor">Monitor (Yellow)</option>
            <option value="Fail">Fail (Red)</option>
          </select>
          <span class="rating-indicator w-4 h-4 rounded-full bg-green-500 shrink-0" data-for="drainage"></span>
        </div>
        <textarea class="component-notes w-full bg-bg-card border border-border rounded-lg px-4 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors resize-y" data-component="drainage" rows="2" placeholder="Notes..."></textarea>
      </div>
    </div>

    <!-- Section: Activity Observations -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Activity Observations</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="supply-temp">Live Pest Count</label>
        <input type="number" id="supply-temp" min="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="return-temp">Droppings / Evidence Sites</label>
        <input type="number" id="return-temp" min="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2">Activity Level</label>
        <div id="temp-split-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="co-reading">Entry Points Found</label>
        <input type="number" id="co-reading" min="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2">Entry Point Severity</label>
        <div id="co-level-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="gas-pressure">Moisture Readings (%)</label>
        <input type="number" id="gas-pressure" step="0.1" min="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="static-pressure">Bait Station Activity (count)</label>
        <input type="number" id="static-pressure" min="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Findings -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Findings</h3>
    <div class="mb-8">
      <div id="findings-table" class="space-y-3">
        <div class="finding-row bg-bg-dark border border-border rounded-lg p-4">
          <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr_120px_140px_40px] gap-3 items-end">
            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">Description</label>
              <input type="text" class="finding-desc w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">Recommended Action</label>
              <input type="text" class="finding-action w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">Est. Cost ($)</label>
              <input type="number" min="0" step="1" class="finding-cost w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">Priority</label>
              <select class="finding-priority w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
                <option value="Immediate/Safety">Immediate / Safety</option>
                <option value="High">High</option>
                <option value="Medium" selected>Medium</option>
                <option value="Low">Low</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">&nbsp;</label>
              <button type="button" class="remove-finding-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove finding">&times;</button>
            </div>
          </div>
        </div>
      </div>
      <button type="button" id="add-finding-btn" class="mt-3 text-accent hover:text-accent-hover transition-colors cursor-pointer text-sm font-medium">+ Add Finding</button>
    </div>

    <!-- Section: Summary -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Summary</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
      <div class="bg-bg-dark rounded-xl p-5 text-center">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Good Condition</div>
        <div id="summary-good" class="font-heading font-extrabold text-3xl text-green-400">0</div>
      </div>
      <div class="bg-bg-dark rounded-xl p-5 text-center">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Needs Attention</div>
        <div id="summary-attention" class="font-heading font-extrabold text-3xl text-yellow-400">0</div>
      </div>
      <div class="bg-bg-dark rounded-xl p-5 text-center">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Repair Cost</div>
        <div id="summary-cost" class="font-heading font-extrabold text-3xl text-accent">$0</div>
      </div>
      <div class="bg-bg-dark rounded-xl p-5 text-center">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Overall Assessment</div>
        <div id="summary-assessment-display" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="overall-assessment">Overall Assessment</label>
        <select id="overall-assessment" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Pass">Pass</option>
          <option value="Conditional Pass" selected>Conditional Pass</option>
          <option value="Fail">Fail</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="additional-notes">Additional Notes</label>
        <textarea id="additional-notes" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
    </div>

    <!-- Generate Button -->
    <button id="generate-btn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
      Generate Inspection Report &rarr;
    </button>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Template</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Fill in your company and property details.</strong> Enter your company name, license number, and the property address. The report number auto-generates as IR-001 — change it to match your numbering system. Select the reason for the inspection (routine, pre-purchase, complaint, follow-up) so the report context is clear.</p>
          <p><strong class="text-text-primary">2. Survey each area and rate pest activity.</strong> Walk through every zone — interior rooms, exterior perimeter, crawl spaces, attic, and outbuildings. For each area, record pest species identified, evidence type (droppings, damage, live sightings, nesting), and assign a severity rating with notes explaining your assessment.</p>
          <p><strong class="text-text-primary">3. Document conducive conditions and findings.</strong> Note moisture issues, entry points, food sources, harborage areas, and sanitation concerns. For every finding, add a row with a description, recommended treatment or exclusion action, estimated cost, and priority level. The summary section auto-calculates totals as you go.</p>
          <p><strong class="text-text-primary">4. Generate the printable report.</strong> Select your overall assessment, add treatment recommendations and follow-up schedule, and hit Generate. The report opens in a new tab with professional formatting, color-coded severity ratings, a findings table with priority flags, and a signature line — ready to print or save as PDF.</p>
        </div>
      </section>

      <!-- What Makes a Professional Report -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Makes a Professional Pest Control Inspection Report</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>A professional pest inspection report does more than list what you found. Every section serves a specific purpose in communicating pest activity, risk level, and treatment needs to the property owner, buyer, or property manager.</p>
          <p><strong class="text-text-primary">Property identification</strong> anchors the report to a specific location and date. Address, property type, square footage, and construction details provide context for the inspection scope. A crawl space home in a humid climate tells a different pest story than a slab-on-grade in a dry region.</p>
          <p><strong class="text-text-primary">Area-by-area ratings</strong> using a standardized severity scale (None, Low, Moderate, Severe) make findings accessible to non-technical readers. A homebuyer does not need to understand pest biology — they need to know the kitchen has moderate rodent activity and the crawl space has severe moisture conducive to termites. The notes behind each rating provide the technical detail.</p>
          <p><strong class="text-text-primary">Evidence documentation</strong> is what separates a professional report from a verbal summary. Photos of droppings, gnaw marks, mud tubes, entry points, and damage create an objective record that cannot be disputed. This evidence supports your treatment recommendations and protects you if conditions change after the inspection.</p>
          <p><strong class="text-text-primary">Prioritized findings</strong> turn observations into actionable recommendations. Each finding includes what was found, where, the recommended treatment or exclusion work, estimated cost, and urgency level. This structure helps property owners make informed decisions about treatment and budgeting.</p>
          <p><strong class="text-text-primary">Documentation matters</strong> because pest inspection reports become legal documents. They are referenced in real estate transactions (WDI/WDO reports), insurance claims for pest damage, warranty disputes, and landlord-tenant disagreements. A thorough, well-structured report protects your client, protects your business, and demonstrates the professionalism that wins ongoing service contracts.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Real estate inspections.</strong> A buyer's agent or homebuyer hires you to evaluate the property for pest activity before closing. The WDI/WDO report becomes part of the due diligence package. A clear assessment with documented evidence and estimated treatment costs gives the buyer leverage to negotiate price reductions or request remediation before closing. This is the highest-stakes use case — your report directly influences a real estate transaction.</p>
          <p><strong class="text-text-primary">Recurring service inspections.</strong> During quarterly or monthly service visits, a formal inspection report documents current pest activity levels and creates a visit-over-visit record. When an area moves from "None" to "Low" activity, you can point to the trend and recommend proactive treatment before it escalates. This builds trust, justifies your service contract, and protects you from customers who claim you never told them about a problem.</p>
          <p><strong class="text-text-primary">Commercial and property management accounts.</strong> Property managers, restaurants, food processing facilities, and healthcare providers require documented pest inspection records for regulatory compliance. A professional report with area ratings, evidence photos, and treatment recommendations gives them exactly what auditors and health inspectors need — without the back-and-forth of incomplete documentation.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should a pest control inspection report include?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A professional pest control inspection report should include property identification, pest species found with evidence type (droppings, damage, live sightings, nesting), area-by-area severity ratings, conducive conditions documented (moisture, entry points, food sources), a prioritized list of findings with treatment recommendations and estimated costs, an overall assessment, and your technician credentials with license number.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much does a pest control inspection cost?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A standard pest control inspection costs $75 to $150, though many companies offer free inspections to win the treatment contract. Real estate termite inspections (WDI/WDO reports) typically run $75 to $250 depending on property size and state requirements. Annual inspection agreements for commercial properties range from $200 to $1,000 per year.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is checked during a pest control inspection?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A thorough pest inspection covers the interior (kitchen, bathrooms, basement, attic, utility rooms), exterior (foundation perimeter, landscaping, drainage, roof line), and structural elements (crawl spaces, wall voids, wood members). Technicians look for live pests, droppings, gnaw marks, mud tubes, wood damage, nesting material, entry points, moisture issues, and conditions that attract or harbor pest activity.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I write a professional pest inspection report?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Start with complete property identification and inspection scope. Document each area with specific findings, evidence type, and severity rating. Include photos of evidence and conducive conditions. List every finding with a recommended treatment, estimated cost, and priority level. Add a property diagram marking activity zones and entry points. Always include your license number, inspection date, and follow-up recommendations.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // --- Default date ---
  const now = new Date();
  const dateInput = document.getElementById('inspection-date') as HTMLInputElement;
  if (dateInput && !dateInput.value) {
    dateInput.value = now.toISOString().slice(0, 10);
  }

  // --- Equipment Age auto-calculation ---
  function updateEquipAge() {
    const installDate = (document.getElementById('install-date') as HTMLInputElement).value;
    const display = document.getElementById('equip-age-display')!;
    if (installDate) {
      const install = new Date(installDate);
      const today = new Date();
      let years = today.getFullYear() - install.getFullYear();
      const monthDiff = today.getMonth() - install.getMonth();
      if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < install.getDate())) {
        years--;
      }
      display.textContent = years + (years === 1 ? ' year' : ' years');
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-primary';
    } else {
      display.textContent = '\u2014';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted';
    }
  }
  document.getElementById('install-date')?.addEventListener('input', updateEquipAge);

  // --- Overall Condition color coding ---
  function updateConditionColor() {
    const select = document.getElementById('overall-condition') as HTMLSelectElement;
    const val = select.value;
    select.classList.remove('text-green-400', 'text-yellow-400', 'text-red-400', 'text-text-primary');
    if (val === 'Excellent' || val === 'Good') {
      select.classList.add('text-green-400');
    } else if (val === 'Fair') {
      select.classList.add('text-yellow-400');
    } else if (val === 'Poor' || val === 'Failed') {
      select.classList.add('text-red-400');
    }
  }
  document.getElementById('overall-condition')?.addEventListener('change', updateConditionColor);
  updateConditionColor();

  // --- Component Rating color indicators ---
  function updateRatingIndicators() {
    document.querySelectorAll('.component-rating').forEach(sel => {
      const select = sel as HTMLSelectElement;
      const component = select.dataset.component;
      const indicator = document.querySelector(`.rating-indicator[data-for="${component}"]`) as HTMLElement;
      if (!indicator) return;
      indicator.classList.remove('bg-green-500', 'bg-yellow-500', 'bg-red-500');
      if (select.value === 'Pass') {
        indicator.classList.add('bg-green-500');
      } else if (select.value === 'Monitor') {
        indicator.classList.add('bg-yellow-500');
      } else {
        indicator.classList.add('bg-red-500');
      }
    });
    updateSummary();
  }
  document.querySelectorAll('.component-rating').forEach(el => {
    el.addEventListener('change', updateRatingIndicators);
  });

  // --- Activity Level auto-calculation ---
  function updateTempSplit() {
    const liveCount = parseFloat((document.getElementById('supply-temp') as HTMLInputElement).value);
    const evidenceSites = parseFloat((document.getElementById('return-temp') as HTMLInputElement).value);
    const display = document.getElementById('temp-split-display')!;
    if (!isNaN(liveCount) && !isNaN(evidenceSites)) {
      const total = liveCount + evidenceSites;
      if (total === 0) {
        display.textContent = 'None';
        display.className = 'w-full bg-bg-dark border border-green-500/50 rounded-lg px-4 py-3 text-lg font-bold text-green-400';
      } else if (total <= 5) {
        display.textContent = 'Low';
        display.className = 'w-full bg-bg-dark border border-green-500/50 rounded-lg px-4 py-3 text-lg font-bold text-green-400';
      } else if (total <= 15) {
        display.textContent = 'Moderate';
        display.className = 'w-full bg-bg-dark border border-yellow-500/50 rounded-lg px-4 py-3 text-lg font-bold text-yellow-400';
      } else {
        display.textContent = 'Severe';
        display.className = 'w-full bg-bg-dark border border-red-500/50 rounded-lg px-4 py-3 text-lg font-bold text-red-400';
      }
    } else {
      display.textContent = '\u2014';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted';
    }
  }
  document.getElementById('supply-temp')?.addEventListener('input', updateTempSplit);
  document.getElementById('return-temp')?.addEventListener('input', updateTempSplit);

  // --- Entry Point Severity indicator ---
  function updateCOLevel() {
    const entryPoints = parseFloat((document.getElementById('co-reading') as HTMLInputElement).value);
    const display = document.getElementById('co-level-display')!;
    if (!isNaN(entryPoints) && entryPoints >= 0) {
      if (entryPoints === 0) {
        display.textContent = 'None Found';
        display.className = 'w-full bg-bg-dark border border-green-500/50 rounded-lg px-4 py-3 text-lg font-bold text-green-400';
      } else if (entryPoints <= 3) {
        display.textContent = entryPoints + ' \u2014 Low';
        display.className = 'w-full bg-bg-dark border border-green-500/50 rounded-lg px-4 py-3 text-lg font-bold text-green-400';
      } else if (entryPoints <= 8) {
        display.textContent = entryPoints + ' \u2014 Moderate';
        display.className = 'w-full bg-bg-dark border border-yellow-500/50 rounded-lg px-4 py-3 text-lg font-bold text-yellow-400';
      } else {
        display.textContent = entryPoints + ' \u2014 Severe';
        display.className = 'w-full bg-bg-dark border border-red-500/50 rounded-lg px-4 py-3 text-lg font-bold text-red-400';
      }
    } else {
      display.textContent = '\u2014';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted';
    }
  }
  document.getElementById('co-reading')?.addEventListener('input', updateCOLevel);

  // --- Dynamic Findings Table ---
  function addFindingRow() {
    const table = document.getElementById('findings-table')!;
    const row = document.createElement('div');
    row.className = 'finding-row bg-bg-dark border border-border rounded-lg p-4';
    row.innerHTML = `
      <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr_120px_140px_40px] gap-3 items-end">
        <div>
          <input type="text" class="finding-desc w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <input type="text" class="finding-action w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <input type="number" min="0" step="1" class="finding-cost w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <select class="finding-priority w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="Immediate/Safety">Immediate / Safety</option>
            <option value="High">High</option>
            <option value="Medium" selected>Medium</option>
            <option value="Low">Low</option>
          </select>
        </div>
        <div>
          <button type="button" class="remove-finding-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove finding">&times;</button>
        </div>
      </div>
    `;
    table.appendChild(row);
    attachFindingListeners();
  }

  document.getElementById('add-finding-btn')?.addEventListener('click', addFindingRow);

  document.getElementById('findings-table')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('remove-finding-btn')) {
      const row = target.closest('.finding-row');
      const allRows = document.querySelectorAll('.finding-row');
      if (allRows.length > 1 && row) {
        row.remove();
        updateSummary();
      }
    }
  });

  function attachFindingListeners() {
    document.querySelectorAll('.finding-cost').forEach(el => {
      el.removeEventListener('input', updateSummary);
      el.addEventListener('input', updateSummary);
    });
  }
  attachFindingListeners();

  // --- Summary auto-calculation ---
  function updateSummary() {
    // Count component ratings
    let good = 0;
    let attention = 0;
    document.querySelectorAll('.component-rating').forEach(sel => {
      const val = (sel as HTMLSelectElement).value;
      if (val === 'Pass') good++;
      else attention++;
    });
    document.getElementById('summary-good')!.textContent = String(good);
    document.getElementById('summary-attention')!.textContent = String(attention);

    // Sum finding costs
    let totalCost = 0;
    document.querySelectorAll('.finding-cost').forEach(el => {
      const val = parseFloat((el as HTMLInputElement).value);
      if (!isNaN(val)) totalCost += val;
    });
    document.getElementById('summary-cost')!.textContent = '$' + totalCost.toLocaleString();

    // Overall assessment display
    const assessment = (document.getElementById('overall-assessment') as HTMLSelectElement).value;
    const assessDisplay = document.getElementById('summary-assessment-display')!;
    assessDisplay.textContent = assessment;
    assessDisplay.classList.remove('text-green-400', 'text-yellow-400', 'text-red-400', 'text-text-primary');
    if (assessment === 'Pass') {
      assessDisplay.classList.add('text-green-400');
    } else if (assessment === 'Conditional Pass') {
      assessDisplay.classList.add('text-yellow-400');
    } else {
      assessDisplay.classList.add('text-red-400');
    }
  }
  document.getElementById('overall-assessment')?.addEventListener('change', updateSummary);
  updateSummary();

  // --- Helper ---
  function getVal(id: string): string {
    const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
    return el ? el.value : '';
  }

  // --- Generate Inspection Report ---
  function generateReport() {
    // Collect component ratings
    const components = [
      { key: 'interior-areas', label: 'Interior Areas' },
      { key: 'electrical', label: 'Exterior Perimeter' },
      { key: 'treatment-areas', label: 'Treatment Areas' },
      { key: 'entry-points', label: 'Entry Points' },
      { key: 'monitoring-stations', label: 'Monitoring Stations' },
      { key: 'filtration', label: 'Sanitation Conditions' },
      { key: 'safety', label: 'Conducive Conditions' },
      { key: 'drainage', label: 'Moisture & Drainage' },
    ];

    let ratingsHtml = '';
    let greenCount = 0;
    let yellowCount = 0;
    let redCount = 0;
    components.forEach(comp => {
      const rating = (document.querySelector(`.component-rating[data-component="${comp.key}"]`) as HTMLSelectElement)?.value || 'Pass';
      const notes = (document.querySelector(`.component-notes[data-component="${comp.key}"]`) as HTMLTextAreaElement)?.value || '';
      let color = '#16a34a';
      let bg = '#dcfce7';
      let label = 'PASS';
      if (rating === 'Monitor') {
        color = '#ca8a04'; bg = '#fef9c3'; label = 'MONITOR'; yellowCount++;
      } else if (rating === 'Fail') {
        color = '#dc2626'; bg = '#fee2e2'; label = 'FAIL'; redCount++;
      } else {
        greenCount++;
      }
      ratingsHtml += `<tr>
        <td style="border:1px solid #ddd;padding:8px 12px;font-weight:600;">${comp.label}</td>
        <td style="border:1px solid #ddd;padding:8px 12px;text-align:center;"><span style="display:inline-block;padding:2px 12px;border-radius:4px;background:${bg};color:${color};font-weight:700;font-size:12px;text-transform:uppercase;">${label}</span></td>
        <td style="border:1px solid #ddd;padding:8px 12px;font-size:13px;color:#555;">${notes || '\u2014'}</td>
      </tr>`;
    });

    // Equipment age
    const installDate = getVal('install-date');
    let equipAge = '\u2014';
    if (installDate) {
      const install = new Date(installDate);
      const today = new Date();
      let years = today.getFullYear() - install.getFullYear();
      const md = today.getMonth() - install.getMonth();
      if (md < 0 || (md === 0 && today.getDate() < install.getDate())) years--;
      equipAge = years + (years === 1 ? ' year' : ' years');
    }

    // Activity observations for report (pest-control specific)

    // Findings
    const findingRows = document.querySelectorAll('.finding-row');
    let findingsHtml = '';
    let totalCost = 0;
    findingRows.forEach(row => {
      const desc = (row.querySelector('.finding-desc') as HTMLInputElement)?.value || '';
      const action = (row.querySelector('.finding-action') as HTMLInputElement)?.value || '';
      const cost = parseFloat((row.querySelector('.finding-cost') as HTMLInputElement)?.value) || 0;
      const priority = (row.querySelector('.finding-priority') as HTMLSelectElement)?.value || 'Medium';
      if (desc || action) {
        totalCost += cost;
        let priBg = '#e0f2e9'; let priColor = '#166534';
        if (priority === 'Immediate/Safety') { priBg = '#fee2e2'; priColor = '#991b1b'; }
        else if (priority === 'High') { priBg = '#fef3c7'; priColor = '#92400e'; }
        else if (priority === 'Medium') { priBg = '#dbeafe'; priColor = '#1e40af'; }
        findingsHtml += `<tr>
          <td style="border:1px solid #ddd;padding:8px 12px;">${desc}</td>
          <td style="border:1px solid #ddd;padding:8px 12px;">${action}</td>
          <td style="border:1px solid #ddd;padding:8px 12px;text-align:right;">$${cost.toLocaleString()}</td>
          <td style="border:1px solid #ddd;padding:8px 12px;text-align:center;"><span style="display:inline-block;padding:2px 10px;border-radius:4px;background:${priBg};color:${priColor};font-weight:600;font-size:11px;text-transform:uppercase;">${priority}</span></td>
        </tr>`;
      }
    });

    // Overall condition color
    const condition = getVal('overall-condition');
    let condColor = '#16a34a';
    if (condition === 'Fair') condColor = '#ca8a04';
    else if (condition === 'Poor' || condition === 'Failed') condColor = '#dc2626';

    // Overall assessment color
    const assessment = getVal('overall-assessment');
    let assessColor = '#16a34a';
    let assessBg = '#dcfce7';
    if (assessment === 'Conditional Pass') { assessColor = '#ca8a04'; assessBg = '#fef9c3'; }
    else if (assessment === 'Fail') { assessColor = '#dc2626'; assessBg = '#fee2e2'; }

    const html = `<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Pest Control Inspection Report ${getVal('report-number')}</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color:#1a1a1a; padding:40px; max-width:850px; margin:0 auto; font-size:14px; line-height:1.5; }
  h1 { font-size:22px; margin-bottom:4px; }
  h2 { font-size:15px; color:#333; margin:24px 0 8px; padding-bottom:4px; border-bottom:2px solid #e5e5e5; text-transform:uppercase; letter-spacing:0.5px; }
  .header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:20px; padding-bottom:16px; border-bottom:3px solid #1a1a1a; }
  .header-left { }
  .header-right { text-align:right; font-size:13px; color:#555; }
  .grid2 { display:grid; grid-template-columns:1fr 1fr; gap:4px 24px; margin-bottom:6px; }
  .grid3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:4px 24px; margin-bottom:6px; }
  .label { font-weight:600; font-size:12px; color:#666; text-transform:uppercase; letter-spacing:0.3px; }
  .value { font-size:14px; margin-bottom:6px; }
  table { width:100%; border-collapse:collapse; margin-bottom:8px; }
  th { background:#f0f0f0; border:1px solid #ddd; padding:8px 12px; text-align:left; font-size:12px; text-transform:uppercase; letter-spacing:0.3px; }
  td { border:1px solid #ddd; padding:8px 12px; }
  .summary-grid { display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:12px; margin:16px 0; }
  .summary-box { border:2px solid #e5e5e5; border-radius:8px; padding:16px; text-align:center; }
  .summary-box .num { font-size:28px; font-weight:800; }
  .summary-box .lbl { font-size:11px; color:#666; text-transform:uppercase; letter-spacing:0.5px; margin-top:4px; }
  .assess-badge { display:inline-block; padding:6px 20px; border-radius:6px; font-size:16px; font-weight:700; text-transform:uppercase; letter-spacing:1px; }
  .disclaimer { margin-top:30px; padding:16px; background:#f9f9f9; border-radius:6px; font-size:12px; color:#666; line-height:1.6; }
  .signature-block { display:grid; grid-template-columns:1fr 1fr; gap:40px; margin-top:40px; padding-top:16px; }
  .sig-line { border-top:1px solid #1a1a1a; padding-top:6px; font-size:12px; color:#666; text-transform:uppercase; }
  .sig-name { font-size:16px; font-weight:600; min-height:20px; }
  @media print { body { padding:20px; } }
</style>
</head><body>

<div class="header">
  <div class="header-left">
    <h1>Pest Control Inspection Report</h1>
    <div style="font-size:13px;color:#555;">${getVal('company-name') || 'Pest Control Inspection Services'}</div>
  </div>
  <div class="header-right">
    <div style="font-size:20px;font-weight:700;">${getVal('report-number')}</div>
    <div>${getVal('inspection-date')}</div>
    <div>${getVal('inspection-reason')}</div>
  </div>
</div>

<h2>Inspector Details</h2>
<div class="grid2">
