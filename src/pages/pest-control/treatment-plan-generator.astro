---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/pestControlTools';

const tool = getToolBySlug('treatment-plan-generator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much can I save with a new Pest Control system?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Savings depend on the efficiency gap between your current and new system, local energy prices, and climate. Replacing a 10 efficiency / 80% efficiency system with a 16 efficiency / 96% efficiency system typically saves $500 to $1,200 per year on a 3-ton unit. Hotter climates with more cooling hours see greater savings on the AC side, while colder climates benefit more from the system upgrade."
      }
    },
    {
      "@type": "Question",
      "name": "What efficiency rating should I get?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For most homeowners, 16 efficiency hits the sweet spot of upfront cost and long-term savings. In hot climates like the South or Southwest with 2,500+ cooling hours per year, 18-20 efficiency can pay back faster. In mild climates with under 1,500 cooling hours, 14-16 efficiency is usually sufficient. Always compare the payback period at different efficiency levels before deciding."
      }
    },
    {
      "@type": "Question",
      "name": "Is a higher efficiency always worth it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not always. Each efficiency point above 16 costs more per unit of efficiency gained, and the savings diminish. A jump from 10 to 16 efficiency cuts cooling costs by 37%, but going from 16 to 20 efficiency only saves an additional 12.5%. In mild climates with low cooling hours, the extra cost of a 20+ efficiency unit may never pay back. Run the comparison to see exact payback for your situation."
      }
    },
    {
      "@type": "Question",
      "name": "How long does a new AC take to pay for itself?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Payback periods typically range from 5 to 12 years depending on the efficiency jump, system size, local energy costs, and climate. A homeowner in the South upgrading from 10 efficiency to 16 efficiency on a 3-ton system often sees payback in 6-8 years. Utility rebates, manufacturer incentives, and federal tax credits can shorten that timeline significantly."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="energy-comp">
    <!-- Two-column system inputs -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <!-- Left Column: Current System -->
      <div class="bg-bg-card border border-border rounded-xl p-6">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-1">Your Current System</h3>
        <p class="text-text-muted text-xs mb-5">Enter your existing equipment specs</p>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="old-seer">efficiency Rating</label>
            <input type="number" id="old-seer" value="10" min="8" max="26" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
            <p class="text-text-muted text-xs mt-1">Don't know? Use 10 for 15+ year old systems</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="old-afue">efficiency %</label>
            <input type="number" id="old-afue" value="80" min="50" max="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
            <p class="text-text-muted text-xs mt-1">Don't know? Use 80% for older systems</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="system-age">System Age (years)</label>
            <input type="number" id="system-age" value="15" min="0" max="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
        </div>
      </div>

      <!-- Right Column: Proposed New System -->
      <div class="bg-bg-card border border-border rounded-xl p-6" style="border-color: rgba(255,107,43,0.3);">
        <h3 class="font-heading font-bold text-lg text-accent mb-1">Proposed New System</h3>
        <p class="text-text-muted text-xs mb-5">Enter the equipment you're quoting</p>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="new-seer">efficiency Rating</label>
            <input type="number" id="new-seer" value="16" min="13" max="26" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-1" for="new-afue">efficiency %</label>
            <input type="number" id="new-afue" value="96" min="50" max="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
        </div>
      </div>
    </div>

    <!-- Shared Inputs -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="tons">System Size (Tons)</label>
        <select id="tons" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="1.5">1.5 Ton</option>
          <option value="2">2 Ton</option>
          <option value="2.5">2.5 Ton</option>
          <option value="3" selected>3 Ton</option>
          <option value="3.5">3.5 Ton</option>
          <option value="4">4 Ton</option>
          <option value="5">5 Ton</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="elec-rate">Electricity Rate ($/kWh)</label>
        <input type="number" id="elec-rate" value="0.16" min="0.01" max="1" step="0.01" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="gas-rate">Gas Rate ($/therm)</label>
        <input type="number" id="gas-rate" value="1.20" min="0.10" max="5" step="0.05" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="region">Region</label>
        <select id="region" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="2500,600">South (2500 / 600 hrs)</option>
          <option value="2200,800">Southeast (2200 / 800 hrs)</option>
          <option value="1400,2000">Midwest (1400 / 2000 hrs)</option>
          <option value="1200,2200">Northeast (1200 / 2200 hrs)</option>
          <option value="2800,400">Southwest (2800 / 400 hrs)</option>
          <option value="800,1800">Northwest (800 / 1800 hrs)</option>
          <option value="2100,1500" selected>National Avg (2100 / 1500 hrs)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="upgrade-cost">Upgrade Cost ($)</label>
        <input type="number" id="upgrade-cost" value="8000" min="0" max="100000" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>


    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <!-- Side-by-side cost comparison -->
      <h3 class="font-heading font-bold text-xl mb-6">Annual Cost Comparison</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <!-- Current System Card -->
        <div class="bg-bg-card border border-border rounded-xl p-6">
          <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Current System</h4>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-text-secondary text-sm">Annual Cooling Cost</span>
              <span id="result-old-cooling" class="font-heading font-bold text-lg text-text-primary">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-text-secondary text-sm">Annual Heating Cost</span>
              <span id="result-old-heating" class="font-heading font-bold text-lg text-text-primary">--</span>
            </div>
            <div class="border-t border-border pt-3 flex justify-between items-center">
              <span class="text-text-primary font-medium">Total Annual Cost</span>
              <span id="result-old-total" class="font-heading font-extrabold text-2xl text-text-primary">--</span>
            </div>
          </div>
        </div>

        <!-- New System Card -->
        <div class="bg-bg-card border rounded-xl p-6" style="border-color: rgba(255,107,43,0.3);">
          <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-accent mb-4">New System</h4>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-text-secondary text-sm">Annual Cooling Cost</span>
              <span id="result-new-cooling" class="font-heading font-bold text-lg text-text-primary">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-text-secondary text-sm">Annual Heating Cost</span>
              <span id="result-new-heating" class="font-heading font-bold text-lg text-text-primary">--</span>
            </div>
            <div class="border-t border-border pt-3 flex justify-between items-center">
              <span class="text-text-primary font-medium">Total Annual Cost</span>
              <span id="result-new-total" class="font-heading font-extrabold text-2xl text-accent">--</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Visual bar chart comparison -->
      <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Annual Cost Comparison</h4>
        <div class="space-y-4">
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">Current System</span>
              <span id="bar-old-label" class="text-text-primary font-medium">--</span>
            </div>
            <div class="w-full bg-bg-dark rounded-full h-8 overflow-hidden">
              <div id="bar-old" class="h-full rounded-full transition-all duration-700 ease-out flex items-center justify-end pr-3" style="width: 100%; background: linear-gradient(90deg, #dc2626, #ef4444);">
                <span class="text-white text-xs font-bold whitespace-nowrap"></span>
              </div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-text-secondary">New System</span>
              <span id="bar-new-label" class="text-text-primary font-medium">--</span>
            </div>
            <div class="w-full bg-bg-dark rounded-full h-8 overflow-hidden">
              <div id="bar-new" class="h-full rounded-full transition-all duration-700 ease-out flex items-center justify-end pr-3" style="width: 50%; background: linear-gradient(90deg, #16a34a, #22c55e);">
                <span class="text-white text-xs font-bold whitespace-nowrap"></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Savings summary cards -->
      <h3 class="font-heading font-bold text-xl mb-6">Your Savings</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center border-2" style="border-color: rgba(255,107,43,0.4);">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Annual Savings</div>
          <div class="flex items-center justify-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
            <span id="result-annual" class="font-heading font-extrabold text-3xl text-accent">--</span>
          </div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Monthly Savings</div>
          <div id="result-monthly" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Payback Period</div>
          <div id="result-payback" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">10-Year Net Savings</div>
          <div id="result-tenyear" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>

      <!-- Environmental impact -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">CO2 Reduction</div>
          <div id="result-co2" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
          <div class="text-text-muted text-xs mt-1">lbs/year</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Environmental Impact</div>
          <div id="result-trees" class="font-heading font-extrabold text-2xl text-green-500">--</div>
          <div class="text-text-muted text-xs mt-1">equivalent trees planted per year</div>
        </div>
      </div>

      <p class="text-text-muted text-sm italic">Estimates based on average usage patterns. Actual savings depend on equipment condition, property condition, pest activity, and local environment. Consult with a licensed Pest Control contractor for a detailed energy audit.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Tool</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter the current system specs.</strong> Check the nameplate on the outdoor condenser for efficiency and the system data plate for efficiency. If the customer doesn't know, use 10 efficiency and 80% efficiency as safe defaults for systems over 15 years old.</p>
          <p><strong class="text-text-primary">2. Enter the proposed system specs.</strong> Use the efficiency and efficiency ratings from the equipment you're quoting. A 16 efficiency / 96% efficiency combination is a common mid-tier upgrade that shows strong savings.</p>
          <p><strong class="text-text-primary">3. Set the shared parameters.</strong> Select the system size in tons, enter the customer's electricity and gas rates from their utility bill, choose their region to auto-fill typical cooling and heating hours, and enter your quoted upgrade cost.</p>
          <p><strong class="text-text-primary">4. Review the side-by-side comparison.</strong> Show the customer the annual cost difference, payback period, and 10-year net savings. The visual bar chart makes the savings immediately obvious during a sales presentation.</p>
        </div>
      </section>

      <!-- Understanding efficiency and efficiency Ratings -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Understanding efficiency and efficiency Ratings</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">efficiency (Seasonal Energy Efficiency Ratio)</strong> measures cooling efficiency. It's the total BTU of heat removed per watt-hour of electricity consumed over a typical cooling season. A 10 efficiency system uses 60% more electricity than a 16 efficiency system to deliver the same cooling. The federal minimum is now 14 efficiency in northern states and 15 efficiency in the South. Higher efficiency means lower electric bills every summer.</p>
          <p><strong class="text-text-primary">efficiency (Annual Fuel Utilization Efficiency)</strong> measures how efficiently a gas system converts fuel to heat. An 80% efficiency system loses 20 cents of every dollar as exhaust waste. A 96% efficiency system captures nearly all of that energy, reducing gas consumption by 20% compared to the older unit. Standard-efficiency systems run at 80% efficiency, while high-efficiency condensing systems reach 95-98%.</p>
          <p><strong class="text-text-primary">Why higher is better:</strong> Both ratings work like miles per gallon for your Pest Control system. Higher numbers mean more output per unit of energy consumed. The difference compounds every month the system runs. In a hot climate, the efficiency upgrade drives most of the savings. In a cold climate, the efficiency improvement often matters more. This tool models both sides so you can show the customer exactly where their money goes.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm">
            <p>Cooling: kWh = (Tons x 12,000 x Cooling_Hours) / (efficiency x 1,000)</p>
            <p>Heating: Therms = (Tons x 12,000 x Heating_Hours) / (efficiency/100 x 100,000)</p>
          </div>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Sales presentations at the kitchen table.</strong> Pull this up on your tablet while sitting with the homeowner. Enter their current system specs on the left, your proposed equipment on the right, and let the visual comparison make the case. The side-by-side layout and bar chart are designed to be shown to customers, not just used behind the scenes.</p>
          <p><strong class="text-text-primary">Proposal support for premium equipment.</strong> When you're quoting a 16 efficiency system against a competitor's 14 efficiency bid, this tool proves the long-term value. Show the customer that paying more upfront saves thousands over 10 years. Screenshot the results and attach them to your written proposal for added credibility.</p>
          <p><strong class="text-text-primary">Customer education on repair vs. replace.</strong> When a customer asks whether to repair their 18-year-old system or replace it, run the comparison. If the annual savings alone cover a significant portion of the repair cost, replacement makes financial sense even before factoring in reliability improvements and reduced breakdown risk.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much can I save with a new Pest Control system?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Savings depend on the efficiency gap between your current and new system, local energy prices, and climate. Replacing a 10 efficiency / 80% efficiency system with a 16 efficiency / 96% efficiency system typically saves $500 to $1,200 per year on a 3-ton unit. Hotter climates with more cooling hours see greater savings on the AC side, while colder climates benefit more from the system upgrade.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What efficiency rating should I get?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">For most homeowners, 16 efficiency hits the sweet spot of upfront cost and long-term savings. In hot climates like the South or Southwest with 2,500+ cooling hours per year, 18-20 efficiency can pay back faster. In mild climates with under 1,500 cooling hours, 14-16 efficiency is usually sufficient. Always compare the payback period at different efficiency levels before deciding.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Is a higher efficiency always worth it?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Not always. Each efficiency point above 16 costs more per unit of efficiency gained, and the savings diminish. A jump from 10 to 16 efficiency cuts cooling costs by 37%, but going from 16 to 20 efficiency only saves an additional 12.5%. In mild climates with low cooling hours, the extra cost of a 20+ efficiency unit may never pay back. Run the comparison to see exact payback for your situation.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How long does a new AC take to pay for itself?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Payback periods typically range from 5 to 12 years depending on the efficiency jump, system size, local energy costs, and climate. A homeowner in the South upgrading from 10 efficiency to 16 efficiency on a 3-ton system often sees payback in 6-8 years. Utility rebates, manufacturer incentives, and federal tax credits can shorten that timeline significantly.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  const regions: Record<string, [number, number]> = {
    '2500,600': [2500, 600],
    '2200,800': [2200, 800],
    '1400,2000': [1400, 2000],
    '1200,2200': [1200, 2200],
    '2800,400': [2800, 400],
    '800,1800': [800, 1800],
    '2100,1500': [2100, 1500],
  };

  function formatCurrency(val: number): string {
    return '$' + val.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function calculate() {
    // Current system inputs
    const oldSeer = parseFloat((document.getElementById('old-seer') as HTMLInputElement).value) || 10;
    const oldAfue = parseFloat((document.getElementById('old-afue') as HTMLInputElement).value) || 80;

    // New system inputs
    const newSeer = parseFloat((document.getElementById('new-seer') as HTMLInputElement).value) || 16;
    const newAfue = parseFloat((document.getElementById('new-afue') as HTMLInputElement).value) || 96;

    // Shared inputs
    const tons = parseFloat((document.getElementById('tons') as HTMLSelectElement).value) || 3;
    const elecRate = parseFloat((document.getElementById('elec-rate') as HTMLInputElement).value) || 0.16;
    const gasRate = parseFloat((document.getElementById('gas-rate') as HTMLInputElement).value) || 1.20;
    const upgradeCost = parseFloat((document.getElementById('upgrade-cost') as HTMLInputElement).value) || 8000;

    // Get hours from region
    const regionVal = (document.getElementById('region') as HTMLSelectElement).value;
    const hours = regions[regionVal] || [2100, 1500];
    const coolHours = hours[0];
    const heatHours = hours[1];

    // Cooling calculations
    const oldCoolingKwh = (tons * 12000 * coolHours) / (oldSeer * 1000);
    const newCoolingKwh = (tons * 12000 * coolHours) / (newSeer * 1000);
    const oldCoolingCost = oldCoolingKwh * elecRate;
    const newCoolingCost = newCoolingKwh * elecRate;

    // Heating calculations (gas)
    const btuOutput = tons * 12000;
    const oldHeatCost = (btuOutput * heatHours) / ((oldAfue / 100) * 100000) * gasRate;
    const newHeatCost = (btuOutput * heatHours) / ((newAfue / 100) * 100000) * gasRate;

    // Totals
    const oldTotalCost = oldCoolingCost + oldHeatCost;
    const newTotalCost = newCoolingCost + newHeatCost;
    const annualSavings = oldTotalCost - newTotalCost;
    const monthlySavings = annualSavings / 12;
    const paybackYears = annualSavings > 0 ? upgradeCost / annualSavings : 0;
    const tenYearNet = (annualSavings * 10) - upgradeCost;

    // Environmental
    const co2Reduction = (oldCoolingKwh - newCoolingKwh) * 0.92;
    const treesEquivalent = co2Reduction / 48;

    // Update side-by-side cost cards
    document.getElementById('result-old-cooling')!.textContent = formatCurrency(Math.round(oldCoolingCost));
    document.getElementById('result-old-heating')!.textContent = formatCurrency(Math.round(oldHeatCost));
    document.getElementById('result-old-total')!.textContent = formatCurrency(Math.round(oldTotalCost));
    document.getElementById('result-new-cooling')!.textContent = formatCurrency(Math.round(newCoolingCost));
    document.getElementById('result-new-heating')!.textContent = formatCurrency(Math.round(newHeatCost));
    document.getElementById('result-new-total')!.textContent = formatCurrency(Math.round(newTotalCost));

    // Update bar chart
    const maxCost = Math.max(oldTotalCost, newTotalCost, 1);
    const oldBarPct = (oldTotalCost / maxCost) * 100;
    const newBarPct = (newTotalCost / maxCost) * 100;
    (document.getElementById('bar-old') as HTMLElement).style.width = oldBarPct + '%';
    (document.getElementById('bar-new') as HTMLElement).style.width = newBarPct + '%';
    document.getElementById('bar-old-label')!.textContent = formatCurrency(Math.round(oldTotalCost));
    document.getElementById('bar-new-label')!.textContent = formatCurrency(Math.round(newTotalCost));

    // Update savings summary
    document.getElementById('result-annual')!.textContent = formatCurrency(Math.round(annualSavings));
    document.getElementById('result-monthly')!.textContent = formatCurrency(Math.round(monthlySavings));
    document.getElementById('result-payback')!.textContent = paybackYears > 0 ? paybackYears.toFixed(1) + ' yrs' : 'N/A';
    document.getElementById('result-tenyear')!.textContent = formatCurrency(Math.round(tenYearNet));

    // Update environmental impact
    document.getElementById('result-co2')!.textContent = Math.round(co2Reduction).toLocaleString();
    document.getElementById('result-trees')!.textContent = Math.round(treesEquivalent).toLocaleString();

  }


  // Auto-calculate on any input change
  document.querySelectorAll('#energy-comp input, #energy-comp select').forEach(el => {
    el.addEventListener('change', calculate);
  });

  // Calculate on load with defaults
  calculate();
</script>
