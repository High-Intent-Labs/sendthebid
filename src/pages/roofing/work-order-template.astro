---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/roofingTools';

const tool = getToolBySlug('work-order-template')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should be on a roofing work order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A complete roofing work order includes dispatch info (date, crew lead, priority), customer details, roof information (type, manufacturer, pitch, layers), reported issue and diagnosis, work performed, materials used (shingles, underlayment, flashing), roof measurements (total squares, ridge LF, valley LF, eave LF, rake LF, penetrations), a fall protection safety checklist, and crew lead signature with arrival and completion times."
      }
    },
    {
      "@type": "Question",
      "name": "Why do I need to record roof measurements?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Roof measurements like total squares, ridge length, valley length, eave and rake linear feet, and penetration count document the roof's dimensions and complexity. These measurements are critical for accurate material ordering, manufacturer warranty registration, insurance claim documentation, and resolving disputes about project scope or billing."
      }
    },
    {
      "@type": "Question",
      "name": "Is detailed documentation required for roofing jobs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Maintaining detailed records is a best practice for every roofing job. Document all work performed, materials installed, and conditions found (rotted decking, ice dam damage). Thorough records protect you during disputes, are required for manufacturer warranty registration, satisfy insurance adjuster requirements, and provide a roof history that builds customer trust."
      }
    },
    {
      "@type": "Question",
      "name": "What safety documentation is needed for roofing work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Roofing safety documentation should include fall protection verification (harness, anchor points, guardrails), ladder inspection, weather condition assessment, PPE compliance, debris containment setup, and end-of-day site security. OSHA requires fall protection for all roofing work above 6 feet, and proper documentation demonstrates compliance during inspections."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="work-order-form">

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Dispatch Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="wo-number">Work Order #</label><input type="text" id="wo-number" value="WO-001" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="wo-date">Date</label><input type="date" id="wo-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="wo-time">Time</label><input type="time" id="wo-time" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="tech-name">Crew Lead</label><input type="text" id="tech-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="truck-number">Truck #</label><input type="text" id="truck-number" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="priority">Priority</label><select id="priority" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors"><option value="Routine" selected>Routine</option><option value="Urgent">Urgent</option><option value="Emergency">Emergency</option></select></div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Customer Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="cust-name">Customer Name</label><input type="text" id="cust-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="cust-address">Address</label><input type="text" id="cust-address" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="cust-phone">Phone</label><input type="text" id="cust-phone" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="access-instructions">Access Instructions</label><input type="text" id="access-instructions" placeholder="Gate code, lockbox, etc." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Roof Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="equip-type">Roof Type</label><select id="equip-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors"><option value="Asphalt Shingles">Asphalt Shingles</option><option value="Metal Roofing">Metal Roofing</option><option value="Tile Roofing">Tile Roofing</option><option value="Flat - TPO">Flat - TPO</option><option value="Flat - EPDM">Flat - EPDM</option><option value="Cedar Shake">Cedar Shake</option><option value="Slate">Slate</option></select></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="equip-make">Material Manufacturer</label><input type="text" id="equip-make" placeholder="GAF, Owens Corning..." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="equip-model">Product Line</label><input type="text" id="equip-model" placeholder="Timberline HDZ" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="equip-serial">Warranty Info</label><input type="text" id="equip-serial" placeholder="Lifetime limited" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="install-date">Install Date</label><input type="date" id="install-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="filter-size">Roof Pitch</label><input type="text" id="filter-size" placeholder="e.g., 6/12" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="refrigerant-type">Number of Layers</label><select id="refrigerant-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors"><option value="1 Layer" selected>1 Layer</option><option value="2 Layers">2 Layers</option><option value="3+ Layers">3+ Layers</option><option value="Unknown">Unknown</option></select></div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Service Details</h3>
    <div class="space-y-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="reported-issue">Reported Issue</label><textarea id="reported-issue" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="diagnosis">Roof Assessment</label><textarea id="diagnosis" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="work-performed">Work Performed</label><textarea id="work-performed" rows="4" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea></div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Materials Used</h3>
    <div class="mb-8">
      <div id="parts-table" class="space-y-3">
        <div class="grid grid-cols-[1fr_1fr_80px_40px] gap-3 items-end part-row">
          <div><label class="block text-sm font-medium text-text-secondary mb-2">Material Name</label><input type="text" class="part-name w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
          <div><label class="block text-sm font-medium text-text-secondary mb-2">SKU / Spec</label><input type="text" class="part-number w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
          <div><label class="block text-sm font-medium text-text-secondary mb-2">Qty</label><input type="number" value="1" min="1" class="part-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
          <div><label class="block text-sm font-medium text-text-secondary mb-2">&nbsp;</label><button type="button" class="remove-part-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove">&times;</button></div>
        </div>
      </div>
      <button type="button" id="add-part-btn" class="mt-3 text-accent hover:text-accent-hover transition-colors cursor-pointer text-sm font-medium">+ Add Material</button>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Materials Log</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="ref-added">Shingle Bundles Used</label><input type="number" id="ref-added" min="0" step="1" value="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="ref-recovered">Debris Removed (bags)</label><input type="number" id="ref-recovered" min="0" step="1" value="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Roof Measurements</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="total-squares">Total Squares</label><input type="number" id="total-squares" step="0.1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="ridge-lf">Ridge (LF)</label><input type="number" id="ridge-lf" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="valley-lf">Valley (LF)</label><input type="number" id="valley-lf" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="eave-lf">Eave (LF)</label><input type="number" id="eave-lf" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="rake-lf">Rake (LF)</label><input type="number" id="rake-lf" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="penetrations">Penetrations</label><input type="number" id="penetrations" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2">Total Linear Ft</label><div id="total-lf-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="pitch-factor">Pitch / Slope</label><input type="text" id="pitch-factor" placeholder="e.g., 6/12" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Safety Checklist</h3>
    <div class="space-y-3 mb-8">
      <div class="flex items-center gap-3"><input type="checkbox" id="chk-harness" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" /><label for="chk-harness" class="text-text-primary cursor-pointer">Fall Protection / Harness Worn</label></div>
      <div class="flex items-center gap-3"><input type="checkbox" id="chk-anchor" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" /><label for="chk-anchor" class="text-text-primary cursor-pointer">Anchor Points Secured</label></div>
      <div class="flex items-center gap-3"><input type="checkbox" id="chk-ladder" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" /><label for="chk-ladder" class="text-text-primary cursor-pointer">Ladder Secured / Inspected</label></div>
      <div class="flex items-center gap-3"><input type="checkbox" id="chk-weather" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" /><label for="chk-weather" class="text-text-primary cursor-pointer">Weather Conditions Safe</label></div>
      <div class="flex items-center gap-3"><input type="checkbox" id="chk-tarps" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" /><label for="chk-tarps" class="text-text-primary cursor-pointer">Ground Tarps / Debris Containment</label></div>
      <div class="flex items-center gap-3"><input type="checkbox" id="chk-cleanup" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" /><label for="chk-cleanup" class="text-text-primary cursor-pointer">Magnetic Nail Sweep Completed</label></div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Completion</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="time-arrived">Time Arrived</label><input type="time" id="time-arrived" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="time-completed">Time Completed</label><input type="time" id="time-completed" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2">Total Hours</label><div id="total-hours-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="tech-signature">Crew Lead Signature</label><input type="text" id="tech-signature" placeholder="Type full name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
    </div>

    <button id="generate-btn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">Generate Work Order &rarr;</button>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section><h2 class="font-heading font-bold text-2xl mb-4">How to Use This Template</h2><div class="text-text-secondary leading-relaxed space-y-3"><p><strong class="text-text-primary">1. Fill in dispatch and customer info.</strong> Start with the work order number, date, and crew lead. Add the customer's name, address, phone, and any access instructions.</p><p><strong class="text-text-primary">2. Identify the roof.</strong> Select the roof type, enter the manufacturer and product line. Record the pitch, number of layers, and warranty information.</p><p><strong class="text-text-primary">3. Document the service.</strong> Write what the customer reported, your roof assessment, and exactly what work was performed. Note any hidden damage found during tear-off.</p><p><strong class="text-text-primary">4. Record measurements and safety checks.</strong> Log total squares, ridge, valley, eave, and rake linear feet, plus penetration count. Run through the fall protection safety checklist.</p><p><strong class="text-text-primary">5. Generate the work order.</strong> Hit the button to create a clean, printable work order for your records, manufacturer warranty registration, or insurance documentation.</p></div></section>
      <section><h2 class="font-heading font-bold text-2xl mb-4">What Goes on a Roofing Work Order</h2><div class="text-text-secondary leading-relaxed space-y-3"><p>A work order is the single document that proves what happened on a job. Every section exists for a reason.</p><p><strong class="text-text-primary">Roof identification</strong> — type, manufacturer, product line, and warranty info — ties the documentation to a specific roof system. This information is essential for manufacturer warranty registration, insurance claims, and future service calls.</p><p><strong class="text-text-primary">Roof measurements</strong> document the scope of the roofing job. Total squares, ridge length, valley length, eave and rake linear feet, and penetration count tell the full story. If a customer disputes the scope, or an insurance adjuster needs verification, your measurements are the definitive record.</p><p><strong class="text-text-primary">Material tracking</strong> is essential for every roofing job. Recording shingle bundles, underlayment rolls, flashing, and ventilation installed protects you during billing disputes and is required for manufacturer warranty registration. Smart roofers document every material regardless of job size.</p><p><strong class="text-text-primary">The safety checklist</strong> is your liability shield. OSHA requires fall protection for all roofing work above 6 feet. Documenting harness use, anchor points, ladder security, and weather assessment shows compliance. If an accident or OSHA inspection occurs, that checklist is your first line of defense.</p><p><strong class="text-text-primary">Materials used</strong> with specs create a clear record for warranty registration, inventory management, and accurate invoicing.</p></div></section>
      <section><h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2><div class="text-text-secondary leading-relaxed space-y-3"><p><strong class="text-text-primary">Full roof replacements.</strong> Every tear-off and re-roof needs a detailed work order. The crew lead fills it out — materials installed, measurements taken, hidden damage found, and safety compliance. It becomes the permanent record for warranty registration and insurance documentation.</p><p><strong class="text-text-primary">Roof repairs and inspections.</strong> Leak repairs, storm damage fixes, and routine inspections all need a work order. Document the location of damage, repairs made, materials used, and measurements to provide a complete service history for the roof.</p><p><strong class="text-text-primary">Insurance and warranty documentation.</strong> When an insurance adjuster needs proof of damage scope, or when a manufacturer warranty claim requires installation records, the work order is your evidence. Complete records with measurements, materials, and photos eliminate disputes.</p></div></section>
      <section><h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2><div class="space-y-4">
        <details class="bg-bg-card border border-border rounded-lg"><summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should be on a roofing work order?</summary><div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A complete roofing work order includes dispatch info (date, crew lead, priority), customer details, roof information (type, manufacturer, pitch, layers), reported issue and diagnosis, work performed, materials used (shingles, underlayment, flashing), roof measurements (total squares, ridge LF, valley LF, eave LF, rake LF, penetrations), a fall protection safety checklist, and crew lead signature with arrival and completion times.</div></details>
        <details class="bg-bg-card border border-border rounded-lg"><summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why do I need to record roof measurements?</summary><div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Roof measurements like total squares, ridge length, valley length, eave and rake linear feet, and penetration count document the roof's dimensions and complexity. These measurements are critical for accurate material ordering, manufacturer warranty registration, insurance claim documentation, and resolving disputes about project scope or billing.</div></details>
        <details class="bg-bg-card border border-border rounded-lg"><summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Is detailed documentation required for roofing jobs?</summary><div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Yes. Maintaining detailed records is a best practice for every roofing job. Document all work performed, materials installed, and conditions found (rotted decking, ice dam damage). Thorough records protect you during disputes, are required for manufacturer warranty registration, satisfy insurance adjuster requirements, and provide a roof history that builds customer trust.</div></details>
        <details class="bg-bg-card border border-border rounded-lg"><summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What safety documentation is needed for roofing work?</summary><div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Roofing safety documentation should include fall protection verification (harness, anchor points, guardrails), ladder inspection, weather condition assessment, PPE compliance, debris containment setup, and end-of-day site security. OSHA requires fall protection for all roofing work above 6 feet, and proper documentation demonstrates compliance during inspections.</div></details>
      </div></section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  const now = new Date();
  const dateInput = document.getElementById('wo-date') as HTMLInputElement;
  const timeInput = document.getElementById('wo-time') as HTMLInputElement;
  if (dateInput && !dateInput.value) dateInput.value = now.toISOString().slice(0, 10);
  if (timeInput && !timeInput.value) timeInput.value = now.toTimeString().slice(0, 5);

  function updateTotalLF() {
    const ridge = parseFloat((document.getElementById('ridge-lf') as HTMLInputElement).value) || 0;
    const valley = parseFloat((document.getElementById('valley-lf') as HTMLInputElement).value) || 0;
    const eave = parseFloat((document.getElementById('eave-lf') as HTMLInputElement).value) || 0;
    const rake = parseFloat((document.getElementById('rake-lf') as HTMLInputElement).value) || 0;
    const display = document.getElementById('total-lf-display')!;
    if (ridge > 0 || valley > 0 || eave > 0 || rake > 0) {
      display.textContent = (ridge + valley + eave + rake).toLocaleString() + ' LF';
      display.className = 'w-full bg-bg-dark border border-green-500/50 rounded-lg px-4 py-3 text-lg font-bold text-green-400';
    } else { display.textContent = '\u2014'; display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted'; }
  }
  document.getElementById('ridge-lf')?.addEventListener('input', updateTotalLF);
  document.getElementById('valley-lf')?.addEventListener('input', updateTotalLF);
  document.getElementById('eave-lf')?.addEventListener('input', updateTotalLF);
  document.getElementById('rake-lf')?.addEventListener('input', updateTotalLF);

  function updateTotalHours() {
    const arrived = (document.getElementById('time-arrived') as HTMLInputElement).value;
    const completed = (document.getElementById('time-completed') as HTMLInputElement).value;
    const display = document.getElementById('total-hours-display')!;
    if (arrived && completed) { const [ah,am]=arrived.split(':').map(Number);const [ch,cm]=completed.split(':').map(Number);let t=(ch*60+cm)-(ah*60+am);if(t<0)t+=1440;display.textContent=Math.floor(t/60)+'h '+(t%60)+'m';display.className='w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-primary'; } else { display.textContent='\u2014';display.className='w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted'; }
  }
  document.getElementById('time-arrived')?.addEventListener('input', updateTotalHours);
  document.getElementById('time-completed')?.addEventListener('input', updateTotalHours);

  function addPartRow(){const t=document.getElementById('parts-table')!;const r=document.createElement('div');r.className='grid grid-cols-[1fr_1fr_80px_40px] gap-3 items-end part-row';r.innerHTML=`<div><input type="text" class="part-name w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div><div><input type="text" class="part-number w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div><div><input type="number" value="1" min="1" class="part-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div><div><button type="button" class="remove-part-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove">&times;</button></div>`;t.appendChild(r);}
  document.getElementById('add-part-btn')?.addEventListener('click', addPartRow);
  document.getElementById('parts-table')?.addEventListener('click',(e)=>{const t=e.target as HTMLElement;if(t.classList.contains('remove-part-btn')){const r=t.closest('.part-row');if(document.querySelectorAll('.part-row').length>1&&r)r.remove();}});

  function getVal(id:string):string{const el=document.getElementById(id) as HTMLInputElement|HTMLSelectElement|HTMLTextAreaElement|null;return el?el.value:'';}
  function getChecked(id:string):boolean{return(document.getElementById(id) as HTMLInputElement)?.checked||false;}

  function generateWorkOrder(){
    const partRows=document.querySelectorAll('.part-row');let partsHtml='';partRows.forEach(row=>{const n=(row.querySelector('.part-name') as HTMLInputElement)?.value||'';const p=(row.querySelector('.part-number') as HTMLInputElement)?.value||'';const q=(row.querySelector('.part-qty') as HTMLInputElement)?.value||'';if(n||p)partsHtml+=`<tr><td style="border:1px solid #ddd;padding:6px 10px;">${n}</td><td style="border:1px solid #ddd;padding:6px 10px;">${p}</td><td style="border:1px solid #ddd;padding:6px 10px;text-align:center;">${q}</td></tr>`;});

    const ridgeLF=parseFloat(getVal('ridge-lf'))||0;const valleyLF=parseFloat(getVal('valley-lf'))||0;const eaveLF=parseFloat(getVal('eave-lf'))||0;const rakeLF=parseFloat(getVal('rake-lf'))||0;
    const totalLF=ridgeLF+valleyLF+eaveLF+rakeLF;const totalLFStr=totalLF>0?totalLF.toLocaleString()+' LF':'';

    const arrived=getVal('time-arrived');const completed=getVal('time-completed');let totalHours='';
    if(arrived&&completed){const[ah,am]=arrived.split(':').map(Number);const[ch,cm]=completed.split(':').map(Number);let t=(ch*60+cm)-(ah*60+am);if(t<0)t+=1440;totalHours=Math.floor(t/60)+'h '+(t%60)+'m';}

    const safetyItems=[{id:'chk-harness',label:'Fall Protection / Harness Worn'},{id:'chk-anchor',label:'Anchor Points Secured'},{id:'chk-ladder',label:'Ladder Secured / Inspected'},{id:'chk-weather',label:'Weather Conditions Safe'},{id:'chk-tarps',label:'Ground Tarps / Debris Containment'},{id:'chk-cleanup',label:'Magnetic Nail Sweep Completed'}];
    let safetyHtml='';safetyItems.forEach(i=>{safetyHtml+=`<div style="margin-bottom:4px;">${getChecked(i.id)?'&#9745;':'&#9744;'} ${i.label}</div>`;});

    const html=`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Work Order ${getVal('wo-number')}</title><style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:#1a1a1a;padding:40px;max-width:850px;margin:0 auto;font-size:14px;line-height:1.5}h1{font-size:22px;margin-bottom:4px}h2{font-size:15px;color:#333;margin:20px 0 8px;padding-bottom:4px;border-bottom:2px solid #e5e5e5;text-transform:uppercase;letter-spacing:.5px}.header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;padding-bottom:16px;border-bottom:3px solid #1a1a1a}.header-right{text-align:right;font-size:13px;color:#555}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:4px 24px;margin-bottom:6px}.grid2 .label{font-weight:600;font-size:12px;color:#666;text-transform:uppercase;letter-spacing:.3px}.grid2 .value{font-size:14px;margin-bottom:6px}.text-block{margin-bottom:12px}.text-block .label{font-weight:600;font-size:12px;color:#666;text-transform:uppercase;letter-spacing:.3px;margin-bottom:2px}.text-block .value{font-size:14px;white-space:pre-wrap;background:#f9f9f9;padding:8px 10px;border-radius:4px;min-height:24px}table{width:100%;border-collapse:collapse;margin-bottom:8px}th{background:#f0f0f0;border:1px solid #ddd;padding:6px 10px;text-align:left;font-size:12px;text-transform:uppercase;letter-spacing:.3px}td{border:1px solid #ddd;padding:6px 10px}.readings-table td{text-align:center}.safety{font-size:14px}.signature-block{display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-top:40px;padding-top:16px}.sig-line{border-top:1px solid #1a1a1a;padding-top:6px;font-size:12px;color:#666;text-transform:uppercase}.sig-name{font-size:16px;font-weight:600;min-height:20px}.priority-badge{display:inline-block;padding:2px 10px;border-radius:4px;font-size:12px;font-weight:600;text-transform:uppercase}.priority-Routine{background:#e0f2e9;color:#166534}.priority-Urgent{background:#fef3c7;color:#92400e}.priority-Emergency{background:#fee2e2;color:#991b1b}@media print{body{padding:20px}}</style></head><body>
<div class="header"><div class="header-left"><h1>Roofing Work Order</h1><div style="font-size:13px;color:#555;">Service Documentation</div></div><div class="header-right"><div style="font-size:20px;font-weight:700;">\${getVal('wo-number')}</div><div>\${getVal('wo-date')}</div><div>\${getVal('wo-time')}</div><span class="priority-badge priority-\${getVal('priority')}">\${getVal('priority')}</span></div></div>
<h2>Dispatch</h2><div class="grid2"><div><span class="label">Crew Lead:</span></div><div><span class="label">Truck #:</span></div><div class="value">\${getVal('tech-name')||'\u2014'}</div><div class="value">\${getVal('truck-number')||'\u2014'}</div></div>
<h2>Customer</h2><div class="grid2"><div><span class="label">Name:</span></div><div><span class="label">Phone:</span></div><div class="value">\${getVal('cust-name')||'\u2014'}</div><div class="value">\${getVal('cust-phone')||'\u2014'}</div><div><span class="label">Address:</span></div><div><span class="label">Access:</span></div><div class="value">\${getVal('cust-address')||'\u2014'}</div><div class="value">\${getVal('access-instructions')||'\u2014'}</div></div>
<h2>Roof Info</h2><div class="grid2"><div><span class="label">Roof Type:</span></div><div><span class="label">Manufacturer:</span></div><div class="value">\${getVal('equip-type')}</div><div class="value">\${getVal('equip-make')||'\u2014'}</div><div><span class="label">Product Line:</span></div><div><span class="label">Warranty:</span></div><div class="value">\${getVal('equip-model')||'\u2014'}</div><div class="value">\${getVal('equip-serial')||'\u2014'}</div><div><span class="label">Install Date:</span></div><div><span class="label">Pitch:</span></div><div class="value">\${getVal('install-date')||'\u2014'}</div><div class="value">\${getVal('filter-size')||'\u2014'}</div><div><span class="label">Layers:</span></div><div></div><div class="value">\${getVal('refrigerant-type')}</div><div></div></div>
<h2>Service Details</h2><div class="text-block"><div class="label">Reported Issue</div><div class="value">\${getVal('reported-issue')||'\u2014'}</div></div><div class="text-block"><div class="label">Roof Assessment</div><div class="value">\${getVal('diagnosis')||'\u2014'}</div></div><div class="text-block"><div class="label">Work Performed</div><div class="value">\${getVal('work-performed')||'\u2014'}</div></div>
\${partsHtml?\`<h2>Materials Used</h2><table><thead><tr><th>Material</th><th>SKU / Spec</th><th style="text-align:center;">Qty</th></tr></thead><tbody>\${partsHtml}</tbody></table>\`:''}
<h2>Materials Log</h2><div class="grid2"><div><span class="label">Shingle Bundles:</span></div><div><span class="label">Debris Removed:</span></div><div class="value">\${getVal('ref-added')||'0'}</div><div class="value">\${getVal('ref-recovered')||'0'} bags</div></div>
<h2>Roof Measurements</h2><table class="readings-table"><thead><tr><th>Total Squares</th><th>Ridge LF</th><th>Valley LF</th><th>Eave LF</th></tr></thead><tbody><tr><td>\${getVal('total-squares')||'\u2014'}</td><td>\${getVal('ridge-lf')?getVal('ridge-lf')+' LF':'\u2014'}</td><td>\${getVal('valley-lf')?getVal('valley-lf')+' LF':'\u2014'}</td><td>\${getVal('eave-lf')?getVal('eave-lf')+' LF':'\u2014'}</td></tr></tbody></table><table class="readings-table" style="margin-top:8px;"><thead><tr><th>Rake LF</th><th>Penetrations</th><th>Total LF</th><th>Pitch</th></tr></thead><tbody><tr><td>\${getVal('rake-lf')?getVal('rake-lf')+' LF':'\u2014'}</td><td>\${getVal('penetrations')||'\u2014'}</td><td>\${totalLFStr||'\u2014'}</td><td>\${getVal('pitch-factor')||'\u2014'}</td></tr></tbody></table>
<h2>Safety Checklist</h2><div class="safety">\${safetyHtml}</div>
<h2>Completion</h2><div class="grid2"><div><span class="label">Time Arrived:</span></div><div><span class="label">Time Completed:</span></div><div class="value">\${arrived||'\u2014'}</div><div class="value">\${completed||'\u2014'}</div><div><span class="label">Total Hours:</span></div><div></div><div class="value">\${totalHours||'\u2014'}</div><div></div></div>
<div class="signature-block"><div><div class="sig-name">\${getVal('tech-signature')||''}</div><div class="sig-line">Crew Lead Signature</div></div><div><div class="sig-name">&nbsp;</div><div class="sig-line">Customer Signature</div></div></div>
</body></html>`;
    const w=window.open('','_blank');if(w){w.document.write(html);w.document.close();}
  }
  document.getElementById('generate-btn')?.addEventListener('click',generateWorkOrder);
</script>
