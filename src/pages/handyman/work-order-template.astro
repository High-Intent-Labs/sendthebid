---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/handymanTools';

const tool = getToolBySlug('work-order-template')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should be on a handyman work order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A complete handyman work order includes dispatch info (date, technician, priority), customer details, job information (category, location in property, scope summary), reported issue and diagnosis, work performed, materials and parts used with costs, job measurements (affected area, materials count, hardware count), a quality checklist, and technician signature with arrival and completion times."
      }
    },
    {
      "@type": "Question",
      "name": "Why do I need detailed work order documentation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Detailed work orders document the condition of the property and the exact work performed at the time of service. These records are critical for warranty claims on parts installed, verifying that work was completed to standard, tracking recurring issues at a property, and protecting your company from liability disputes about the quality or scope of work."
      }
    },
    {
      "@type": "Question",
      "name": "Is materials tracking important for handyman work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Tracking every material and part used on a job protects you during disputes, helps with accurate invoicing, and builds a service history for each customer. Detailed records make it easy to reorder supplies, verify warranty coverage on parts, and provide documentation if a customer questions a charge."
      }
    },
    {
      "@type": "Question",
      "name": "How long should a typical handyman service call take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most routine handyman service calls take 1 to 3 hours depending on the scope of work. Simple tasks like fixing a leaky faucet or mounting a TV take about 1 hour. Multi-task visits or moderate repairs like drywall patching and painting typically run 2 to 3 hours. Tracking arrival and completion times on every work order helps you estimate future jobs more accurately."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="work-order-form">

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Dispatch Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="wo-number">Work Order #</label><input type="text" id="wo-number" value="WO-001" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="wo-date">Date</label><input type="date" id="wo-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="wo-time">Time</label><input type="time" id="wo-time" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="tech-name">Technician Name</label><input type="text" id="tech-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="truck-number">Truck #</label><input type="text" id="truck-number" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="priority">Priority</label><select id="priority" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors"><option value="Routine" selected>Routine</option><option value="Urgent">Urgent</option><option value="Emergency">Emergency</option></select></div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Customer Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="cust-name">Customer Name</label><input type="text" id="cust-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="cust-address">Address</label><input type="text" id="cust-address" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="cust-phone">Phone</label><input type="text" id="cust-phone" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="access-instructions">Access Instructions</label><input type="text" id="access-instructions" placeholder="Gate code, lockbox, etc." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Job Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="equip-type">Job Category</label><select id="equip-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors"><option value="General Repair">General Repair</option><option value="Plumbing">Plumbing</option><option value="Electrical">Electrical</option><option value="Drywall / Painting">Drywall / Painting</option><option value="Carpentry">Carpentry</option><option value="Fixture Install">Fixture Install</option><option value="Other">Other</option></select></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="equip-make">Location in Property</label><input type="text" id="equip-make" placeholder="e.g., Kitchen, Master Bath" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="equip-model">Property Type</label><input type="text" id="equip-model" placeholder="e.g., Single Family, Condo" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="equip-serial">Reference / PO #</label><input type="text" id="equip-serial" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="install-date">Scheduled Date</label><input type="date" id="install-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="filter-size">Scope Summary</label><input type="text" id="filter-size" placeholder="e.g., Fix leak, mount TV, patch drywall" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Service Details</h3>
    <div class="space-y-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="reported-issue">Reported Issue</label><textarea id="reported-issue" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="diagnosis">Diagnosis</label><textarea id="diagnosis" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="work-performed">Work Performed</label><textarea id="work-performed" rows="4" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea></div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Parts Used</h3>
    <div class="mb-8">
      <div id="parts-table" class="space-y-3">
        <div class="grid grid-cols-[1fr_1fr_80px_40px] gap-3 items-end part-row">
          <div><label class="block text-sm font-medium text-text-secondary mb-2">Part Name</label><input type="text" class="part-name w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
          <div><label class="block text-sm font-medium text-text-secondary mb-2">Part #</label><input type="text" class="part-number w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
          <div><label class="block text-sm font-medium text-text-secondary mb-2">Qty</label><input type="number" value="1" min="1" class="part-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
          <div><label class="block text-sm font-medium text-text-secondary mb-2">&nbsp;</label><button type="button" class="remove-part-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove">&times;</button></div>
        </div>
      </div>
      <button type="button" id="add-part-btn" class="mt-3 text-accent hover:text-accent-hover transition-colors cursor-pointer text-sm font-medium">+ Add Part</button>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Materials Cost</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="ref-added">Materials Cost ($)</label><input type="number" id="ref-added" min="0" step="1" value="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="ref-recovered">Disposal / Hauling ($)</label><input type="number" id="ref-recovered" min="0" step="1" value="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Job Measurements</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="affected-sqft">Affected Area (sq ft)</label><input type="number" id="affected-sqft" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="length-ft">Length (ft)</label><input type="number" id="length-ft" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="width-ft">Width (ft)</label><input type="number" id="width-ft" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="height-ft">Height (ft)</label><input type="number" id="height-ft" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="materials-count">Materials Count</label><input type="number" id="materials-count" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="hardware-count">Hardware Count</label><input type="number" id="hardware-count" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2">Calculated Area (sq ft)</label><div id="calc-area-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="other-measurement">Other Measurement</label><input type="number" id="other-measurement" step="0.1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Quality Checklist</h3>
    <div class="space-y-3 mb-8">
      <div class="flex items-center gap-3"><input type="checkbox" id="chk-clean" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" /><label for="chk-clean" class="text-text-primary cursor-pointer">Work Area Clean</label><input type="text" id="chk-notes" placeholder="Notes" class="w-24 bg-bg-dark border border-border rounded-lg px-3 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" /></div>
      <div class="flex items-center gap-3"><input type="checkbox" id="chk-debris" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" /><label for="chk-debris" class="text-text-primary cursor-pointer">Debris Removed / Disposed</label></div>
      <div class="flex items-center gap-3"><input type="checkbox" id="chk-tested" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" /><label for="chk-tested" class="text-text-primary cursor-pointer">Functionality Tested</label></div>
      <div class="flex items-center gap-3"><input type="checkbox" id="chk-walkthrough" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" /><label for="chk-walkthrough" class="text-text-primary cursor-pointer">Customer Walked Through Work</label></div>
      <div class="flex items-center gap-3"><input type="checkbox" id="chk-photos" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" /><label for="chk-photos" class="text-text-primary cursor-pointer">Before / After Photos Taken</label></div>
      <div class="flex items-center gap-3"><input type="checkbox" id="chk-safety" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" /><label for="chk-safety" class="text-text-primary cursor-pointer">No Outstanding Safety Hazards</label></div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Completion</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="time-arrived">Time Arrived</label><input type="time" id="time-arrived" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="time-completed">Time Completed</label><input type="time" id="time-completed" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2">Total Hours</label><div id="total-hours-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="tech-signature">Technician Signature</label><input type="text" id="tech-signature" placeholder="Type full name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
    </div>

    <button id="generate-btn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">Generate Work Order &rarr;</button>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section><h2 class="font-heading font-bold text-2xl mb-4">How to Use This Template</h2><div class="text-text-secondary leading-relaxed space-y-3"><p><strong class="text-text-primary">1. Fill in dispatch and customer info.</strong> Start with the work order number, date, and technician assignment. Add the customer's name, address, phone, and any access instructions like gate codes or lockbox combos.</p><p><strong class="text-text-primary">2. Describe the job.</strong> Select the job category and enter the location within the property. Add a scope summary so the next tech has a complete picture.</p><p><strong class="text-text-primary">3. Document the service.</strong> Write what the customer reported, your diagnosis, and exactly what work you performed. Be specific -- vague notes cause problems during warranty claims and callbacks.</p><p><strong class="text-text-primary">4. Record measurements and run the quality checklist.</strong> Log any relevant measurements for the job. Run through the quality checklist to confirm the work area is clean and the customer is satisfied.</p><p><strong class="text-text-primary">5. Generate the work order.</strong> Hit the button to create a clean, printable work order. Have the customer review it, then use it for your records, warranty documentation, or office filing.</p></div></section>
      <section><h2 class="font-heading font-bold text-2xl mb-4">What Goes on a Handyman Work Order</h2><div class="text-text-secondary leading-relaxed space-y-3"><p>A work order is the single document that proves what happened on a job. Every section exists for a reason.</p><p><strong class="text-text-primary">Job identification</strong> -- category, location in property, and scope summary -- ties the documentation to a specific service visit. This information is essential for warranty claims, follow-up visits, and customer records.</p><p><strong class="text-text-primary">Job measurements</strong> document the scope and dimensions of the work completed. Lengths, areas, and quantities tell the full story. If a customer calls back two weeks later questioning the work, your measurements prove exactly what was done.</p><p><strong class="text-text-primary">Documentation</strong> is essential for every job. Detailed records of work performed, materials used, and before/after conditions protect both you and the customer. Smart contractors document everything regardless of job size.</p><p><strong class="text-text-primary">The quality checklist</strong> is your liability shield. Documenting that you cleaned the work area, tested functionality, and walked the customer through the completed work shows due diligence.</p><p><strong class="text-text-primary">Parts used</strong> with part numbers create a clear record for inventory management, warranty tracking, and accurate invoicing.</p></div></section>
      <section><h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2><div class="text-text-secondary leading-relaxed space-y-3"><p><strong class="text-text-primary">Service and repair calls.</strong> Every handyman visit needs a work order. The tech fills it out on site -- reported issue, diagnosis, work performed, parts used, and measurements. It becomes the permanent record of the visit and the basis for the invoice.</p><p><strong class="text-text-primary">Multi-task visits.</strong> When a customer has a punch list of items, the work order tracks each task completed, materials used for each, and total time on site. Over multiple visits, these records show the property's service history and help you plan future work.</p><p><strong class="text-text-primary">Warranty and callback documentation.</strong> When a customer disputes what was done or a part fails under warranty, the work order is your evidence. Complete work orders with measurements, parts, and signatures eliminate he-said-she-said situations.</p></div></section>
      <section><h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2><div class="space-y-4">
        <details class="bg-bg-card border border-border rounded-lg"><summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should be on a handyman work order?</summary><div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A complete handyman work order includes dispatch info (date, technician, priority), customer details, job information (category, location in property, scope summary), reported issue and diagnosis, work performed, materials and parts used with costs, job measurements (affected area, materials count, hardware count), a quality checklist, and technician signature with arrival and completion times.</div></details>
        <details class="bg-bg-card border border-border rounded-lg"><summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why do I need detailed work order documentation?</summary><div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Detailed work orders document the condition of the property and the exact work performed at the time of service. These records are critical for warranty claims on parts installed, verifying that work was completed to standard, tracking recurring issues at a property, and protecting your company from liability disputes about the quality or scope of work.</div></details>
        <details class="bg-bg-card border border-border rounded-lg"><summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Is materials tracking important for handyman work?</summary><div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Yes. Tracking every material and part used on a job protects you during disputes, helps with accurate invoicing, and builds a service history for each customer. Detailed records make it easy to reorder supplies, verify warranty coverage on parts, and provide documentation if a customer questions a charge.</div></details>
        <details class="bg-bg-card border border-border rounded-lg"><summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How long should a typical handyman service call take?</summary><div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most routine handyman service calls take 1 to 3 hours depending on the scope of work. Simple tasks like fixing a leaky faucet or mounting a TV take about 1 hour. Multi-task visits or moderate repairs like drywall patching and painting typically run 2 to 3 hours. Tracking arrival and completion times on every work order helps you estimate future jobs more accurately.</div></details>
      </div></section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  const now = new Date();
  const dateInput = document.getElementById('wo-date') as HTMLInputElement;
  const timeInput = document.getElementById('wo-time') as HTMLInputElement;
  if (dateInput && !dateInput.value) dateInput.value = now.toISOString().slice(0, 10);
  if (timeInput && !timeInput.value) timeInput.value = now.toTimeString().slice(0, 5);

  function updateCalcArea() {
    const len = parseFloat((document.getElementById('length-ft') as HTMLInputElement).value) || 0;
    const wid = parseFloat((document.getElementById('width-ft') as HTMLInputElement).value) || 0;
    const display = document.getElementById('calc-area-display')!;
    if (len > 0 && wid > 0) {
      display.textContent = (len * wid).toFixed(0) + ' sq ft';
      display.className = 'w-full bg-bg-dark border border-green-500/50 rounded-lg px-4 py-3 text-lg font-bold text-green-400';
    } else { display.textContent = '\u2014'; display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted'; }
  }
  document.getElementById('length-ft')?.addEventListener('input', updateCalcArea);
  document.getElementById('width-ft')?.addEventListener('input', updateCalcArea);

  function updateTotalHours() {
    const arrived = (document.getElementById('time-arrived') as HTMLInputElement).value;
    const completed = (document.getElementById('time-completed') as HTMLInputElement).value;
    const display = document.getElementById('total-hours-display')!;
    if (arrived && completed) { const[ah,am]=arrived.split(':').map(Number);const[ch,cm]=completed.split(':').map(Number);let t=(ch*60+cm)-(ah*60+am);if(t<0)t+=1440;display.textContent=Math.floor(t/60)+'h '+(t%60)+'m';display.className='w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-primary'; } else { display.textContent='\u2014';display.className='w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted'; }
  }
  document.getElementById('time-arrived')?.addEventListener('input', updateTotalHours);
  document.getElementById('time-completed')?.addEventListener('input', updateTotalHours);

  function addPartRow(){const t=document.getElementById('parts-table')!;const r=document.createElement('div');r.className='grid grid-cols-[1fr_1fr_80px_40px] gap-3 items-end part-row';r.innerHTML=`<div><input type="text" class="part-name w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div><div><input type="text" class="part-number w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div><div><input type="number" value="1" min="1" class="part-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div><div><button type="button" class="remove-part-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove">&times;</button></div>`;t.appendChild(r);}
  document.getElementById('add-part-btn')?.addEventListener('click', addPartRow);
  document.getElementById('parts-table')?.addEventListener('click',(e)=>{const t=e.target as HTMLElement;if(t.classList.contains('remove-part-btn')){const r=t.closest('.part-row');if(document.querySelectorAll('.part-row').length>1&&r)r.remove();}});

  function getVal(id:string):string{const el=document.getElementById(id) as HTMLInputElement|HTMLSelectElement|HTMLTextAreaElement|null;return el?el.value:'';}
  function getChecked(id:string):boolean{return(document.getElementById(id) as HTMLInputElement)?.checked||false;}

  function generateWorkOrder(){
    const partRows=document.querySelectorAll('.part-row');let partsHtml='';partRows.forEach(row=>{const n=(row.querySelector('.part-name') as HTMLInputElement)?.value||'';const p=(row.querySelector('.part-number') as HTMLInputElement)?.value||'';const q=(row.querySelector('.part-qty') as HTMLInputElement)?.value||'';if(n||p)partsHtml+=`<tr><td style="border:1px solid #ddd;padding:6px 10px;">${n}</td><td style="border:1px solid #ddd;padding:6px 10px;">${p}</td><td style="border:1px solid #ddd;padding:6px 10px;text-align:center;">${q}</td></tr>`;});

    const lenVal=parseFloat(getVal('length-ft'))||0;const widVal=parseFloat(getVal('width-ft'))||0;
    const calcArea=(lenVal>0&&widVal>0)?(lenVal*widVal).toFixed(0)+' sq ft':'';

    const arrived=getVal('time-arrived');const completed=getVal('time-completed');let totalHours='';
    if(arrived&&completed){const[ah,am]=arrived.split(':').map(Number);const[ch,cm]=completed.split(':').map(Number);let t=(ch*60+cm)-(ah*60+am);if(t<0)t+=1440;totalHours=Math.floor(t/60)+'h '+(t%60)+'m';}

    const safetyItems=[{id:'chk-clean',label:'Work Area Clean',extra:getVal('chk-notes')?' \u2014 '+getVal('chk-notes'):''},{id:'chk-debris',label:'Debris Removed / Disposed',extra:''},{id:'chk-tested',label:'Functionality Tested',extra:''},{id:'chk-walkthrough',label:'Customer Walked Through Work',extra:''},{id:'chk-photos',label:'Before / After Photos Taken',extra:''},{id:'chk-safety',label:'No Outstanding Safety Hazards',extra:''}];
    let safetyHtml='';safetyItems.forEach(i=>{safetyHtml+=`<div style="margin-bottom:4px;">${getChecked(i.id)?'&#9745;':'&#9744;'} ${i.label}${i.extra}</div>`;});

    const html=`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Work Order ${getVal('wo-number')}</title><style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:#1a1a1a;padding:40px;max-width:850px;margin:0 auto;font-size:14px;line-height:1.5}h1{font-size:22px;margin-bottom:4px}h2{font-size:15px;color:#333;margin:20px 0 8px;padding-bottom:4px;border-bottom:2px solid #e5e5e5;text-transform:uppercase;letter-spacing:.5px}.header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;padding-bottom:16px;border-bottom:3px solid #1a1a1a}.header-right{text-align:right;font-size:13px;color:#555}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:4px 24px;margin-bottom:6px}.grid2 .label{font-weight:600;font-size:12px;color:#666;text-transform:uppercase;letter-spacing:.3px}.grid2 .value{font-size:14px;margin-bottom:6px}.text-block{margin-bottom:12px}.text-block .label{font-weight:600;font-size:12px;color:#666;text-transform:uppercase;letter-spacing:.3px;margin-bottom:2px}.text-block .value{font-size:14px;white-space:pre-wrap;background:#f9f9f9;padding:8px 10px;border-radius:4px;min-height:24px}table{width:100%;border-collapse:collapse;margin-bottom:8px}th{background:#f0f0f0;border:1px solid #ddd;padding:6px 10px;text-align:left;font-size:12px;text-transform:uppercase;letter-spacing:.3px}td{border:1px solid #ddd;padding:6px 10px}.readings-table td{text-align:center}.safety{font-size:14px}.signature-block{display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-top:40px;padding-top:16px}.sig-line{border-top:1px solid #1a1a1a;padding-top:6px;font-size:12px;color:#666;text-transform:uppercase}.sig-name{font-size:16px;font-weight:600;min-height:20px}.priority-badge{display:inline-block;padding:2px 10px;border-radius:4px;font-size:12px;font-weight:600;text-transform:uppercase}.priority-Routine{background:#e0f2e9;color:#166534}.priority-Urgent{background:#fef3c7;color:#92400e}.priority-Emergency{background:#fee2e2;color:#991b1b}@media print{body{padding:20px}}</style></head><body>
<div class="header"><div class="header-left"><h1>Handyman Work Order</h1><div style="font-size:13px;color:#555;">Service Documentation</div></div><div class="header-right"><div style="font-size:20px;font-weight:700;">\${getVal('wo-number')}</div><div>\${getVal('wo-date')}</div><div>\${getVal('wo-time')}</div><span class="priority-badge priority-\${getVal('priority')}">\${getVal('priority')}</span></div></div>
<h2>Dispatch</h2><div class="grid2"><div><span class="label">Technician:</span></div><div><span class="label">Truck #:</span></div><div class="value">\${getVal('tech-name')||'\u2014'}</div><div class="value">\${getVal('truck-number')||'\u2014'}</div></div>
<h2>Customer</h2><div class="grid2"><div><span class="label">Name:</span></div><div><span class="label">Phone:</span></div><div class="value">\${getVal('cust-name')||'\u2014'}</div><div class="value">\${getVal('cust-phone')||'\u2014'}</div><div><span class="label">Address:</span></div><div><span class="label">Access:</span></div><div class="value">\${getVal('cust-address')||'\u2014'}</div><div class="value">\${getVal('access-instructions')||'\u2014'}</div></div>
<h2>Job Info</h2><div class="grid2"><div><span class="label">Category:</span></div><div><span class="label">Location:</span></div><div class="value">\${getVal('equip-type')}</div><div class="value">\${getVal('equip-make')||'\u2014'}</div><div><span class="label">Property Type:</span></div><div><span class="label">Reference #:</span></div><div class="value">\${getVal('equip-model')||'\u2014'}</div><div class="value">\${getVal('equip-serial')||'\u2014'}</div><div><span class="label">Scheduled:</span></div><div><span class="label">Scope:</span></div><div class="value">\${getVal('install-date')||'\u2014'}</div><div class="value">\${getVal('filter-size')||'\u2014'}</div></div>
<h2>Service Details</h2><div class="text-block"><div class="label">Reported Issue</div><div class="value">\${getVal('reported-issue')||'\u2014'}</div></div><div class="text-block"><div class="label">Diagnosis</div><div class="value">\${getVal('diagnosis')||'\u2014'}</div></div><div class="text-block"><div class="label">Work Performed</div><div class="value">\${getVal('work-performed')||'\u2014'}</div></div>
\${partsHtml?\`<h2>Parts Used</h2><table><thead><tr><th>Part Name</th><th>Part #</th><th style="text-align:center;">Qty</th></tr></thead><tbody>\${partsHtml}</tbody></table>\`:''}
<h2>Materials Cost</h2><div class="grid2"><div><span class="label">Materials:</span></div><div><span class="label">Disposal:</span></div><div class="value">$\${getVal('ref-added')||'0'}</div><div class="value">$\${getVal('ref-recovered')||'0'}</div></div>
<h2>Job Measurements</h2><table class="readings-table"><thead><tr><th>Affected Area</th><th>Length</th><th>Width</th><th>Height</th></tr></thead><tbody><tr><td>\${getVal('affected-sqft')?getVal('affected-sqft')+' sq ft':'\u2014'}</td><td>\${getVal('length-ft')?getVal('length-ft')+' ft':'\u2014'}</td><td>\${getVal('width-ft')?getVal('width-ft')+' ft':'\u2014'}</td><td>\${getVal('height-ft')?getVal('height-ft')+' ft':'\u2014'}</td></tr></tbody></table><table class="readings-table" style="margin-top:8px;"><thead><tr><th>Materials Count</th><th>Hardware Count</th><th>Calc. Area</th><th>Other</th></tr></thead><tbody><tr><td>\${getVal('materials-count')||'\u2014'}</td><td>\${getVal('hardware-count')||'\u2014'}</td><td>\${calcArea||'\u2014'}</td><td>\${getVal('other-measurement')||'\u2014'}</td></tr></tbody></table>
<h2>Quality Checklist</h2><div class="safety">\${safetyHtml}</div>
<h2>Completion</h2><div class="grid2"><div><span class="label">Time Arrived:</span></div><div><span class="label">Time Completed:</span></div><div class="value">\${arrived||'\u2014'}</div><div class="value">\${completed||'\u2014'}</div><div><span class="label">Total Hours:</span></div><div></div><div class="value">\${totalHours||'\u2014'}</div><div></div></div>
<div class="signature-block"><div><div class="sig-name">\${getVal('tech-signature')||''}</div><div class="sig-line">Technician Signature</div></div><div><div class="sig-name">&nbsp;</div><div class="sig-line">Customer Signature</div></div></div>
</body></html>`;
    const w=window.open('','_blank');if(w){w.document.write(html);w.document.close();}
  }
  document.getElementById('generate-btn')?.addEventListener('click',generateWorkOrder);
</script>
