---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/cleaningTools';

const tool = getToolBySlug('work-order-template')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should be on a cleaning work order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A complete cleaning work order includes dispatch info (date, cleaner assigned, priority), customer details (name, address, phone, access instructions), job details (service type, number of rooms, square footage, special instructions), a room-by-room task checklist, supplies used with quantities, a quality checklist, before and after condition notes, time tracking with arrival and departure times, and a customer sign-off section."
      }
    },
    {
      "@type": "Question",
      "name": "Why should I document supplies used on a cleaning work order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tracking supplies used on each job helps you calculate true job costs, manage inventory, and reorder before you run out. It also identifies which jobs consume more product than average so you can adjust pricing. For commercial contracts, supply documentation may be required to verify that approved products were used, especially in medical or food service environments."
      }
    },
    {
      "@type": "Question",
      "name": "How do I handle customer sign-off on a cleaning work order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Have the customer do a walkthrough after the clean is complete and sign off on the work order before you leave. This confirms they are satisfied with the service and protects you from disputes later. If the customer is not home, note it on the work order and send them a digital copy with photos. Many cleaning companies use before and after photos as a substitute for in-person sign-off."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between a work order and an invoice?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A work order documents what work was performed, how long it took, and what supplies were used. It is the service record for the job. An invoice is the billing document that tells the customer what they owe. The work order feeds the invoice — once you know what was done, you can generate an accurate bill. Many cleaning companies generate both from the same job visit, using the work order details to populate the invoice automatically."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="work-order-form">

    <!-- Section: Dispatch Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Dispatch Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-number">Work Order #</label>
        <input type="text" id="wo-number" value="WO-001" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-date">Date</label>
        <input type="date" id="wo-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cleaner-name">Cleaner Assigned</label>
        <input type="text" id="cleaner-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="priority">Priority</label>
        <select id="priority" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Routine" selected>Routine</option>
          <option value="Urgent">Urgent</option>
          <option value="Same-Day">Same-Day</option>
        </select>
      </div>
    </div>

    <!-- Section: Customer Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Customer Details</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-name">Customer Name</label>
        <input type="text" id="cust-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-phone">Phone</label>
        <input type="text" id="cust-phone" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-address">Address</label>
        <input type="text" id="cust-address" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="property-type">Property Type</label>
        <select id="property-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="House">House</option>
          <option value="Apartment">Apartment</option>
          <option value="Condo">Condo</option>
          <option value="Townhouse">Townhouse</option>
          <option value="Office">Office</option>
          <option value="Retail">Retail</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="access-instructions">Access Instructions</label>
        <input type="text" id="access-instructions" placeholder="Gate code, lockbox, key under mat..." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Job Details -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Job Details</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="service-type">Service Type</label>
        <select id="service-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Standard Clean">Standard Clean</option>
          <option value="Deep Clean">Deep Clean</option>
          <option value="Move-Out Clean">Move-Out Clean</option>
          <option value="Post-Construction">Post-Construction</option>
          <option value="Commercial Clean">Commercial Clean</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="num-bedrooms"># Bedrooms</label>
        <input type="number" id="num-bedrooms" min="0" max="20" value="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="num-bathrooms"># Bathrooms</label>
        <input type="number" id="num-bathrooms" min="0" max="20" step="0.5" value="2" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="sqft">Square Footage</label>
        <input type="number" id="sqft" min="0" step="100" placeholder="e.g. 1800" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div class="md:col-span-2 lg:col-span-4">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="special-instructions">Special Instructions</label>
        <textarea id="special-instructions" rows="2" placeholder="Pet hair focus, skip master bedroom, use green products only..." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
    </div>

    <!-- Section: Room-by-Room Tasks -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Room-by-Room Task Checklist</h3>
    <div class="space-y-6 mb-8">

      <!-- Kitchen -->
      <div class="bg-bg-dark rounded-lg p-4">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-3">Kitchen</h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Counters and backsplash wiped</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Stovetop and range hood cleaned</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Appliance exteriors wiped</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Sink and faucet sanitized</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Floor swept and mopped</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Trash emptied</span></label>
        </div>
      </div>

      <!-- Bathrooms -->
      <div class="bg-bg-dark rounded-lg p-4">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-3">Bathrooms</h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Toilets scrubbed and sanitized</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Sinks and counters cleaned</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Mirrors and glass cleaned</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Shower/tub surfaces wiped</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Fixtures polished</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Floor swept and mopped</span></label>
        </div>
      </div>

      <!-- Bedrooms -->
      <div class="bg-bg-dark rounded-lg p-4">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-3">Bedrooms</h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">All surfaces dusted</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Beds made and linens straightened</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Mirrors and glass cleaned</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Floors vacuumed or mopped</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Trash emptied</span></label>
        </div>
      </div>

      <!-- Living Areas -->
      <div class="bg-bg-dark rounded-lg p-4">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-3">Living Areas</h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">All surfaces dusted</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Electronics wiped (dry cloth)</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Cushions and pillows straightened</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Floors vacuumed or mopped</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Trash emptied</span></label>
        </div>
      </div>

      <!-- Laundry Room -->
      <div class="bg-bg-dark rounded-lg p-4">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-3">Laundry Room</h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Washer/dryer exteriors wiped</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Surfaces and folding area wiped</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Floor swept and mopped</span></label>
        </div>
      </div>

      <!-- Entryway / Hallways -->
      <div class="bg-bg-dark rounded-lg p-4">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-3">Entryway &amp; Hallways</h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Door and handles wiped</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Surfaces dusted</span></label>
          <label class="flex items-center gap-2 cursor-pointer group"><input type="checkbox" class="room-check w-4 h-4 rounded border-border bg-bg-dark text-accent focus:ring-accent" /><span class="text-sm text-text-secondary group-hover:text-text-primary transition-colors">Floors vacuumed or swept</span></label>
        </div>
      </div>
    </div>

    <!-- Section: Supplies Used -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Supplies Used</h3>
    <div class="mb-8">
      <div class="hidden md:grid grid-cols-[1fr_80px_40px] gap-3 mb-2 px-1">
        <span class="text-text-muted text-xs font-medium uppercase tracking-wider">Item</span>
        <span class="text-text-muted text-xs font-medium uppercase tracking-wider">Qty</span>
        <span></span>
      </div>
      <div id="supplies-table" class="space-y-3">
        <div class="grid grid-cols-[1fr_80px_40px] gap-3 items-end supply-row">
          <div>
            <label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Item</label>
            <input type="text" placeholder="e.g. All-purpose cleaner" class="supply-name w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Qty</label>
            <input type="text" value="1" class="supply-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg text-center focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <button type="button" class="remove-supply-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove">&times;</button>
          </div>
        </div>
      </div>
      <button type="button" id="add-supply-btn" class="mt-3 text-accent hover:text-accent-hover transition-colors cursor-pointer text-sm font-medium">+ Add Supply</button>
    </div>

    <!-- Section: Quality Checklist -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Quality Checklist</h3>
    <div class="space-y-3 mb-8">
      <label class="flex items-center gap-3 cursor-pointer group">
        <input type="checkbox" id="qc-surfaces" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent" />
        <span class="text-text-secondary group-hover:text-text-primary transition-colors">All surfaces dusted and wiped</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer group">
        <input type="checkbox" id="qc-floors" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent" />
        <span class="text-text-secondary group-hover:text-text-primary transition-colors">All floors vacuumed and/or mopped</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer group">
        <input type="checkbox" id="qc-bathrooms" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent" />
        <span class="text-text-secondary group-hover:text-text-primary transition-colors">Bathrooms fully sanitized</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer group">
        <input type="checkbox" id="qc-kitchen" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent" />
        <span class="text-text-secondary group-hover:text-text-primary transition-colors">Kitchen cleaned and appliances wiped</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer group">
        <input type="checkbox" id="qc-trash" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent" />
        <span class="text-text-secondary group-hover:text-text-primary transition-colors">All trash removed and liners replaced</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer group">
        <input type="checkbox" id="qc-supplies" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent" />
        <span class="text-text-secondary group-hover:text-text-primary transition-colors">Cleaning supplies restocked in caddy</span>
      </label>
    </div>

    <!-- Section: Before/After Condition Notes -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Condition Notes</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="before-notes">Before (Arrival Condition)</label>
        <textarea id="before-notes" rows="3" placeholder="Note any pre-existing damage, heavy soiling, pest issues, etc." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="after-notes">After (Departure Condition)</label>
        <textarea id="after-notes" rows="3" placeholder="Note any areas needing follow-up, items left for client, etc." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
    </div>

    <!-- Section: Time Tracking -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Time Tracking</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="time-arrived">Arrival Time</label>
        <input type="time" id="time-arrived" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="time-departed">Departure Time</label>
        <input type="time" id="time-departed" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2">Total Time</label>
        <div id="total-time-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div>
      </div>
    </div>

    <!-- Section: Customer Sign-off -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Customer Sign-off</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cleaner-signature">Cleaner Signature</label>
        <input type="text" id="cleaner-signature" placeholder="Type full name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customer-signature">Customer Signature</label>
        <input type="text" id="customer-signature" placeholder="Type full name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div class="md:col-span-2">
        <label class="flex items-center gap-3 cursor-pointer group">
          <input type="checkbox" id="customer-satisfied" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Customer confirms satisfaction with cleaning service</span>
        </label>
      </div>
    </div>

    <!-- Generate Button -->
    <button id="generate-btn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
      Generate Work Order &rarr;
    </button>
    <p class="text-text-muted text-sm italic mt-3">Opens a print-ready work order in a new window. Use your browser's print dialog to save as PDF.</p>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Template</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Fill in dispatch and customer info.</strong> Start with the work order number, date, and cleaner assignment. Add the customer's name, address, phone, property type, and any access instructions like gate codes or lockbox combos.</p>
          <p><strong class="text-text-primary">2. Set the job scope.</strong> Select the service type, enter the number of bedrooms and bathrooms, estimated square footage, and any special instructions from the client. This gives the cleaner a clear picture of what is expected.</p>
          <p><strong class="text-text-primary">3. Check off room tasks as you clean.</strong> Work through the room-by-room checklist during the job. Each room has the core tasks for a standard clean. Check them off as you complete each area.</p>
          <p><strong class="text-text-primary">4. Log supplies and complete the quality check.</strong> Record which supplies and how much you used. Then run through the quality checklist before you leave to make sure nothing was missed.</p>
          <p><strong class="text-text-primary">5. Generate the work order.</strong> Hit the button to create a clean, printable work order. Have the customer review and sign off, then use it for your records or office filing.</p>
        </div>
      </section>

      <!-- What Goes on a Work Order -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Goes on a Cleaning Work Order</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>A work order is the single document that proves what happened on a job. Every section exists for a reason.</p>
          <p><strong class="text-text-primary">Job identification</strong> ties the work order to a specific visit. The work order number, date, cleaner name, and customer details create an audit trail. If a customer calls back about an issue, you can pull up exactly who was there, when, and what was done.</p>
          <p><strong class="text-text-primary">The room-by-room checklist</strong> ensures consistency. Whether it is your best cleaner or a new hire, the checklist guarantees every room gets the same attention. It also protects you from disputes. When a client says the bathrooms were not cleaned, the checked-off work order tells the real story.</p>
          <p><strong class="text-text-primary">Supplies tracking</strong> feeds your cost analysis. When you know how much product each job consumes, you can price accurately, manage inventory, and identify jobs that eat more supplies than they should. Over time, this data shows you where your margins are strongest.</p>
          <p><strong class="text-text-primary">Customer sign-off</strong> is your proof of satisfaction. Having the client confirm the work was completed to their standards before you leave eliminates the most common disputes in the cleaning business. No signature means the conversation happened in person.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Every cleaning job.</strong> Whether it is a standard weekly maintenance clean or a one-time deep clean, every visit should have a work order. It takes five minutes to fill out and saves hours of back-and-forth if something comes up later.</p>
          <p><strong class="text-text-primary">Move-out and post-construction cleans.</strong> These high-stakes jobs need thorough documentation. Before and after condition notes protect you from damage claims, and the detailed task checklist ensures nothing gets missed in a property that may be inspected by landlords or general contractors.</p>
          <p><strong class="text-text-primary">Teams without cleaning management software.</strong> If you are a solo cleaner or small team and do not use ZenMaid, Launch27, or similar platforms, this template gives you professional documentation at no cost. Generate a PDF for every job and build a filing system that keeps you organized as you grow.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should be on a cleaning work order?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A complete cleaning work order includes dispatch info (date, cleaner assigned, priority), customer details (name, address, phone, access instructions), job details (service type, number of rooms, square footage, special instructions), a room-by-room task checklist, supplies used with quantities, a quality checklist, before and after condition notes, time tracking with arrival and departure times, and a customer sign-off section.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why should I document supplies used on a cleaning work order?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Tracking supplies used on each job helps you calculate true job costs, manage inventory, and reorder before you run out. It also identifies which jobs consume more product than average so you can adjust pricing. For commercial contracts, supply documentation may be required to verify that approved products were used, especially in medical or food service environments.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I handle customer sign-off on a cleaning work order?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Have the customer do a walkthrough after the clean is complete and sign off on the work order before you leave. This confirms they are satisfied with the service and protects you from disputes later. If the customer is not home, note it on the work order and send them a digital copy with photos. Many cleaning companies use before and after photos as a substitute for in-person sign-off.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is the difference between a work order and an invoice?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A work order documents what work was performed, how long it took, and what supplies were used. It is the service record for the job. An invoice is the billing document that tells the customer what they owe. The work order feeds the invoice — once you know what was done, you can generate an accurate bill. Many cleaning companies generate both from the same job visit, using the work order details to populate the invoice automatically.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // --- Default date ---
    const now = new Date();
    const dateInput = document.getElementById('wo-date') as HTMLInputElement;
    if (dateInput && !dateInput.value) {
      dateInput.value = now.toISOString().slice(0, 10);
    }

    // --- Total Time auto-calculation ---
    function updateTotalTime() {
      const arrived = (document.getElementById('time-arrived') as HTMLInputElement).value;
      const departed = (document.getElementById('time-departed') as HTMLInputElement).value;
      const display = document.getElementById('total-time-display')!;
      if (arrived && departed) {
        const [ah, am] = arrived.split(':').map(Number);
        const [dh, dm] = departed.split(':').map(Number);
        let totalMinutes = (dh * 60 + dm) - (ah * 60 + am);
        if (totalMinutes < 0) totalMinutes += 24 * 60;
        const hours = Math.floor(totalMinutes / 60);
        const minutes = totalMinutes % 60;
        display.textContent = hours + 'h ' + minutes + 'm';
        display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-primary';
      } else {
        display.textContent = '\u2014';
        display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted';
      }
    }
    document.getElementById('time-arrived')?.addEventListener('input', updateTotalTime);
    document.getElementById('time-departed')?.addEventListener('input', updateTotalTime);

    // --- Dynamic Supplies Table ---
    function addSupplyRow() {
      const table = document.getElementById('supplies-table')!;
      const row = document.createElement('div');
      row.className = 'grid grid-cols-[1fr_80px_40px] gap-3 items-end supply-row';
      row.innerHTML = `
        <div>
          <label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Item</label>
          <input type="text" placeholder="e.g. Glass cleaner" class="supply-name w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Qty</label>
          <input type="text" value="1" class="supply-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg text-center focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <button type="button" class="remove-supply-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove">&times;</button>
        </div>
      `;
      table.appendChild(row);
    }

    document.getElementById('add-supply-btn')?.addEventListener('click', addSupplyRow);

    document.getElementById('supplies-table')?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains('remove-supply-btn')) {
        const row = target.closest('.supply-row');
        const allRows = document.querySelectorAll('.supply-row');
        if (allRows.length > 1 && row) {
          row.remove();
        }
      }
    });

    // --- Helper functions ---
    function getVal(id: string): string {
      const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
      return el ? el.value : '';
    }
    function getChecked(id: string): boolean {
      return (document.getElementById(id) as HTMLInputElement)?.checked || false;
    }
    function escapeHtml(str: string): string {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // --- Generate Work Order ---
    function generateWorkOrder() {
      // Collect supplies
      const supplyRows = document.querySelectorAll('.supply-row');
      let suppliesHtml = '';
      supplyRows.forEach(row => {
        const name = (row.querySelector('.supply-name') as HTMLInputElement)?.value || '';
        const qty = (row.querySelector('.supply-qty') as HTMLInputElement)?.value || '';
        if (name) {
          suppliesHtml += `<tr><td style="border:1px solid #ddd;padding:6px 10px;">${escapeHtml(name)}</td><td style="border:1px solid #ddd;padding:6px 10px;text-align:center;">${escapeHtml(qty)}</td></tr>`;
        }
      });

      // Room tasks
      const roomSections = document.querySelectorAll('#work-order-form .bg-bg-dark.rounded-lg.p-4');
      let roomTasksHtml = '';
      roomSections.forEach(section => {
        const title = section.querySelector('h4')?.textContent || '';
        const checks = section.querySelectorAll<HTMLInputElement>('.room-check');
        let tasksHtml = '';
        checks.forEach(cb => {
          const label = cb.closest('label')?.querySelector('span')?.textContent || '';
          const mark = cb.checked ? '&#9745;' : '&#9744;';
          tasksHtml += `<div style="margin-bottom:2px;">${mark} ${escapeHtml(label)}</div>`;
        });
        roomTasksHtml += `<div style="margin-bottom:12px;"><div style="font-weight:700;font-size:13px;text-transform:uppercase;color:#555;margin-bottom:4px;">${escapeHtml(title)}</div>${tasksHtml}</div>`;
      });

      // Quality checklist
      const qcItems = [
        { id: 'qc-surfaces', label: 'All surfaces dusted and wiped' },
        { id: 'qc-floors', label: 'All floors vacuumed and/or mopped' },
        { id: 'qc-bathrooms', label: 'Bathrooms fully sanitized' },
        { id: 'qc-kitchen', label: 'Kitchen cleaned and appliances wiped' },
        { id: 'qc-trash', label: 'All trash removed and liners replaced' },
        { id: 'qc-supplies', label: 'Cleaning supplies restocked in caddy' },
      ];
      let qcHtml = '';
      qcItems.forEach(item => {
        const checked = getChecked(item.id);
        const mark = checked ? '&#9745;' : '&#9744;';
        qcHtml += `<div style="margin-bottom:4px;">${mark} ${item.label}</div>`;
      });

      // Total time
      const arrived = getVal('time-arrived');
      const departed = getVal('time-departed');
      let totalTime = '';
      if (arrived && departed) {
        const [ah, am] = arrived.split(':').map(Number);
        const [dh, dm] = departed.split(':').map(Number);
        let totalMin = (dh * 60 + dm) - (ah * 60 + am);
        if (totalMin < 0) totalMin += 24 * 60;
        totalTime = Math.floor(totalMin / 60) + 'h ' + (totalMin % 60) + 'm';
      }

      const html = `<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Work Order ${escapeHtml(getVal('wo-number'))}</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color:#1a1a1a; padding:40px; max-width:850px; margin:0 auto; font-size:14px; line-height:1.5; }
  h1 { font-size:22px; margin-bottom:4px; }
  h2 { font-size:15px; color:#333; margin:20px 0 8px; padding-bottom:4px; border-bottom:2px solid #e5e5e5; text-transform:uppercase; letter-spacing:0.5px; }
  .header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:20px; padding-bottom:16px; border-bottom:3px solid #1a1a1a; }
  .grid2 { display:grid; grid-template-columns:1fr 1fr; gap:4px 24px; margin-bottom:6px; }
  .grid2 .label { font-weight:600; font-size:12px; color:#666; text-transform:uppercase; letter-spacing:0.3px; }
  .grid2 .value { font-size:14px; margin-bottom:6px; }
  .text-block { margin-bottom:12px; }
  .text-block .label { font-weight:600; font-size:12px; color:#666; text-transform:uppercase; letter-spacing:0.3px; margin-bottom:2px; }
  .text-block .value { font-size:14px; white-space:pre-wrap; background:#f9f9f9; padding:8px 10px; border-radius:4px; min-height:24px; }
  table { width:100%; border-collapse:collapse; margin-bottom:8px; }
  th { background:#f0f0f0; border:1px solid #ddd; padding:6px 10px; text-align:left; font-size:12px; text-transform:uppercase; letter-spacing:0.3px; }
  td { border:1px solid #ddd; padding:6px 10px; }
  .priority-badge { display:inline-block; padding:2px 10px; border-radius:4px; font-size:12px; font-weight:600; text-transform:uppercase; }
  .priority-Routine { background:#e0f2e9; color:#166534; }
  .priority-Urgent { background:#fef3c7; color:#92400e; }
  .priority-Same-Day { background:#fee2e2; color:#991b1b; }
  .signature-block { display:grid; grid-template-columns:1fr 1fr; gap:40px; margin-top:40px; padding-top:16px; }
  .sig-line { border-top:1px solid #1a1a1a; padding-top:6px; font-size:12px; color:#666; text-transform:uppercase; }
  .sig-name { font-size:16px; font-weight:600; min-height:20px; }
  @media print { body { padding:20px; } }
</style>
</head><body>
<div class="header">
  <div>
    <h1>Cleaning Work Order</h1>
    <div style="font-size:13px;color:#555;">Service Documentation</div>
  </div>
  <div style="text-align:right;">
    <div style="font-size:20px;font-weight:700;">${escapeHtml(getVal('wo-number'))}</div>
    <div>${getVal('wo-date')}</div>
    <span class="priority-badge priority-${getVal('priority')}">${escapeHtml(getVal('priority'))}</span>
  </div>
</div>

<h2>Dispatch</h2>
<div class="grid2">
  <div><span class="label">Cleaner:</span></div><div><span class="label">Priority:</span></div>
  <div class="value">${escapeHtml(getVal('cleaner-name')) || '\u2014'}</div><div class="value">${escapeHtml(getVal('priority'))}</div>
</div>

<h2>Customer</h2>
<div class="grid2">
  <div><span class="label">Name:</span></div><div><span class="label">Phone:</span></div>
  <div class="value">${escapeHtml(getVal('cust-name')) || '\u2014'}</div><div class="value">${escapeHtml(getVal('cust-phone')) || '\u2014'}</div>
  <div><span class="label">Address:</span></div><div><span class="label">Access:</span></div>
  <div class="value">${escapeHtml(getVal('cust-address')) || '\u2014'}</div><div class="value">${escapeHtml(getVal('access-instructions')) || '\u2014'}</div>
  <div><span class="label">Property Type:</span></div><div></div>
  <div class="value">${escapeHtml(getVal('property-type'))}</div><div></div>
</div>

<h2>Job Details</h2>
<div class="grid2">
  <div><span class="label">Service Type:</span></div><div><span class="label">Bedrooms / Bathrooms:</span></div>
  <div class="value">${escapeHtml(getVal('service-type'))}</div><div class="value">${getVal('num-bedrooms')} bed / ${getVal('num-bathrooms')} bath</div>
  <div><span class="label">Square Footage:</span></div><div></div>
  <div class="value">${getVal('sqft') ? getVal('sqft') + ' sq ft' : '\u2014'}</div><div></div>
</div>
${getVal('special-instructions') ? `<div class="text-block"><div class="label">Special Instructions</div><div class="value">${escapeHtml(getVal('special-instructions'))}</div></div>` : ''}

<h2>Room-by-Room Tasks</h2>
${roomTasksHtml}

${suppliesHtml ? `<h2>Supplies Used</h2>
<table><thead><tr><th>Item</th><th style="text-align:center;">Qty</th></tr></thead><tbody>${suppliesHtml}</tbody></table>` : ''}

<h2>Quality Checklist</h2>
<div style="font-size:14px;">${qcHtml}</div>

<h2>Condition Notes</h2>
<div class="grid2">
  <div><span class="label">Before (Arrival):</span></div><div><span class="label">After (Departure):</span></div>
  <div class="value">${escapeHtml(getVal('before-notes')) || '\u2014'}</div><div class="value">${escapeHtml(getVal('after-notes')) || '\u2014'}</div>
</div>

<h2>Time Tracking</h2>
<div class="grid2">
  <div><span class="label">Arrival:</span></div><div><span class="label">Departure:</span></div>
  <div class="value">${arrived || '\u2014'}</div><div class="value">${departed || '\u2014'}</div>
  <div><span class="label">Total Time:</span></div><div></div>
  <div class="value" style="font-weight:700;">${totalTime || '\u2014'}</div><div></div>
</div>

<div class="signature-block">
  <div>
    <div class="sig-name">${escapeHtml(getVal('cleaner-signature'))}</div>
    <div class="sig-line">Cleaner Signature</div>
  </div>
  <div>
    <div class="sig-name">${escapeHtml(getVal('customer-signature'))}</div>
    <div class="sig-line">Customer Signature${getChecked('customer-satisfied') ? ' (Satisfied)' : ''}</div>
  </div>
</div>

</body></html>`;

      const printWindow = window.open('', '_blank');
      if (printWindow) {
        printWindow.document.write(html);
        printWindow.document.close();
      }
    }

    document.getElementById('generate-btn')?.addEventListener('click', generateWorkOrder);
  });
</script>
