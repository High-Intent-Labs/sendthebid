  <div><span class="label">License #:</span></div><div><span class="label">Property Address:</span></div>
  <div class="value">${getVal('license-number') || '\u2014'}</div><div class="value">${getVal('property-address') || '\u2014'}</div>
</div>

<h2>Project Details</h2>
<div class="grid3">
  <div><span class="label">Surface Type:</span></div><div><span class="label">Paint Brand:</span></div><div><span class="label">Color / Code:</span></div>
  <div class="value">${getVal('equip-type')}</div><div class="value">${getVal('paint-brand') || '\u2014'}</div><div class="value">${getVal('paint-color') || '\u2014'}</div>
  <div><span class="label">Finish:</span></div><div><span class="label">Coats:</span></div><div><span class="label">Primer:</span></div>
  <div class="value">${getVal('paint-finish') || '\u2014'}</div><div class="value">${getVal('num-coats') || '\u2014'}</div><div class="value">${getVal('primer-used') || '\u2014'}</div>
  <div><span class="label">Total Sq Ft:</span></div><div><span class="label">Gallons Used:</span></div><div><span class="label">Overall Condition:</span></div>
  <div class="value">${getVal('total-sqft') || '\u2014'}</div><div class="value">${getVal('gallons-used') || '\u2014'}</div><div class="value" style="color:${condColor};font-weight:700;">${condition}</div>
</div>

<h2>Area Ratings</h2>
<table>
  <thead><tr><th>Component</th><th style="text-align:center;">Rating</th><th>Notes</th></tr></thead>
  <tbody>${ratingsHtml}</tbody>
</table>


${findingsHtml ? `<h2>Findings &amp; Recommendations</h2>
<table>
  <thead><tr><th>Description</th><th>Recommended Action</th><th style="text-align:right;">Est. Cost</th><th style="text-align:center;">Priority</th></tr></thead>
  <tbody>${findingsHtml}</tbody>
</table>` : ''}

<h2>Summary</h2>
<div class="summary-grid">
  <div class="summary-box">
    <div class="num" style="color:#16a34a;">${greenCount}</div>
    <div class="lbl">Good Condition</div>
  </div>
  <div class="summary-box">
    <div class="num" style="color:#ca8a04;">${yellowCount + redCount}</div>
    <div class="lbl">Needs Attention</div>
  </div>
