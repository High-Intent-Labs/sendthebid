</div>

<div class="signature-block">
  <div>
    <div class="sig-name">${getVal('inspector-name') || ''}</div>
    <div class="sig-line">Inspector Signature / Date</div>
  </div>
  <div>
    <div class="sig-name">&nbsp;</div>
    <div class="sig-line">Property Owner / Recipient</div>
  </div>
</div>

</body></html>`;

