---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/handymanTools';

const tool = getToolBySlug('job-profitability-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a good profit margin for handyman work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most profitable handyman businesses target 30-50% gross profit margin on completed jobs. The industry average sits around 35%. Below 25% means you are likely losing money after overhead. Simple tasks like mounting and assembly can hit 50%+ margins because material costs are low. Complex multi-trade jobs (drywall, plumbing, electrical) tend to land closer to 25-35% due to higher material and time costs."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate profit on a handyman job?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Add up all your costs for the job: labor (hours times your loaded hourly cost), materials you purchased, any subcontractor fees, and an overhead allocation. Subtract that total from what the customer paid you. The result is your gross profit. Divide gross profit by the customer price and multiply by 100 to get your profit margin percentage. Track this for every job to identify which types of work make you the most money."
      }
    },
    {
      "@type": "Question",
      "name": "What should I include in handyman job costs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Include every expense tied to the job: your labor hours at your true cost (not your billing rate, but what it costs you including taxes and benefits), all materials and supplies purchased for the job, any subcontractor payments, travel costs, and an overhead allocation that covers your vehicle, insurance, tools, and business expenses. Many handymen forget to include overhead, which makes jobs look more profitable than they really are."
      }
    },
    {
      "@type": "Question",
      "name": "Which handyman jobs are most profitable?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most profitable handyman jobs are typically quick-turn tasks with low material costs: TV mounting, picture hanging, furniture assembly, door hardware replacement, and minor drywall patches. These jobs often take under two hours and command flat rates of $150-$400 with minimal material spend. Multi-task bundles are also highly profitable because you eliminate redundant travel time. Track your actual profit per job type to find your sweet spot."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="profitability-calc">
    <!-- Job Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Job Details</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="job-type">Job Type</label>
        <select id="job-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="general" selected>General Handyman</option>
          <option value="drywall">Drywall Repair</option>
          <option value="painting">Painting / Touchup</option>
          <option value="assembly">Furniture Assembly</option>
          <option value="mounting">TV / Shelf Mounting</option>
          <option value="tile">Tile Work</option>
          <option value="carpentry">Carpentry / Trim</option>
          <option value="plumbing">Minor Plumbing</option>
          <option value="electrical">Minor Electrical</option>
          <option value="doors-windows">Doors / Windows</option>
          <option value="multi-task">Multi-Task Bundle</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="job-name">Job Name / Description</label>
        <input type="text" id="job-name" placeholder="e.g. Kitchen drywall patch + paint" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Labor Section -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Labor Cost</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="labor-hours">Hours Worked</label>
        <input type="number" id="labor-hours" value="3" min="0.25" max="100" step="0.25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="labor-cost-rate">Your Loaded Cost ($/hr)</label>
        <input type="number" id="labor-cost-rate" value="30" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Your true cost per hour (wages + taxes + benefits)</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="travel-time">Travel Time (hrs)</label>
        <input type="number" id="travel-time" value="0.5" min="0" max="10" step="0.25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Materials Section -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Materials Cost</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="materials-cost">Materials / Supplies ($)</label>
        <input type="number" id="materials-cost" value="45" min="0" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Hardware, lumber, fasteners, finishing materials</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="sub-cost">Subcontractor Cost ($)</label>
        <input type="number" id="sub-cost" value="0" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">If you hired a specialist for part of the job</p>
      </div>
    </div>

    <!-- Overhead Section -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Overhead Allocation</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="overhead-allocation">Overhead per Job ($)</label>
        <input type="number" id="overhead-allocation" value="25" min="0" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">Vehicle, insurance, tools, phone, marketing share</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customer-price">Customer Price ($)</label>
        <input type="number" id="customer-price" value="350" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1">What the customer paid for this job</p>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Job Profitability Summary</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Job Cost</div>
          <div id="result-total-cost" class="font-heading font-extrabold text-3xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Gross Profit</div>
          <div id="result-gross-profit" class="font-heading font-extrabold text-3xl text-[#34D399]">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Profit Margin</div>
          <div id="result-margin" class="font-heading font-extrabold text-3xl">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Effective $/Hour</div>
          <div id="result-effective-rate" class="font-heading font-extrabold text-3xl text-text-primary">&mdash;</div>
        </div>
      </div>

      <!-- Breakdown -->
      <div class="bg-bg-dark rounded-xl p-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Cost Breakdown</h4>
        <div class="space-y-3">
          <div class="flex justify-between items-center text-sm py-2 border-b border-border">
            <span class="text-text-secondary">Labor <span class="text-text-muted text-xs">(hours x loaded cost + travel)</span></span>
            <span id="breakdown-labor" class="text-text-primary font-semibold">$0</span>
          </div>
          <div class="flex justify-between items-center text-sm py-2 border-b border-border">
            <span class="text-text-secondary">Materials / Supplies</span>
            <span id="breakdown-materials" class="text-text-primary font-semibold">$0</span>
          </div>
          <div class="flex justify-between items-center text-sm py-2 border-b border-border">
            <span class="text-text-secondary">Subcontractor</span>
            <span id="breakdown-sub" class="text-text-primary font-semibold">$0</span>
          </div>
          <div class="flex justify-between items-center text-sm py-2">
            <span class="text-text-secondary">Overhead Allocation</span>
            <span id="breakdown-overhead" class="text-text-primary font-semibold">$0</span>
          </div>
        </div>
        <div class="mt-4 pt-4 border-t border-border flex justify-between items-center font-heading font-bold">
          <span class="text-text-primary">Total Cost</span>
          <span id="breakdown-total-cost" class="text-text-primary">$0</span>
        </div>
        <div class="flex justify-between items-center font-heading font-bold mt-2">
          <span class="text-text-primary">Customer Price</span>
          <span id="breakdown-customer-price" class="text-accent">$0</span>
        </div>
        <div class="flex justify-between items-center font-heading font-bold mt-2">
          <span class="text-text-primary">Gross Profit</span>
          <span id="breakdown-gross-profit" class="text-[#34D399]">$0</span>
        </div>
      </div>

      <!-- Margin Health Indicator -->
      <div class="bg-bg-dark rounded-xl p-6 mt-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Margin Health</h4>
        <div class="relative w-full h-4 bg-[rgba(255,255,255,0.05)] rounded-full overflow-hidden mb-3">
          <div id="margin-bar" class="absolute h-full rounded-full transition-all duration-500 bg-[#34D399]" style="left: 0%; width: 0%;"></div>
        </div>
        <div class="flex justify-between text-xs text-text-muted">
          <span>0%</span>
          <span class="text-[#EF4444]">Danger &lt;20%</span>
          <span class="text-[#FBBF24]">OK 20-30%</span>
          <span class="text-[#34D399]">Target 30-50%</span>
          <span>100%</span>
        </div>
        <div id="margin-advice" class="mt-4 text-sm text-text-secondary"></div>
      </div>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Select the job type.</strong> Choose the category that best matches the work you completed. This helps you compare profitability across different types of handyman jobs over time.</p>
          <p><strong class="text-text-primary">2. Enter your labor details.</strong> Put in the total hours you worked on-site, your loaded cost per hour (what it actually costs you including taxes and benefits, not your billing rate), and travel time to and from the job.</p>
          <p><strong class="text-text-primary">3. Add materials and subcontractor costs.</strong> Enter what you spent on hardware, lumber, fasteners, paint, and any other supplies. If you hired a specialist (plumber, electrician) for part of the job, include their invoice amount.</p>
          <p><strong class="text-text-primary">4. Set your overhead allocation.</strong> This is the share of your monthly business costs (vehicle, insurance, tools, phone, marketing) that this job should carry. A simple method: divide your monthly overhead by your average number of jobs per month.</p>
          <p><strong class="text-text-primary">5. Enter the customer price and review.</strong> The calculator instantly shows your gross profit, profit margin, and effective hourly rate. Use this to evaluate whether the job was worth your time and to identify which job types deliver the best margins.</p>
        </div>
      </section>

      <!-- How Job Profitability Works -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How Job Profitability Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Profitability is what you keep after every cost is accounted for.</strong> Revenue is not profit. A $500 job that cost you $400 in labor, materials, and overhead only netted $100. Knowing this number for every job you complete is the difference between growing a business and running in place.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Labor_Cost = (Hours_Worked + Travel_Time) x Loaded_Cost_Per_Hour</p>
            <p>Total_Job_Cost = Labor_Cost + Materials + Subcontractor + Overhead</p>
            <p>Gross_Profit = Customer_Price - Total_Job_Cost</p>
            <p>Profit_Margin = (Gross_Profit / Customer_Price) x 100</p>
            <p>Effective_Hourly = Gross_Profit / Hours_Worked</p>
          </div>
          <p><strong class="text-text-primary">Target 30-50% gross margin on handyman jobs.</strong> Below 25% means you are underpricing or spending too long on the job. Above 50% is strong and usually happens on quick-turn mounting and assembly work. The effective hourly rate tells you what your time is actually worth after all costs. If it is below $40 per hour, you need to raise prices or improve efficiency.</p>
          <p><strong class="text-text-primary">Track every job to find patterns.</strong> After 20-30 entries, you will see which job types consistently deliver the best margins. Double down on those. If drywall repairs always land at 22% but TV mounting hits 55%, you know where to focus your marketing dollars.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">After every completed job.</strong> Run your numbers while they are fresh. Enter the actual hours, actual material receipts, and what the customer paid. The five minutes it takes to log a job saves you from repeating unprofitable work for months without realizing it.</p>
          <p><strong class="text-text-primary">Reviewing your pricing strategy.</strong> If you have been quoting drywall patches at $250 but this calculator consistently shows 18% margins on that work, you know your price needs to go up to $300 or more. Data-driven pricing removes the guesswork and the guilt of raising rates.</p>
          <p><strong class="text-text-primary">Deciding whether to take on a new job type.</strong> A customer asks about tile work you have never quoted before. Estimate the costs, plug in what you would charge, and see if the margin is worth your time. Better to know before you say yes than to discover after the job that you lost money.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is a good profit margin for handyman work?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most profitable handyman businesses target 30-50% gross profit margin on completed jobs. The industry average sits around 35%. Below 25% means you are likely losing money after overhead. Simple tasks like mounting and assembly can hit 50%+ margins because material costs are low. Complex multi-trade jobs tend to land closer to 25-35% due to higher material and time costs.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate profit on a handyman job?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Add up all your costs for the job: labor (hours times your loaded hourly cost), materials you purchased, any subcontractor fees, and an overhead allocation. Subtract that total from what the customer paid you. The result is your gross profit. Divide gross profit by the customer price and multiply by 100 to get your profit margin percentage.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should I include in handyman job costs?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Include every expense tied to the job: your labor hours at your true cost (not your billing rate), all materials and supplies, any subcontractor payments, travel costs, and an overhead allocation for vehicle, insurance, tools, and business expenses. Many handymen forget to include overhead, which makes jobs look more profitable than they really are.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Which handyman jobs are most profitable?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">The most profitable handyman jobs are typically quick-turn tasks with low material costs: TV mounting, picture hanging, furniture assembly, door hardware replacement, and minor drywall patches. These jobs often take under two hours and command flat rates of $150-$400 with minimal material spend. Multi-task bundles are also highly profitable because you eliminate redundant travel time.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    // Labor
    const laborHours = parseFloat((document.getElementById('labor-hours') as HTMLInputElement).value) || 0;
    const laborCostRate = parseFloat((document.getElementById('labor-cost-rate') as HTMLInputElement).value) || 0;
    const travelTime = parseFloat((document.getElementById('travel-time') as HTMLInputElement).value) || 0;
    const laborCost = (laborHours + travelTime) * laborCostRate;

    // Materials
    const materialsCost = parseFloat((document.getElementById('materials-cost') as HTMLInputElement).value) || 0;

    // Subcontractor
    const subCost = parseFloat((document.getElementById('sub-cost') as HTMLInputElement).value) || 0;

    // Overhead
    const overheadAllocation = parseFloat((document.getElementById('overhead-allocation') as HTMLInputElement).value) || 0;

    // Customer price
    const customerPrice = parseFloat((document.getElementById('customer-price') as HTMLInputElement).value) || 0;

    // Calculations
    const totalJobCost = laborCost + materialsCost + subCost + overheadAllocation;
    const grossProfit = customerPrice - totalJobCost;
    const profitMargin = customerPrice > 0 ? (grossProfit / customerPrice) * 100 : 0;
    const effectiveRate = laborHours > 0 ? grossProfit / laborHours : 0;

    // Format currency
    const fmt = (n: number) => '$' + Math.round(n).toLocaleString();

    // Main results
    document.getElementById('result-total-cost')!.textContent = fmt(totalJobCost);
    document.getElementById('result-gross-profit')!.textContent = fmt(grossProfit);
    document.getElementById('result-effective-rate')!.textContent = fmt(effectiveRate) + '/hr';

    // Profit color
    const profitEl = document.getElementById('result-gross-profit')!;
    profitEl.className = 'font-heading font-extrabold text-3xl';
    profitEl.classList.add(grossProfit >= 0 ? 'text-[#34D399]' : 'text-[#EF4444]');

    // Margin with color coding
    const marginEl = document.getElementById('result-margin')!;
    marginEl.textContent = profitMargin.toFixed(1) + '%';
    marginEl.className = 'font-heading font-extrabold text-3xl';
    if (profitMargin >= 30) {
      marginEl.classList.add('text-[#34D399]');
    } else if (profitMargin >= 20) {
      marginEl.classList.add('text-[#FBBF24]');
    } else {
      marginEl.classList.add('text-[#EF4444]');
    }

    // Effective rate color
    const rateEl = document.getElementById('result-effective-rate')!;
    rateEl.className = 'font-heading font-extrabold text-3xl';
    if (effectiveRate >= 60) {
      rateEl.classList.add('text-[#34D399]');
    } else if (effectiveRate >= 40) {
      rateEl.classList.add('text-[#FBBF24]');
    } else {
      rateEl.classList.add('text-text-primary');
    }

    // Breakdown
    document.getElementById('breakdown-labor')!.textContent = fmt(laborCost);
    document.getElementById('breakdown-materials')!.textContent = fmt(materialsCost);
    document.getElementById('breakdown-sub')!.textContent = fmt(subCost);
    document.getElementById('breakdown-overhead')!.textContent = fmt(overheadAllocation);
    document.getElementById('breakdown-total-cost')!.textContent = fmt(totalJobCost);
    document.getElementById('breakdown-customer-price')!.textContent = fmt(customerPrice);

    const bpEl = document.getElementById('breakdown-gross-profit')!;
    bpEl.textContent = fmt(grossProfit);
    bpEl.className = 'font-heading font-bold';
    bpEl.classList.add(grossProfit >= 0 ? 'text-[#34D399]' : 'text-[#EF4444]');

    // Margin bar
    const clampedMargin = Math.max(0, Math.min(100, profitMargin));
    const marginBar = document.getElementById('margin-bar')!;
    marginBar.style.width = clampedMargin + '%';
    marginBar.classList.remove('bg-[#34D399]', 'bg-[#FBBF24]', 'bg-[#EF4444]');
    if (profitMargin >= 30) {
      marginBar.classList.add('bg-[#34D399]');
    } else if (profitMargin >= 20) {
      marginBar.classList.add('bg-[#FBBF24]');
    } else {
      marginBar.classList.add('bg-[#EF4444]');
    }

    // Margin advice
    const adviceEl = document.getElementById('margin-advice')!;
    if (profitMargin >= 50) {
      adviceEl.innerHTML = '<span class="text-[#34D399] font-medium">Excellent margin.</span> This job type is a strong earner. Consider whether you can do more of this work.';
    } else if (profitMargin >= 30) {
      adviceEl.innerHTML = '<span class="text-[#34D399] font-medium">Healthy margin.</span> This job is profitable and sustainable. You are in the target range for handyman work.';
    } else if (profitMargin >= 20) {
      adviceEl.innerHTML = '<span class="text-[#FBBF24] font-medium">Thin margin.</span> Consider raising your price by 10-15% or reducing time on-site. At this level, one callback wipes out your profit.';
    } else if (profitMargin > 0) {
      adviceEl.innerHTML = '<span class="text-[#EF4444] font-medium">Danger zone.</span> After overhead and unexpected costs, you are likely losing money on this job type. Raise your price significantly or stop offering this service.';
    } else {
      adviceEl.innerHTML = '<span class="text-[#EF4444] font-medium">Negative margin.</span> This job lost money. Review your pricing, reduce material costs, or improve efficiency before taking on similar work.';
    }
  }

  // Auto-calculate on any input change
  document.querySelectorAll('#profitability-calc input[type="number"], #profitability-calc select').forEach(el => {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  // Calculate on load
  calculate();
</script>
