---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/gcTools';

const tool = getToolBySlug('overhead-cost-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are typical general contractor overhead costs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most general contractors carry 25-35% overhead relative to revenue. The largest categories are usually people (owner salary, office staff, project managers), insurance (general liability, workers comp, umbrella), vehicles and equipment, and marketing. A mid-size GC running two to three crews typically spends $15,000-$30,000 per month in overhead before any job-level labor or materials."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate overhead per billable hour for a GC business?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Divide your total annual overhead by the total billable hours your crews produce in a year. For example, if annual overhead is $250,000 and you have 3 crews each billing 160 hours per month, your annual billable hours are 5,760. Overhead per hour is $250,000 / 5,760 = $43.40. This number must be built into your billing rate on top of labor cost and profit margin."
      }
    },
    {
      "@type": "Question",
      "name": "What percentage of revenue should a GC spend on overhead?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The target range for general contractors is 25-35% of revenue going to overhead. Below 25% usually means a lean operation or underinvestment in growth. Above 35% signals overspending or underpricing. Marketing should be 5-8% of revenue for a stable business and 10-15% during growth phases. Insurance typically runs 3-6% and fleet costs 5-10%."
      }
    },
    {
      "@type": "Question",
      "name": "How do I reduce overhead in my contracting business?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start by identifying your top three overhead categories. Common wins include renegotiating insurance annually, consolidating software subscriptions, cross-training office staff to handle multiple roles, and auditing equipment rental costs versus purchasing. Do not cut marketing below 5% of revenue or you will shrink your pipeline. Focus on efficiency gains rather than blanket cuts."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="overhead-calc">
    <!-- Facility -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Facility (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="officeRent">Office / Shop Rent ($)</label>
          <input type="number" id="officeRent" value="2500" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="utilities">Utilities ($)</label>
          <input type="number" id="utilities" value="450" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="yardStorage">Yard / Storage ($)</label>
          <input type="number" id="yardStorage" value="500" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Vehicles & Equipment -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Vehicles &amp; Equipment (Per Vehicle)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="sm:col-span-2 lg:col-span-3">
          <label class="block text-xs text-text-muted mb-1" for="numVehicles">Number of Vehicles</label>
          <input type="number" id="numVehicles" value="3" min="1" max="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="fuelPerVehicle">Fuel per Vehicle ($)</label>
          <input type="number" id="fuelPerVehicle" value="650" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="insurancePerVehicle">Insurance per Vehicle ($)</label>
          <input type="number" id="insurancePerVehicle" value="275" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="maintPerVehicle">Maintenance per Vehicle ($)</label>
          <input type="number" id="maintPerVehicle" value="250" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="paymentPerVehicle">Payment per Vehicle ($)</label>
          <input type="number" id="paymentPerVehicle" value="500" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="equipmentRental">Equipment Rental ($)</label>
          <input type="number" id="equipmentRental" value="800" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Insurance -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Insurance (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="generalLiability">General Liability ($)</label>
          <input type="number" id="generalLiability" value="600" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="workersComp">Workers Comp ($)</label>
          <input type="number" id="workersComp" value="1200" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="umbrella">Umbrella / Builders Risk ($)</label>
          <input type="number" id="umbrella" value="350" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- People -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">People (Monthly, Non-Field)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="ownerSalary">Owner Salary ($)</label>
          <input type="number" id="ownerSalary" value="12000" min="0" step="500" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="projectManager">Project Manager ($)</label>
          <input type="number" id="projectManager" value="5500" min="0" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="officeAdmin">Office Admin ($)</label>
          <input type="number" id="officeAdmin" value="3500" min="0" step="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="bookkeeper">Bookkeeper ($)</label>
          <input type="number" id="bookkeeper" value="500" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Operations -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Operations (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="softwareSubs">Software / PM Tools ($)</label>
          <input type="number" id="softwareSubs" value="400" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="phoneInternet">Phone / Internet ($)</label>
          <input type="number" id="phoneInternet" value="300" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="toolsSmallEquip">Tools / Small Equipment ($)</label>
          <input type="number" id="toolsSmallEquip" value="300" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="safetyGear">Safety Gear / PPE ($)</label>
          <input type="number" id="safetyGear" value="150" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="dumpsterWaste">Dumpster / Waste ($)</label>
          <input type="number" id="dumpsterWaste" value="400" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Compliance -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Compliance (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="gcLicense">GC License / Permits ($)</label>
          <input type="number" id="gcLicense" value="100" min="0" step="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="businessLicenses">Business Licenses ($)</label>
          <input type="number" id="businessLicenses" value="75" min="0" step="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="continuingEd">Continuing Ed / Training ($)</label>
          <input type="number" id="continuingEd" value="150" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Marketing -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Marketing (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="onlineAds">Online Ads ($)</label>
          <input type="number" id="onlineAds" value="1500" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="seoWebsite">SEO / Website ($)</label>
          <input type="number" id="seoWebsite" value="500" min="0" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="printMail">Print / Signage ($)</label>
          <input type="number" id="printMail" value="200" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="referralPrograms">Referral Programs ($)</label>
          <input type="number" id="referralPrograms" value="300" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Other -->
    <details class="mb-4 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Other (Monthly)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="accountingLegal">Accounting / Legal ($)</label>
          <input type="number" id="accountingLegal" value="500" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="badDebt">Bad Debt Allowance ($)</label>
          <input type="number" id="badDebt" value="300" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="misc">Misc ($)</label>
          <input type="number" id="misc" value="300" min="0" step="25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Context -->
    <details class="mb-8 bg-bg-card border border-border rounded-lg" open>
      <summary class="px-5 py-4 cursor-pointer text-text-primary font-heading font-bold text-sm uppercase tracking-wider hover:text-accent transition-colors">Context (For Per-Hour Math)</summary>
      <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="numCrews">Number of Crews</label>
          <input type="number" id="numCrews" value="3" min="1" max="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="billableHours">Billable Hours/Month per Crew</label>
          <input type="number" id="billableHours" value="160" min="1" max="250" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="annualRevenue">Annual Revenue ($)</label>
          <input type="number" id="annualRevenue" value="1500000" min="0" step="10000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="avgProjectSize">Avg Project Size ($)</label>
          <input type="number" id="avgProjectSize" value="50000" min="0" step="1000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="workingDays">Working Days per Month</label>
          <input type="number" id="workingDays" value="22" min="1" max="31" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </details>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Results</h3>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center sm:col-span-2">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Monthly Overhead</div>
          <div id="result-monthly" class="font-heading font-extrabold text-4xl text-accent">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center sm:col-span-2">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Annual Overhead</div>
          <div id="result-annual" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Per Crew (Annual)</div>
          <div id="result-per-crew" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Per Billable Hour</div>
          <div id="result-per-hour" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Per Project</div>
          <div id="result-per-project" class="font-heading font-extrabold text-2xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Overhead % of Revenue</div>
          <div id="result-pct" class="font-heading font-extrabold text-2xl">--</div>
        </div>
      </div>

      <!-- Category breakdown -->
      <div class="bg-bg-dark rounded-xl p-6 mb-8">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Category Breakdown (Monthly)</h4>
        <div class="space-y-3" id="category-breakdown">
          <div class="flex justify-between text-sm"><span class="text-text-secondary">Facility</span><span id="cat-facility" class="text-text-primary font-semibold">--</span></div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div id="bar-facility" class="bg-[#60A5FA] h-2 rounded-full transition-all duration-500" style="width: 0%"></div></div>
          <div class="flex justify-between text-sm"><span class="text-text-secondary">Vehicles &amp; Equipment</span><span id="cat-vehicles" class="text-text-primary font-semibold">--</span></div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div id="bar-vehicles" class="bg-[#34D399] h-2 rounded-full transition-all duration-500" style="width: 0%"></div></div>
          <div class="flex justify-between text-sm"><span class="text-text-secondary">Insurance</span><span id="cat-insurance" class="text-text-primary font-semibold">--</span></div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div id="bar-insurance" class="bg-[#C084FC] h-2 rounded-full transition-all duration-500" style="width: 0%"></div></div>
          <div class="flex justify-between text-sm"><span class="text-text-secondary">People</span><span id="cat-people" class="text-text-primary font-semibold">--</span></div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div id="bar-people" class="bg-[#FBBF24] h-2 rounded-full transition-all duration-500" style="width: 0%"></div></div>
          <div class="flex justify-between text-sm"><span class="text-text-secondary">Operations</span><span id="cat-operations" class="text-text-primary font-semibold">--</span></div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div id="bar-operations" class="bg-[#F472B6] h-2 rounded-full transition-all duration-500" style="width: 0%"></div></div>
          <div class="flex justify-between text-sm"><span class="text-text-secondary">Compliance</span><span id="cat-compliance" class="text-text-primary font-semibold">--</span></div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div id="bar-compliance" class="bg-[#A78BFA] h-2 rounded-full transition-all duration-500" style="width: 0%"></div></div>
          <div class="flex justify-between text-sm"><span class="text-text-secondary">Marketing</span><span id="cat-marketing" class="text-text-primary font-semibold">--</span></div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div id="bar-marketing" class="bg-[#FB923C] h-2 rounded-full transition-all duration-500" style="width: 0%"></div></div>
          <div class="flex justify-between text-sm"><span class="text-text-secondary">Other</span><span id="cat-other" class="text-text-primary font-semibold">--</span></div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div id="bar-other" class="bg-[#94A3B8] h-2 rounded-full transition-all duration-500" style="width: 0%"></div></div>
        </div>
      </div>

      <!-- Benchmarks -->
      <div class="bg-bg-dark rounded-xl p-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">GC Overhead Benchmarks</h4>
        <div class="space-y-3">
          <div>
            <div class="flex justify-between text-sm mb-1"><span class="text-text-secondary">Target Overhead</span><span class="text-text-primary font-semibold">25 &ndash; 35% of revenue</span></div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div class="bg-[#34D399] h-2 rounded-full" style="width: 30%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1"><span class="text-text-secondary">Marketing</span><span class="text-text-primary font-semibold">5 &ndash; 8% of revenue (10%+ for growth)</span></div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div class="bg-[#FB923C] h-2 rounded-full" style="width: 10%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1"><span class="text-text-secondary">Vehicles &amp; Equipment</span><span class="text-text-primary font-semibold">5 &ndash; 10% of revenue</span></div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div class="bg-[#60A5FA] h-2 rounded-full" style="width: 20%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1"><span class="text-text-secondary">Insurance</span><span class="text-text-primary font-semibold">3 &ndash; 6% of revenue</span></div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div class="bg-[#FBBF24] h-2 rounded-full" style="width: 8%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1"><span class="text-text-secondary">Billable Hours</span><span class="text-text-primary font-semibold">~2,000 hrs/crew/year typical</span></div>
            <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2"><div class="bg-[#C084FC] h-2 rounded-full" style="width: 18%"></div></div>
          </div>
          <div id="benchmark-warning" class="hidden mt-3 bg-[rgba(239,68,68,0.1)] border border-[rgba(239,68,68,0.3)] rounded-lg px-4 py-3 text-sm text-[#FCA5A5]">
            Your overhead exceeds 35% of revenue. Review your largest categories for cost reduction opportunities.
          </div>
        </div>
        <div class="mt-4 pt-4 border-t border-border">
          <div class="flex justify-between text-sm mb-1"><span class="text-text-secondary font-medium">Your Overhead % of Revenue</span><span id="benchmark-your-pct" class="font-heading font-bold">--</span></div>
          <div class="w-full bg-[rgba(255,255,255,0.05)] rounded-full h-2.5"><div id="benchmark-bar" class="h-2.5 rounded-full transition-all duration-500" style="width: 0%"></div></div>
        </div>
      </div>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Fill in each overhead category.</strong> Start with the defaults and adjust to match your actual expenses. Every dollar you spend to keep the business running that is not tied to a specific job belongs here. Open each section and enter your real monthly numbers.</p>
          <p><strong class="text-text-primary">2. Set your vehicle count.</strong> Enter the number of trucks and work vehicles you operate. The calculator multiplies per-vehicle costs (fuel, insurance, maintenance, payments) by your fleet size to get the total vehicle overhead.</p>
          <p><strong class="text-text-primary">3. Enter your context numbers.</strong> The number of crews, billable hours per crew, annual revenue, average project size, and working days let the calculator translate raw overhead into per-hour and per-project figures you can use for pricing.</p>
          <p><strong class="text-text-primary">4. Review your results.</strong> Check whether your overhead percentage falls within the 25-35% target range. Use the per-hour and per-project numbers to make sure your billing rates cover overhead plus profit.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How GC Overhead Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Overhead is every cost that keeps the business running but cannot be billed to a specific job.</strong> It includes rent, vehicles, insurance, office salaries, software, marketing, and licensing. Unlike materials or field labor, overhead does not change based on how many jobs you run in a given week.</p>
          <p>Most GC owners know their overhead exists but have never added it up. That means they are guessing when they price projects. If your overhead is $30,000 per month and you do not know it, you cannot build it into your rates, and every project looks more profitable than it actually is.</p>
          <p><strong class="text-text-primary">The per-hour number is the most important output.</strong> It tells you exactly how much overhead you burn for every billable hour a crew works. If your overhead per hour is $45 and your average labor rate is $65 per hour, you only have $20 left to cover actual field wages and profit. Knowing this number forces you to price correctly.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Vehicle_Monthly = Vehicles &times; (Fuel + Insurance + Maintenance + Payment) + Equipment_Rental</p>
            <p>Total_Monthly = Facility + Vehicles + Insurance + People + Operations + Compliance + Marketing + Other</p>
            <p>Annual_Overhead = Total_Monthly &times; 12</p>
            <p>Per_Crew = Annual_Overhead / Number_of_Crews</p>
            <p>Per_Hour = Annual_Overhead / (Crews &times; Billable_Hours &times; 12)</p>
            <p>Per_Project = Annual_Overhead / (Annual_Revenue / Avg_Project_Size)</p>
            <p>Overhead_Pct = (Annual_Overhead / Annual_Revenue) &times; 100</p>
          </div>
          <p>The category breakdown shows where your money goes so you can identify the biggest line items. People and vehicles are almost always the top two. If marketing is below 5% of revenue, you may be underinvesting in growth.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Setting project pricing.</strong> Before you decide what to charge per hour or how to mark up a job, you need to know your overhead per hour. This calculator gives you that number so you can build rates that actually cover your costs and leave room for profit.</p>
          <p><strong class="text-text-primary">Annual budgeting and planning.</strong> At the start of each year, plug in your expected costs to see where you will land. If overhead is creeping above 35% of projected revenue, you know you need to either cut costs or grow revenue before the year gets away from you.</p>
          <p><strong class="text-text-primary">Evaluating growth decisions.</strong> Thinking about adding a crew, hiring a project manager, or increasing your ad spend? Enter the new numbers and see how they change your overhead per hour and overhead percentage. This prevents surprises when the bills start rolling in.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What are typical general contractor overhead costs?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most general contractors carry 25-35% overhead relative to revenue. The largest categories are usually people (owner salary, office staff, project managers), insurance (general liability, workers comp, umbrella), vehicles and equipment, and marketing. A mid-size GC running two to three crews typically spends $15,000-$30,000 per month in overhead before any job-level labor or materials.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate overhead per billable hour?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Divide your total annual overhead by the total billable hours your crews produce in a year. For example, if annual overhead is $250,000 and you have 3 crews each billing 160 hours per month, your annual billable hours are 5,760. Overhead per hour is $250,000 / 5,760 = $43.40. This number must be built into your billing rate on top of labor cost and profit margin.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What percentage of revenue should go to overhead?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">The target range for general contractors is 25-35% of revenue going to overhead. Below 25% usually means a lean operation or underinvestment in growth. Above 35% signals overspending or underpricing. Marketing should be 5-8% of revenue for a stable business and 10-15% during growth phases. Insurance typically runs 3-6% and fleet costs 5-10%.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I reduce overhead in my contracting business?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Start by identifying your top three overhead categories. Common wins include renegotiating insurance annually, consolidating software subscriptions, cross-training office staff to handle multiple roles, and auditing equipment rental costs versus purchasing. Do not cut marketing below 5% of revenue or you will shrink your pipeline. Focus on efficiency gains rather than blanket cuts.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  function calculate() {
    const officeRent = parseFloat((document.getElementById('officeRent') as HTMLInputElement).value) || 0;
    const utilities = parseFloat((document.getElementById('utilities') as HTMLInputElement).value) || 0;
    const yardStorage = parseFloat((document.getElementById('yardStorage') as HTMLInputElement).value) || 0;
    const facilityTotal = officeRent + utilities + yardStorage;

    const numVehicles = parseFloat((document.getElementById('numVehicles') as HTMLInputElement).value) || 0;
    const fuelPerVehicle = parseFloat((document.getElementById('fuelPerVehicle') as HTMLInputElement).value) || 0;
    const insurancePerVehicle = parseFloat((document.getElementById('insurancePerVehicle') as HTMLInputElement).value) || 0;
    const maintPerVehicle = parseFloat((document.getElementById('maintPerVehicle') as HTMLInputElement).value) || 0;
    const paymentPerVehicle = parseFloat((document.getElementById('paymentPerVehicle') as HTMLInputElement).value) || 0;
    const equipmentRental = parseFloat((document.getElementById('equipmentRental') as HTMLInputElement).value) || 0;
    const vehiclesTotal = numVehicles * (fuelPerVehicle + insurancePerVehicle + maintPerVehicle + paymentPerVehicle) + equipmentRental;

    const generalLiability = parseFloat((document.getElementById('generalLiability') as HTMLInputElement).value) || 0;
    const workersComp = parseFloat((document.getElementById('workersComp') as HTMLInputElement).value) || 0;
    const umbrella = parseFloat((document.getElementById('umbrella') as HTMLInputElement).value) || 0;
    const insuranceTotal = generalLiability + workersComp + umbrella;

    const ownerSalary = parseFloat((document.getElementById('ownerSalary') as HTMLInputElement).value) || 0;
    const projectManager = parseFloat((document.getElementById('projectManager') as HTMLInputElement).value) || 0;
    const officeAdmin = parseFloat((document.getElementById('officeAdmin') as HTMLInputElement).value) || 0;
    const bookkeeper = parseFloat((document.getElementById('bookkeeper') as HTMLInputElement).value) || 0;
    const peopleTotal = ownerSalary + projectManager + officeAdmin + bookkeeper;

    const softwareSubs = parseFloat((document.getElementById('softwareSubs') as HTMLInputElement).value) || 0;
    const phoneInternet = parseFloat((document.getElementById('phoneInternet') as HTMLInputElement).value) || 0;
    const toolsSmallEquip = parseFloat((document.getElementById('toolsSmallEquip') as HTMLInputElement).value) || 0;
    const safetyGear = parseFloat((document.getElementById('safetyGear') as HTMLInputElement).value) || 0;
    const dumpsterWaste = parseFloat((document.getElementById('dumpsterWaste') as HTMLInputElement).value) || 0;
    const operationsTotal = softwareSubs + phoneInternet + toolsSmallEquip + safetyGear + dumpsterWaste;

    const gcLicense = parseFloat((document.getElementById('gcLicense') as HTMLInputElement).value) || 0;
    const businessLicenses = parseFloat((document.getElementById('businessLicenses') as HTMLInputElement).value) || 0;
    const continuingEd = parseFloat((document.getElementById('continuingEd') as HTMLInputElement).value) || 0;
    const complianceTotal = gcLicense + businessLicenses + continuingEd;

    const onlineAds = parseFloat((document.getElementById('onlineAds') as HTMLInputElement).value) || 0;
    const seoWebsite = parseFloat((document.getElementById('seoWebsite') as HTMLInputElement).value) || 0;
    const printMail = parseFloat((document.getElementById('printMail') as HTMLInputElement).value) || 0;
    const referralPrograms = parseFloat((document.getElementById('referralPrograms') as HTMLInputElement).value) || 0;
    const marketingTotal = onlineAds + seoWebsite + printMail + referralPrograms;

    const accountingLegal = parseFloat((document.getElementById('accountingLegal') as HTMLInputElement).value) || 0;
    const badDebt = parseFloat((document.getElementById('badDebt') as HTMLInputElement).value) || 0;
    const misc = parseFloat((document.getElementById('misc') as HTMLInputElement).value) || 0;
    const otherTotal = accountingLegal + badDebt + misc;

    const numCrews = parseFloat((document.getElementById('numCrews') as HTMLInputElement).value) || 1;
    const billableHours = parseFloat((document.getElementById('billableHours') as HTMLInputElement).value) || 1;
    const annualRevenue = parseFloat((document.getElementById('annualRevenue') as HTMLInputElement).value) || 0;
    const avgProjectSize = parseFloat((document.getElementById('avgProjectSize') as HTMLInputElement).value) || 1;

    const totalMonthly = facilityTotal + vehiclesTotal + insuranceTotal + peopleTotal + operationsTotal + complianceTotal + marketingTotal + otherTotal;
    const totalAnnual = totalMonthly * 12;
    const perCrew = totalAnnual / numCrews;
    const perHour = totalAnnual / (numCrews * billableHours * 12);
    const projectsPerYear = annualRevenue > 0 ? annualRevenue / avgProjectSize : 0;
    const perProject = projectsPerYear > 0 ? totalAnnual / projectsPerYear : 0;
    const overheadPct = annualRevenue > 0 ? (totalAnnual / annualRevenue) * 100 : 0;

    const fmt = (n: number) => '$' + n.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    const fmtDec = (n: number) => '$' + n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    document.getElementById('result-monthly')!.textContent = fmt(totalMonthly);
    document.getElementById('result-annual')!.textContent = fmt(totalAnnual);
    document.getElementById('result-per-crew')!.textContent = fmt(perCrew);
    document.getElementById('result-per-hour')!.textContent = fmtDec(perHour);
    document.getElementById('result-per-project')!.textContent = fmt(perProject);
    document.getElementById('result-pct')!.textContent = overheadPct.toFixed(1) + '%';

    const pctEl = document.getElementById('result-pct')!;
    pctEl.classList.remove('text-[#34D399]', 'text-[#FBBF24]', 'text-[#EF4444]');
    if (overheadPct <= 25) pctEl.classList.add('text-[#34D399]');
    else if (overheadPct <= 35) pctEl.classList.add('text-[#FBBF24]');
    else pctEl.classList.add('text-[#EF4444]');

    const categories = [
      { id: 'facility', total: facilityTotal },
      { id: 'vehicles', total: vehiclesTotal },
      { id: 'insurance', total: insuranceTotal },
      { id: 'people', total: peopleTotal },
      { id: 'operations', total: operationsTotal },
      { id: 'compliance', total: complianceTotal },
      { id: 'marketing', total: marketingTotal },
      { id: 'other', total: otherTotal },
    ];

    categories.forEach(cat => {
      document.getElementById('cat-' + cat.id)!.textContent = fmt(cat.total);
      const barPct = totalMonthly > 0 ? (cat.total / totalMonthly) * 100 : 0;
      (document.getElementById('bar-' + cat.id) as HTMLElement).style.width = barPct + '%';
    });

    const clampedPct = Math.max(0, Math.min(100, overheadPct));
    const benchmarkBar = document.getElementById('benchmark-bar')!;
    benchmarkBar.style.width = Math.min(clampedPct, 60) / 60 * 100 + '%';
    benchmarkBar.classList.remove('bg-[#34D399]', 'bg-[#FBBF24]', 'bg-[#EF4444]');
    if (overheadPct <= 25) benchmarkBar.classList.add('bg-[#34D399]');
    else if (overheadPct <= 35) benchmarkBar.classList.add('bg-[#FBBF24]');
    else benchmarkBar.classList.add('bg-[#EF4444]');

    const yourPctEl = document.getElementById('benchmark-your-pct')!;
    yourPctEl.textContent = overheadPct.toFixed(1) + '%';
    yourPctEl.classList.remove('text-[#34D399]', 'text-[#FBBF24]', 'text-[#EF4444]');
    if (overheadPct <= 25) yourPctEl.classList.add('text-[#34D399]');
    else if (overheadPct <= 35) yourPctEl.classList.add('text-[#FBBF24]');
    else yourPctEl.classList.add('text-[#EF4444]');

    const warningEl = document.getElementById('benchmark-warning')!;
    if (overheadPct > 35) warningEl.classList.remove('hidden');
    else warningEl.classList.add('hidden');
  }

  document.querySelectorAll('#overhead-calc input').forEach(el => {
    el.addEventListener('change', calculate);
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
