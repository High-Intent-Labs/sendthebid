---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/paintingTools';

const tool = getToolBySlug('interior-cost-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I price an interior painting job?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Calculate the total square footage, determine paint and primer needs, estimate labor hours based on surface condition and complexity, then add your material costs with markup. A standard interior room takes 4-8 hours for a two-person crew depending on size and prep. Target 35-45% gross margin on residential interior work."
      }
    },
    {
      "@type": "Question",
      "name": "What profit margin should I target on interior painting?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most successful painting companies target 35-45% gross margin on interior work. The industry average sits around 40%. Below 25% means you are likely losing money after overhead. Interior work has lower equipment costs than exterior, so margins should be higher. Track your actual margins per job to find your sweet spot."
      }
    },
    {
      "@type": "Question",
      "name": "How much does it cost to paint a room?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A standard bedroom costs $400-800 to paint professionally. A living room runs $900-1,500 depending on size. These ranges assume two coats, standard prep, and mid-grade paint. Add 20-30% for poor surface conditions requiring heavy prep. Premium paint adds 15-25% to material costs."
      }
    },
    {
      "@type": "Question",
      "name": "How long does it take to paint a room?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A single painter can complete a standard 12x12 bedroom in 4-6 hours including prep, two coats, and cleanup. A two-person crew can do it in 2.5-4 hours. Larger rooms like living rooms take 6-10 hours for one painter. Heavy prep work (patching, sanding, priming) can add 2-4 hours per room."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="interior-calc">
    <!-- Project Details -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Project Details</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="num-rooms">Number of Rooms</label>
        <input type="number" id="num-rooms" value="3" min="1" max="50" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="total-sqft">Total Wall Area (sq ft)</label>
        <input type="number" id="total-sqft" value="1200" min="50" max="50000" step="50" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="surface-condition">Surface Condition</label>
        <select id="surface-condition" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="good" selected>Good (light cleaning only)</option>
          <option value="fair">Fair (minor patching, sanding)</option>
          <option value="poor">Poor (heavy prep, skim coat)</option>
        </select>
      </div>
    </div>

    <!-- Paint & Materials -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Paint & Materials</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-4">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="paint-quality">Paint Quality</label>
        <select id="paint-quality" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="budget">Budget (~$25/gal)</option>
          <option value="standard" selected>Standard (~$40/gal)</option>
          <option value="premium">Premium (~$60/gal)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="num-coats">Number of Coats</label>
        <select id="num-coats" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="1">1 Coat</option>
          <option value="2" selected>2 Coats</option>
          <option value="3">3 Coats</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="primer-needed">Primer Needed?</label>
        <select id="primer-needed" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="no">No</option>
          <option value="yes" selected>Yes (1 coat)</option>
        </select>
      </div>
    </div>

    <!-- Additional Services -->
    <div class="bg-bg-dark border border-border rounded-lg p-4 mb-8">
      <p class="text-sm font-medium text-text-secondary mb-3">Additional Services <span class="text-text-muted">(check to include)</span></p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
        <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer hover:text-text-primary transition-colors">
          <input type="checkbox" class="addon-item accent-accent" data-hours="0.5" data-materials="15" data-label="trim" />
          Trim/baseboards per room
        </label>
        <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer hover:text-text-primary transition-colors">
          <input type="checkbox" class="addon-item accent-accent" data-hours="1.5" data-materials="20" data-label="ceiling" />
          Ceiling painting per room
        </label>
        <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer hover:text-text-primary transition-colors">
          <input type="checkbox" class="addon-item accent-accent" data-hours="1" data-materials="10" data-label="doors" />
          Door painting (per door, ~2 doors/room)
        </label>
        <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer hover:text-text-primary transition-colors">
          <input type="checkbox" class="addon-item accent-accent" data-hours="0.5" data-materials="8" data-label="closets" />
          Closet interiors per room
        </label>
        <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer hover:text-text-primary transition-colors">
          <input type="checkbox" class="addon-item accent-accent" data-hours="2" data-materials="25" data-label="wallpaper" />
          Wallpaper removal per room
        </label>
        <label class="flex items-center gap-2 text-sm text-text-secondary cursor-pointer hover:text-text-primary transition-colors">
          <input type="checkbox" class="addon-item accent-accent" data-hours="1" data-materials="15" data-label="accent" />
          Accent wall (2-color) per room
        </label>
      </div>
    </div>

    <!-- Labor & Pricing -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Labor & Pricing</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="crew-size">Crew Size</label>
        <input type="number" id="crew-size" value="2" min="1" max="10" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="hourly-rate">Your Billable Rate ($/hr)</label>
        <input type="number" id="hourly-rate" value="55" min="10" max="200" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="materials-markup">Materials Markup (%)</label>
        <input type="number" id="materials-markup" value="40" min="0" max="200" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Reverse Calculator Toggle -->
    <div class="bg-bg-dark border border-border rounded-lg p-5 mb-8">
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" id="reverse-toggle" class="accent-accent w-4 h-4" />
        <span class="text-sm font-medium text-text-primary">I want to hit a target price</span>
      </label>
      <div id="reverse-section" class="hidden mt-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2" for="target-price">Target Sell Price ($)</label>
            <input type="number" id="target-price" value="3500" min="0" step="100" class="w-full bg-bg-dark border border-[rgba(255,107,43,0.4)] rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div class="flex items-end">
            <div class="bg-bg-card border border-border rounded-lg p-4 w-full">
              <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">That Target Gives You</div>
              <div id="reverse-margin" class="font-heading font-extrabold text-2xl text-text-primary">&mdash;</div>
              <div class="text-text-muted text-xs mt-1">gross margin</div>
            </div>
          </div>
        </div>
      </div>
    </div>


    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Interior Painting Estimate</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Suggested Price</div>
          <div id="result-total-sell" class="font-heading font-extrabold text-3xl text-accent">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Gross Profit</div>
          <div id="result-gross-profit" class="font-heading font-extrabold text-3xl text-[#34D399]">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Profit Margin</div>
          <div id="result-margin" class="font-heading font-extrabold text-3xl">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cost per Sq Ft</div>
          <div id="result-per-sqft" class="font-heading font-extrabold text-3xl text-text-primary">&mdash;</div>
        </div>
      </div>

      <!-- Breakdown -->
      <div class="bg-bg-dark rounded-xl p-6 mb-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Cost &amp; Sell Breakdown</h4>
        <div class="space-y-3">
          <div class="flex justify-between items-center text-sm py-2 border-b border-border">
            <span class="text-text-secondary">Paint</span>
            <div class="flex gap-6">
              <span class="text-text-muted w-24 text-right">Cost: <span id="breakdown-paint-cost" class="text-text-primary">$0</span></span>
              <span class="text-text-muted w-24 text-right">Sell: <span id="breakdown-paint-sell" class="text-accent">$0</span></span>
            </div>
          </div>
          <div class="flex justify-between items-center text-sm py-2 border-b border-border">
            <span class="text-text-secondary">Primer</span>
            <div class="flex gap-6">
              <span class="text-text-muted w-24 text-right">Cost: <span id="breakdown-primer-cost" class="text-text-primary">$0</span></span>
              <span class="text-text-muted w-24 text-right">Sell: <span id="breakdown-primer-sell" class="text-accent">$0</span></span>
            </div>
          </div>
          <div class="flex justify-between items-center text-sm py-2 border-b border-border">
            <span class="text-text-secondary">Supplies <span class="text-text-muted text-xs">(tape, drop cloths, rollers)</span></span>
            <div class="flex gap-6">
              <span class="text-text-muted w-24 text-right">Cost: <span id="breakdown-supplies-cost" class="text-text-primary">$0</span></span>
              <span class="text-text-muted w-24 text-right">Sell: <span id="breakdown-supplies-sell" class="text-accent">$0</span></span>
            </div>
          </div>
          <div class="flex justify-between items-center text-sm py-2 border-b border-border">
            <span class="text-text-secondary">Labor</span>
            <div class="flex gap-6">
              <span class="text-text-muted w-24 text-right"><span id="breakdown-labor-hours" class="text-text-primary">0</span> hrs</span>
              <span class="text-text-muted w-24 text-right">Sell: <span id="breakdown-labor-sell" class="text-accent">$0</span></span>
            </div>
          </div>
          <div class="flex justify-between items-center text-sm py-2">
            <span class="text-text-secondary">Add-Ons</span>
            <div class="flex gap-6">
              <span class="text-text-muted w-24 text-right">Cost: <span id="breakdown-addon-cost" class="text-text-primary">$0</span></span>
              <span class="text-text-muted w-24 text-right">Sell: <span id="breakdown-addon-sell" class="text-accent">$0</span></span>
            </div>
          </div>
        </div>
        <div class="mt-4 pt-4 border-t border-border flex justify-between items-center font-heading font-bold">
          <span class="text-text-primary">Totals</span>
          <div class="flex gap-6">
            <span class="text-text-muted w-24 text-right">Cost: <span id="breakdown-total-cost" class="text-text-primary">$0</span></span>
            <span class="text-text-muted w-24 text-right">Sell: <span id="breakdown-total-sell" class="text-accent">$0</span></span>
          </div>
        </div>
      </div>

      <!-- Per Room Average -->
      <div class="bg-bg-dark rounded-xl p-5">
        <p class="text-text-secondary text-sm"><strong class="text-text-primary">Per Room Average:</strong> <span id="per-room-avg">--</span> &mdash; Industry range for a standard room: $400-$800.</p>
      </div>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter the project scope.</strong> Set the number of rooms and total wall area in square feet. If you have not measured yet, a standard bedroom is about 400 sq ft of wall area and a living room is about 600-800 sq ft.</p>
          <p><strong class="text-text-primary">2. Assess the surface condition.</strong> Good condition means light cleaning and minimal prep. Fair means some patching, sanding, and spot priming. Poor means heavy prep work like skim coating, scraping, or dealing with wallpaper removal.</p>
          <p><strong class="text-text-primary">3. Choose paint quality and coats.</strong> Budget paint covers about 350 sq ft per gallon, standard about 400, and premium about 400 with better hide. Two coats is standard for most color changes. Three coats may be needed for dark-to-light transitions.</p>
          <p><strong class="text-text-primary">4. Add extras.</strong> Check any additional services like trim, ceilings, doors, or wallpaper removal. Each adds labor hours and materials to the estimate.</p>
          <p><strong class="text-text-primary">5. Set your labor rate and markup.</strong> Enter your billable rate per painter per hour and your materials markup percentage. The calculator builds the total estimate and shows your margin.</p>
        </div>
      </section>

      <!-- How It Works -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How Interior Cost Calculation Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Materials are calculated from area and coverage.</strong> Paint coverage runs about 350-400 sq ft per gallon depending on quality. Primer covers about 300-350 sq ft per gallon. The calculator figures gallons needed, multiplies by price per gallon, adds supplies (tape, drop cloths, rollers), then applies your markup.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Paint_Gallons = (Area x Coats) / Coverage_Rate</p>
            <p>Labor_Hours = (Area / 350) + Prep_Hours + Addon_Hours</p>
            <p>Material_Cost = Paint + Primer + Supplies</p>
            <p>Suggested_Price = (Material_Cost x Markup) + (Labor_Hours x Billable_Rate)</p>
          </div>
          <p><strong class="text-text-primary">Labor is the biggest line item.</strong> Interior painting runs about 350 sq ft per hour for walls with a roller. Prep adds 20-50% depending on condition. Trim work runs about 200 sq ft per hour. The crew size determines elapsed time on site but not total labor hours charged.</p>
          <p><strong class="text-text-primary">Target 35-45% gross margin.</strong> If the calculator shows you below 30%, increase your rate or markup. Interior work should carry higher margins than exterior because equipment costs are lower and weather is not a factor.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Building a quote after the walkthrough.</strong> You have measured the rooms, assessed the surfaces, and the customer wants a number. Plug in the details and have a professional estimate ready in minutes.</p>
          <p><strong class="text-text-primary">Comparing options for the customer.</strong> Run the calculator with standard paint, then again with premium. Show the customer both price points. The difference is usually smaller than they expect, which helps upsell to better products.</p>
          <p><strong class="text-text-primary">Training new estimators.</strong> New team members often underestimate prep time or forget to include primer. This calculator forces them to account for every cost category so nothing gets missed in the quote.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I price an interior painting job?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Calculate the total square footage, determine paint and primer needs, estimate labor hours based on surface condition and complexity, then add your material costs with markup. A standard interior room takes 4-8 hours for a two-person crew depending on size and prep. Target 35-45% gross margin on residential interior work.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What profit margin should I target on interior painting?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most successful painting companies target 35-45% gross margin on interior work. The industry average sits around 40%. Below 25% means you are likely losing money after overhead. Interior work has lower equipment costs than exterior, so margins should be higher.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much does it cost to paint a room?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A standard bedroom costs $400-800 to paint professionally. A living room runs $900-1,500 depending on size. These ranges assume two coats, standard prep, and mid-grade paint. Add 20-30% for poor surface conditions requiring heavy prep. Premium paint adds 15-25% to material costs.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How long does it take to paint a room?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A single painter can complete a standard 12x12 bedroom in 4-6 hours including prep, two coats, and cleanup. A two-person crew can do it in 2.5-4 hours. Larger rooms like living rooms take 6-10 hours for one painter. Heavy prep work can add 2-4 hours per room.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // Paint cost per gallon by quality
  const paintPrices: Record<string, number> = {
    'budget': 25,
    'standard': 40,
    'premium': 60,
  };

  // Coverage rates (sq ft per gallon)
  const coverageRates: Record<string, number> = {
    'budget': 350,
    'standard': 400,
    'premium': 400,
  };

  // Primer cost per gallon and coverage
  const PRIMER_PRICE = 30;
  const PRIMER_COVERAGE = 325;

  // Prep multipliers by surface condition
  const prepMultipliers: Record<string, number> = {
    'good': 0.1,
    'fair': 0.3,
    'poor': 0.5,
  };

  // Base production rate: sq ft per hour for wall painting
  const BASE_PRODUCTION_RATE = 350;

  // Supplies cost per room
  const SUPPLIES_PER_ROOM = 15;

  // Internal labor cost per hour (for margin calculation)
  const INTERNAL_LABOR_COST = 25;

  // Reverse calculator toggle
  document.getElementById('reverse-toggle')?.addEventListener('change', () => {
    const checked = (document.getElementById('reverse-toggle') as HTMLInputElement).checked;
    const section = document.getElementById('reverse-section')!;
    if (checked) {
      section.classList.remove('hidden');
    } else {
      section.classList.add('hidden');
    }
    calculate();
  });

  function calculate() {
    // Inputs
    const numRooms = parseInt((document.getElementById('num-rooms') as HTMLInputElement).value) || 3;
    const totalSqft = parseFloat((document.getElementById('total-sqft') as HTMLInputElement).value) || 1200;
    const surfaceCondition = (document.getElementById('surface-condition') as HTMLSelectElement).value;
    const paintQuality = (document.getElementById('paint-quality') as HTMLSelectElement).value;
    const numCoats = parseInt((document.getElementById('num-coats') as HTMLSelectElement).value) || 2;
    const primerNeeded = (document.getElementById('primer-needed') as HTMLSelectElement).value === 'yes';
    const crewSize = parseInt((document.getElementById('crew-size') as HTMLInputElement).value) || 2;
    const hourlyRate = parseFloat((document.getElementById('hourly-rate') as HTMLInputElement).value) || 55;
    const materialsMarkup = parseFloat((document.getElementById('materials-markup') as HTMLInputElement).value) || 40;

    // Paint calculation
    const pricePerGallon = paintPrices[paintQuality] || 40;
    const coverageRate = coverageRates[paintQuality] || 400;
    const paintGallons = Math.ceil((totalSqft * numCoats) / coverageRate);
    const paintCost = paintGallons * pricePerGallon;

    // Primer calculation
    let primerCost = 0;
    if (primerNeeded) {
      const primerGallons = Math.ceil(totalSqft / PRIMER_COVERAGE);
      primerCost = primerGallons * PRIMER_PRICE;
    }

    // Supplies
    const suppliesCost = numRooms * SUPPLIES_PER_ROOM;

    // Add-on calculations
    let addonHours = 0;
    let addonMaterialsCost = 0;
    document.querySelectorAll('.addon-item').forEach(cb => {
      const checkbox = cb as HTMLInputElement;
      if (checkbox.checked) {
        addonHours += parseFloat(checkbox.dataset.hours || '0') * numRooms;
        addonMaterialsCost += parseFloat(checkbox.dataset.materials || '0') * numRooms;
      }
    });

    // Labor hours
    const baseHours = totalSqft / BASE_PRODUCTION_RATE;
    const prepHours = baseHours * (prepMultipliers[surfaceCondition] || 0.1);
    const primerHours = primerNeeded ? (totalSqft / 400) : 0;
    const totalLaborHours = (baseHours * numCoats) + prepHours + primerHours + addonHours;

    // Costs
    const totalMaterialsCost = paintCost + primerCost + suppliesCost + addonMaterialsCost;
    const totalMaterialsSell = totalMaterialsCost * (1 + materialsMarkup / 100);
    const laborSell = totalLaborHours * hourlyRate;
    const laborCost = totalLaborHours * INTERNAL_LABOR_COST;

    // Addon breakdown
    const addonSell = (addonMaterialsCost * (1 + materialsMarkup / 100)) + (addonHours * hourlyRate);
    const addonCostTotal = addonMaterialsCost + (addonHours * INTERNAL_LABOR_COST);

    // Totals
    const totalCost = (paintCost + primerCost + suppliesCost) + laborCost + addonCostTotal;
    const totalSell = totalMaterialsSell + laborSell;
    const grossProfit = totalSell - totalCost;
    const margin = totalSell > 0 ? (grossProfit / totalSell) * 100 : 0;
    const perSqft = totalSell / totalSqft;
    const perRoom = totalSell / numRooms;

    // Format currency
    const fmt = (n: number) => '$' + Math.round(n).toLocaleString();

    // Main results
    document.getElementById('result-total-sell')!.textContent = fmt(totalSell);
    document.getElementById('result-gross-profit')!.textContent = fmt(grossProfit);
    document.getElementById('result-per-sqft')!.textContent = '$' + perSqft.toFixed(2);

    // Profit color
    const profitEl = document.getElementById('result-gross-profit')!;
    profitEl.className = 'font-heading font-extrabold text-3xl';
    profitEl.classList.add(grossProfit >= 0 ? 'text-[#34D399]' : 'text-[#EF4444]');

    // Margin with color coding
    const marginEl = document.getElementById('result-margin')!;
    marginEl.textContent = margin.toFixed(1) + '%';
    marginEl.className = 'font-heading font-extrabold text-3xl';
    if (margin >= 35) {
      marginEl.classList.add('text-[#34D399]');
    } else if (margin >= 25) {
      marginEl.classList.add('text-[#FBBF24]');
    } else {
      marginEl.classList.add('text-[#EF4444]');
    }

    // Breakdown - materials split
    const paintSell = paintCost * (1 + materialsMarkup / 100);
    const primerSell = primerCost * (1 + materialsMarkup / 100);
    const suppliesSell = suppliesCost * (1 + materialsMarkup / 100);

    document.getElementById('breakdown-paint-cost')!.textContent = fmt(paintCost);
    document.getElementById('breakdown-paint-sell')!.textContent = fmt(paintSell);
    document.getElementById('breakdown-primer-cost')!.textContent = fmt(primerCost);
    document.getElementById('breakdown-primer-sell')!.textContent = fmt(primerSell);
    document.getElementById('breakdown-supplies-cost')!.textContent = fmt(suppliesCost);
    document.getElementById('breakdown-supplies-sell')!.textContent = fmt(suppliesSell);
    document.getElementById('breakdown-labor-hours')!.textContent = totalLaborHours.toFixed(1);
    document.getElementById('breakdown-labor-sell')!.textContent = fmt(laborSell);
    document.getElementById('breakdown-addon-cost')!.textContent = fmt(addonCostTotal);
    document.getElementById('breakdown-addon-sell')!.textContent = fmt(addonSell);
    document.getElementById('breakdown-total-cost')!.textContent = fmt(totalCost);
    document.getElementById('breakdown-total-sell')!.textContent = fmt(totalSell);

    // Per room
    document.getElementById('per-room-avg')!.textContent = fmt(perRoom) + '/room';

    // Reverse calculator
    const reverseToggle = (document.getElementById('reverse-toggle') as HTMLInputElement).checked;
    if (reverseToggle) {
      const targetPrice = parseFloat((document.getElementById('target-price') as HTMLInputElement).value) || 0;
      const targetProfit = targetPrice - totalCost;
      const targetMargin = targetPrice > 0 ? (targetProfit / targetPrice) * 100 : 0;

      const reverseMarginEl = document.getElementById('reverse-margin')!;
      reverseMarginEl.textContent = targetMargin.toFixed(1) + '% margin';
      reverseMarginEl.className = 'font-heading font-extrabold text-2xl';
      if (targetMargin >= 35) {
        reverseMarginEl.classList.add('text-[#34D399]');
      } else if (targetMargin >= 25) {
        reverseMarginEl.classList.add('text-[#FBBF24]');
      } else {
        reverseMarginEl.classList.add('text-[#EF4444]');
      }
    }
  }

  // Auto-calculate on any input change
  document.querySelectorAll('#interior-calc input[type="number"], #interior-calc select, #interior-calc input[type="checkbox"]').forEach(el => {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  // Initial calculation
  calculate();
</script>
