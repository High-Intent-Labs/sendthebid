<script>
  (() => {
    const meta = (window as any).__ntqToolMeta;
    if (!meta || typeof (window as any).posthog === 'undefined') return;
    // Never cache window.posthog — real lib replaces the stub after async load.
    const props = {
      tool_slug: meta.toolSlug,
      trade_slug: meta.tradeSlug,
      trade_name: meta.tradeName,
      tool_name: meta.toolName,
      tool_category: meta.category,
    };
    // Tool Viewed — safe to use stub, fires synchronously
    (window as any).posthog.capture('tool_viewed', props);

    // Tool Used — first interaction with calculator
    let toolUsedFired = false;
    const calcArea = document.getElementById('ac-calc');
    if (calcArea) {
      const fireToolUsed = () => {
        if (toolUsedFired) return;
        toolUsedFired = true;
        (window as any).posthog?.capture('tool_used', props);
        if (typeof (window as any).gtag === 'function') {
          (window as any).gtag('event', 'conversion', { send_to: 'AW-17899660858/cBlqCOfI6JgcELrMnNdC' });
        }
      };
      calcArea.addEventListener('input', fireToolUsed, { once: true });
      calcArea.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('.space-pill, .region-pill, .ins-pill, .sun-pill, .glass-pill')) fireToolUsed();
      }, { once: true });
    }
  })();
</script>

<!-- Main calculator logic -->
<script>
  import { lookupZip, lookupRegion, REGIONS } from '../lib/climate';
  import type { ClimateLookup, Region } from '../lib/climate';
  import { calcRoom } from '../lib/hvac-calc';
  import type { RoomInputs, RoomResult, RoomType, Orientation, ExposedWalls, RoomInsulation } from '../lib/hvac-calc';
  import { recommendUnit, formatCost } from '../lib/unit-recommender';
  import type { SpaceType, Recommendation } from '../lib/unit-recommender';
  import { initSteppers } from '../lib/stepper';

  initSteppers();

  // ---------------------------------------------------------------------
  // A/B/C copy test on the email gate (experiment: acsize_gate_copy)
  // ---------------------------------------------------------------------
  const AB_EXPERIMENT = 'acsize_gate_copy';
  const AB_KEY = 'ntq_ab_acsize_gate';
  const AB_ASSIGNED_KEY = 'ntq_ab_acsize_gate_fired';
  const VARIANTS = {
    A: {
      headline: 'Get 3 installers near you with your results',
      subhead: "Enter your email — we'll send your sizing report plus a shortlist of HVAC pros in your ZIP.",
      cta: 'See Installers + Results',
    },
    B: {
      headline: 'Email me my full sizing report',
      subhead: 'Your BTU size, recommended unit type, and estimated install cost — delivered to your inbox so you can share with a contractor.',
      cta: 'Email My Report',
    },
    C: {
      headline: 'See what this install typically costs in your area',
      subhead: "We'll email your sizing results plus a local installed cost range based on 2026 HVAC installs in your ZIP.",
      cta: 'See My Cost Estimate',
    },
  } as const;
  type Variant = keyof typeof VARIANTS;

  function pickVariant(): Variant {
    const keys: Variant[] = ['A', 'B', 'C'];
    try {
      const stored = localStorage.getItem(AB_KEY);
      if (stored === 'A' || stored === 'B' || stored === 'C') return stored;
      const chosen = keys[Math.floor(Math.random() * keys.length)];
      localStorage.setItem(AB_KEY, chosen);
      return chosen;
    } catch {
      return keys[Math.floor(Math.random() * keys.length)];
    }
  }
  const abVariant = pickVariant();
  const copy = VARIANTS[abVariant];
  document.getElementById('gate-headline')!.textContent = copy.headline;
  document.getElementById('gate-subhead')!.textContent = copy.subhead;
  document.getElementById('gate-submit')!.textContent = copy.cta;

  try {
    if (!localStorage.getItem(AB_ASSIGNED_KEY)) {
      (window as any).posthog?.capture('ab_variant_assigned', {
        experiment: AB_EXPERIMENT,
        ab_variant: abVariant,
        tool_slug: 'ac-size-for-my-room',
      });
      localStorage.setItem(AB_ASSIGNED_KEY, '1');
    }
  } catch { /* ignore storage errors */ }

  // ---------------------------------------------------------------------
  // State
  // ---------------------------------------------------------------------
  let space: SpaceType | null = null;
  let climate: ClimateLookup | null = null;
  let insulation: RoomInsulation = 'average';
  let sun: 'shaded' | 'some' | 'lots' = 'some';
  let glass: 'little' | 'average' | 'lots' = 'average';

  // Sun exposure → Orientation (rough mapping; consumer doesn't know compass)
  const SUN_TO_ORIENT: Record<typeof sun, Orientation> = {
    shaded: 'N',
    some: 'E',
    lots: 'S',
  };
  // Glass amount → sq ft of window (rough; varies by space type, see computeWindowArea)
  function computeWindowArea(sqft: number, g: typeof glass): number {
    // base ratio scales with room size, then we bracket by user pick
    const base = sqft * 0.10; // 10% of floor area is the "average" envelope default
    if (g === 'little') return Math.round(base * 0.5);
    if (g === 'lots')   return Math.round(base * 2.0);
    return Math.round(base);
  }
  // Default exposed-walls count by space type
  const SPACE_TO_EXPOSED: Record<SpaceType, ExposedWalls> = {
    'garage': 2,
    'addition': 2,
    'bedroom': 2,
    'basement': 1,
    'home-office': 2,
    'whole-house': 2,
    'other': 2,
  };
  // Map space → roomType for internal-gains baseline in calcRoom
  const SPACE_TO_ROOMTYPE: Record<SpaceType, RoomType> = {
    'garage': 'other',
    'addition': 'living',
    'bedroom': 'bedroom',
    'basement': 'living',
    'home-office': 'office',
    'whole-house': 'living',
    'other': 'other',
  };

  // ---------------------------------------------------------------------
  // Step reveal helpers
  // ---------------------------------------------------------------------
  function revealStep(id: string) {
    const el = document.getElementById(id);
    if (el && el.classList.contains('hidden')) {
      el.classList.remove('hidden');
    }
  }

  // ---------------------------------------------------------------------
  // Space pill handlers
  // ---------------------------------------------------------------------
  document.querySelectorAll<HTMLButtonElement>('.space-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      const v = btn.dataset.space as SpaceType;
      space = v;
      document.querySelectorAll<HTMLButtonElement>('.space-pill').forEach(b => {
        b.classList.remove('border-accent');
        if (!b.classList.contains('border-dashed')) b.classList.add('border-border');
      });
      btn.classList.add('border-accent');

      if (v === 'whole-house') {
        // Redirect suggestion — hide all further steps + show redirect card
        document.getElementById('whole-house-redirect')!.classList.remove('hidden');
        ['step-2', 'step-3', 'step-4', 'calc-btn-area'].forEach(id => {
          document.getElementById(id)!.classList.add('hidden');
        });
      } else {
        document.getElementById('whole-house-redirect')!.classList.add('hidden');
        revealStep('step-2');
        revealStep('step-3');
        revealStep('step-4');
        revealStep('calc-btn-area');
      }
    });
  });

  // ---------------------------------------------------------------------
  // ZIP handler
  // ---------------------------------------------------------------------
  const zipInput = document.getElementById('zip') as HTMLInputElement;
  const zipDisplay = document.getElementById('zip-display')!;
  const zipFallback = document.getElementById('zip-fallback')!;

  function setClimateFromZip(raw: string) {
    const zip = raw.replace(/\D/g, '').slice(0, 5);
    if (zip.length < 3) {
      climate = null;
      zipDisplay.textContent = 'We use this to factor in your local climate.';
      zipFallback.classList.add('hidden');
      return;
    }
    const lookup = lookupZip(zip);
    if (lookup) {
      climate = lookup;
      zipDisplay.innerHTML = `<span class="text-text-primary font-medium">${lookup.state}</span> &middot; <span class="text-accent font-medium">${lookup.regionLabel} climate</span>`;
      zipFallback.classList.add('hidden');
    } else if (zip.length >= 3) {
      climate = null;
      zipDisplay.textContent = 'ZIP not recognized.';
      zipFallback.classList.remove('hidden');
    }
  }
  zipInput.addEventListener('input', () => setClimateFromZip(zipInput.value));

  document.querySelectorAll<HTMLButtonElement>('.region-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      const region = btn.dataset.region as Region;
      climate = lookupRegion(region, zipInput.value, '');
      const meta = REGIONS[region];
      zipDisplay.innerHTML = `<span class="text-accent font-medium">${meta.label} climate</span> <span class="text-text-muted">(manually selected)</span>`;
      zipFallback.classList.add('hidden');
      document.querySelectorAll<HTMLButtonElement>('.region-pill').forEach(b => b.classList.remove('border-accent'));
      btn.classList.add('border-accent');
    });
  });

  // ---------------------------------------------------------------------
  // Pill handlers: insulation / sun / glass
  // ---------------------------------------------------------------------
  function wirePills(selector: string, handler: (val: string) => void) {
    document.querySelectorAll<HTMLButtonElement>(selector).forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll<HTMLButtonElement>(selector).forEach(b => {
          b.classList.remove('border-accent');
          b.classList.add('border', 'border-border');
        });
        btn.classList.remove('border-border');
        btn.classList.add('border-accent');
        const data = Object.values(btn.dataset)[0];
        if (data) handler(data);
      });
    });
  }
  wirePills('.ins-pill',   v => { insulation = v as RoomInsulation; });
  wirePills('.sun-pill',   v => { sun = v as typeof sun; });
  wirePills('.glass-pill', v => { glass = v as typeof glass; });

  // ---------------------------------------------------------------------
  // Derived sqft display
  // ---------------------------------------------------------------------
  function updateDerived() {
    const l = parseFloat((document.getElementById('length') as HTMLInputElement).value) || 0;
    const w = parseFloat((document.getElementById('width') as HTMLInputElement).value) || 0;
    document.getElementById('d-sqft')!.textContent = (l * w).toLocaleString();
  }
  ['length', 'width'].forEach(id => {
    document.getElementById(id)!.addEventListener('input', updateDerived);
  });
  updateDerived();

  // ---------------------------------------------------------------------
  // Calculate — runs the load formula + unit recommender, then either
  // shows the gate (pro-grade install) or shows results inline (window /
  // portable — not worth the email capture)
  // ---------------------------------------------------------------------
  let pendingInputs: RoomInputs | null = null;
  let pendingResult: RoomResult | null = null;
  let pendingRec: Recommendation | null = null;
  const calcBtn = document.getElementById('calculate-btn') as HTMLButtonElement;
  const calcHint = document.getElementById('calc-hint')!;

  function readInputs(): RoomInputs | null {
    if (!space || space === 'whole-house') {
      calcHint.textContent = 'Please pick a space above.';
      calcHint.classList.remove('hidden');
      return null;
    }
    if (!climate) {
      calcHint.textContent = 'Please enter a valid ZIP code or pick a climate.';
      calcHint.classList.remove('hidden');
      return null;
    }
    calcHint.classList.add('hidden');
    const length = parseFloat((document.getElementById('length') as HTMLInputElement).value) || 20;
    const width = parseFloat((document.getElementById('width') as HTMLInputElement).value) || 20;
    const sqft = length * width;
    return {
      climate,
      roomType: SPACE_TO_ROOMTYPE[space],
      orientation: SUN_TO_ORIENT[sun],
      length,
      width,
      ceilingHeight: parseFloat((document.getElementById('ceiling') as HTMLInputElement).value) || 8,
      exposedWalls: SPACE_TO_EXPOSED[space],
      windowAreaSqFt: computeWindowArea(sqft, glass),
      doorAreaSqFt: space === 'garage' ? 60 : 0, // garages have big uninsulated doors
      insulation,
    };
  }

  calcBtn.addEventListener('click', () => {
    const inputs = readInputs();
    if (!inputs || !space) return;
    pendingInputs = inputs;
    pendingResult = calcRoom(inputs);
    pendingRec = recommendUnit({
      space,
      sqft: pendingResult.sqft,
      region: inputs.climate.region,
      insulation: insulation === 'average' ? 'average' : insulation,
      coolingBTU: pendingResult.coolingBTU,
      closestStandardBTU: pendingResult.closestStandardBTU,
      closestStandardLabel: pendingResult.closestStandardLabel,
    });

    if (pendingRec.needsPro) {
      // Show email gate
      document.getElementById('calc-btn-area')!.classList.add('hidden');
      document.getElementById('email-gate')!.classList.remove('hidden');
      (document.getElementById('gate-email') as HTMLInputElement).focus();
      (window as any).posthog?.capture('gate_shown', {
        experiment: AB_EXPERIMENT,
        ab_variant: abVariant,
        tool_slug: 'ac-size-for-my-room',
        recommended_unit_type: pendingRec.unitType,
        space,
      });
    } else {
      // Low-value cases (window / portable) — skip the gate, show results inline
      (window as any).posthog?.capture('gate_skipped_low_value', {
        tool_slug: 'ac-size-for-my-room',
        recommended_unit_type: pendingRec.unitType,
        space,
      });
      document.getElementById('calc-btn-area')!.classList.add('hidden');
      renderResults(/* emailSent */ false);
    }
  });

  // ---------------------------------------------------------------------
  // Render results — assembles the result card from pendingResult + pendingRec
  // ---------------------------------------------------------------------
  function renderResults(emailSent: boolean) {
    if (!pendingResult || !pendingRec || !pendingInputs) return;
    const r = pendingResult;
    const rec = pendingRec;
    const inputs = pendingInputs;

    // Header
    const spaceLabel = space === 'garage' ? 'garage'
      : space === 'addition' ? 'addition'
      : space === 'bedroom' ? 'bedroom'
      : space === 'basement' ? 'basement'
      : space === 'home-office' ? 'home office'
      : 'space';
    document.getElementById('r-space-intro')!.textContent = `For your ${r.sqft} sq ft ${spaceLabel}`;
    document.getElementById('r-location')!.textContent = `${inputs.climate.state ? inputs.climate.state + ' — ' : ''}${inputs.climate.regionLabel} climate`;

    // BTU + tonnage
    document.getElementById('r-btu')!.textContent = `${r.coolingBTU.toLocaleString()} BTU`;
    document.getElementById('r-tonnage')!.textContent = `That's about ${r.tonnage} ton${r.tonnage !== 1 ? 's' : ''}. Closest standard size: ${r.closestStandardLabel.replace(' mini-split', '')}.`;

    // Unit recommendation
    document.getElementById('r-unit-label')!.textContent = rec.unitLabel;
    document.getElementById('r-unit-why')!.textContent = rec.why;
    document.getElementById('r-cost')!.textContent = formatCost(rec.installCostLow, rec.installCostHigh);
    document.getElementById('r-pro')!.textContent = rec.needsPro ? 'Needs a licensed pro' : 'Fully DIY';
    document.getElementById('r-install-notes')!.textContent = rec.installNotes;

    const altEl = document.getElementById('r-alt-note')!;
    if (rec.alternativeNote) {
      altEl.textContent = rec.alternativeNote;
      altEl.classList.remove('hidden');
    } else {
      altEl.classList.add('hidden');
    }

    // Installer CTA — shown only for Angi-lead recommendations
    const ctaEl = document.getElementById('installer-cta')!;
    if (rec.isAngiLead) {
      ctaEl.classList.remove('hidden');
      // Pass ZIP + unit type to the Angi handoff URL (Alison to confirm final URL)
      const zip5 = (zipInput.value || '').replace(/\D/g, '').slice(0, 5);
      const link = document.getElementById('installer-link') as HTMLAnchorElement;
      const url = new URL(link.href);
      if (zip5) url.searchParams.set('zip', zip5);
      url.searchParams.set('unit', rec.unitType);
      url.searchParams.set('space', space || '');
      link.href = url.toString();
    } else {
      ctaEl.classList.add('hidden');
    }

    // "Results also sent to your inbox" banner — only if we actually sent an email
    const sentBanner = document.getElementById('sent-banner')!;
    if (emailSent) sentBanner.classList.remove('hidden');
    else sentBanner.classList.add('hidden');

    const resultsEl = document.getElementById('results')!;
    resultsEl.classList.remove('hidden');
    resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Track installer CTA clicks (the KPI that matters most)
  document.getElementById('installer-link')?.addEventListener('click', () => {
    (window as any).posthog?.capture('installer_match_clicked', {
      tool_slug: 'ac-size-for-my-room',
      recommended_unit_type: pendingRec?.unitType,
      space,
    });
  });

  // ---------------------------------------------------------------------
  // Email gate submission
  // ---------------------------------------------------------------------
  const gateSubmit = document.getElementById('gate-submit') as HTMLButtonElement;
  const gateEmail = document.getElementById('gate-email') as HTMLInputElement;
  const gateError = document.getElementById('gate-error')!;

  gateSubmit.addEventListener('click', async () => {
    const email = gateEmail.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      gateError.textContent = 'Please enter a valid email address.';
      gateError.classList.remove('hidden');
      return;
    }
    if (!pendingResult || !pendingInputs || !pendingRec) return;
    gateError.classList.add('hidden');
    gateSubmit.disabled = true;
    gateSubmit.textContent = 'Sending...';

    try {
      const res = await fetch('/api/email-capture', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          toolSlug: 'ac-size-for-my-room',
          toolName: 'What Size AC Do I Need?',
          tradeSlug: 'hvac',
          tradeName: 'HVAC',
          marketingConsent: true,
          sourceUrl: window.location.pathname,
          calculationResults: {
            mode: 'ac-room',
            space,
            coolingBTU: pendingResult.coolingBTU,
            heatingBTU: pendingResult.heatingBTU,
            tonnage: pendingResult.tonnage,
            closestStandardBTU: pendingResult.closestStandardBTU,
            closestStandardLabel: pendingResult.closestStandardLabel,
            sqft: pendingResult.sqft,
            state: pendingInputs.climate.state,
            region: pendingInputs.climate.regionLabel,
            dimensions: `${pendingInputs.length} × ${pendingInputs.width} ft`,
            insulation: pendingInputs.insulation,
            sun,
            recommendedUnitType: pendingRec.unitType,
            recommendedUnitLabel: pendingRec.unitLabel,
            recommendedUnitWhy: pendingRec.why,
            installCostLow: pendingRec.installCostLow,
            installCostHigh: pendingRec.installCostHigh,
            installNotes: pendingRec.installNotes,
            isAngiLead: pendingRec.isAngiLead,
          },
        }),
      });
      if (!res.ok) throw new Error('Failed to send');

      document.getElementById('email-gate')!.classList.add('hidden');
      renderResults(/* emailSent */ true);

      const meta = (window as any).__ntqToolMeta;
      if ((window as any).posthog && meta) {
        (window as any).posthog.capture('email_captured', {
          tool_slug: meta.toolSlug,
          trade_slug: meta.tradeSlug,
          trade_name: meta.tradeName,
          tool_name: meta.toolName,
          tool_category: meta.category,
          marketing_consent: true,
          gated: true,
          mode: 'ac-room',
          experiment: AB_EXPERIMENT,
          ab_variant: abVariant,
          recommended_unit_type: pendingRec.unitType,
          is_angi_lead: pendingRec.isAngiLead,
          space,
        });
      }
      if (typeof (window as any).gtag === 'function') {
        (window as any).gtag('event', 'conversion', { send_to: 'AW-17899660858/rqouCLin75gcELrMnNdC' });
      }
    } catch {
      gateError.textContent = 'Something went wrong. Please try again.';
      gateError.classList.remove('hidden');
      gateSubmit.disabled = false;
      gateSubmit.textContent = copy.cta;
    }
  });

  gateEmail.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') gateSubmit.click();
  });
</script>
