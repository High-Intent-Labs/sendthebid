---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/hvacTools';

const tool = getToolBySlug('mini-split-sizing-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What size mini-split do I need for a 12x14 bedroom?",
      "acceptedAnswer": { "@type": "Answer", "text": "A typical 12x14 (168 sqft) bedroom in a mixed climate needs roughly 6,000-9,000 BTU depending on insulation, orientation, and exposed walls. A 9,000 BTU mini-split is usually the right starting size. Enter your specific details above for a precise recommendation." }
    },
    {
      "@type": "Question",
      "name": "How is room-level sizing different from whole-house sizing?",
      "acceptedAnswer": { "@type": "Answer", "text": "Whole-house sizing averages across all spaces and assumes central distribution. Room-level sizing accounts for each room's specific exposure — a corner room facing south with 3 exposed walls has 40-50% more cooling load than an interior room of the same size. For mini-split sizing, room-level accuracy matters a lot more than whole-house." }
    },
    {
      "@type": "Question",
      "name": "What BTU sizes do standard mini-splits come in?",
      "acceptedAnswer": { "@type": "Answer", "text": "Standard residential mini-split head units come in 9k, 12k, 18k, 24k, and 36k BTU. Our tool rounds your calculated load to the closest standard size. Oversizing by more than one tier leads to short-cycling and humidity problems, so aim to match the standard size or slightly undersize if you're close to the boundary." }
    },
    {
      "@type": "Question",
      "name": "What does CFM mean in the results?",
      "acceptedAnswer": { "@type": "Answer", "text": "CFM (cubic feet per minute) is the airflow the unit needs to deliver the calculated cooling load. Useful if you're designing ductwork or selecting a ducted mini-split. The rule of thumb is cooling BTU ÷ 30, which assumes a 20°F temperature differential across the coil." }
    },
    {
      "@type": "Question",
      "name": "Does orientation really matter that much?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. A west-facing room in summer takes direct afternoon sun and can run 15-20% hotter than an east-facing room of the same size. South-facing rooms in hot climates are even worse. Our tool applies an orientation factor (N: 0.95, E: 1.0, W: 1.10, S: 1.15) to account for this." }
    }
  ]
};

const roomTypes = [
  { v: 'bedroom',  l: 'Bedroom' },
  { v: 'living',   l: 'Living Room' },
  { v: 'kitchen',  l: 'Kitchen' },
  { v: 'bathroom', l: 'Bathroom' },
  { v: 'office',   l: 'Home Office' },
  { v: 'dining',   l: 'Dining Room' },
  { v: 'garage',   l: 'Garage' },
  { v: 'basement', l: 'Basement' },
  { v: 'sunroom',  l: 'Sunroom' },
  { v: 'addition', l: 'Addition' },
  { v: 'other',    l: 'Other' },
];
---

<ToolLayout tool={tool} extraSchema={[faqSchema]} hideCards>
  <div id="mss-calc">
    <!-- ZIP + climate display -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-text-primary mb-2" for="zip">ZIP Code</label>
      <input type="text" id="zip" inputmode="numeric" maxlength="5" placeholder="e.g. 02108"
        class="w-full sm:max-w-[180px] bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      <!-- zip-display hosts one of four states injected by JS:
           empty (helper text), partial (keep typing), resolved (pro card
           with city + state + climate + IECC zone + design temps), or
           unrecognized (hint pointing to the fallback region picker). -->
      <div id="zip-display" class="mt-3 text-text-primary text-sm">Enter a 5-digit US ZIP to detect your climate region.</div>
      <div id="zip-fallback" class="hidden mt-3">
        <p class="text-text-primary text-xs mb-2">ZIP not found — pick your climate region:</p>
        <div class="flex flex-wrap gap-2">
          <button type="button" data-region="hot"   class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Hot</button>
          <button type="button" data-region="warm"  class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Warm</button>
          <button type="button" data-region="mixed" class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Mixed</button>
          <button type="button" data-region="cool"  class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Cool</button>
          <button type="button" data-region="cold"  class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Cold</button>
        </div>
      </div>
    </div>

    <!-- Room type pill picker -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-text-primary mb-2" for="roomtype-select">Room Type</label>
      <!-- Mobile: dropdown (11 pills wrap awkwardly on narrow screens).
           Wrapped in relative container with a chevron overlay so it reads
           unmistakably as a dropdown on iOS/Android (native appearance can
           be subtle or get reset by form-resets). -->
      <div class="relative md:hidden">
        <select id="roomtype-select"
          class="appearance-none w-full bg-bg-dark border border-border rounded-lg px-4 pr-10 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          {roomTypes.map((r) => (
            <option value={r.v}>{r.l}</option>
          ))}
        </select>
        <svg
          class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-primary"
          fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
      <!-- Desktop: pills (discoverable, one-click) -->
      <div class="hidden md:flex flex-wrap gap-2" id="roomtype-pills">
        {roomTypes.map((r, i) => (
          <button type="button" data-roomtype={r.v}
            class={`roomtype-pill bg-bg-dark border ${i === 0 ? 'border-accent' : 'border-border'} rounded-lg px-4 py-2 text-sm hover:border-accent transition-colors`}>
            {r.l}
          </button>
        ))}
      </div>
    </div>

    <!-- Room geometry -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
      <div>
        <label class="block text-sm font-medium text-text-primary mb-2" for="length">Room Length (ft)</label>
        <div class="number-stepper flex items-stretch bg-bg-dark border border-border rounded-lg focus-within:border-accent transition-colors overflow-hidden">
          <button type="button" aria-label="Decrease room length" class="stepper-minus px-6 md:px-4 text-text-primary hover:text-accent text-2xl font-bold leading-none select-none">−</button>
          <input type="number" id="length" value="12" min="4" max="100" step="1"
            class="flex-1 bg-transparent text-text-primary text-lg text-center focus:outline-none min-w-0 py-3 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
          <button type="button" aria-label="Increase room length" class="stepper-plus px-6 md:px-4 text-text-primary hover:text-accent text-2xl font-bold leading-none select-none">+</button>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-primary mb-2" for="width">Room Width (ft)</label>
        <div class="number-stepper flex items-stretch bg-bg-dark border border-border rounded-lg focus-within:border-accent transition-colors overflow-hidden">
          <button type="button" aria-label="Decrease room width" class="stepper-minus px-6 md:px-4 text-text-primary hover:text-accent text-2xl font-bold leading-none select-none">−</button>
          <input type="number" id="width" value="12" min="4" max="100" step="1"
            class="flex-1 bg-transparent text-text-primary text-lg text-center focus:outline-none min-w-0 py-3 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
          <button type="button" aria-label="Increase room width" class="stepper-plus px-6 md:px-4 text-text-primary hover:text-accent text-2xl font-bold leading-none select-none">+</button>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-primary mb-2" for="ceiling">Ceiling Height (ft)</label>
        <div class="number-stepper flex items-stretch bg-bg-dark border border-border rounded-lg focus-within:border-accent transition-colors overflow-hidden">
          <button type="button" aria-label="Decrease ceiling height" class="stepper-minus px-6 md:px-4 text-text-primary hover:text-accent text-2xl font-bold leading-none select-none">−</button>
          <input type="number" id="ceiling" value="8" min="6" max="20" step="1"
            class="flex-1 bg-transparent text-text-primary text-lg text-center focus:outline-none min-w-0 py-3 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
          <button type="button" aria-label="Increase ceiling height" class="stepper-plus px-6 md:px-4 text-text-primary hover:text-accent text-2xl font-bold leading-none select-none">+</button>
        </div>
      </div>
      <div>
        <div class="flex items-center gap-1.5 mb-2">
          <label class="block text-sm font-medium text-text-primary" for="exposed">Exposed Walls</label>
          <button type="button"
            data-help-toggle="exposed-help"
            aria-expanded="false"
            aria-controls="exposed-help"
            aria-label="How to count exposed walls"
            class="text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
        </div>
        <div class="relative">
          <select id="exposed"
            class="appearance-none w-full bg-bg-dark border border-border rounded-lg px-4 pr-10 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="0">0 — fully interior room</option>
            <option value="1">1 — one exterior wall</option>
            <option value="2" selected>2 — corner room</option>
            <option value="3">3 walls</option>
            <option value="4">4 — detached</option>
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-primary"
            fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
        <div id="exposed-help" class="hidden relative mt-2 rounded-lg border border-border bg-bg-dark/60 p-3 pr-8 text-xs text-text-primary leading-relaxed">
          <button type="button"
            data-help-toggle="exposed-help"
            aria-expanded="false"
            aria-controls="exposed-help"
            aria-label="Close help"
            class="absolute top-2 right-2 text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <p class="font-medium text-text-primary mb-1">How to count exposed walls</p>
          <p class="mb-2">Count walls that touch <strong>outside air or an unconditioned space</strong>. Walls adjoining a heated/cooled hallway or room don't count.</p>
          <ul class="space-y-0.5 mb-2">
            <li><strong>0</strong> — fully interior room (media room, interior office, walk-in closet). All walls, ceiling, and floor border conditioned space.</li>
            <li><strong>1</strong> — one exterior wall</li>
            <li><strong>2</strong> — corner room (most common)</li>
            <li><strong>3</strong> — bonus room or addition with three outside walls</li>
            <li><strong>4</strong> — detached garage, ADU, or freestanding structure</li>
          </ul>
          <p class="mb-1"><span class="text-text-primary">Also count:</span> walls bordering an unheated garage or unfinished attic; basement walls below grade.</p>
          <p class="mb-1"><span class="text-text-primary">Don't count:</span> walls between this room and a conditioned hallway or adjacent room.</p>
          <p class="mb-2"><span class="text-text-primary">Picking 0:</span> internal gains (people, equipment) dominate the load; the orientation picker stops affecting the result (there's no exterior wall to catch sun).</p>
          <p class="text-text-primary">This factor changes the cooling load by up to 50%.</p>
        </div>
      </div>
      <div>
        <div class="flex items-center gap-1.5 mb-2">
          <label class="block text-sm font-medium text-text-primary">Primary Orientation</label>
          <button type="button"
            data-help-toggle="orientation-help"
            aria-expanded="false"
            aria-controls="orientation-help"
            aria-label="How to pick primary orientation"
            class="text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
        </div>
        <div class="flex gap-2" id="orientation-pills">
          <button type="button" data-orient="N" class="orient-pill flex-1 bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-sm hover:border-accent transition-colors">N</button>
          <button type="button" data-orient="E" class="orient-pill flex-1 bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-sm hover:border-accent transition-colors">E</button>
          <button type="button" data-orient="S" class="orient-pill flex-1 bg-bg-dark border-accent rounded-lg px-3 py-2.5 text-sm hover:border-accent transition-colors">S</button>
          <button type="button" data-orient="W" class="orient-pill flex-1 bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-sm hover:border-accent transition-colors">W</button>
        </div>
        <div id="orientation-help" class="hidden relative mt-2 rounded-lg border border-border bg-bg-dark/60 p-3 pr-8 text-xs text-text-primary leading-relaxed">
          <button type="button"
            data-help-toggle="orientation-help"
            aria-expanded="false"
            aria-controls="orientation-help"
            aria-label="Close help"
            class="absolute top-2 right-2 text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <p class="font-medium text-text-primary mb-1">How to pick primary orientation</p>
          <p class="mb-2">The direction the <strong>largest exterior wall</strong> faces — not the front door.</p>
          <ul class="space-y-0.5 mb-2">
            <li>Room with one exterior wall → that direction.</li>
            <li>Corner room (2 exterior walls) → pick the wall with <strong>more window area</strong>.</li>
            <li>3-4 exterior walls → pick the wall with the greatest combined window + door area.</li>
          </ul>
          <p class="text-text-primary">South and west walls take the most summer solar load; north the least. Factor range: 0.95 (N) to 1.15 (S).</p>
        </div>
      </div>
      <div>
        <div class="flex items-center gap-1.5 mb-2">
          <label class="block text-sm font-medium text-text-primary" for="insulation">Insulation Level</label>
          <button type="button"
            data-help-toggle="insulation-help"
            aria-expanded="false"
            aria-controls="insulation-help"
            aria-label="How to pick insulation level"
            class="text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
        </div>
        <div class="relative">
          <select id="insulation"
            class="appearance-none w-full bg-bg-dark border border-border rounded-lg px-4 pr-10 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="excellent">Excellent (new construction / deep retrofit)</option>
            <option value="good">Good (above average)</option>
            <option value="average" selected>Average (standard code)</option>
            <option value="poor">Poor (pre-1990 unimproved)</option>
            <option value="bad">Bad (no wall insulation)</option>
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-primary"
            fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
        <div id="insulation-help" class="hidden relative mt-2 rounded-lg border border-border bg-bg-dark/60 p-3 pr-8 text-xs text-text-primary leading-relaxed">
          <button type="button"
            data-help-toggle="insulation-help"
            aria-expanded="false"
            aria-controls="insulation-help"
            aria-label="Close help"
            class="absolute top-2 right-2 text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <p class="font-medium text-text-primary mb-1">How to pick insulation level</p>
          <p class="mb-2">When in doubt, drop a tier — houses are usually a bit worse than they look.</p>
          <ul class="space-y-0.5 mb-2">
            <li><strong>Excellent</strong> — post-2018 code or deep retrofit. R-19+ walls, R-38+ attic, spray foam, blower-door tested.</li>
            <li><strong>Good</strong> — 2010-era. R-15 walls, R-30 attic, double-pane low-E windows.</li>
            <li><strong>Average</strong> — standard-code compliant. R-13 walls, R-30 attic, double-pane windows.</li>
            <li><strong>Poor</strong> — pre-1990 unimproved. R-11 or less, single-pane windows, visibly drafty.</li>
            <li><strong>Bad</strong> — no wall insulation. Pre-1950 construction; cold spots, daylight around outlets.</li>
          </ul>
          <p class="text-text-primary">Changes cooling load by up to 30%.</p>
        </div>
      </div>
      <div>
        <div class="flex items-center gap-1.5 mb-2">
          <label class="block text-sm font-medium text-text-primary" for="windowArea">Window Area (sq ft)</label>
          <button type="button"
            data-help-toggle="windowArea-help"
            aria-expanded="false"
            aria-controls="windowArea-help"
            aria-label="How to estimate window area"
            class="text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
        </div>
        <div class="number-stepper flex items-stretch bg-bg-dark border border-border rounded-lg focus-within:border-accent transition-colors overflow-hidden">
          <button type="button" aria-label="Decrease window area" class="stepper-minus px-6 md:px-4 text-text-primary hover:text-accent text-2xl font-bold leading-none select-none">−</button>
          <input type="number" id="windowArea" value="20" min="0" max="500" step="1"
            class="flex-1 bg-transparent text-text-primary text-lg text-center focus:outline-none min-w-0 py-3 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
          <button type="button" aria-label="Increase window area" class="stepper-plus px-6 md:px-4 text-text-primary hover:text-accent text-2xl font-bold leading-none select-none">+</button>
        </div>
        <div id="windowArea-help" class="hidden relative mt-2 rounded-lg border border-border bg-bg-dark/60 p-3 pr-8 text-xs text-text-primary leading-relaxed">
          <button type="button"
            data-help-toggle="windowArea-help"
            aria-expanded="false"
            aria-controls="windowArea-help"
            aria-label="Close help"
            class="absolute top-2 right-2 text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <p class="font-medium text-text-primary mb-1">How to estimate window area</p>
          <p class="mb-2">Total glass area in this room, in sqft. Measure the <strong>glass</strong>, not the rough opening — subtract ~10% for the frame if unsure.</p>
          <ul class="space-y-0.5 mb-2">
            <li>Standard double-hung: ~3 × 5 ft = <strong>15 sqft</strong></li>
            <li>Large picture window: ~4 × 6 ft = <strong>24 sqft</strong></li>
            <li>Sliding patio door: ~6 × 6.5 ft = <strong>39 sqft</strong> (count here, not in Door Area)</li>
            <li>Count skylights too.</li>
          </ul>
          <p class="mb-2"><strong class="text-text-primary">Include sliding glass doors and French doors here</strong> — not in Door Area. They behave as windows for heat transfer.</p>
          <p class="text-text-primary">Glass dominates the cooling load: 870 BTU/hr per sqft of window vs 25 BTU/hr per sqft of floor.</p>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-primary mb-2" for="doorArea">Exterior Door Area (sq ft)</label>
        <div class="number-stepper flex items-stretch bg-bg-dark border border-border rounded-lg focus-within:border-accent transition-colors overflow-hidden">
          <button type="button" aria-label="Decrease door area" class="stepper-minus px-6 md:px-4 text-text-primary hover:text-accent text-2xl font-bold leading-none select-none">−</button>
          <input type="number" id="doorArea" value="0" min="0" max="100" step="1"
            class="flex-1 bg-transparent text-text-primary text-lg text-center focus:outline-none min-w-0 py-3 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
          <button type="button" aria-label="Increase door area" class="stepper-plus px-6 md:px-4 text-text-primary hover:text-accent text-2xl font-bold leading-none select-none">+</button>
        </div>
      </div>
      <div class="flex flex-col justify-end">
        <p id="derived" class="text-text-primary text-xs leading-snug">
          <span class="text-text-primary">Room floor area:</span> <span id="d-sqft">144</span> sq ft<br>
          <span class="text-text-primary">Volume:</span> <span id="d-vol">1,152</span> cu ft
        </p>
      </div>
    </div>

    <div id="calc-btn-area" class="mt-2">
      <button id="calculate-btn" type="button"
        class="w-full bg-accent hover:bg-accent-hover text-white font-heading font-bold text-lg px-8 py-4 rounded-xl transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
        Calculate Mini-Split Size
      </button>
      <p id="calc-hint" class="hidden mt-3 text-sm text-[#EF4444]"></p>
    </div>

    <div id="email-gate" class="hidden mt-8 border-t border-border pt-8">
      <div class="max-w-lg mx-auto text-center">
        <div class="w-14 h-14 rounded-2xl bg-accent/15 flex items-center justify-center mx-auto mb-4">
          <svg width="28" height="28" viewBox="0 0 20 20" fill="none" class="text-accent">
            <path d="M2.5 6.667L9.025 11.05a1.667 1.667 0 001.95 0L17.5 6.667M4.167 15h11.666A1.667 1.667 0 0017.5 13.333V6.667A1.667 1.667 0 0015.833 5H4.167A1.667 1.667 0 002.5 6.667v6.666A1.667 1.667 0 004.167 15z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 id="gate-headline" class="font-heading font-bold text-xl text-text-primary mb-2">Your mini-split size is ready</h3>
        <p id="gate-subhead" class="text-text-primary text-sm mb-6">Enter your email to get your room load calculation — cooling BTU, closest standard mini-split size, and suggested airflow.</p>
        <div class="flex flex-col sm:flex-row gap-3 mb-3">
          <label for="gate-email" class="sr-only">Your work email</label>
          <input type="email" id="gate-email" placeholder="you@company.com" required
            class="flex-1 bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-base focus:border-accent focus:outline-none transition-colors placeholder:text-text-primary" />
          <button id="gate-submit" type="button"
            class="bg-accent hover:bg-accent-hover text-white font-semibold px-6 py-3 rounded-lg transition-colors whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed">
            Send My Results
          </button>
        </div>
        <label class="flex items-center justify-center gap-2 cursor-pointer select-none">
          <input type="checkbox" id="gate-consent" checked class="w-4 h-4 rounded border-border bg-bg-dark accent-gray-500 opacity-70" />
          <span class="text-text-primary text-xs">Also send me free tools and tips for pros. Unsubscribe anytime.</span>
        </label>
        <div id="gate-error" class="hidden mt-3 text-sm text-[#EF4444]"></div>
      </div>
    </div>

    <div id="results" class="hidden mt-8 border-t border-border pt-8">
      <div class="mb-6 bg-[rgba(52,211,153,0.08)] border border-[rgba(52,211,153,0.25)] rounded-xl p-4 flex items-start gap-3">
        <div class="shrink-0 w-8 h-8 rounded-full bg-[rgba(52,211,153,0.15)] flex items-center justify-center">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" class="text-[#34D399]">
            <path d="M16.667 5L7.5 14.167 3.333 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <p class="text-text-primary font-semibold text-sm">Results also sent to your inbox</p>
          <p class="text-text-primary text-xs mt-0.5">Don't see it? Check your Spam or Promotions folder.</p>
        </div>
      </div>

      <h3 class="font-heading font-bold text-xl mb-6">Your Mini-Split Size</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-primary text-xs font-medium uppercase tracking-wider mb-2">Cooling Load</div>
          <div id="r-cool" class="font-heading font-extrabold text-2xl text-accent">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-primary text-xs font-medium uppercase tracking-wider mb-2">Closest Standard Size</div>
          <div id="r-std" class="font-heading font-extrabold text-lg text-text-primary">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-primary text-xs font-medium uppercase tracking-wider mb-2">Heating Load</div>
          <div id="r-heat" class="font-heading font-extrabold text-2xl text-text-primary">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-primary text-xs font-medium uppercase tracking-wider mb-2">Suggested Airflow</div>
          <div id="r-cfm" class="font-heading font-extrabold text-2xl text-text-primary">—</div>
        </div>
      </div>
      <p class="text-text-primary text-sm italic">Estimate only. Match to the closest standard size — oversizing leads to short-cycling and humidity problems.</p>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-primary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter the ZIP of the job site.</strong> Auto-detects climate region — one of the top drivers of cooling load.</p>
          <p><strong class="text-text-primary">2. Pick the room type.</strong> Bedroom, living, kitchen, bathroom, office, dining, garage, basement, sunroom, or addition. This sets internal gains automatically (kitchens get 4,000+ BTU extra for cooking; bedrooms and bathrooms far less).</p>
          <p><strong class="text-text-primary">3. Measure the room.</strong> Inside wall to inside wall. Length × Width × Ceiling height. We derive floor area and volume automatically.</p>
          <p><strong class="text-text-primary">4. Count exposed walls.</strong> An interior room with 1 wall touching outside air behaves very differently from a 3-walled corner. This factor changes the load by up to 40%.</p>
          <p><strong class="text-text-primary">5. Pick the primary orientation.</strong> Which direction the main exterior wall faces. South and west take more solar load in summer.</p>
          <p><strong class="text-text-primary">6. Measure window and door area.</strong> Actual glass/door area in sqft — a standard door is 20 sqft. Glass is the dominant envelope heat transfer path.</p>
          <p><strong class="text-text-primary">7. Click Calculate.</strong> Enter your email. We'll send the cooling BTU, closest mini-split size (9k/12k/18k/24k/36k), and suggested CFM.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How the Calculation Works</h2>
        <div class="text-text-primary leading-relaxed space-y-3">
          <p>We use a 25 BTU/sqft room baseline (higher than whole-house because individual rooms don't benefit from shared thermal mass and ductwork losses), then apply multipliers for each driver.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm overflow-x-auto">
            <p>base = length × width × 25 × (ceiling / 8)</p>
            <p class="mt-2">envelope = base × exposedWallFactor × orientationFactor × insulationFactor</p>
            <p class="mt-2">gains = windowArea × 870 + doorArea × 50 + roomTypeInternal</p>
            <p class="mt-2">coolingBTU = (envelope + gains) × climateFactor</p>
            <p class="mt-2">heatingBTU = coolingBTU × heatingFactor(region)</p>
            <p class="mt-2">closest = nearest([9000, 12000, 18000, 24000, 36000])</p>
            <p class="mt-2">CFM = coolingBTU / 30</p>
          </div>
          <p>Exposed wall factor: 0.85 (interior) → 1.25 (4-wall detached). Orientation factor: N 0.95, E 1.00, W 1.10, S 1.15. These follow standard Manual J adjustment patterns for room-level calculations.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When to Use This vs Whole-House</h2>
        <div class="text-text-primary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Use this tool when:</strong> sizing an individual mini-split head for a single room, sizing a zoned addition, troubleshooting a room that's too hot or cold, or designing room-level ductwork.</p>
          <p><strong class="text-text-primary">Use the whole-house <a href="/hvac/load-calculator/" class="text-accent hover:underline">Load Calculator</a> when:</strong> sizing a central system, a single outdoor heat pump unit, or quoting a full-house replacement. Room-level accuracy doesn't matter as much at that scale.</p>
          <p><strong class="text-text-primary">For permit work:</strong> neither of our tools is ACCA-accredited. Use ACCA-accredited Manual J software instead.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What size mini-split do I need for a 12x14 bedroom?</summary>
            <div class="px-5 pb-4 text-text-primary text-sm leading-relaxed">Roughly 6,000-9,000 BTU for a typical 12×14 bedroom in a mixed climate, depending on insulation, orientation, and exposed walls. A 9k mini-split is usually the right starting point. Enter your specifics above for a precise number.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How is this different from whole-house sizing?</summary>
            <div class="px-5 pb-4 text-text-primary text-sm leading-relaxed">Room-level accounts for each room's specific exposure. A corner bedroom facing south with 3 exposed walls has 40-50% more cooling load than an interior room of the same size. For mini-splits, this accuracy matters — for central systems, less so.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What BTU sizes do mini-splits come in?</summary>
            <div class="px-5 pb-4 text-text-primary text-sm leading-relaxed">Standard residential head units: 9k, 12k, 18k, 24k, 36k BTU. We round your calculated load to the closest standard. Avoid oversizing by more than one tier — it causes short-cycling and humidity problems.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What does CFM mean in the results?</summary>
            <div class="px-5 pb-4 text-text-primary text-sm leading-relaxed">Cubic feet per minute — the airflow needed to deliver the calculated cooling load. Useful for ductwork or selecting a ducted mini-split. Rule of thumb: cooling BTU ÷ 30, assuming a 20°F coil ΔT.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Does orientation really matter?</summary>
            <div class="px-5 pb-4 text-text-primary text-sm leading-relaxed">Yes. A west-facing room in summer takes direct afternoon sun and can run 15-20% hotter than an east-facing room of the same size. Our factor: N 0.95, E 1.00, W 1.10, S 1.15.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  import { lookupZip, lookupRegion, REGIONS } from '../../lib/climate';
  import type { Region } from '../../lib/climate';
  import { calcRoom } from '../../lib/hvac-calc';
  import type {
    RoomInputs, RoomType, Orientation, ExposedWalls, RoomInsulation, RoomResult,
  } from '../../lib/hvac-calc';
  import { initSteppers } from '../../lib/stepper';

  // Wire up +/- buttons on numeric inputs (mobile-friendly)
  initSteppers();

  // ---------------------------------------------------------------------------
  // A/B/C copy test on the email gate (experiment: mss_gate_copy)
  // ---------------------------------------------------------------------------
  // Assigns a sticky variant per user via localStorage, applies the copy to the
  // gate headline / subhead / CTA button before the gate is shown. Conversion
  // rate per variant is measured via two PostHog events tagged with ab_variant:
  //   - gate_shown    (fires when the email gate is revealed — denominator)
  //   - email_captured (fires on successful gate submission — numerator)
  // Analysis query (HogQL): filter events where properties.experiment =
  // 'mss_gate_copy', group by properties.ab_variant, count email_captured /
  // count gate_shown = per-variant conversion rate.
  const AB_EXPERIMENT = 'mss_gate_copy';
  const AB_KEY = 'ntq_ab_mss_gate';
  const AB_ASSIGNED_KEY = 'ntq_ab_mss_gate_fired';
  const VARIANTS = {
    A: {
      headline: 'Your sizing specs are ready.',
      subhead: 'Email yourself a summary — BTU, unit size, CFM, and the inputs that got you there.',
      cta: 'Email Me the Specs',
    },
    B: {
      headline: 'Where should we send your sizing?',
      subhead: "We'll email the full breakdown — so you never lose the inputs and results.",
      cta: 'Email My Results',
    },
    C: {
      headline: 'One email — so you have it saved.',
      subhead: "We'll email the full breakdown — BTU, unit size, CFM, and the inputs that got you there.",
      cta: 'Send My Results',
    },
  } as const;
  type Variant = keyof typeof VARIANTS;

  function pickVariant(): Variant {
    const keys: Variant[] = ['A', 'B', 'C'];
    try {
      const stored = localStorage.getItem(AB_KEY);
      if (stored === 'A' || stored === 'B' || stored === 'C') return stored;
      const chosen = keys[Math.floor(Math.random() * keys.length)];
      localStorage.setItem(AB_KEY, chosen);
      return chosen;
    } catch {
      // Private browsing / localStorage blocked → random per pageview (still valid data)
      return keys[Math.floor(Math.random() * keys.length)];
    }
  }

  const abVariant = pickVariant();
  const copy = VARIANTS[abVariant];

  // Apply variant copy to the gate (gate is hidden until Calculate, so no FOUC)
  document.getElementById('gate-headline')!.textContent = copy.headline;
  document.getElementById('gate-subhead')!.textContent = copy.subhead;
  document.getElementById('gate-submit')!.textContent = copy.cta;

  // Fire ab_variant_assigned exactly once per user (not per pageview)
  try {
    if (!localStorage.getItem(AB_ASSIGNED_KEY)) {
      (window as any).posthog?.capture('ab_variant_assigned', {
        experiment: AB_EXPERIMENT,
        ab_variant: abVariant,
        tool_slug: 'mini-split-sizing-calculator',
      });
      localStorage.setItem(AB_ASSIGNED_KEY, '1');
    }
  } catch { /* ignore storage errors */ }

  let climate: ReturnType<typeof lookupZip> = null;
  let roomType: RoomType = 'bedroom';
  let orientation: Orientation = 'S';

  const zipInput = document.getElementById('zip') as HTMLInputElement;
  const zipDisplay = document.getElementById('zip-display')!;
  const zipFallback = document.getElementById('zip-fallback')!;

  // ZIP card rendering + enrichment --------------------------------------
  // Sync path uses lookupZip for the climate region (drives the calc).
  // Async path hits /api/zip-lookup to enrich the card with city name,
  // IECC zone, and design temps — display only, never affects calculation.
  type ZipCardState = {
    kind: 'empty' | 'partial' | 'unrecognized' | 'manual';
  } | {
    kind: 'resolved';
    zip: string;
    city: string | null;
    state: string;
    regionLabel: string;
    ieccZone?: string;
    designCoolingDB?: number;
    designHeatingDB?: number;
  };

  function escapeHtml(s: string): string {
    return String(s).replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    } as Record<string, string>)[c]);
  }

  function renderZipCard(s: ZipCardState) {
    if (s.kind === 'empty') {
      zipDisplay.innerHTML = '<span class="text-text-primary text-sm">Enter a 5-digit US ZIP to detect your climate region.</span>';
      return;
    }
    if (s.kind === 'partial') {
      zipDisplay.innerHTML = '<span class="text-text-primary text-sm">Keep typing — 5 digits total.</span>';
      return;
    }
    if (s.kind === 'unrecognized') {
      zipDisplay.innerHTML = '<span class="text-text-primary text-sm">ZIP not recognized.</span>';
      return;
    }
    if (s.kind === 'manual') {
      // Set by the region-pill handler below with its own markup.
      return;
    }
    // resolved
    const place = s.city ? `${escapeHtml(s.city)}, ${escapeHtml(s.state)}` : escapeHtml(s.state);
    const iecc = s.ieccZone ? ` <span class="text-text-primary">(IECC ${escapeHtml(s.ieccZone)})</span>` : '';
    const designLine = (s.designCoolingDB != null && s.designHeatingDB != null)
      ? `<div class="text-sm text-text-primary mt-0.5">Design temp: ${s.designCoolingDB}°F cooling / ${s.designHeatingDB}°F heating</div>`
      : '';
    zipDisplay.innerHTML = `
      <div class="rounded-lg border border-border bg-bg-dark/60 p-4">
        <div class="flex items-center gap-2 text-text-primary font-medium">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>${place} · ${escapeHtml(s.zip)}</span>
        </div>
        <div class="mt-1 text-sm text-text-primary">Climate: <span class="text-accent font-medium">${escapeHtml(s.regionLabel)}</span>${iecc}</div>
        ${designLine}
      </div>`;
  }

  let zipLookupAbort: AbortController | null = null;
  let zipLookupTimer: number | null = null;

  function setClimateFromZip(raw: string) {
    const zip = raw.replace(/\D/g, '').slice(0, 5);

    if (zipLookupAbort) { zipLookupAbort.abort(); zipLookupAbort = null; }
    if (zipLookupTimer !== null) { window.clearTimeout(zipLookupTimer); zipLookupTimer = null; }

    if (zip.length === 0) {
      climate = null;
      renderZipCard({ kind: 'empty' });
      zipFallback.classList.add('hidden');
      return;
    }
    if (zip.length < 5) {
      climate = null;
      renderZipCard({ kind: 'partial' });
      zipFallback.classList.add('hidden');
      return;
    }

    // 5 digits entered — sync lookup (drives calculation)
    const lookup = lookupZip(zip);
    if (!lookup) {
      climate = null;
      renderZipCard({ kind: 'unrecognized' });
      zipFallback.classList.remove('hidden');
      return;
    }
    climate = lookup;
    zipFallback.classList.add('hidden');

    // Render what we know synchronously (no city, no IECC zone yet).
    renderZipCard({
      kind: 'resolved',
      zip,
      city: null,
      state: lookup.state,
      regionLabel: lookup.regionLabel,
    });

    // Debounced async enrichment
    zipLookupTimer = window.setTimeout(() => {
      zipLookupAbort = new AbortController();
      fetch(`/api/zip-lookup?zip=${zip}`, { signal: zipLookupAbort.signal })
        .then((r) => (r.ok ? r.json() : null))
        .then((data: any) => {
          if (!data || data.error) return;
          renderZipCard({
            kind: 'resolved',
            zip: data.zip,
            city: data.city ?? null,
            state: data.state,
            regionLabel: data.regionLabel,
            ieccZone: data.ieccZone,
            designCoolingDB: data.designCoolingDB,
            designHeatingDB: data.designHeatingDB,
          });
          window.posthog?.capture('zip_resolved', {
            tool_slug: 'mini-split-sizing-calculator',
            trade_slug: 'hvac',
            zip: data.zip,
            city: data.city,
            state: data.state,
            climate_region: data.region,
            iecc_zone: data.ieccZone,
          });
        })
        .catch(() => { /* aborted / network — sync card still visible */ });
    }, 250) as unknown as number;
  }
  zipInput.addEventListener('input', () => setClimateFromZip(zipInput.value));

  document.querySelectorAll<HTMLButtonElement>('.region-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      const region = btn.dataset.region as Region;
      climate = lookupRegion(region, zipInput.value, '');
      const meta = REGIONS[region];
      zipDisplay.innerHTML = `
        <div class="rounded-lg border border-border bg-bg-dark/60 p-4">
          <div class="text-text-primary font-medium">Manual region selection</div>
          <div class="mt-1 text-sm text-text-primary">Climate: <span class="text-accent font-medium">${escapeHtml(meta.label)}</span> <span class="text-text-primary">(ZIP not in our database)</span></div>
        </div>`;
      zipFallback.classList.add('hidden');
      document.querySelectorAll<HTMLButtonElement>('.region-pill').forEach(b => b.classList.remove('border-accent'));
      btn.classList.add('border-accent');
    });
  });

  // Per-room-type auto-fill defaults. Applied only on the FIRST change
  // of room type away from the initial default (bedroom). Subsequent
  // room-type picks preserve whatever the pro has edited. Primary
  // Orientation is intentionally NOT included (too site-specific).
  // If `?restore=` is present in the URL, we short-circuit this — the
  // restored inputs should stand as-is.
  interface RoomDefaults {
    length: number;
    width: number;
    ceiling: number;
    exposedWalls: number;
    insulation: RoomInsulation;
    windowArea: number;
    doorArea: number;
  }
  const ROOM_DEFAULTS: Partial<Record<RoomType, RoomDefaults>> = {
    bedroom:  { length: 12, width: 12, ceiling: 8, exposedWalls: 2, insulation: 'average', windowArea: 15, doorArea: 0 },
    living:   { length: 16, width: 18, ceiling: 9, exposedWalls: 2, insulation: 'average', windowArea: 40, doorArea: 0 },
    kitchen:  { length: 12, width: 14, ceiling: 8, exposedWalls: 1, insulation: 'average', windowArea: 20, doorArea: 0 },
    bathroom: { length: 8,  width: 8,  ceiling: 8, exposedWalls: 1, insulation: 'average', windowArea: 6,  doorArea: 0 },
    office:   { length: 10, width: 12, ceiling: 8, exposedWalls: 2, insulation: 'average', windowArea: 15, doorArea: 0 },
    dining:   { length: 12, width: 14, ceiling: 9, exposedWalls: 2, insulation: 'average', windowArea: 20, doorArea: 0 },
    garage:   { length: 20, width: 22, ceiling: 8, exposedWalls: 3, insulation: 'poor',    windowArea: 0,  doorArea: 128 },
    basement: { length: 18, width: 18, ceiling: 8, exposedWalls: 3, insulation: 'poor',    windowArea: 6,  doorArea: 0 },
    sunroom:  { length: 12, width: 14, ceiling: 9, exposedWalls: 3, insulation: 'poor',    windowArea: 80, doorArea: 0 },
    addition: { length: 14, width: 16, ceiling: 8, exposedWalls: 3, insulation: 'average', windowArea: 30, doorArea: 0 },
    // 'other' deliberately omitted — no auto-fill on pick
  };
  // Flag guards the "only on first change" behavior. Pre-set to true if
  // we're mid-restore so we don't clobber restored values.
  let roomTypeAutofillDone = new URLSearchParams(window.location.search).has('restore');

  function applyRoomDefaults(type: RoomType) {
    const d = ROOM_DEFAULTS[type];
    if (!d) return;
    const set = (id: string, value: string) => {
      const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null;
      if (!el) return;
      el.value = value;
      el.dispatchEvent(new Event('input', { bubbles: true }));
      el.dispatchEvent(new Event('change', { bubbles: true }));
    };
    set('length', String(d.length));
    set('width', String(d.width));
    set('ceiling', String(d.ceiling));
    set('exposed', String(d.exposedWalls));
    set('insulation', d.insulation);
    set('windowArea', String(d.windowArea));
    set('doorArea', String(d.doorArea));
  }

  // Room type picker — pills (desktop) + select (mobile) share state.
  const roomSelect = document.getElementById('roomtype-select') as HTMLSelectElement | null;
  function setRoomType(v: RoomType) {
    const prev = roomType;
    roomType = v;
    document.querySelectorAll<HTMLButtonElement>('.roomtype-pill').forEach(b => {
      if (b.dataset.roomtype === v) {
        b.classList.remove('border-border');
        b.classList.add('border-accent');
      } else {
        b.classList.remove('border-accent');
        b.classList.add('border-border');
      }
    });
    if (roomSelect && roomSelect.value !== v) roomSelect.value = v;
    // First-time change from the initial default: fill in likely values
    // for the picked room type. Any subsequent change (even back to
    // bedroom) does not auto-fill, preserving the pro's edits.
    if (!roomTypeAutofillDone && v !== prev) {
      roomTypeAutofillDone = true;
      applyRoomDefaults(v);
    }
  }
  document.querySelectorAll<HTMLButtonElement>('.roomtype-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      setRoomType((btn.dataset.roomtype || 'bedroom') as RoomType);
    });
  });
  roomSelect?.addEventListener('change', () => {
    setRoomType(roomSelect.value as RoomType);
  });

  // Orientation pills
  document.querySelectorAll<HTMLButtonElement>('.orient-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      orientation = (btn.dataset.orient || 'S') as Orientation;
      document.querySelectorAll<HTMLButtonElement>('.orient-pill').forEach(b => {
        b.classList.remove('border-accent');
        b.classList.add('border', 'border-border');
      });
      btn.classList.remove('border-border');
      btn.classList.add('border-accent');
    });
  });

  // Generic help-toggle: any <button data-help-toggle="some-id"> toggles
  // the hidden panel with that id. Reusable for field help popovers and
  // the in-panel close (×) buttons — both point at the same panel id via
  // data-help-toggle, so clicking either one flips the panel state. We
  // also sync aria-expanded on ALL buttons targeting the same panel, so
  // the info icon and its close button stay consistent after either is
  // clicked.
  //
  // Analytics: fires a help_opened PostHog event each time a panel is
  // opened (not on close). Gives us a per-field count of "where users
  // need clarification" — the field with the highest open-rate is the
  // one whose label is least self-evident and most deserves a rewrite.
  //
  // Guard: data-help-wired matches the stepper guard pattern so each
  // button gets at most one listener even if this script re-executes.
  document.querySelectorAll<HTMLButtonElement>('[data-help-toggle]').forEach(btn => {
    if (btn.dataset.helpWired) return;
    btn.dataset.helpWired = '1';
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.helpToggle;
      if (!targetId) return;
      const target = document.getElementById(targetId);
      if (!target) return;
      const willBeOpen = target.classList.contains('hidden');
      target.classList.toggle('hidden');
      document.querySelectorAll<HTMLButtonElement>(`[data-help-toggle="${targetId}"]`).forEach(b => {
        b.setAttribute('aria-expanded', String(willBeOpen));
      });
      if (willBeOpen) {
        // Never cache window.posthog — reference directly per the
        // repo-wide rule (the stub gets replaced by the real library).
        (window as any).posthog?.capture('help_opened', {
          tool_slug: 'mini-split-sizing-calculator',
          trade_slug: 'hvac',
          // 'exposed-help' → 'exposed', 'windowArea-help' → 'windowArea'
          field: targetId.replace(/-help$/, ''),
        });
      }
    });
  });

  // Number-stepper +/- buttons: each .number-stepper wrapper has a
  // minus button, a number input, and a plus button. stepUp()/stepDown()
  // honor the input's step / min / max. We dispatch an 'input' event
  // after stepping so updateDerived() (below) recomputes sqft/volume.
  //
  // Guard: the data-stepper-wired attribute prevents double-binding if
  // this script ever re-executes (Astro hoisting quirks, view transitions,
  // hot reload, mobile touch → click duplication). Without it, a second
  // execution attaches a second listener to each button, causing one
  // click to fire stepUp() twice and the value to jump by 2×step instead
  // of 1×step. See fix in commit c. 2026-04-16.
  document.querySelectorAll<HTMLElement>('.number-stepper').forEach(wrapper => {
    if (wrapper.dataset.stepperWired) return;
    wrapper.dataset.stepperWired = '1';
    const input = wrapper.querySelector<HTMLInputElement>('input[type="number"]');
    if (!input) return;
    wrapper.querySelector<HTMLButtonElement>('.stepper-minus')?.addEventListener('click', () => {
      input.stepDown();
      input.dispatchEvent(new Event('input', { bubbles: true }));
    });
    wrapper.querySelector<HTMLButtonElement>('.stepper-plus')?.addEventListener('click', () => {
      input.stepUp();
      input.dispatchEvent(new Event('input', { bubbles: true }));
    });
  });

  // Derived sqft/volume live display
  function updateDerived() {
    const l = parseFloat((document.getElementById('length') as HTMLInputElement).value) || 0;
    const w = parseFloat((document.getElementById('width') as HTMLInputElement).value) || 0;
    const c = parseFloat((document.getElementById('ceiling') as HTMLInputElement).value) || 0;
    document.getElementById('d-sqft')!.textContent = (l * w).toLocaleString();
    document.getElementById('d-vol')!.textContent = (l * w * c).toLocaleString();
  }
  ['length', 'width', 'ceiling'].forEach(id => {
    document.getElementById(id)!.addEventListener('input', updateDerived);
  });
  updateDerived();

  let pendingResult: RoomResult | null = null;
  let pendingInputs: RoomInputs | null = null;
  const calcBtn = document.getElementById('calculate-btn') as HTMLButtonElement;
  const calcHint = document.getElementById('calc-hint')!;

  function readInputs(): RoomInputs | null {
    if (!climate) {
      calcHint.textContent = 'Please enter a valid ZIP code or pick a climate region.';
      calcHint.classList.remove('hidden');
      return null;
    }
    calcHint.classList.add('hidden');
    return {
      climate,
      roomType,
      orientation,
      length: parseFloat((document.getElementById('length') as HTMLInputElement).value) || 12,
      width: parseFloat((document.getElementById('width') as HTMLInputElement).value) || 12,
      ceilingHeight: parseFloat((document.getElementById('ceiling') as HTMLInputElement).value) || 8,
      exposedWalls: parseInt((document.getElementById('exposed') as HTMLSelectElement).value) as ExposedWalls,
      windowAreaSqFt: parseFloat((document.getElementById('windowArea') as HTMLInputElement).value) || 0,
      doorAreaSqFt: parseFloat((document.getElementById('doorArea') as HTMLInputElement).value) || 0,
      insulation: (document.getElementById('insulation') as HTMLSelectElement).value as RoomInsulation,
    };
  }

  calcBtn.addEventListener('click', () => {
    const inputs = readInputs();
    if (!inputs) return;
    pendingInputs = inputs;
    pendingResult = calcRoom(inputs);
    document.getElementById('calc-btn-area')!.classList.add('hidden');
    document.getElementById('email-gate')!.classList.remove('hidden');
    (document.getElementById('gate-email') as HTMLInputElement).focus();

    // A/B/C: record that the gate was shown to this arm (denominator for conversion rate)
    (window as any).posthog?.capture('gate_shown', {
      experiment: AB_EXPERIMENT,
      ab_variant: abVariant,
      tool_slug: 'mini-split-sizing-calculator',
    });
  });

  const gateSubmit = document.getElementById('gate-submit') as HTMLButtonElement;
  const gateEmail = document.getElementById('gate-email') as HTMLInputElement;
  const gateConsent = document.getElementById('gate-consent') as HTMLInputElement;
  const gateError = document.getElementById('gate-error')!;

  function showResults(r: RoomResult) {
    document.getElementById('r-cool')!.textContent = r.coolingBTU.toLocaleString() + ' BTU';
    document.getElementById('r-heat')!.textContent = r.heatingBTU.toLocaleString() + ' BTU';
    document.getElementById('r-std')!.textContent = r.closestStandardLabel;
    document.getElementById('r-cfm')!.textContent = r.suggestedCFM + ' CFM';
    document.getElementById('results')!.classList.remove('hidden');
    document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  gateSubmit.addEventListener('click', async () => {
    const email = gateEmail.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      gateError.textContent = 'Please enter a valid email address.';
      gateError.classList.remove('hidden');
      return;
    }
    if (!pendingResult || !pendingInputs) return;
    gateError.classList.add('hidden');
    gateSubmit.disabled = true;
    gateSubmit.textContent = 'Sending...';

    try {
      const res = await fetch('/api/email-capture', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          toolSlug: 'mini-split-sizing-calculator',
          toolName: 'Mini-Split Sizing Calculator',
          tradeSlug: 'hvac',
          tradeName: 'HVAC',
          marketingConsent: gateConsent.checked,
          sourceUrl: window.location.pathname,
          calculationResults: {
            mode: 'mini-split',
            coolingBTU: pendingResult.coolingBTU,
            heatingBTU: pendingResult.heatingBTU,
            tonnage: pendingResult.tonnage,
            closestStandardBTU: pendingResult.closestStandardBTU,
            closestStandardLabel: pendingResult.closestStandardLabel,
            suggestedCFM: pendingResult.suggestedCFM,
            sqft: pendingResult.sqft,
            state: pendingInputs.climate.state,
            region: pendingInputs.climate.regionLabel,
            roomType: pendingInputs.roomType,
            dimensions: `${pendingInputs.length} × ${pendingInputs.width} ft`,
            exposedWalls: pendingInputs.exposedWalls,
            orientation: pendingInputs.orientation,
            insulation: pendingInputs.insulation,
            windowArea: pendingInputs.windowAreaSqFt,
          },
        }),
      });
      if (!res.ok) throw new Error('Failed to send');

      document.getElementById('email-gate')!.classList.add('hidden');
      showResults(pendingResult);

      const meta = (window as any).__ntqToolMeta;
      if ((window as any).posthog && meta) {
        (window as any).posthog.capture('email_captured', {
          tool_slug: meta.toolSlug,
          trade_slug: meta.tradeSlug,
          trade_name: meta.tradeName,
          tool_name: meta.toolName,
          tool_category: meta.category,
          marketing_consent: gateConsent.checked,
          gated: true,
          mode: 'mini-split',
          // A/B/C test tagging — pairs with gate_shown for conversion rate
          experiment: AB_EXPERIMENT,
          ab_variant: abVariant,
        });
      }
      if (typeof (window as any).gtag === 'function') {
        (window as any).gtag('event', 'conversion', { send_to: 'AW-17899660858/rqouCLin75gcELrMnNdC' });
      }
    } catch {
      gateError.textContent = 'Something went wrong. Please try again.';
      gateError.classList.remove('hidden');
      gateSubmit.disabled = false;
      gateSubmit.textContent = 'Send My Results';
    }
  });

  gateEmail.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') gateSubmit.click();
  });
</script>
