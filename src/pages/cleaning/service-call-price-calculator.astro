---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/cleaningTools';

const tool = getToolBySlug('service-call-price-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I price a one-time cleaning job?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start with your minimum service fee ($75-$150 depending on your market), then add labor hours multiplied by your hourly rate, estimated supply costs for the job, and a travel fee if the property is outside your core service area. A typical one-time standard clean for a 1,500 sq ft home runs $150-$250 total. Use a job pricing calculator to build the total from your actual costs and confirm you are hitting at least a 40-50% profit margin."
      }
    },
    {
      "@type": "Question",
      "name": "What hourly rate should a cleaning business charge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most residential cleaning businesses charge $35-$60 per cleaner per hour as their billable rate. Your billable rate must cover your loaded labor cost (wages plus taxes, insurance, and benefits), supplies, vehicle costs, and overhead, plus leave room for profit. If your loaded wage is $18-$22 per hour, a $40-$50 billable rate gives you roughly 50-55% labor margin before supplies and overhead."
      }
    },
    {
      "@type": "Question",
      "name": "How much should I budget for cleaning supplies per job?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Plan for $5-$15 in supply costs per residential cleaning job. This covers all-purpose cleaner, disinfectant, glass cleaner, floor cleaner, toilet bowl cleaner, trash bags, microfiber cloth wear, and gloves. Supply costs should stay between 3-8% of your job revenue. Buying concentrates in bulk and tracking per-clean usage keeps costs at the low end."
      }
    },
    {
      "@type": "Question",
      "name": "Should I charge a travel fee for cleaning jobs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If the property is within your core service area (typically a 15-20 minute drive), travel is usually built into your base pricing. For jobs outside that radius, charge a travel fee of $0.50-$1.00 per mile or a flat $15-$30 surcharge. This covers fuel, vehicle wear, and the lost productivity of extra drive time. Be upfront about travel fees when quoting."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="job-pricing-calc">
    <!-- Base Pricing -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Base Pricing</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="minimum-fee">Minimum Service Fee ($)</label>
        <input type="number" id="minimum-fee" value="100" min="0" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1.5">Typical range: $75 &ndash; $150</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="job-type">Job Type</label>
        <select id="job-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="standard">Standard Clean</option>
          <option value="deep">Deep Clean</option>
          <option value="moveout">Move-Out Clean</option>
          <option value="post-construction">Post-Construction</option>
          <option value="commercial">Commercial Clean</option>
        </select>
      </div>
    </div>

    <!-- Labor -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Labor</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="num-cleaners">Number of Cleaners</label>
        <input type="number" id="num-cleaners" value="1" min="1" max="10" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="labor-hours">Hours per Cleaner</label>
        <input type="number" id="labor-hours" value="2" min="0.25" step="0.25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="billable-rate">Billable Rate ($/hr)</label>
        <input type="number" id="billable-rate" value="45" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1.5">Typical: $35 &ndash; $60 per cleaner/hr</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="loaded-wage">
          Your Loaded Wage ($/hr)
          <span class="inline-block ml-1 text-text-muted cursor-help" title="Your actual cost per hour per cleaner including wages, payroll taxes, insurance, workers comp, and benefits">&#9432;</span>
        </label>
        <input type="number" id="loaded-wage" value="20" min="0" step="0.5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Supplies -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Supplies</h3>
    <div class="mb-2 text-sm text-text-muted">Select supplies used on this job. Costs are per-unit estimates &mdash; adjust to match your actual costs.</div>
    <div id="supplies-table" class="space-y-3 mb-4">
      <!-- Supply rows inserted by JS -->
    </div>
    <button id="add-supply-btn" class="bg-bg-dark border border-border rounded-lg px-5 py-2.5 text-sm text-text-secondary hover:border-accent hover:text-accent transition-colors cursor-pointer">
      + Add Supply
    </button>

    <!-- Travel -->
    <h3 class="font-heading font-bold text-lg mt-8 mb-4 text-text-primary">Travel</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="travel-fee">Travel Fee ($)</label>
        <input type="number" id="travel-fee" value="0" min="0" step="5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1.5">$0 for jobs in your core area. $15 &ndash; $30 for distant properties.</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="tax-rate">Tax Rate (%)</label>
        <input type="number" id="tax-rate" value="0" min="0" max="20" step="0.1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1.5">Applied to entire invoice &mdash; check your state rules.</p>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Customer Price Breakdown</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Customer Total</div>
          <div id="result-customer-total" class="font-heading font-extrabold text-3xl text-accent">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Base + Labor</div>
          <div id="result-labor-revenue" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Supplies</div>
          <div id="result-supplies-revenue" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Travel + Tax</div>
          <div id="result-other-revenue" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
      </div>

      <h3 class="font-heading font-bold text-xl mb-6">Your Profitability</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Gross Profit</div>
          <div id="result-gross-profit" class="font-heading font-extrabold text-3xl text-[#34D399]">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Profit Margin</div>
          <div id="result-profit-margin" class="font-heading font-extrabold text-3xl">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Your Total Cost</div>
          <div id="result-total-cost" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Profit per Hour</div>
          <div id="result-profit-per-hour" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
      </div>

      <!-- Benchmark Bar -->
      <div class="bg-bg-dark rounded-xl p-5 mt-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Benchmark &mdash; Average Residential Cleaning Job: $100 &ndash; $300</h4>
        <div class="relative h-6 bg-bg-card rounded-full overflow-hidden border border-border">
          <div class="absolute inset-0 flex">
            <div class="w-1/3 bg-[rgba(52,211,153,0.15)] border-r border-border"></div>
            <div class="w-1/3 bg-[rgba(251,191,36,0.1)] border-r border-border"></div>
            <div class="w-1/3 bg-[rgba(239,68,68,0.1)]"></div>
          </div>
          <div id="benchmark-marker" class="absolute top-0 h-full w-1 bg-accent rounded transition-all" style="left: 0%"></div>
        </div>
        <div class="flex justify-between text-xs text-text-muted mt-2">
          <span>$0</span>
          <span>$100</span>
          <span>$200</span>
          <span>$300</span>
          <span>$400+</span>
        </div>
        <p id="benchmark-text" class="text-text-secondary text-sm mt-3">Your price: &mdash;</p>
      </div>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Set your base fee.</strong> Enter your minimum service fee and select the job type. The minimum fee covers your show-up cost including drive time, setup, and the overhead of having a cleaner on site.</p>
          <p><strong class="text-text-primary">2. Configure labor.</strong> Enter the number of cleaners, estimated hours per cleaner, your billable rate per hour, and your loaded wage. The loaded wage should include wages plus payroll taxes, insurance, workers comp, and benefits.</p>
          <p><strong class="text-text-primary">3. Add supplies.</strong> Select supplies from the preset dropdown or enter custom items. Adjust quantities and unit costs to match your actual usage per job.</p>
          <p><strong class="text-text-primary">4. Add travel and tax.</strong> Include a travel fee for distant properties and your local tax rate. Then review the full price breakdown and profit margin below.</p>
        </div>
      </section>

      <!-- How Pricing Works -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How Cleaning Job Pricing Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>A cleaning job price is built from four components: <strong class="text-text-primary">base fee, labor, supplies, and travel</strong>. Each one contributes to revenue differently and has different margin characteristics.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Customer Total = Base Fee + (Cleaners x Hours x Rate) + Supplies + Travel + Tax</p>
            <p>Your Cost = (Cleaners x Hours x Loaded Wage) + Supply Cost + Travel Cost</p>
            <p>Gross Profit = Customer Total - Your Cost</p>
          </div>
          <p><strong class="text-text-primary">Why the base fee matters.</strong> Your minimum service fee guarantees you cover the fixed costs of every job: drive time, vehicle wear, scheduling overhead, and setup time. Without a base fee, small jobs become money losers. Even a quick 45-minute touchup should never go out the door below your minimum.</p>
          <p><strong class="text-text-primary">Labor is your biggest cost.</strong> For most cleaning companies, labor represents 40-55% of revenue. Keeping your billable rate at least 2x your loaded wage gives you enough margin to cover supplies, overhead, and profit. If your loaded wage is $20/hr, your billable rate should be at least $40/hr.</p>
          <p><strong class="text-text-primary">Supplies should be small but tracked.</strong> Supply costs typically run 3-8% of job revenue. Buying concentrates in bulk, tracking per-clean usage, and not over-applying product keeps supply costs at the low end. Many cleaners underestimate supply costs because they never track them per job.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Quoting a new customer.</strong> A potential client calls asking for a price on a deep clean. Pull up this calculator, enter their property details, and build the price from your actual costs. You present a confident, itemized quote instead of guessing or lowballing to win the job.</p>
          <p><strong class="text-text-primary">Training new team members on pricing.</strong> New cleaners often do not understand why jobs cost what they do. Walk them through the calculator to show how base fee, labor rate, supplies, and travel all add up. Show them what happens to profit when they take too long on a job or when supply waste creeps up.</p>
          <p><strong class="text-text-primary">Comparing job types.</strong> Enter a standard clean, a deep clean, and a move-out clean side by side. Compare the labor hours, supply costs, and resulting margins. This helps you decide which job types to pursue and which ones to price higher because they eat more time and supplies.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I price a one-time cleaning job?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Start with your minimum service fee ($75-$150 depending on your market), then add labor hours multiplied by your hourly rate, estimated supply costs for the job, and a travel fee if the property is outside your core service area. A typical one-time standard clean for a 1,500 sq ft home runs $150-$250 total. Use this calculator to build the total from your actual costs and confirm you are hitting at least a 40-50% profit margin.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What hourly rate should a cleaning business charge?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most residential cleaning businesses charge $35-$60 per cleaner per hour as their billable rate. Your billable rate must cover your loaded labor cost (wages plus taxes, insurance, and benefits), supplies, vehicle costs, and overhead, plus leave room for profit. If your loaded wage is $18-$22 per hour, a $40-$50 billable rate gives you roughly 50-55% labor margin before supplies and overhead.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much should I budget for cleaning supplies per job?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Plan for $5-$15 in supply costs per residential cleaning job. This covers all-purpose cleaner, disinfectant, glass cleaner, floor cleaner, toilet bowl cleaner, trash bags, microfiber cloth wear, and gloves. Supply costs should stay between 3-8% of your job revenue. Buying concentrates in bulk and tracking per-clean usage keeps costs at the low end.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should I charge a travel fee for cleaning jobs?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">If the property is within your core service area (typically a 15-20 minute drive), travel is usually built into your base pricing. For jobs outside that radius, charge a travel fee of $0.50-$1.00 per mile or a flat $15-$30 surcharge. This covers fuel, vehicle wear, and the lost productivity of extra drive time. Be upfront about travel fees when quoting.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // Preset supplies with typical per-unit costs
  const presetSupplies: Record<string, number> = {
    'All-Purpose Cleaner': 5,
    'Disinfectant': 6,
    'Glass Cleaner': 4,
    'Floor Cleaner': 7,
    'Toilet Bowl Cleaner': 3,
    'Trash Bags (each)': 0.75,
    'Microfiber Cloths (each)': 2,
    'Mop Head': 8,
    'Vacuum Bags (each)': 5,
    'Rubber Gloves (pair)': 1.50,
    'Scrub Sponges (each)': 1,
    'Dusting Spray': 4,
  };

  let supplyCounter = 0;

  function addSupplyRow(name = '', cost = 0, qty = 1) {
    const id = supplyCounter++;
    const table = document.getElementById('supplies-table')!;
    const row = document.createElement('div');
    row.className = 'grid grid-cols-1 md:grid-cols-[1fr_120px_80px_120px_40px] gap-3 items-end supply-row';
    row.dataset.supplyId = String(id);

    const presetOptions = Object.entries(presetSupplies).map(([n, c]) =>
      `<option value="${n}" ${n === name ? 'selected' : ''}>${n} &mdash; $${c.toFixed(2)}</option>`
    ).join('');

    row.innerHTML = `
      <div>
        <label class="block text-xs font-medium text-text-muted mb-1">Supply Item</label>
        <select class="supply-preset w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors">
          <option value="">Custom item...</option>
          ${presetOptions}
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-text-muted mb-1">Unit Cost ($)</label>
        <input type="number" class="supply-cost w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" value="${cost}" min="0" step="0.01" />
      </div>
      <div>
        <label class="block text-xs font-medium text-text-muted mb-1">Qty</label>
        <input type="number" class="supply-qty w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm text-center focus:border-accent focus:outline-none transition-colors" value="${qty}" min="0" step="1" />
      </div>
      <div>
        <label class="block text-xs font-medium text-text-muted mb-1">Subtotal</label>
        <div class="supply-subtotal bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-accent text-sm font-medium">&mdash;</div>
      </div>
      <div>
        <button class="remove-supply-btn mt-5 text-text-muted hover:text-red-400 transition-colors cursor-pointer text-lg leading-none" title="Remove supply">&times;</button>
      </div>
    `;

    table.appendChild(row);

    // Preset dropdown change
    const presetSelect = row.querySelector('.supply-preset') as HTMLSelectElement;
    const costInput = row.querySelector('.supply-cost') as HTMLInputElement;

    presetSelect.addEventListener('change', () => {
      const selected = presetSelect.value;
      if (selected && presetSupplies[selected] !== undefined) {
        costInput.value = String(presetSupplies[selected]);
      }
      calculate();
    });

    // Input change listeners
    row.querySelectorAll('input').forEach(input => {
      input.addEventListener('input', calculate);
    });

    // Remove button
    row.querySelector('.remove-supply-btn')!.addEventListener('click', () => {
      row.remove();
      calculate();
    });

    // Auto-fill cost if preset name passed
    if (name && presetSupplies[name] !== undefined && cost === 0) {
      costInput.value = String(presetSupplies[name]);
    }

    updateSupplySubtotal(row);
    calculate();
  }

  function updateSupplySubtotal(row: Element) {
    const cost = parseFloat((row.querySelector('.supply-cost') as HTMLInputElement).value) || 0;
    const qty = parseFloat((row.querySelector('.supply-qty') as HTMLInputElement).value) || 0;
    const subtotal = cost * qty;
    (row.querySelector('.supply-subtotal') as HTMLElement).textContent = `$${subtotal.toFixed(2)}`;
  }

  function calculate() {
    // Base pricing
    const minimumFee = parseFloat((document.getElementById('minimum-fee') as HTMLInputElement).value) || 0;

    // Labor
    const numCleaners = parseFloat((document.getElementById('num-cleaners') as HTMLInputElement).value) || 1;
    const laborHours = parseFloat((document.getElementById('labor-hours') as HTMLInputElement).value) || 0;
    const billableRate = parseFloat((document.getElementById('billable-rate') as HTMLInputElement).value) || 0;
    const loadedWage = parseFloat((document.getElementById('loaded-wage') as HTMLInputElement).value) || 0;

    const totalLaborHours = numCleaners * laborHours;
    const laborRevenue = totalLaborHours * billableRate;
    const laborCost = totalLaborHours * loadedWage;

    // Supplies
    let suppliesCost = 0;
    document.querySelectorAll('.supply-row').forEach(row => {
      updateSupplySubtotal(row);
      const cost = parseFloat((row.querySelector('.supply-cost') as HTMLInputElement).value) || 0;
      const qty = parseFloat((row.querySelector('.supply-qty') as HTMLInputElement).value) || 0;
      suppliesCost += cost * qty;
    });

    // Travel and tax
    const travelFee = parseFloat((document.getElementById('travel-fee') as HTMLInputElement).value) || 0;
    const taxRate = parseFloat((document.getElementById('tax-rate') as HTMLInputElement).value) || 0;

    // Calculate totals
    const subtotal = minimumFee + laborRevenue + suppliesCost + travelFee;
    const taxAmount = subtotal * (taxRate / 100);
    const customerTotal = subtotal + taxAmount;
    const totalCost = laborCost + suppliesCost;
    const grossProfit = customerTotal - totalCost;
    const profitMargin = customerTotal > 0 ? (grossProfit / customerTotal) * 100 : 0;
    const profitPerHour = totalLaborHours > 0 ? grossProfit / totalLaborHours : 0;

    // Update customer breakdown
    document.getElementById('result-customer-total')!.textContent = `$${customerTotal.toFixed(0)}`;
    document.getElementById('result-labor-revenue')!.textContent = `$${(minimumFee + laborRevenue).toFixed(0)}`;
    document.getElementById('result-supplies-revenue')!.textContent = `$${suppliesCost.toFixed(2)}`;
    document.getElementById('result-other-revenue')!.textContent = `$${(travelFee + taxAmount).toFixed(0)}`;

    // Update profitability
    document.getElementById('result-gross-profit')!.textContent = `$${grossProfit.toFixed(0)}`;
    document.getElementById('result-total-cost')!.textContent = `$${totalCost.toFixed(0)}`;
    document.getElementById('result-profit-per-hour')!.textContent = `$${profitPerHour.toFixed(0)}/hr`;

    // Profit margin with color coding
    const marginEl = document.getElementById('result-profit-margin')!;
    marginEl.textContent = `${profitMargin.toFixed(1)}%`;
    marginEl.className = 'font-heading font-extrabold text-3xl';
    if (profitMargin < 30) {
      marginEl.classList.add('text-red-400');
    } else if (profitMargin < 50) {
      marginEl.classList.add('text-yellow-400');
    } else {
      marginEl.classList.add('text-[#34D399]');
    }

    // Benchmark bar (range $0 - $400+)
    const maxBenchmark = 400;
    const markerPct = Math.min((customerTotal / maxBenchmark) * 100, 100);
    const marker = document.getElementById('benchmark-marker')!;
    marker.style.left = `${markerPct}%`;

    let benchmarkNote = '';
    if (customerTotal < 100) {
      benchmarkNote = 'Below average range. Confirm your margins are healthy at this price point.';
    } else if (customerTotal <= 300) {
      benchmarkNote = 'Within the typical range for residential cleaning jobs.';
    } else {
      benchmarkNote = 'Above average. Typical for deep cleans, move-outs, or larger properties.';
    }
    document.getElementById('benchmark-text')!.textContent = `Your price: $${customerTotal.toFixed(0)} \u2014 ${benchmarkNote}`;
  }

  // Add Supply button
  document.getElementById('add-supply-btn')?.addEventListener('click', () => addSupplyRow());

  // Auto-calculate on any input/select change within main sections
  document.querySelectorAll('#job-pricing-calc > .grid input, #job-pricing-calc > .grid select').forEach(el => {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  // Initialize with common default supplies and run calculation
  addSupplyRow('All-Purpose Cleaner', 5, 1);
  addSupplyRow('Trash Bags (each)', 0.75, 3);
  addSupplyRow('Rubber Gloves (pair)', 1.50, 1);
  calculate();
</script>
