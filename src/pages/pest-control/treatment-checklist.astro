---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/pestControlTools';
const tool = getToolBySlug('treatment-checklist')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What should a pest control treatment checklist include?", "acceptedAnswer": { "@type": "Answer", "text": "A complete pest control treatment checklist should cover pre-treatment inspection and species identification, customer notification and preparation requirements, PPE and safety equipment checks, product selection with EPA registration numbers, application rates and methods, bait station placement and monitoring, exclusion work performed, sanitation recommendations, post-treatment documentation, and follow-up scheduling." } },
    { "@type": "Question", "name": "How often should pest control treatments be performed?", "acceptedAnswer": { "@type": "Answer", "text": "For general pest management, quarterly treatments are the industry standard for residential accounts. Monthly service is recommended for restaurants, food processing, and commercial kitchens. Bi-monthly works well for moderate pest pressure. Termite monitoring stations should be checked quarterly. One-time treatments may be sufficient for isolated infestations, but recurring service prevents re-infestation and is the foundation of a profitable pest control business." } },
    { "@type": "Question", "name": "What safety precautions should pest technicians follow?", "acceptedAnswer": { "@type": "Answer", "text": "Always read and follow the product label — it is the law. Wear appropriate PPE including chemical-resistant gloves, safety glasses, and respirator when required. Keep SDS sheets accessible on the truck. Notify the customer about re-entry intervals and pet safety. Never apply pesticides in a manner inconsistent with labeling. Document every product used, the amount applied, and the exact locations treated. Carry spill kits and know your emergency procedures." } },
    { "@type": "Question", "name": "What documentation is required for pest control treatments?", "acceptedAnswer": { "@type": "Answer", "text": "State regulations typically require documentation of the target pest, products applied (trade name, EPA registration number, active ingredient), application rate, total amount used, areas treated, date and time, technician name and license number, and customer notification. Keep records for a minimum of 3 years (some states require longer). Commercial accounts often require additional documentation for health department audits." } }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="checklist-app">
    <!-- Progress Bar -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-medium text-text-secondary">Progress</span>
        <span id="progress-text" class="text-sm font-bold text-accent">0 of 0 items checked</span>
      </div>
      <div class="w-full bg-bg-dark rounded-full h-3 overflow-hidden">
        <div id="progress-bar" class="bg-accent h-3 rounded-full transition-all duration-300" style="width: 0%"></div>
      </div>
    </div>

    <!-- Tab Toggle -->
    <div class="flex gap-2 mb-8">
      <button id="tab-cooling" class="flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-accent text-white" data-tab="cooling">
        General Pest Treatment
      </button>
      <button id="tab-heating" class="flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-bg-dark text-text-muted border border-border hover:border-accent hover:text-text-primary" data-tab="heating">
        Termite / WDO Treatment
      </button>
    </div>

    <!-- ============ GENERAL PEST TREATMENT ============ -->
    <div id="panel-cooling">

      <!-- Exterior Inspection -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Exterior Inspection
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Inspect foundation for cracks and entry points</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Check door sweeps, weatherstripping, and thresholds</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Inspect utility penetrations (pipes, wires, conduit)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Check eaves, soffits, and roof line for pest activity</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Inspect landscaping and mulch beds near structure</span>
          </label>
        </div>
      </div>

      <!-- Interior Inspection -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Interior Inspection
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Check kitchen and bathrooms for moisture and harborage</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Inspect baseboards, behind appliances, and under sinks</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Check attic, crawlspace, and garage for activity</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Look for droppings, gnaw marks, nesting, or damage</span>
          </label>
        </div>
      </div>

      <!-- Treatment Application -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Treatment Application
        </h3>
        <div class="space-y-3">
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Apply perimeter spray treatment</span>
            </label>
            <div class="flex flex-wrap items-center gap-2 ml-8">
              <label class="text-xs text-text-muted">Product:</label>
              <input type="text" data-field="product-name" placeholder="e.g. Demand CS" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-36 focus:border-accent focus:outline-none" />
              <label class="text-xs text-text-muted">EPA Reg #:</label>
              <input type="text" data-field="epa-reg" placeholder="e.g. 100-1066" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-28 focus:border-accent focus:outline-none" />
            </div>
          </div>
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Apply interior crack and crevice treatment</span>
            </label>
            <div class="flex flex-wrap items-center gap-2 ml-8">
              <label class="text-xs text-text-muted">Amount used:</label>
              <input type="text" data-field="amount-used" placeholder="e.g. 2 gal" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-24 focus:border-accent focus:outline-none" />
            </div>
          </div>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Apply granular treatment to landscape beds and perimeter</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Treat entry points, utility penetrations, and gaps</span>
          </label>
        </div>
      </div>

      <!-- Bait Stations -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Bait Stations
        </h3>
        <div class="space-y-3">
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Place or check exterior bait stations</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <label class="text-xs text-text-muted">Qty:</label>
              <input type="number" data-field="bait-station-count" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-16 focus:border-accent focus:outline-none" />
            </div>
          </div>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Place or check interior bait stations / glue boards</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Document bait consumption and activity levels</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Replace bait as needed and secure station locks</span>
          </label>
        </div>
      </div>

      <!-- Exclusion Work -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Exclusion Work
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Seal cracks and gaps with caulk or copper mesh</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Install or repair door sweeps and weatherstripping</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Seal pipe and utility entry points</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Recommend repairs beyond scope (note for customer)</span>
          </label>
        </div>
      </div>

      <!-- Documentation -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Documentation
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Record all products used, rates, and EPA reg numbers</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Note customer about re-entry intervals and pet safety</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Provide sanitation recommendations to customer</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="cooling" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Schedule follow-up visit if needed</span>
          </label>
        </div>
      </div>

    </div>

    <!-- ============ TERMITE / WDO TREATMENT ============ -->
    <div id="panel-heating" class="hidden">

      <!-- Pre-Treatment Inspection -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Pre-Treatment Inspection
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Inspect for mud tubes on foundation and piers</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Probe wood members for damage (sill plates, joists, studs)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Check crawlspace for WDO evidence and moisture</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Identify species (subterranean, drywood, dampwood)</span>
          </label>
        </div>
      </div>

      <!-- Soil Treatment -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Soil Treatment
        </h3>
        <div class="space-y-3">
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Trench and treat perimeter foundation</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <label class="text-xs text-text-muted">Linear ft:</label>
              <input type="number" data-field="linear-ft" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" />
            </div>
          </div>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Rod and treat beneath slab areas (bath traps, expansion joints)</span>
          </label>
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Termiticide product and rate</span>
            </label>
            <div class="flex flex-wrap items-center gap-2 ml-8">
              <label class="text-xs text-text-muted">Product:</label>
              <input type="text" data-field="termiticide-product" placeholder="e.g. Termidor SC" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-36 focus:border-accent focus:outline-none" />
              <label class="text-xs text-text-muted">Gallons used:</label>
              <input type="number" data-field="gallons-used" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-20 focus:border-accent focus:outline-none" />
            </div>
          </div>
        </div>
      </div>

      <!-- Monitoring Stations -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Monitoring Stations
        </h3>
        <div class="space-y-3">
          <div class="flex flex-wrap items-start gap-3">
            <label class="flex items-start gap-3 cursor-pointer group shrink-0">
              <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
              <span class="text-text-secondary group-hover:text-text-primary transition-colors">Install or check termite monitoring stations</span>
            </label>
            <div class="flex items-center gap-2 ml-8">
              <label class="text-xs text-text-muted">Qty:</label>
              <input type="number" data-field="monitor-count" placeholder="0" class="bg-bg-dark border border-border rounded px-3 py-1.5 text-text-primary text-sm w-16 focus:border-accent focus:outline-none" />
            </div>
          </div>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Document activity at each station location</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Replace bait cartridges where activity is found</span>
          </label>
        </div>
      </div>

      <!-- Wood Damage Assessment -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Wood Damage Assessment
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Document all wood damage locations and severity</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Note structural vs. cosmetic damage</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Recommend wood repair or replacement as needed</span>
          </label>
        </div>
      </div>

      <!-- Conducive Conditions -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Conducive Conditions
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Check for wood-to-soil contact</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Identify moisture sources (leaks, poor drainage, grade issues)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Note cellulose debris in crawlspace (form boards, cardboard)</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Recommend corrective actions for conducive conditions</span>
          </label>
        </div>
      </div>

      <!-- WDO Documentation -->
      <div class="mb-8">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> WDO Documentation
        </h3>
        <div class="space-y-3">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Complete WDI/WDO report form if required</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Record all products, amounts, and application areas</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" data-season="heating" />
            <span class="text-text-secondary group-hover:text-text-primary transition-colors">Provide warranty terms and renewal information</span>
          </label>
        </div>
      </div>

    </div>

    <!-- Results Summary -->
    <div id="results-summary" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Treatment Summary</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Items Checked</div>
          <div id="summary-checked" class="font-heading font-extrabold text-3xl text-accent">0 / 0</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Completion</div>
          <div id="summary-pct" class="font-heading font-extrabold text-3xl text-text-primary">0%</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Flagged Items</div>
          <div id="summary-flags" class="font-heading font-extrabold text-3xl text-text-primary">0</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Completeness Grade</div>
          <div id="summary-grade" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
        </div>
      </div>
      <div id="flag-list" class="hidden mb-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-3">Flagged Items</h4>
        <div id="flag-items" class="space-y-2"></div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-wrap gap-3 mt-6">
      <button id="generate-report" class="bg-accent text-white font-heading font-bold text-sm uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
        Generate Report &rarr;
      </button>
      <button id="reset-checklist" class="bg-bg-dark text-text-secondary border border-border font-heading font-bold text-sm uppercase tracking-wider px-8 py-3.5 rounded-lg hover:border-accent hover:text-text-primary transition-all cursor-pointer">
        Reset Checklist
      </button>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Checklist</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Choose your service type.</strong> Toggle between General Pest Treatment and Termite/WDO Treatment tabs at the top. Each tab has its own checklist tailored to the procedures and documentation for that service type.</p>
          <p><strong class="text-text-primary">2. Work through each section.</strong> Check off items as you complete them. Enter product details, EPA registration numbers, and quantities directly into the fields. The tool tracks your progress and ensures nothing gets missed.</p>
          <p><strong class="text-text-primary">3. Monitor your progress.</strong> The progress bar updates in real time. The summary section shows your completion percentage and a grade based on items checked. Incomplete sections flag items that still need attention.</p>
          <p><strong class="text-text-primary">4. Generate a report.</strong> When finished, hit Generate Report to create a printable summary of everything checked, every product recorded, and any items that need follow-up. Your progress auto-saves so you never lose work.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What a Complete Pest Control Treatment Covers</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Exterior inspection.</strong> Walk the entire perimeter looking for entry points, conducive conditions, and pest evidence. Foundation cracks, gaps around pipes, damaged weatherstripping, and overgrown landscaping touching the structure are the most common pathways pests use to get inside.</p>
          <p><strong class="text-text-primary">Interior inspection.</strong> Focus on moisture-prone areas — kitchens, bathrooms, laundry rooms, and basements. Check behind appliances, under sinks, along baseboards, and in storage areas. Look for droppings, gnaw marks, grease trails, and nesting materials that indicate active pest populations.</p>
          <p><strong class="text-text-primary">Treatment application.</strong> Perimeter spray creates a chemical barrier around the structure. Interior crack and crevice treatment targets harborage areas directly. Granular treatments in landscape beds address ant colonies and perimeter pressure. Documenting every product, rate, and area treated is required by law in every state.</p>
          <p><strong class="text-text-primary">Bait station management.</strong> Exterior bait stations provide ongoing rodent monitoring and control between visits. Interior stations and glue boards track pest activity and help identify species. Checking stations, recording activity, and replacing bait is critical for IPM-based service programs.</p>
          <p><strong class="text-text-primary">Exclusion work.</strong> Sealing entry points is the most effective long-term pest prevention. Caulking cracks, installing door sweeps, and stuffing copper mesh into gaps around pipes stops pests from entering in the first place. Document what you sealed and recommend repairs beyond your scope.</p>
          <p><strong class="text-text-primary">Documentation and customer communication.</strong> Record every product used with EPA registration numbers, application rates, and total amounts. Inform the customer about re-entry intervals, pet safety precautions, and sanitation recommendations. Schedule follow-up visits as needed and document everything for regulatory compliance.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Routine treatment visits.</strong> Use this as your standard operating procedure for every service call. It ensures nothing gets skipped, products get recorded, and the customer sees a professional report documenting every step.</p>
          <p><strong class="text-text-primary">New technician training.</strong> Hand this checklist to every new hire. It teaches them the complete process for a thorough treatment visit and builds consistent habits from day one. Consistent documentation protects your business and satisfies state regulators.</p>
          <p><strong class="text-text-primary">Commercial account visits.</strong> If you service restaurants, food processing, or healthcare facilities, this checklist is your proof of service. Generate the report, file it with the account, and have documentation ready for health department audits.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should a pest control treatment checklist include?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A complete pest control treatment checklist should cover pre-treatment inspection and species identification, customer notification and preparation requirements, PPE and safety equipment checks, product selection with EPA registration numbers, application rates and methods, bait station placement and monitoring, exclusion work performed, sanitation recommendations, post-treatment documentation, and follow-up scheduling.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How often should pest control treatments be performed?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">For general pest management, quarterly treatments are the industry standard for residential accounts. Monthly service is recommended for restaurants, food processing, and commercial kitchens. Bi-monthly works well for moderate pest pressure. Termite monitoring stations should be checked quarterly. One-time treatments may be sufficient for isolated infestations, but recurring service prevents re-infestation.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What documentation is required for pest control treatments?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">State regulations typically require documentation of the target pest, products applied (trade name, EPA registration number, active ingredient), application rate, total amount used, areas treated, date and time, technician name and license number, and customer notification. Keep records for a minimum of 3 years. Commercial accounts often require additional documentation for health department audits.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What safety precautions should pest technicians follow?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Always read and follow the product label. Wear appropriate PPE including chemical-resistant gloves, safety glasses, and respirator when required. Keep SDS sheets accessible on the truck. Notify the customer about re-entry intervals and pet safety. Never apply pesticides in a manner inconsistent with labeling. Carry spill kits and know your emergency procedures.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // ===== STATE =====
  const STORAGE_KEY = 'pest-control-treatment-checklist';
  let activeTab: 'cooling' | 'heating' = 'cooling';

  interface SavedState {
    activeTab: string;
    checks: Record<string, boolean>;
    fields: Record<string, string>;
  }

  // ===== PERSISTENCE =====
  function saveState(): void {
    const checks: Record<string, boolean> = {};
    document.querySelectorAll('.cl-check').forEach((cb, i) => {
      checks[`check-${i}`] = (cb as HTMLInputElement).checked;
    });
    const fields: Record<string, string> = {};
    document.querySelectorAll('[data-field]').forEach(el => {
      const key = (el as HTMLElement).dataset.field!;
      fields[key] = (el as HTMLInputElement | HTMLSelectElement).value;
    });
    const state: SavedState = { activeTab, checks, fields };
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch {}
  }

  function loadState(): void {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const state: SavedState = JSON.parse(raw);
      if (state.activeTab === 'heating') switchTab('heating');
      if (state.checks) {
        document.querySelectorAll('.cl-check').forEach((cb, i) => {
          (cb as HTMLInputElement).checked = !!state.checks[`check-${i}`];
        });
      }
      if (state.fields) {
        document.querySelectorAll('[data-field]').forEach(el => {
          const key = (el as HTMLElement).dataset.field!;
          if (state.fields[key] !== undefined) {
            (el as HTMLInputElement | HTMLSelectElement).value = state.fields[key];
          }
        });
      }
    } catch {}
  }

  // ===== TABS =====
  function switchTab(tab: 'cooling' | 'heating'): void {
    activeTab = tab;
    const coolingPanel = document.getElementById('panel-cooling')!;
    const heatingPanel = document.getElementById('panel-heating')!;
    const coolingBtn = document.getElementById('tab-cooling')!;
    const heatingBtn = document.getElementById('tab-heating')!;

    if (tab === 'cooling') {
      coolingPanel.classList.remove('hidden');
      heatingPanel.classList.add('hidden');
      coolingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-accent text-white';
      heatingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-bg-dark text-text-muted border border-border hover:border-accent hover:text-text-primary';
    } else {
      coolingPanel.classList.add('hidden');
      heatingPanel.classList.remove('hidden');
      heatingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-accent text-white';
      coolingBtn.className = 'flex-1 py-3 px-4 rounded-lg font-heading font-bold text-sm uppercase tracking-wider transition-all bg-bg-dark text-text-muted border border-border hover:border-accent hover:text-text-primary';
    }
    updateProgress();
    saveState();
  }

  document.getElementById('tab-cooling')?.addEventListener('click', () => switchTab('cooling'));
  document.getElementById('tab-heating')?.addEventListener('click', () => switchTab('heating'));

  // ===== PROGRESS & SUMMARY =====
  function getActiveChecks(): NodeListOf<HTMLInputElement> {
    const panel = activeTab === 'cooling' ? '#panel-cooling' : '#panel-heating';
    return document.querySelectorAll(`${panel} .cl-check`);
  }

  function evaluateFlags(): { count: number; items: string[] } {
    const flags: string[] = [];
    return { count: flags.length, items: flags };
  }

  function getGrade(pct: number, flagCount: number): string {
    if (pct === 0) return '--';
    const penalty = flagCount * 10;
    const score = Math.max(0, pct - penalty);
    if (score >= 90) return 'A';
    if (score >= 80) return 'B';
    if (score >= 70) return 'C';
    if (score >= 60) return 'D';
    return 'F';
  }

  function gradeColor(grade: string): string {
    if (grade === 'A') return 'text-[#34D399]';
    if (grade === 'B') return 'text-[#60A5FA]';
    if (grade === 'C') return 'text-[#FBBF24]';
    if (grade === 'D') return 'text-[#FB923C]';
    if (grade === 'F') return 'text-[#F87171]';
    return 'text-text-primary';
  }

  function updateProgress(): void {
    const checks = getActiveChecks();
    const total = checks.length;
    const checked = Array.from(checks).filter(c => c.checked).length;
    const pct = total > 0 ? Math.round((checked / total) * 100) : 0;

    document.getElementById('progress-text')!.textContent = `${checked} of ${total} items checked`;
    (document.getElementById('progress-bar') as HTMLElement).style.width = `${pct}%`;

    const flags = evaluateFlags();
    const grade = getGrade(pct, flags.count);

    document.getElementById('summary-checked')!.textContent = `${checked} / ${total}`;
    document.getElementById('summary-pct')!.textContent = `${pct}%`;
    document.getElementById('summary-flags')!.textContent = flags.count.toString();

    const gradeEl = document.getElementById('summary-grade')!;
    gradeEl.textContent = grade;
    gradeEl.className = `font-heading font-extrabold text-3xl ${gradeColor(grade)}`;

    if (flags.count > 0) {
      document.getElementById('summary-flags')!.className = 'font-heading font-extrabold text-3xl text-[#FBBF24]';
    } else {
      document.getElementById('summary-flags')!.className = 'font-heading font-extrabold text-3xl text-[#34D399]';
    }

    const flagList = document.getElementById('flag-list')!;
    const flagItems = document.getElementById('flag-items')!;
    if (flags.count > 0) {
      flagList.classList.remove('hidden');
      flagItems.innerHTML = flags.items.map(f => `<div class="bg-[rgba(251,191,36,0.1)] border border-[rgba(251,191,36,0.3)] rounded-lg px-4 py-2 text-sm text-[#FBBF24]">${f}</div>`).join('');
    } else {
      flagList.classList.add('hidden');
      flagItems.innerHTML = '';
    }
  }

  // ===== COLOR INDICATORS =====
  function updateIndicators(): void {
    // Pest control checklist uses completion-based grading, no numeric indicators
  }

  // ===== EVENT LISTENERS =====
  document.querySelectorAll('.cl-check').forEach(cb => {
    cb.addEventListener('change', () => {
      updateProgress();
      saveState();
    });
  });

  document.querySelectorAll('[data-field]').forEach(el => {
    el.addEventListener('input', () => {
      updateIndicators();
      updateProgress();
      saveState();
    });
    el.addEventListener('change', () => {
      updateIndicators();
      updateProgress();
      saveState();
    });
  });

  // ===== RESET =====
  document.getElementById('reset-checklist')?.addEventListener('click', () => {
    if (!confirm('Reset all checked items and field entries? This cannot be undone.')) return;
    document.querySelectorAll('.cl-check').forEach(cb => { (cb as HTMLInputElement).checked = false; });
    document.querySelectorAll('[data-field]').forEach(el => { (el as HTMLInputElement | HTMLSelectElement).value = ''; });
    try { localStorage.removeItem(STORAGE_KEY); } catch {}
    updateIndicators();
    updateProgress();
  });

  // ===== REPORT GENERATION =====
  document.getElementById('generate-report')?.addEventListener('click', () => {
    const seasonLabel = activeTab === 'cooling' ? 'General Pest Treatment' : 'Termite / WDO Treatment';
    const panel = activeTab === 'cooling' ? '#panel-cooling' : '#panel-heating';
    const checks = document.querySelectorAll(`${panel} .cl-check`);
    const total = checks.length;
    const checked = Array.from(checks).filter(c => (c as HTMLInputElement).checked).length;
    const pct = total > 0 ? Math.round((checked / total) * 100) : 0;
    const flags = evaluateFlags();
    const grade = getGrade(pct, flags.count);
    const now = new Date();
    const dateStr = now.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    const timeStr = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });

    // Gather field data
    const fields: Record<string, string> = {};
    document.querySelectorAll('[data-field]').forEach(el => {
      const key = (el as HTMLElement).dataset.field!;
      const val = (el as HTMLInputElement | HTMLSelectElement).value;
      if (val) fields[key] = val;
    });

    // Build sections from the active panel
    const sections: { title: string; items: { text: string; checked: boolean }[] }[] = [];
    const sectionEls = document.querySelectorAll(`${panel} > .mb-8`);
    sectionEls.forEach(sec => {
      const h3 = sec.querySelector('h3');
      if (!h3) return;
      const title = h3.textContent?.trim().replace(/^\u25CF\s*/, '') || '';
      const items: { text: string; checked: boolean }[] = [];
      sec.querySelectorAll('.cl-check').forEach(cb => {
        const label = (cb as HTMLElement).closest('label') || (cb as HTMLElement).closest('.flex');
        const span = label?.querySelector('span');
        const text = span?.textContent?.trim() || '';
        items.push({ text, checked: (cb as HTMLInputElement).checked });
      });
      sections.push({ title, items });
    });

    // Build HTML for print
    let html = `<!DOCTYPE html><html><head><meta charset="utf-8"><title>Pest Control Treatment Report - ${seasonLabel}</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1a1a1a; padding: 40px; max-width: 800px; margin: 0 auto; font-size: 13px; line-height: 1.5; }
      h1 { font-size: 22px; margin-bottom: 4px; }
      h2 { font-size: 16px; margin: 20px 0 8px; border-bottom: 2px solid #e5e7eb; padding-bottom: 4px; }
      .meta { color: #6b7280; font-size: 12px; margin-bottom: 20px; }
      .summary-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px; }
      .summary-box { border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px; text-align: center; }
      .summary-box .label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280; margin-bottom: 4px; }
      .summary-box .value { font-size: 22px; font-weight: 700; }
      .grade-A { color: #10b981; } .grade-B { color: #3b82f6; } .grade-C { color: #f59e0b; } .grade-D { color: #f97316; } .grade-F { color: #ef4444; }
      .item { padding: 3px 0; display: flex; align-items: center; gap: 8px; }
      .check { width: 14px; height: 14px; border: 1.5px solid #d1d5db; border-radius: 3px; display: inline-flex; align-items: center; justify-content: center; font-size: 10px; flex-shrink: 0; }
      .check.done { background: #10b981; border-color: #10b981; color: white; }
      .readings { margin: 8px 0 8px 22px; padding: 8px 12px; background: #f9fafb; border-radius: 6px; font-size: 12px; }
      .readings span { margin-right: 16px; }
      .flag { background: #fef3c7; border: 1px solid #f59e0b; border-radius: 6px; padding: 6px 12px; margin: 4px 0; font-size: 12px; color: #92400e; }
      @media print { body { padding: 20px; } }
    </style></head><body>`;

    html += `<h1>Pest Control Treatment Report</h1>`;
    html += `<div class="meta">${seasonLabel} &mdash; ${dateStr} at ${timeStr}</div>`;

    html += `<div class="summary-grid">`;
    html += `<div class="summary-box"><div class="label">Checked</div><div class="value">${checked}/${total}</div></div>`;
    html += `<div class="summary-box"><div class="label">Completion</div><div class="value">${pct}%</div></div>`;
    html += `<div class="summary-box"><div class="label">Flags</div><div class="value">${flags.count}</div></div>`;
    html += `<div class="summary-box"><div class="label">Grade</div><div class="value grade-${grade}">${grade}</div></div>`;
    html += `</div>`;

    if (flags.count > 0) {
      html += `<h2>Flagged Items</h2>`;
      flags.items.forEach(f => { html += `<div class="flag">${f}</div>`; });
    }

    sections.forEach(sec => {
      html += `<h2>${sec.title}</h2>`;
      sec.items.forEach(item => {
        html += `<div class="item"><span class="check ${item.checked ? 'done' : ''}">${item.checked ? '&#10003;' : ''}</span> ${item.text}</div>`;
      });
    });

    // Add recorded field data if any
    const readingLabels: Record<string, string> = {
      'product-name': 'Product Name', 'epa-reg': 'EPA Reg #', 'amount-used': 'Amount Used',
      'bait-station-count': 'Bait Stations (Qty)',
      'linear-ft': 'Linear Feet Treated', 'termiticide-product': 'Termiticide Product',
      'gallons-used': 'Gallons Used', 'monitor-count': 'Monitoring Stations (Qty)',
    };
    const activeFields = Object.entries(fields).filter(([_, v]) => v);
    if (activeFields.length > 0) {
      html += `<h2>Recorded Details</h2><div class="readings">`;
      activeFields.forEach(([k, v]) => {
        const label = readingLabels[k] || k;
        html += `<span><strong>${label}:</strong> ${v}</span>`;
      });
      html += `</div>`;
    }

    html += `</body></html>`;

    const printWin = window.open('', '_blank');
    if (printWin) {
      printWin.document.write(html);
      printWin.document.close();
      setTimeout(() => printWin.print(), 400);
    }
  });

  // ===== INIT =====
  loadState();
  updateIndicators();
  updateProgress();
</script>
