---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/hvacTools';

const tool = getToolBySlug('manual-j-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a Manual J calculation?",
      "acceptedAnswer": { "@type": "Answer", "text": "Manual J is the ACCA-standard method for calculating residential heating and cooling loads. It considers building size, insulation, windows, climate zone, occupancy, and other factors to determine the correct HVAC system size. This calculator provides a simplified Manual J estimate." }
    },
    {
      "@type": "Question",
      "name": "When do I need a Manual J calculation?",
      "acceptedAnswer": { "@type": "Answer", "text": "A Manual J is required for new construction permits, major HVAC replacements, and to validate equipment warranties. Use this simplified calculator for on-site estimates and sales calls, then run a full Manual J in software (Wrightsoft, CoolCalc) for permit applications." }
    },
    {
      "@type": "Question",
      "name": "How accurate is a simplified Manual J?",
      "acceptedAnswer": { "@type": "Answer", "text": "A simplified Manual J using baseline factors typically gets within 15-20% of a full Manual J calculation. The main variables it doesn't capture are exact wall R-values, window SHGC ratings, duct losses, and infiltration rates. The size range output accounts for this margin." }
    },
    {
      "@type": "Question",
      "name": "What is the difference between cooling and heating load?",
      "acceptedAnswer": { "@type": "Answer", "text": "Cooling load is the BTU capacity needed to remove heat on the hottest design day. Heating load is the BTU capacity needed to add heat on the coldest design day. In hot climates, cooling load is larger. In cold climates, heating load dominates. Both are needed for proper heat pump or dual-fuel sizing." }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]} hideCards>
  <div id="mj-calc">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="sqft">Total Square Footage</label>
        <input type="number" id="sqft" value="2000" min="200" max="20000" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="ceiling">Ceiling Height (ft)</label>
        <input type="number" id="ceiling" value="8" min="6" max="20" step="0.5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="zone">Climate Zone</label>
        <select id="zone" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="1">Zone 1 — Hot Humid (Miami, Houston)</option>
          <option value="2">Zone 2 — Hot Dry (Phoenix, Las Vegas)</option>
          <option value="3">Zone 3 — Warm (Atlanta, Dallas)</option>
          <option value="4" selected>Zone 4 — Mixed (DC, Nashville, St. Louis)</option>
          <option value="5">Zone 5 — Cool (Chicago, Boston, Denver)</option>
          <option value="6">Zone 6 — Cold (Minneapolis, Milwaukee)</option>
          <option value="7">Zone 7 — Very Cold (Duluth, Anchorage)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="insulation">Insulation Quality</label>
        <select id="insulation" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="poor">Poor — Little/no wall insulation, single-pane</option>
          <option value="average" selected>Average — Standard fiberglass, double-pane</option>
          <option value="good">Good — Above-code insulation, Low-E glass</option>
          <option value="excellent">Excellent — Spray foam, triple-pane, tight envelope</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="windows">Number of Windows</label>
        <input type="number" id="windows" value="10" min="0" max="100" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="windowType">Window Type</label>
        <select id="windowType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="1200">Single-pane</option>
          <option value="800" selected>Double-pane</option>
          <option value="500">Triple-pane / Low-E</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="doors">Exterior Doors</label>
        <input type="number" id="doors" value="2" min="0" max="20" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="sun">Sun Exposure</label>
        <select id="sun" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="heavy">Heavy — South/west facing, lots of glass</option>
          <option value="moderate" selected>Moderate — Mixed exposure</option>
          <option value="minimal">Minimal — North facing, heavy shade</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="occupants">Number of Occupants</label>
        <input type="number" id="occupants" value="4" min="1" max="30" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="kitchen">Kitchen?</label>
        <select id="kitchen" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="4000" selected>Yes</option>
          <option value="0">No</option>
        </select>
      </div>
    </div>

    <!-- Calculate button -->
    <div id="calc-btn-area" class="mt-2">
      <button
        id="calculate-btn"
        type="button"
        class="w-full bg-accent hover:bg-accent-hover text-white font-heading font-bold text-lg px-8 py-4 rounded-xl transition-colors"
      >
        Calculate My Load
      </button>
    </div>

    <!-- Email gate (hidden until Calculate is clicked) -->
    <div id="email-gate" class="hidden mt-8 border-t border-border pt-8">
      <div class="max-w-lg mx-auto text-center">
        <div class="w-14 h-14 rounded-2xl bg-accent/15 flex items-center justify-center mx-auto mb-4">
          <svg width="28" height="28" viewBox="0 0 20 20" fill="none" class="text-accent">
            <path d="M2.5 6.667L9.025 11.05a1.667 1.667 0 001.95 0L17.5 6.667M4.167 15h11.666A1.667 1.667 0 0017.5 13.333V6.667A1.667 1.667 0 0015.833 5H4.167A1.667 1.667 0 002.5 6.667v6.666A1.667 1.667 0 004.167 15z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="font-heading font-bold text-xl text-text-primary mb-2">Your results are ready</h3>
        <p class="text-text-secondary text-sm mb-6">Enter your email to get your Manual J load calculation — cooling BTU, heating BTU, tonnage, and size range.</p>

        <div class="flex flex-col sm:flex-row gap-3 mb-3">
          <label for="gate-email" class="sr-only">Your work email</label>
          <input
            type="email"
            id="gate-email"
            placeholder="you@company.com"
            required
            class="flex-1 bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-base focus:border-accent focus:outline-none transition-colors placeholder:text-text-muted"
          />
          <button
            id="gate-submit"
            type="button"
            class="bg-accent hover:bg-accent-hover text-white font-semibold px-6 py-3 rounded-lg transition-colors whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Send My Results
          </button>
        </div>

        <label class="flex items-center justify-center gap-2 cursor-pointer select-none">
          <input type="checkbox" id="gate-consent" checked class="w-4 h-4 rounded border-border bg-bg-dark accent-accent" />
          <span class="text-text-muted text-xs">Also send me free tools and tips for pros. Unsubscribe anytime.</span>
        </label>

        <div id="gate-error" class="hidden mt-3 text-sm text-[#EF4444]"></div>
      </div>
    </div>

    <!-- Results (hidden until email is submitted) -->
    <div id="results" class="hidden mt-8 border-t border-border pt-8">
      <!-- Email-sent confirmation banner -->
      <div class="mb-6 bg-[rgba(52,211,153,0.08)] border border-[rgba(52,211,153,0.25)] rounded-xl p-4 flex items-start gap-3">
        <div class="shrink-0 w-8 h-8 rounded-full bg-[rgba(52,211,153,0.15)] flex items-center justify-center">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" class="text-[#34D399]">
            <path d="M16.667 5L7.5 14.167 3.333 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <p class="text-text-primary font-semibold text-sm">Results also sent to your inbox</p>
          <p class="text-text-secondary text-xs mt-0.5">Don't see it? Check your Spam or Promotions folder.</p>
        </div>
      </div>

      <h3 class="font-heading font-bold text-xl mb-6">Your Manual J Results</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cooling BTU</div>
          <div id="r-cool" class="font-heading font-extrabold text-2xl text-accent">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Heating BTU</div>
          <div id="r-heat" class="font-heading font-extrabold text-2xl text-text-primary">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">System Tonnage</div>
          <div id="r-tons" class="font-heading font-extrabold text-2xl text-text-primary">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Size Range</div>
          <div id="r-range" class="font-heading font-extrabold text-lg text-text-primary">—</div>
        </div>
      </div>
      <p class="text-text-muted text-sm italic">This is a simplified estimate. A full Manual J calculation is required for permit applications and final equipment selection.</p>

      <!-- Post-results: related tools suggestion -->
      <div class="mt-6 bg-bg-dark/50 border border-border rounded-xl p-5">
        <p class="text-text-secondary text-sm mb-3">
          <strong class="text-text-primary">Next steps:</strong> Use the <a href="/hvac/cfm-calculator/" class="text-accent hover:underline">CFM Calculator</a> to determine airflow per room, then the <a href="/hvac/duct-size-calculator/" class="text-accent hover:underline">Duct Size Calculator</a> to size your ductwork.
        </p>
      </div>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter total square footage.</strong> Include all conditioned living space. Don't include unfinished basements, garages, or unconditioned attics.</p>
          <p><strong class="text-text-primary">2. Select your climate zone.</strong> Zones 1-2 are hot (southern US), zones 4-5 are moderate (mid-Atlantic, Midwest), zones 6-7 are cold (northern US). This adjusts both cooling and heating loads.</p>
          <p><strong class="text-text-primary">3. Rate insulation quality.</strong> "Poor" means pre-1980 construction with minimal upgrades. "Excellent" means spray foam walls, triple-pane windows, and verified air sealing.</p>
          <p><strong class="text-text-primary">4. Count windows and doors.</strong> Each window and exterior door is a heat transfer point. Window type matters — single-pane transfers 2.4x more heat than triple-pane Low-E.</p>
          <p><strong class="text-text-primary">5. Set sun exposure and occupants.</strong> South and west-facing homes in zones 1-3 take heavy solar load. Each occupant adds ~600 BTU of body heat.</p>
          <p><strong class="text-text-primary">6. Click Calculate.</strong> We'll email you the complete results — cooling BTU, heating BTU, tonnage, and size range — so you can reference them on the job or attach to a quote.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How the Manual J Formula Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>This calculator uses a simplified ACCA Manual J approach with a <strong class="text-text-primary">20 BTU/sq ft baseline</strong> and seven adjustment factors.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm overflow-x-auto">
            <p>Cooling_BTU = (20 x Sqft x Climate x Ceiling x Insulation x Sun) + (Windows x Window_BTU) + (Doors x 1000) + (Occupants x 600) + Kitchen</p>
            <p class="mt-2">Heating_BTU = Cooling_BTU x Heating_Factor (varies by climate zone)</p>
            <p class="mt-2">Tonnage = Cooling_BTU / 12,000 (rounded to nearest 0.5 ton)</p>
          </div>
          <p>The climate zone adjusts cooling demand (hot zones multiply up, cold zones multiply down) and applies a separate heating factor. Cold zones like Minneapolis need significantly more heating BTU than cooling BTU.</p>
          <p>The size range accounts for variables this calculator doesn't capture — duct losses, building orientation, thermal mass, and infiltration rate. Use the low end for tight, well-built homes and the high end for older construction.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">On-site estimates.</strong> Run a quick Manual J in front of the customer to show you're sizing the system properly — not just guessing or matching the old unit's tonnage.</p>
          <p><strong class="text-text-primary">Pre-qualifying leads.</strong> Before driving to the job site, ask the homeowner for square footage and home details. Get a ballpark tonnage so you know what to quote before you arrive.</p>
          <p><strong class="text-text-primary">Sanity-checking existing systems.</strong> Customer complains their system runs all day? Check if it was properly sized. A 2-ton unit on a home that needs 4 tons was never going to keep up.</p>
          <p><strong class="text-text-primary">Quick comparisons.</strong> Run the calculation multiple times with different insulation or window scenarios to show customers the impact of envelope improvements on system sizing.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is a Manual J calculation?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Manual J is the ACCA-standard method for calculating residential heating and cooling loads. It considers building size, insulation, windows, climate zone, occupancy, and other factors to determine the correct HVAC system size. This calculator provides a simplified estimate — a full Manual J is required for permits.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">When do I need a full Manual J?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A full Manual J is required for new construction permits, major system replacements in many jurisdictions, and to validate equipment warranties. Use this simplified calculator for on-site estimates, then run a full Manual J in software like Wrightsoft or CoolCalc for permit applications.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How accurate is this compared to a full Manual J?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A simplified Manual J using baseline factors typically gets within 15-20% of a full calculation. The main variables it doesn't capture are exact wall R-values, window SHGC ratings, duct losses, and infiltration rates. The size range output accounts for this margin.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is the difference between cooling and heating load?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Cooling load is the BTU needed to remove heat on the hottest design day. Heating load is the BTU needed to add heat on the coldest design day. In hot climates (zones 1-2), cooling load is larger. In cold climates (zones 6-7), heating load dominates. Both matter for heat pump sizing.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // ---- Manual J Calculator with email gate ----
  // Results are calculated but NOT shown until the user provides their email.

  interface CalcResults {
    coolBtu: number;
    heatBtu: number;
    tonnage: number;
    lowRange: number;
    highRange: number;
    // Inputs for email
    sqft: number;
    climateZoneLabel: string;
    insulationLabel: string;
  }

  let pendingResults: CalcResults | null = null;

  function calculate(): CalcResults {
    const sqft = parseFloat((document.getElementById('sqft') as HTMLInputElement).value) || 2000;
    const ceiling = parseFloat((document.getElementById('ceiling') as HTMLInputElement).value) || 8;
    const zone = parseInt((document.getElementById('zone') as HTMLSelectElement).value);
    const insulation = (document.getElementById('insulation') as HTMLSelectElement).value;
    const windows = parseInt((document.getElementById('windows') as HTMLInputElement).value) || 0;
    const windowBtu = parseInt((document.getElementById('windowType') as HTMLSelectElement).value);
    const doors = parseInt((document.getElementById('doors') as HTMLInputElement).value) || 0;
    const sunVal = (document.getElementById('sun') as HTMLSelectElement).value;
    const occupants = parseInt((document.getElementById('occupants') as HTMLInputElement).value) || 2;
    const kitchen = parseInt((document.getElementById('kitchen') as HTMLSelectElement).value);

    const climateFactor: Record<number, number> = { 1: 1.3, 2: 1.2, 3: 1.1, 4: 1.0, 5: 0.95, 6: 0.9, 7: 0.85 };
    const insulationFactor: Record<string, number> = { poor: 1.2, average: 1.0, good: 0.9, excellent: 0.8 };
    const sunFactor: Record<string, number> = { heavy: 1.15, moderate: 1.0, minimal: 0.9 };
    const heatingFactor: Record<number, number> = { 1: 0.8, 2: 0.8, 3: 1.0, 4: 1.1, 5: 1.2, 6: 1.3, 7: 1.4 };

    const ceilingF = ceiling / 8;
    const baseBtu = 20 * sqft * climateFactor[zone] * ceilingF * insulationFactor[insulation] * sunFactor[sunVal];
    const coolBtu = Math.round(baseBtu + (windows * windowBtu) + (doors * 1000) + (occupants * 600) + kitchen);
    const heatBtu = Math.round(coolBtu * heatingFactor[zone]);
    const tonnageRaw = coolBtu / 12000;
    const tonnage = Math.round(tonnageRaw * 2) / 2;

    const zoneEl = document.getElementById('zone') as HTMLSelectElement;
    const insEl = document.getElementById('insulation') as HTMLSelectElement;

    return {
      coolBtu,
      heatBtu,
      tonnage,
      lowRange: Math.round(coolBtu * 0.85),
      highRange: Math.round(coolBtu * 1.15),
      sqft,
      climateZoneLabel: zoneEl.options[zoneEl.selectedIndex].text,
      insulationLabel: insEl.options[insEl.selectedIndex].text,
    };
  }

  function showResults(results: CalcResults) {
    document.getElementById('r-cool')!.textContent = results.coolBtu.toLocaleString() + ' BTU';
    document.getElementById('r-heat')!.textContent = results.heatBtu.toLocaleString() + ' BTU';
    document.getElementById('r-tons')!.textContent = results.tonnage + ' ton';
    document.getElementById('r-range')!.textContent = results.lowRange.toLocaleString() + ' \u2013 ' + results.highRange.toLocaleString();
    document.getElementById('results')!.classList.remove('hidden');
    document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Calculate button — show email gate
  document.getElementById('calculate-btn')!.addEventListener('click', () => {
    pendingResults = calculate();
    document.getElementById('calc-btn-area')!.classList.add('hidden');
    document.getElementById('email-gate')!.classList.remove('hidden');
    document.getElementById('gate-email')!.focus();

    // Fire tool_used event here since this is the meaningful interaction
    // (ToolLayout's auto-fire on 'input' still works for the input fields,
    //  but the Calculate click is the real commitment signal)
  });

  // Email submission
  const gateSubmit = document.getElementById('gate-submit') as HTMLButtonElement;
  const gateEmail = document.getElementById('gate-email') as HTMLInputElement;
  const gateConsent = document.getElementById('gate-consent') as HTMLInputElement;
  const gateError = document.getElementById('gate-error')!;

  gateSubmit.addEventListener('click', async () => {
    const email = gateEmail.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      gateError.textContent = 'Please enter a valid email address.';
      gateError.classList.remove('hidden');
      return;
    }

    gateError.classList.add('hidden');
    gateSubmit.disabled = true;
    gateSubmit.textContent = 'Sending...';

    try {
      // Include calculation results in the email capture call
      const res = await fetch('/api/email-capture', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          toolSlug: 'manual-j-calculator',
          toolName: 'Manual J Calculator',
          tradeSlug: 'hvac',
          tradeName: 'HVAC',
          marketingConsent: gateConsent.checked,
          sourceUrl: window.location.pathname,
          // Extra: calculation results for the enhanced email
          calculationResults: pendingResults ? {
            coolBtu: pendingResults.coolBtu,
            heatBtu: pendingResults.heatBtu,
            tonnage: pendingResults.tonnage,
            lowRange: pendingResults.lowRange,
            highRange: pendingResults.highRange,
            sqft: pendingResults.sqft,
            climateZone: pendingResults.climateZoneLabel,
            insulation: pendingResults.insulationLabel,
          } : null,
        }),
      });

      if (!res.ok) throw new Error('Failed to send');

      // Hide the email gate, show results
      document.getElementById('email-gate')!.classList.add('hidden');
      if (pendingResults) showResults(pendingResults);

      // PostHog: track email capture
      const meta = (window as any).__ntqToolMeta;
      if ((window as any).posthog && meta) {
        (window as any).posthog.capture('email_captured', {
          tool_slug: meta.toolSlug,
          trade_slug: meta.tradeSlug,
          trade_name: meta.tradeName,
          tool_name: meta.toolName,
          tool_category: meta.category,
          marketing_consent: gateConsent.checked,
          gated: true,
        });
      }
      // Google Ads conversion: NTQ - Email Captured
      if (typeof gtag === 'function') gtag('event', 'conversion', {'send_to': 'AW-17899660858/rqouCLin75gcELrMnNdC'});

    } catch {
      gateError.textContent = 'Something went wrong. Please try again.';
      gateError.classList.remove('hidden');
      gateSubmit.disabled = false;
      gateSubmit.textContent = 'Send My Results';
    }
  });

  // Enter key submits email
  gateEmail.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') gateSubmit.click();
  });
</script>
