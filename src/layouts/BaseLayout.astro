---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SignupModal from '../components/SignupModal.astro';
import Tier2Triggers from '../components/Tier2Triggers.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  currentPath?: string;
  schema?: object[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage = '/images/og-default.png',
  currentPath = Astro.url.pathname,
  schema = [],
  noindex = false
} = Astro.props;

const siteUrl = 'https://nailthequote.com';
const canonical = canonicalUrl || `${siteUrl}${currentPath}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={canonical} />
  <meta name="google-site-verification" content="fjqa3ABRAdp_e1EXOy5tFvEKZN6PUbS60yaODrru9DY" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:site_name" content="NailTheQuote" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Schema markup -->
  {schema.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <!-- Ad attribution capture — reads gclid/UTM params from URL on first page of a session
       and persists to sessionStorage (first-touch). Every subsequent email capture POST
       reads window.__ntqAttribution to stamp the Supabase row with where the user came
       from. Must be `is:inline` so it runs before PostHog init below (so we can also
       set it as person properties). See migration 008 for the matching Supabase cols. -->
  <script is:inline>
    (function(){
      var STORE = 'ntq_attrib';
      var keys = ['gclid','utm_source','utm_medium','utm_campaign','utm_term','utm_content'];
      var params;
      try { params = new URLSearchParams(window.location.search); } catch (e) { params = null; }

      var urlHas = params ? keys.some(function(k){ return params.get(k); }) : false;
      var stored = null;
      try { stored = JSON.parse(sessionStorage.getItem(STORE) || 'null'); } catch (e) { stored = null; }

      // Refresh attribution if this page load carries any ad params, OR if nothing is
      // stored yet. Otherwise keep the session's first-touch attribution as-is.
      var attrib;
      if (urlHas || !stored) {
        attrib = {};
        if (params) keys.forEach(function(k){ var v = params.get(k); if (v) attrib[k] = v; });
        attrib.landing_url = window.location.href;
        attrib.referrer = document.referrer || null;
        attrib.first_seen = new Date().toISOString();
        try { sessionStorage.setItem(STORE, JSON.stringify(attrib)); } catch (e) {}
      } else {
        attrib = stored;
      }
      window.__ntqAttribution = attrib;
    })();
  </script>

  <!-- Google tag (gtag.js) - Google Ads: AW-17899660858 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=AW-17899660858"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-17899660858');
  </script>

  <!-- Cloudflare Analytics: uncomment and add token when ready -->
  <!-- <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "YOUR_TOKEN_HERE"}'></script> -->
</head>
<body class="min-h-screen flex flex-col">
  <Header currentPath={currentPath} />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
  <SignupModal />
  <Tier2Triggers />
  <script is:inline>
    !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.async=!0,p.src=s.api_host+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once unregister opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing isFeatureEnabled getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group resetGroups setPersonProperties setPersonPropertiesForFlags setGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
    posthog.init('phc_CZ6VYQBtN5eNJNTH4PriDMUXyuRtprsVWB7ZrXetnkcP',{api_host:'/ingest',ui_host:'https://eu.posthog.com',person_profiles:'identified_only'});

    // Register ad attribution as event properties on every event, and as person
    // properties (first-touch) so we can segment people by acquisition source in
    // PostHog. Uses window.posthog directly (not a cached ref) per the Apr 11 lesson.
    (function(){
      var a = window.__ntqAttribution;
      if (!a || !window.posthog) return;
      var props = {};
      ['gclid','utm_source','utm_medium','utm_campaign','utm_term','utm_content','landing_url','referrer'].forEach(function(k){
        if (a[k]) props['$initial_' + k] = a[k];
      });
      try { window.posthog.register(props); } catch (e) {}
    })();
  </script>
</body>
</html>
