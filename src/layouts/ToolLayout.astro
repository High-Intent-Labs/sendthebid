---
import BaseLayout from './BaseLayout.astro';
import AccountCreationCard from '../components/AccountCreationCard.astro';
import EmailCaptureCard from '../components/EmailCaptureCard.astro';
import { categoryColors, type Tool } from '../data/types';

interface Props {
  tool: Tool;
  extraSchema?: Record<string, unknown>[];
  /** Hide the default AccountCreationCard and EmailCaptureCard (use when the page has its own gate) */
  hideCards?: boolean;
}

const { tool, extraSchema = [], hideCards = false } = Astro.props;

// Dynamic imports — resolve the trade's tool utilities at build time
const tradeModules: Record<string, () => Promise<{ getRelatedTools: (slug: string) => Tool[] }>> = {
  hvac: () => import('../data/hvacTools'),
  electrical: () => import('../data/electricalTools'),
  roofing: () => import('../data/roofingTools'),
  painting: () => import('../data/paintingTools'),
  landscaping: () => import('../data/landscapingTools'),
  gc: () => import('../data/gcTools'),
  handyman: () => import('../data/handymanTools'),
  'pest-control': () => import('../data/pestControlTools'),
  cleaning: () => import('../data/cleaningTools'),
  plumbing: () => import('../data/plumbingTools'),
};

let relatedTools: Tool[] = [];
const loader = tradeModules[tool.tradeSlug];
if (loader) {
  const mod = await loader();
  relatedTools = mod.getRelatedTools(tool.slug);
}

const catColor = categoryColors[tool.category];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://nailthequote.com/" },
    { "@type": "ListItem", "position": 2, "name": `${tool.tradeName} Tools`, "item": `https://nailthequote.com/${tool.tradeSlug}/` },
    { "@type": "ListItem", "position": 3, "name": tool.name }
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": tool.name,
  "description": tool.metaDescription,
  "url": `https://nailthequote.com/${tool.tradeSlug}/${tool.slug}/`,
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "creator": {
    "@type": "Organization",
    "name": "NailTheQuote"
  }
};
---

<BaseLayout
  title={tool.seoTitle}
  description={tool.metaDescription}
  currentPath={`/${tool.tradeSlug}/${tool.slug}/`}
  schema={[breadcrumbSchema, webAppSchema, ...extraSchema]}
>
  <!-- Breadcrumb -->
  <nav class="max-w-[1080px] mx-auto px-6 md:px-12 pt-4 pb-2" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-text-muted">
      <li><a href="/" class="hover:text-text-secondary transition-colors no-underline">Home</a></li>
      <li class="before:content-['/'] before:mx-2"><a href={`/${tool.tradeSlug}/`} class="hover:text-text-secondary transition-colors no-underline">{tool.tradeName} Tools</a></li>
      <li class="before:content-['/'] before:mx-2 text-text-secondary">{tool.shortName}</li>
    </ol>
  </nav>

  <!-- Tool header -->
  <div class="max-w-[1080px] mx-auto px-6 md:px-12 pt-6 pb-8">
    <div class="flex items-center gap-3 mb-4">
      <span class:list={["text-[11px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded", catColor.text, catColor.bg]}>
        {tool.categoryLabel}
      </span>
      <span class="text-text-muted text-xs">Free</span>
    </div>
    <h1 class="font-heading font-extrabold text-3xl md:text-5xl tracking-tight mb-3">{tool.name}</h1>
    <p class="text-text-secondary text-lg max-w-2xl">{tool.description}</p>
  </div>

  <!-- Calculator area -->
  <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16">
    <div class="bg-bg-card border border-border rounded-2xl p-6 md:p-8">
      <slot />
    </div>
  </div>

  {!hideCards && (
    <>
      {/* Account creation card */}
      <div class="max-w-[1080px] mx-auto px-6 md:px-12 -mt-8 pb-4">
        <AccountCreationCard
          toolName={tool.name}
          toolSlug={tool.slug}
          tradeSlug={tool.tradeSlug}
          tradeName={tool.tradeName}
          category={tool.category}
        />
      </div>

      {/* Email capture card */}
      <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16">
        <EmailCaptureCard
          toolName={tool.name}
          toolSlug={tool.slug}
          tradeSlug={tool.tradeSlug}
          tradeName={tool.tradeName}
        />
      </div>
    </>
  )}

  <!-- Content sections (How to Use, How It Works, etc.) -->
  <slot name="content" />

  <!-- Related Tools -->
  {relatedTools.length > 0 && (
    <section class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16">
      <h2 class="font-heading font-bold text-2xl mb-6">Related {tool.tradeName} Tools</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {relatedTools.map(rt => {
          const rc = categoryColors[rt.category];
          return (
            <a href={`/${rt.tradeSlug}/${rt.slug}/`} class="bg-bg-card border border-border rounded-xl p-5 no-underline hover:border-[#3A4755] hover:bg-bg-card-hover hover:-translate-y-0.5 transition-all">
              <span class:list={["text-[11px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded inline-block mb-2", rc.text, rc.bg]}>
                {rt.categoryLabel}
              </span>
              <h3 class="font-heading font-bold text-base text-text-primary mb-1">{rt.shortName}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{rt.shortDescription}</p>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- Back to hub CTA -->
  <div class="text-center py-12 border-t border-border max-w-[1080px] mx-auto">
    <a href={`/${tool.tradeSlug}/`} class="inline-flex items-center gap-2 text-accent font-semibold text-sm hover:gap-3 transition-all no-underline">
      &larr; View all {tool.tradeName} tools
    </a>
  </div>

  <!-- PostHog custom tool analytics -->
  <script define:vars={{ toolSlug: tool.slug, tradeSlug: tool.tradeSlug, tradeName: tool.tradeName, toolName: tool.name, category: tool.category }}>
    window.__ntqToolMeta = { toolSlug, tradeSlug, tradeName, toolName, category };
  </script>
  <script>
    (() => {
      const meta = (window as any).__ntqToolMeta;
      if (!meta || typeof (window as any).posthog === 'undefined') return;
      // IMPORTANT: Do NOT cache window.posthog in a variable for deferred calls.
      // PostHog's real library replaces the stub object on window.posthog after async load.
      // Synchronous calls (tool_viewed) can use the stub safely, but event handler
      // callbacks must reference window.posthog directly to get the real instance.
      const props = {
        tool_slug: meta.toolSlug,
        trade_slug: meta.tradeSlug,
        trade_name: meta.tradeName,
        tool_name: meta.toolName,
        tool_category: meta.category,
      };

      // 1. Tool Viewed — fires on page load (safe to use stub)
      (window as any).posthog.capture('tool_viewed', props);

      // 2. Tool Used — fires when user interacts with any calculator input
      //    (debounced: only fires once per session per tool)
      let toolUsedFired = false;
      const toolArea = document.querySelector('.bg-bg-card.border');
      if (toolArea) {
        toolArea.addEventListener('input', () => {
          if (toolUsedFired) return;
          toolUsedFired = true;
          (window as any).posthog?.capture('tool_used', props);
          // Google Ads conversion: NTQ - Tool Used
          if (typeof gtag === 'function') gtag('event', 'conversion', {'send_to': 'AW-17899660858/cBlqCOfI6JgcELrMnNdC'});
        }, { once: true });
      }

      // 3. Calculation Completed — fires when result values change
      //    (debounced to 1.5s after last input)
      let calcTimer: ReturnType<typeof setTimeout> | null = null;
      let calcCount = 0;
      const resultEls = document.querySelectorAll('[id*="result"], [id*="output"]');
      if (resultEls.length > 0 && toolArea) {
        const observer = new MutationObserver(() => {
          if (calcTimer) clearTimeout(calcTimer);
          calcTimer = setTimeout(() => {
            calcCount++;
            // Only fire on the first meaningful calculation (skip the auto-calc on load)
            if (calcCount === 2) {
              (window as any).posthog?.capture('calculation_completed', props);
            }
          }, 1500);
        });
        resultEls.forEach(el => observer.observe(el, { childList: true, characterData: true, subtree: true }));
      }

      // 4. PDF Generated — fires when Generate PDF/Estimate button is clicked
      document.querySelectorAll('#generate-btn, #generate-pdf-btn, [data-generate-pdf]').forEach(btn => {
        btn.addEventListener('click', () => {
          (window as any).posthog?.capture('pdf_generated', props);
        });
      });

      // 5. Calculation Saved — fires when save button succeeds
      const saveBtn = document.getElementById('account-card-save');
      if (saveBtn) {
        const origClick = saveBtn.onclick;
        saveBtn.addEventListener('click', () => {
          // Watch for the button text to change to "Saved"
          const observer = new MutationObserver(() => {
            const text = document.getElementById('save-btn-text')?.textContent;
            if (text === 'Saved') {
              (window as any).posthog?.capture('calculation_saved', props);
              observer.disconnect();
            }
          });
          const btnText = document.getElementById('save-btn-text');
          if (btnText) observer.observe(btnText, { childList: true, characterData: true, subtree: true });
          // Auto-disconnect after 10s to avoid leaks
          setTimeout(() => observer.disconnect(), 10000);
        });
      }

      // 6. Signup Prompt Shown — fires when the signup modal opens from a tool page
      const modalObserver = new MutationObserver(() => {
        const modal = document.getElementById('signup-modal');
        if (modal && !modal.classList.contains('hidden')) {
          (window as any).posthog?.capture('signup_prompt_shown', {
            ...props,
            trigger: 'tool_page',
          });
        }
      });
      const modal = document.getElementById('signup-modal');
      if (modal) modalObserver.observe(modal, { attributes: true, attributeFilter: ['class'] });

      // 7. Account CTA Clicked — fires when "Create Free Account" is clicked from tool page
      document.getElementById('account-card-cta')?.addEventListener('click', () => {
        (window as any).posthog?.capture('account_cta_clicked', {
          ...props,
          location: 'tool_card',
        });
      });

      // 8. Related Tool Clicked — fires when a related tool link is clicked
      document.querySelectorAll('a[href]').forEach(link => {
        const href = (link as HTMLAnchorElement).getAttribute('href') || '';
        if (href.match(/^\/[a-z-]+\/[a-z-]+/) && link.closest('section')?.querySelector('h2')?.textContent?.includes('Related')) {
          link.addEventListener('click', () => {
            const targetSlug = href.split('/').filter(Boolean).pop() || '';
            (window as any).posthog?.capture('related_tool_clicked', {
              ...props,
              target_tool: targetSlug,
              target_url: href,
            });
          });
        }
      });
    })();
  </script>

  <!-- Generic state collection helper (used by AccountCreationCard save) -->
  <script>
    (window as any).__ntqCollectState = () => {
      const skip = (el: Element) => !!el.closest('#email-capture-card, #signup-modal, #account-creation-card');
      const inputs: Record<string, string> = {};
      const textareas: Record<string, string> = {};
      const checkboxes: Record<string, boolean> = {};

      document.querySelectorAll<HTMLInputElement | HTMLSelectElement>(
        'input[type="number"], input[type="text"], input[type="tel"], input[type="email"], input[type="hidden"], select'
      ).forEach(el => {
        if (skip(el)) return;
        const key = el.id || el.name;
        if (key && el.value) inputs[key] = el.value;
      });

      document.querySelectorAll<HTMLTextAreaElement>('textarea').forEach(el => {
        if (skip(el)) return;
        const key = el.id || el.name;
        if (key && el.value) textareas[key] = el.value;
      });

      document.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach(el => {
        if (skip(el)) return;
        const key = el.id || el.name || el.getAttribute('data-field');
        if (key) checkboxes[key] = el.checked;
      });

      const custom = (window as any).__ntqGetState?.() || null;

      return { version: 1, type: custom ? 'custom' : 'generic', inputs, textareas, checkboxes, custom };
    };
  </script>

  <!-- Restore saved state from ?restore=<id> -->
  <script>
    (async () => {
      try {
        const restoreId = new URLSearchParams(window.location.search).get('restore');
        if (!restoreId) return;

        let session: any = {};
        try { session = JSON.parse(localStorage.getItem('ntq_session') || '{}'); } catch {}
        if (!session.access_token) return;

        const res = await fetch(`/api/dashboard/calculation/${restoreId}`, {
          headers: { Authorization: `Bearer ${session.access_token}` },
        });
        if (!res.ok) return;

        const calc = await res.json();
        const state = calc.full_state;
        if (!state) {
          // Fallback: try URL params from old saves
          if (calc.url && calc.url.includes('?')) {
            const params = new URLSearchParams(calc.url.split('?')[1]);
            params.forEach((value, key) => {
              const el = document.getElementById(key) as HTMLInputElement | HTMLSelectElement | null;
              if (el && !el.closest('#email-capture-card, #signup-modal')) {
                el.value = value;
                el.dispatchEvent(new Event('input', { bubbles: true }));
              }
            });
          }
          return;
        }

        // Wait for page scripts to initialize
        await new Promise(r => requestAnimationFrame(() => requestAnimationFrame(r)));

        // 1. Restore custom state first (creates dynamic rows)
        if (state.custom && (window as any).__ntqSetState) {
          (window as any).__ntqSetState(state.custom);
        }

        // 2. Restore inputs and selects
        if (state.inputs) {
          for (const [key, value] of Object.entries(state.inputs)) {
            const el = document.getElementById(key) as HTMLInputElement | HTMLSelectElement | null
              || document.querySelector<HTMLInputElement | HTMLSelectElement>(`[name="${key}"]`);
            if (!el || el.closest('#email-capture-card, #signup-modal')) continue;
            el.value = value as string;
          }
        }

        // 3. Restore textareas
        if (state.textareas) {
          for (const [key, value] of Object.entries(state.textareas)) {
            const el = document.getElementById(key) as HTMLTextAreaElement | null
              || document.querySelector<HTMLTextAreaElement>(`textarea[name="${key}"]`);
            if (el) el.value = value as string;
          }
        }

        // 4. Restore checkboxes
        if (state.checkboxes) {
          for (const [key, checked] of Object.entries(state.checkboxes)) {
            const el = document.getElementById(key) as HTMLInputElement | null
              || document.querySelector<HTMLInputElement>(`input[type="checkbox"][name="${key}"]`)
              || document.querySelector<HTMLInputElement>(`input[type="checkbox"][data-field="${key}"]`);
            if (el) el.checked = checked as boolean;
          }
        }

        // 5. Dispatch events to trigger recalculations
        document.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
          'input, select, textarea'
        ).forEach(el => {
          if (!el.closest('#email-capture-card, #signup-modal')) {
            el.dispatchEvent(new Event('input', { bubbles: true }));
            el.dispatchEvent(new Event('change', { bubbles: true }));
          }
        });

        // 6. Clean URL
        const cleanUrl = window.location.pathname;
        history.replaceState(null, '', cleanUrl);

      } catch { /* silent */ }
    })();
  </script>

  <!-- Auto-fill profile data for logged-in users -->
  <script>
    (async () => {
      try {
        const session = JSON.parse(localStorage.getItem('ntq_session') || '{}');
        if (!session.access_token) return;

        const res = await fetch('/api/auth/me', {
          headers: { Authorization: `Bearer ${session.access_token}` },
        });
        if (!res.ok) return;

        const { profile } = await res.json();
        if (!profile) return;

        // Auto-fill by matching input ID directly to profile fields
        const idMap: Record<string, string | undefined> = {
          'companyName': profile.business_name,
          'companyname': profile.business_name,
          'company-name': profile.business_name,
          'businessName': profile.business_name,
          'business-name': profile.business_name,
          'company': profile.business_name,
          'companyPhone': profile.phone,
          'companyphone': profile.phone,
          'company-phone': profile.phone,
          'phone': profile.phone,
          'companyEmail': profile.email,
          'companyemail': profile.email,
          'company-email': profile.email,
          'ownerName': profile.owner_name,
          'owner-name': profile.owner_name,
          'tech-name': profile.owner_name,
          'licenseNum': profile.license_number,
          'license-num': profile.license_number,
          'license': profile.license_number,
          'hourly-rate': profile.default_hourly_rate,
          'labor-rate': profile.default_hourly_rate,
          'billable-rate': profile.default_hourly_rate,
          'rate': profile.default_hourly_rate,
          'markup': profile.default_markup,
          'parts-markup': profile.default_markup,
          'materials-markup': profile.default_markup,
        };

        const inputs = document.querySelectorAll<HTMLInputElement>('input[type="text"], input[type="tel"], input[type="email"], input[type="number"]');
        inputs.forEach(input => {
          if (input.value && input.value !== input.defaultValue) return;
          if (input.closest('#email-capture-card') || input.closest('#signup-modal')) return;

          // Match by exact ID first
          const val = idMap[input.id] || idMap[input.name];
          if (val) {
            input.value = String(val);
            input.dispatchEvent(new Event('input', { bubbles: true }));
          }
        });
      } catch { /* silent — don't break the page */ }
    })();
  </script>
</BaseLayout>
