          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Clean shower door or curtain</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Polish chrome fixtures and towel bars</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Wipe light switches and door handles</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Sweep and mop bathroom floor</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Empty trash and replace liner</span>
        </label>
      </div>
    </div>

    <!-- Bedrooms -->
    <div class="mb-8">
      <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Bedrooms
      </h3>
      <div class="space-y-3">
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Dust all surfaces (nightstands, dressers, shelves)</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Make beds and straighten linens</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Wipe mirrors and glass surfaces</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Wipe light switches, door handles, and outlets</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Vacuum carpet or dust mop hard floors</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Vacuum under bed edges (if accessible)</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Empty trash and replace liner</span>
        </label>
      </div>
    </div>

    <!-- Living Areas -->
    <div class="mb-8">
      <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Living Areas
      </h3>
      <div class="space-y-3">
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Dust all surfaces (coffee table, end tables, TV stand, shelves)</span>
