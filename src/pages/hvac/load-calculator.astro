---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/hvacTools';

const tool = getToolBySlug('load-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is this a Manual J calculation?",
      "acceptedAnswer": { "@type": "Answer", "text": "No — this is a simplified whole-house load estimator for pre-quote sanity checks. It's not permit-ready. For ACCA-stamped Manual J reports, use ACCA-accredited software. This tool gets you to within 15-20% of a full Manual J in 60 seconds, which is all most sales conversations need." }
    },
    {
      "@type": "Question",
      "name": "How accurate is this compared to a full load calculation?",
      "acceptedAnswer": { "@type": "Answer", "text": "Within 15-20% of a proper Manual J, typically. The main factors this tool doesn't capture are exact R-values, window SHGC ratings, duct losses, infiltration rate, and individual window orientations. Fine for sizing sanity checks. Not fine for permit applications." }
    },
    {
      "@type": "Question",
      "name": "Why do I need to enter a ZIP code?",
      "acceptedAnswer": { "@type": "Answer", "text": "Climate zone dramatically affects both cooling and heating loads. A 2,000 sqft home in Phoenix needs ~40% more cooling capacity than the same home in Seattle. Your ZIP maps to one of five climate regions (Hot / Warm / Mixed / Cool / Cold) that we use as a multiplier on the base load." }
    },
    {
      "@type": "Question",
      "name": "Does this work for mini-splits or ductless systems?",
      "acceptedAnswer": { "@type": "Answer", "text": "This tool sizes the whole-house load. For sizing an individual mini-split in a specific room, use our Mini-Split Sizing Calculator instead — it accounts for room dimensions, orientation, and exposed walls per-room, which matters a lot at the room level." }
    },
    {
      "@type": "Question",
      "name": "Why is heating BTU different from cooling BTU?",
      "acceptedAnswer": { "@type": "Answer", "text": "Cooling and heating loads are driven by different design conditions. In hot climates, cooling load dominates; in cold climates, heating load dominates. We apply a heating factor based on climate region to estimate the heating side — this matters especially for heat pump sizing where you need to know which load is bigger." }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]} hideCards>
  <div id="lc-calc">
    <!-- ZIP + climate display -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-text-primary mb-2" for="zip">ZIP Code</label>
      <input type="text" id="zip" inputmode="numeric" maxlength="5" placeholder="e.g. 85001"
        class="w-full sm:max-w-[180px] bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      <!-- zip-display hosts one of four states injected by JS:
           empty / partial / resolved (pro card with city + state +
           climate + IECC zone + design temps) / unrecognized. -->
      <div id="zip-display" class="mt-3 text-text-primary text-sm"></div>
      <div id="zip-fallback" class="hidden mt-3">
        <p class="text-text-primary text-xs mb-2">ZIP not found — pick your climate region:</p>
        <div class="flex flex-wrap gap-2">
          <button type="button" data-region="hot"   class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Hot</button>
          <button type="button" data-region="warm"  class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Warm</button>
          <button type="button" data-region="mixed" class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Mixed</button>
          <button type="button" data-region="cool"  class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Cool</button>
          <button type="button" data-region="cold"  class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Cold</button>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-primary mb-2" for="sqft">Square Footage</label>
        <div class="number-stepper flex items-stretch bg-bg-dark border border-border rounded-lg focus-within:border-accent transition-colors overflow-hidden">
          <button type="button" aria-label="Decrease square footage" class="stepper-minus px-4 text-text-primary hover:text-accent text-2xl font-bold leading-none select-none">−</button>
          <input type="number" id="sqft" value="2000" min="200" max="20000" step="50"
            class="flex-1 bg-transparent text-text-primary text-lg text-center focus:outline-none min-w-0 py-3 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
          <button type="button" aria-label="Increase square footage" class="stepper-plus px-4 text-text-primary hover:text-accent text-2xl font-bold leading-none select-none">+</button>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-primary mb-2" for="ceiling">Ceiling Height (ft)</label>
        <div class="relative">
          <select id="ceiling"
            class="appearance-none w-full bg-bg-dark border border-border rounded-lg px-4 pr-10 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="7">7 ft</option>
            <option value="8" selected>8 ft</option>
            <option value="9">9 ft</option>
            <option value="10">10 ft</option>
            <option value="11">11 ft</option>
            <option value="12">12 ft</option>
            <option value="13">13 ft</option>
            <option value="14">14 ft</option>
            <option value="15">15 ft</option>
            <option value="16">16 ft</option>
            <option value="17">17 ft</option>
            <option value="18">18 ft</option>
            <option value="19">19 ft</option>
            <option value="20">20 ft</option>
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-primary"
            fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>
      <div>
        <div class="flex items-center gap-1.5 mb-2">
          <label class="block text-sm font-medium text-text-primary" for="insulation">Insulation Quality</label>
          <button type="button"
            data-help-toggle="insulation-help"
            aria-expanded="false"
            aria-controls="insulation-help"
            aria-label="How to pick insulation quality"
            class="text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
        </div>
        <div class="relative">
          <select id="insulation" class="appearance-none w-full bg-bg-dark border border-border rounded-lg px-4 pr-10 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="excellent">Excellent</option>
            <option value="better">Better than average</option>
            <option value="average" selected>Average</option>
            <option value="worse">Worse than average</option>
            <option value="bad">Bad</option>
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-primary"
            fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
        <div id="insulation-help" class="hidden relative mt-2 rounded-lg border border-border bg-bg-dark/60 p-3 pr-8 text-xs text-text-primary leading-relaxed">
          <button type="button" data-help-toggle="insulation-help" aria-expanded="false" aria-controls="insulation-help" aria-label="Close help"
            class="absolute top-2 right-2 text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <ul class="space-y-0.5">
            <li><strong>Excellent</strong> — post-2018 code or deep retrofit. R-19+ walls, R-38+ attic, spray foam.</li>
            <li><strong>Better than average</strong> — 2010-era. R-15 walls, R-30 attic, double-pane low-E windows.</li>
            <li><strong>Average</strong> — standard-code compliant. R-13 walls, R-30 attic, double-pane windows.</li>
            <li><strong>Worse than average</strong> — pre-1990 unimproved. R-11 or less, single-pane windows, visibly drafty.</li>
            <li><strong>Bad</strong> — no wall insulation. Pre-1950 construction; cold spots, daylight around outlets.</li>
          </ul>
        </div>
      </div>
      <div>
        <div class="flex items-center gap-1.5 mb-2">
          <label class="block text-sm font-medium text-text-primary" for="sun">Sun Exposure</label>
          <button type="button"
            data-help-toggle="sun-help"
            aria-expanded="false"
            aria-controls="sun-help"
            aria-label="How to pick sun exposure"
            class="text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
        </div>
        <div class="relative">
          <select id="sun" class="appearance-none w-full bg-bg-dark border border-border rounded-lg px-4 pr-10 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="lots">A large amount</option>
            <option value="medium" selected>A medium amount</option>
            <option value="little">Little or none</option>
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-primary"
            fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
        <div id="sun-help" class="hidden relative mt-2 rounded-lg border border-border bg-bg-dark/60 p-3 pr-8 text-xs text-text-primary leading-relaxed">
          <button type="button" data-help-toggle="sun-help" aria-expanded="false" aria-controls="sun-help" aria-label="Close help"
            class="absolute top-2 right-2 text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <ul class="space-y-0.5">
            <li><strong>A large amount</strong> — mostly south/west-facing with few trees or shade.</li>
            <li><strong>A medium amount</strong> — mix of sun and shade across the day.</li>
            <li><strong>Little or none</strong> — north-facing or heavily shaded by trees or neighbors.</li>
          </ul>
        </div>
      </div>
      <div>
        <div class="flex items-center gap-1.5 mb-2">
          <label class="block text-sm font-medium text-text-primary" for="windows">Amount of Windows</label>
          <button type="button"
            data-help-toggle="windows-help"
            aria-expanded="false"
            aria-controls="windows-help"
            aria-label="What counts as standard vs many windows"
            class="text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
        </div>
        <div class="relative">
          <select id="windows" class="appearance-none w-full bg-bg-dark border border-border rounded-lg px-4 pr-10 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="standard" selected>Standard amount</option>
            <option value="many">Many (more than standard)</option>
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-primary"
            fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
        <div id="windows-help" class="hidden relative mt-2 rounded-lg border border-border bg-bg-dark/60 p-3 pr-8 text-xs text-text-primary leading-relaxed">
          <button type="button" data-help-toggle="windows-help" aria-expanded="false" aria-controls="windows-help" aria-label="Close help"
            class="absolute top-2 right-2 text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <ul class="space-y-0.5">
            <li><strong>Standard</strong> — typical residential. Glass is ~15-20% of floor area.</li>
            <li><strong>Many</strong> — large glass expanses, walls of windows, multiple skylights, sunroom-style spaces. More than 25% of floor area in glass.</li>
          </ul>
        </div>
      </div>
      <div>
        <div class="flex items-center gap-1.5 mb-2">
          <label class="block text-sm font-medium text-text-primary" for="tightness">Windows &amp; Doors Tightness</label>
          <button type="button"
            data-help-toggle="tightness-help"
            aria-expanded="false"
            aria-controls="tightness-help"
            aria-label="How to pick tightness"
            class="text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
        </div>
        <div class="relative">
          <select id="tightness" class="appearance-none w-full bg-bg-dark border border-border rounded-lg px-4 pr-10 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="sealed">Sealed tight &amp; double-paned</option>
            <option value="typical" selected>Typical fit and seal</option>
            <option value="leaky">Not well-sealed &amp; single-paned</option>
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-primary"
            fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
        <div id="tightness-help" class="hidden relative mt-2 rounded-lg border border-border bg-bg-dark/60 p-3 pr-8 text-xs text-text-primary leading-relaxed">
          <button type="button" data-help-toggle="tightness-help" aria-expanded="false" aria-controls="tightness-help" aria-label="Close help"
            class="absolute top-2 right-2 text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <ul class="space-y-0.5">
            <li><strong>Sealed tight &amp; double-paned</strong> — modern double-pane with weatherstripping. Newer construction or recent retrofit.</li>
            <li><strong>Typical fit and seal</strong> — average 2000s-era double-pane, some minor drafts.</li>
            <li><strong>Not well-sealed &amp; single-paned</strong> — old single-pane, visible drafts, weatherstripping gone.</li>
          </ul>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-primary mb-2" for="occupants">Occupants</label>
        <div class="relative">
          <select id="occupants" class="appearance-none w-full bg-bg-dark border border-border rounded-lg px-4 pr-10 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="2" selected>2 or less</option>
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5">5</option>
            <option value="6">6</option>
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-primary"
            fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>
      <div>
        <div class="flex items-center gap-1.5 mb-2">
          <label class="block text-sm font-medium text-text-primary" for="devices">Extra Devices (heat-generating)</label>
          <button type="button"
            data-help-toggle="devices-help"
            aria-expanded="false"
            aria-controls="devices-help"
            aria-label="What counts as a heat-generating device"
            class="text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
        </div>
        <div class="relative">
          <select id="devices" class="appearance-none w-full bg-bg-dark border border-border rounded-lg px-4 pr-10 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="0" selected>0</option>
            <option value="600">1</option>
            <option value="1200">2</option>
            <option value="1800">3</option>
            <option value="2400">4</option>
            <option value="3000">5</option>
            <option value="3600">6</option>
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-primary"
            fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
        <div id="devices-help" class="hidden relative mt-2 rounded-lg border border-border bg-bg-dark/60 p-3 pr-8 text-xs text-text-primary leading-relaxed">
          <button type="button" data-help-toggle="devices-help" aria-expanded="false" aria-controls="devices-help" aria-label="Close help"
            class="absolute top-2 right-2 text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <p class="mb-1">Count: TVs, desktop computers, servers, halogen lighting. Each adds ~600 BTU/h.</p>
          <p><strong>Skip:</strong> modern LED lighting, phone chargers, anything in standby. Baseline is 0; most homes don't need more than 2-3.</p>
        </div>
      </div>
      <div>
        <div class="flex items-center gap-1.5 mb-2">
          <label class="block text-sm font-medium text-text-primary" for="kitchen">Kitchen?</label>
          <button type="button"
            data-help-toggle="kitchen-help"
            aria-expanded="false"
            aria-controls="kitchen-help"
            aria-label="When to pick yes or no for kitchen"
            class="text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
        </div>
        <div class="relative">
          <select id="kitchen" class="appearance-none w-full bg-bg-dark border border-border rounded-lg px-4 pr-10 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="yes" selected>Yes</option>
            <option value="no">No</option>
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-primary"
            fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
        <div id="kitchen-help" class="hidden relative mt-2 rounded-lg border border-border bg-bg-dark/60 p-3 pr-8 text-xs text-text-primary leading-relaxed">
          <button type="button" data-help-toggle="kitchen-help" aria-expanded="false" aria-controls="kitchen-help" aria-label="Close help"
            class="absolute top-2 right-2 text-text-primary hover:text-accent transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <p><strong>Yes</strong> if the space includes a kitchen — adds ~4,000 BTU for cooking + appliances. <strong>No</strong> for kitchen-less spaces (in-law suites, basement conversions without cooking) or when you're accounting for kitchen load elsewhere.</p>
        </div>
      </div>
    </div>

    <div id="calc-btn-area" class="mt-2">
      <button id="calculate-btn" type="button"
        class="w-full bg-accent hover:bg-accent-hover text-white font-heading font-bold text-lg px-8 py-4 rounded-xl transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
        Calculate My Load
      </button>
      <p id="calc-hint" class="hidden mt-3 text-sm text-[#EF4444]"></p>
    </div>

    <!-- Segment gate: shown after Calculate, before the email gate.
         Pro vs homeowner split, feeds analytics + downstream routing. -->
    <div id="segment-gate" class="hidden mt-8">
      <!-- Accent-framed container so the segment step clearly reads as
           the next action. Matches the Calculate CTA's orange without
           competing — subtle bg tint + 2px accent border. -->
      <div class="max-w-lg mx-auto rounded-2xl border-2 border-accent bg-accent/5 p-6 sm:p-8 text-center">
        <h3 class="font-heading font-bold text-xl text-text-primary mb-6">Who's this for?</h3>
        <div class="flex flex-col sm:flex-row gap-3">
          <button type="button" data-segment="home"
            class="segment-pill flex-1 bg-bg-dark border border-border rounded-lg px-4 py-4 text-text-primary text-base hover:border-accent transition-colors">
            My own home
          </button>
          <button type="button" data-segment="customer"
            class="segment-pill flex-1 bg-bg-dark border border-border rounded-lg px-4 py-4 text-text-primary text-base hover:border-accent transition-colors">
            A customer's job
          </button>
        </div>
      </div>
    </div>

    <!-- Q2: DIY check. Shown only for segment=home. Pro path skips this. -->
    <div id="diy-gate" class="hidden mt-8">
      <div class="max-w-lg mx-auto rounded-2xl border-2 border-accent bg-accent/5 p-6 sm:p-8 text-center">
        <h3 class="font-heading font-bold text-xl text-text-primary mb-2">Is this a DIY project?</h3>
        <p class="text-text-primary text-sm mb-6">We'll tailor your results to match.</p>
        <div class="flex flex-col sm:flex-row gap-3">
          <button type="button" data-diy="yes"
            class="diy-pill flex-1 bg-bg-dark border border-border rounded-lg px-4 py-4 text-text-primary text-base hover:border-accent transition-colors">
            Yes — I'm installing it myself
          </button>
          <button type="button" data-diy="no"
            class="diy-pill flex-1 bg-bg-dark border border-border rounded-lg px-4 py-4 text-text-primary text-base hover:border-accent transition-colors">
            No — I'm hiring a pro
          </button>
        </div>
      </div>
    </div>

    <!-- Q3: Contractor stage. Shown only after diy=no. -->
    <div id="contractor-gate" class="hidden mt-8">
      <div class="max-w-lg mx-auto rounded-2xl border-2 border-accent bg-accent/5 p-6 sm:p-8 text-center">
        <h3 class="font-heading font-bold text-xl text-text-primary mb-2">Have you talked to an HVAC contractor yet?</h3>
        <p class="text-text-primary text-sm mb-6">Helps us point you in the right direction.</p>
        <div class="flex flex-col gap-3">
          <button type="button" data-stage="not_yet"
            class="contractor-pill bg-bg-dark border border-border rounded-lg px-4 py-4 text-text-primary text-base hover:border-accent transition-colors">
            Not yet — I'm starting now
          </button>
          <button type="button" data-stage="has_estimates"
            class="contractor-pill bg-bg-dark border border-border rounded-lg px-4 py-4 text-text-primary text-base hover:border-accent transition-colors">
            Yes — I already have estimates
          </button>
          <button type="button" data-stage="researching"
            class="contractor-pill bg-bg-dark border border-border rounded-lg px-4 py-4 text-text-primary text-base hover:border-accent transition-colors">
            Just researching — not ready to hire
          </button>
        </div>
      </div>
    </div>

    <div id="email-gate" class="hidden mt-8">
      <!-- Accent-framed container matching the segment gate + results
           sections — this is the primary next action. -->
      <div class="max-w-lg mx-auto rounded-2xl border-2 border-accent bg-accent/5 p-6 sm:p-8 text-center">
        <div class="w-14 h-14 rounded-2xl bg-accent/15 flex items-center justify-center mx-auto mb-4">
          <svg width="28" height="28" viewBox="0 0 20 20" fill="none" class="text-accent">
            <path d="M2.5 6.667L9.025 11.05a1.667 1.667 0 001.95 0L17.5 6.667M4.167 15h11.666A1.667 1.667 0 0017.5 13.333V6.667A1.667 1.667 0 0015.833 5H4.167A1.667 1.667 0 002.5 6.667v6.666A1.667 1.667 0 004.167 15z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 id="gate-headline" class="font-heading font-bold text-xl text-text-primary mb-2">Your results are ready</h3>
        <p id="gate-subhead" class="text-text-primary text-sm mb-6">Enter your email to get your whole-house load calculation — cooling BTU, heating BTU, and system tonnage.</p>
        <div class="flex flex-col sm:flex-row gap-3 mb-3">
          <label for="gate-email" class="sr-only">Your work email</label>
          <input type="email" id="gate-email" placeholder="your email" required
            class="flex-1 bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-base focus:border-accent focus:outline-none transition-colors placeholder:text-text-primary" />
          <button id="gate-submit" type="button"
            class="bg-accent hover:bg-accent-hover text-white font-semibold px-6 py-3 rounded-lg transition-colors whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed">
            Send My Results
          </button>
        </div>
        <p class="text-text-muted text-xs mt-3">We'll also send occasional HVAC tips. Unsubscribe any time.</p>
        <div id="gate-error" class="hidden mt-3 text-sm text-[#EF4444]"></div>
      </div>
    </div>

    <div id="results" class="hidden mt-8">
      <!-- Accent-framed container so the results card reads as the
           answer the user came for. -->
      <div class="rounded-2xl border-2 border-accent bg-accent/5 p-6 sm:p-8">
      <div class="mb-6 bg-[rgba(52,211,153,0.08)] border border-[rgba(52,211,153,0.25)] rounded-xl p-4 flex items-start gap-3">
        <div class="shrink-0 w-8 h-8 rounded-full bg-[rgba(52,211,153,0.15)] flex items-center justify-center">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" class="text-[#34D399]">
            <path d="M16.667 5L7.5 14.167 3.333 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <p class="text-text-primary font-semibold text-sm">Results also sent to your inbox</p>
          <p class="text-text-primary text-xs mt-0.5">Don't see it? Check your Spam or Promotions folder.</p>
        </div>
      </div>

      <h3 class="font-heading font-bold text-xl mb-6">Your Load Calculation</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-primary text-xs font-medium uppercase tracking-wider mb-2">Cooling Load</div>
          <div id="r-cool" class="font-heading font-extrabold text-2xl text-accent">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-primary text-xs font-medium uppercase tracking-wider mb-2">Heating Load</div>
          <div id="r-heat" class="font-heading font-extrabold text-2xl text-text-primary">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-primary text-xs font-medium uppercase tracking-wider mb-2">System Tonnage</div>
          <div id="r-tons" class="font-heading font-extrabold text-2xl text-text-primary">—</div>
        </div>
      </div>
      <p class="text-text-primary text-sm italic">Estimate only. For permit-ready Manual J, use ACCA-accredited software.</p>
      </div> <!-- end accent-framed results card -->
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-primary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter a ZIP code.</strong> Auto-detects the climate region — a major factor in both cooling and heating load.</p>
          <p><strong class="text-text-primary">2. Add square footage and ceiling height.</strong> Total conditioned living space only. Exclude unfinished basements, garages, and unconditioned attics.</p>
          <p><strong class="text-text-primary">3. Rate insulation and window/door tightness.</strong> A 1980s retrofit with single-pane windows is "Bad" / "Not well-sealed." A 2020s tight envelope is "Excellent" / "Sealed tight."</p>
          <p><strong class="text-text-primary">4. Set sun, window count, and internal gains.</strong> South/west-facing homes with lots of glass take heavy cooling load. Each extra occupant adds ~600 BTU. Devices × 3.412 = BTU.</p>
          <p><strong class="text-text-primary">5. Click Calculate.</strong> Enter your email. We'll send the full results so you can reference them on-site or attach to a quote.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How the Calculation Works</h2>
        <div class="text-text-primary leading-relaxed space-y-3">
          <p>We use a 20 BTU/sqft baseline with six adjustment factors (climate, insulation, sun, windows, tightness, ceiling height), then add internal gains for occupants, devices, and kitchen equipment.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm overflow-x-auto">
            <p>base = sqft × 20 × (ceiling / 8)</p>
            <p class="mt-2">modSum = climate + insulation + sun + windows + tightness</p>
            <p class="mt-2">coolingBTU = base × (1 + modSum) + occupants + devices + kitchen</p>
            <p class="mt-2">heatingBTU = coolingBTU × heatingFactor(region)</p>
            <p class="mt-2">tonnage = round(coolingBTU / 12,000, 0.5)</p>
          </div>
          <p>Climate regions range from +10% (Hot) to -10% (Cold). Heating factor ranges from 0.70 (Hot) to 1.45 (Cold) — so a home in Minneapolis will have a heating load roughly 1.5× the cooling load, while a home in Phoenix will have heating at ~70% of cooling.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When You Need a Full Manual J</h2>
        <div class="text-text-primary leading-relaxed space-y-3">
          <p>This tool is a pre-quote sanity check. Accurate enough to keep you from badly oversizing or undersizing a system in a sales conversation, and to back up a quote with a defensible number.</p>
          <p>You need a full ACCA Manual J when:</p>
          <ul class="list-disc list-inside space-y-1 ml-2">
            <li>The job requires a permit (most new construction, many major replacements)</li>
            <li>The homeowner is pursuing ENERGY STAR certification or rebate programs</li>
            <li>A HERS rater or building department is involved</li>
            <li>Equipment warranties require a Manual J for the full capacity</li>
          </ul>
          <p>For those cases, use ACCA-accredited Manual J software — free options exist alongside the paid industry standards.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Is this a Manual J calculation?</summary>
            <div class="px-5 pb-4 text-text-primary text-sm leading-relaxed">No. This is a simplified whole-house estimator for pre-quote sanity checks — not permit-ready. For ACCA-approved Manual J, use ACCA-accredited software.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How accurate is this compared to a full load calc?</summary>
            <div class="px-5 pb-4 text-text-primary text-sm leading-relaxed">Within 15-20% of a proper Manual J. Doesn't capture exact R-values, window SHGC, duct losses, infiltration, or per-wall window orientation. Fine for sanity checks. Not fine for permits.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why does the ZIP matter so much?</summary>
            <div class="px-5 pb-4 text-text-primary text-sm leading-relaxed">Climate dominates HVAC sizing. A 2,000 sqft home in Phoenix needs roughly 40% more cooling than the same home in Seattle. ZIP → one of five regions (Hot / Warm / Mixed / Cool / Cold) with its own multipliers.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Does this work for mini-splits?</summary>
            <div class="px-5 pb-4 text-text-primary text-sm leading-relaxed">This is whole-house. For sizing an individual mini-split in a specific room, use our <a href="/hvac/mini-split-sizing-calculator/" class="text-accent hover:underline">Mini-Split Sizing Calculator</a>.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why is heating BTU different from cooling BTU?</summary>
            <div class="px-5 pb-4 text-text-primary text-sm leading-relaxed">Different design conditions. In hot climates, cooling dominates. In cold climates, heating dominates. Heat pump sizing especially requires knowing which load is bigger — you size for the bigger of the two.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  import { lookupZip, lookupRegion, REGIONS } from '../../lib/climate';
  import type { Region } from '../../lib/climate';
  import { calcWholeHouse } from '../../lib/hvac-calc';
  import type {
    WholeHouseInputs, InsulationGrade, SunExposure, WindowAmount, Tightness,
    WholeHouseResult,
  } from '../../lib/hvac-calc';
  import { initSteppers } from '../../lib/stepper';

  // Wire up +/- buttons on numeric inputs (mobile-friendly)
  initSteppers();

  // -------------------------------------------------------------------
  // A/B/C test on the email-gate copy. Experiment: lc_gate_copy.
  // Sticky per user via localStorage; random assignment fallback if
  // localStorage is blocked. Fires ab_variant_assigned once on first
  // assignment, then gate_shown + email_captured carry ab_variant as
  // a property for analysis. Mirrors mss_gate_copy on the mini-split
  // page — see §5 of mini-split-sizing-calculator.md for methodology.
  // -------------------------------------------------------------------
  const AB_EXPERIMENT = 'lc_gate_copy';
  const VARIANT_COPY: Record<'A' | 'B' | 'C', { headline: string; subhead: string; cta: string }> = {
    A: {
      headline: 'Your load calculation is ready.',
      subhead: 'Email yourself the full calc — cooling BTU, heating BTU, and system tonnage.',
      cta: 'Email Me the Calc',
    },
    B: {
      headline: 'Where should we send your results?',
      subhead: "We'll email the full breakdown — cooling BTU, heating BTU, and system tonnage.",
      cta: 'Email My Results',
    },
    C: {
      headline: 'One email — so you have it saved.',
      subhead: "We'll email the full breakdown — cooling BTU, heating BTU, and system tonnage.",
      cta: 'Send My Results',
    },
  };
  let abVariant: 'A' | 'B' | 'C';
  try {
    const stored = localStorage.getItem('ntq_ab_lc_gate');
    if (stored === 'A' || stored === 'B' || stored === 'C') {
      abVariant = stored;
    } else {
      const r = Math.random();
      abVariant = r < 1 / 3 ? 'A' : r < 2 / 3 ? 'B' : 'C';
      localStorage.setItem('ntq_ab_lc_gate', abVariant);
      (window as any).posthog?.capture('ab_variant_assigned', {
        experiment: AB_EXPERIMENT,
        ab_variant: abVariant,
        tool_slug: 'load-calculator',
      });
    }
  } catch {
    const r = Math.random();
    abVariant = r < 1 / 3 ? 'A' : r < 2 / 3 ? 'B' : 'C';
  }
  // Apply variant copy to the gate (gate is hidden until Calculate — no FOUC)
  {
    const copy = VARIANT_COPY[abVariant];
    document.getElementById('gate-headline')!.textContent = copy.headline;
    document.getElementById('gate-subhead')!.textContent = copy.subhead;
    document.getElementById('gate-submit')!.textContent = copy.cta;
  }

  // -------------------------------------------------------------------
  // Generic help-toggle handler: any <button data-help-toggle="id">
  // toggles the hidden <div id="id"> panel. Fires help_opened on open
  // (not close). data-help-wired guard prevents double-binding if the
  // script re-executes. Same pattern as the mini-split page.
  // -------------------------------------------------------------------
  document.querySelectorAll<HTMLButtonElement>('[data-help-toggle]').forEach(btn => {
    if (btn.dataset.helpWired) return;
    btn.dataset.helpWired = '1';
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.helpToggle;
      if (!targetId) return;
      const target = document.getElementById(targetId);
      if (!target) return;
      const willBeOpen = target.classList.contains('hidden');
      target.classList.toggle('hidden');
      document.querySelectorAll<HTMLButtonElement>(`[data-help-toggle="${targetId}"]`).forEach(b => {
        b.setAttribute('aria-expanded', String(willBeOpen));
      });
      if (willBeOpen) {
        (window as any).posthog?.capture('help_opened', {
          tool_slug: 'load-calculator',
          trade_slug: 'hvac',
          field: targetId.replace(/-help$/, ''),
        });
      }
    });
  });

  let climate: ReturnType<typeof lookupZip> = null;
  const zipInput = document.getElementById('zip') as HTMLInputElement;
  const zipDisplay = document.getElementById('zip-display')!;
  const zipFallback = document.getElementById('zip-fallback')!;

  // ZIP card rendering + enrichment --------------------------------------
  // Sync path uses lookupZip for the climate region (drives the calc).
  // Async path hits /api/zip-lookup to enrich the card with city name,
  // IECC zone, and design temps — display only, never affects calculation.
  type ZipCardState = {
    kind: 'empty' | 'partial' | 'unrecognized' | 'manual';
  } | {
    kind: 'resolved';
    zip: string;
    city: string | null;
    state: string;
    regionLabel: string;
    ieccZone?: string;
    designCoolingDB?: number;
    designHeatingDB?: number;
  };

  function escapeHtml(s: string): string {
    return String(s).replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    } as Record<string, string>)[c]);
  }

  function renderZipCard(s: ZipCardState) {
    if (s.kind === 'empty') {
      zipDisplay.innerHTML = '';
      return;
    }
    if (s.kind === 'partial') {
      zipDisplay.innerHTML = '<span class="text-text-primary text-sm">Keep typing — 5 digits total.</span>';
      return;
    }
    if (s.kind === 'unrecognized') {
      zipDisplay.innerHTML = '<span class="text-text-primary text-sm">ZIP not recognized.</span>';
      return;
    }
    if (s.kind === 'manual') {
      // Set by the region-pill handler below with its own markup.
      return;
    }
    // resolved
    const place = s.city ? `${escapeHtml(s.city)}, ${escapeHtml(s.state)}` : escapeHtml(s.state);
    const iecc = s.ieccZone ? ` <span class="text-text-primary">(IECC ${escapeHtml(s.ieccZone)})</span>` : '';
    const designLine = (s.designCoolingDB != null && s.designHeatingDB != null)
      ? `<div class="text-sm text-text-primary mt-0.5">Design temp: ${s.designCoolingDB}°F cooling / ${s.designHeatingDB}°F heating</div>`
      : '';
    zipDisplay.innerHTML = `
      <div class="rounded-lg border border-border bg-bg-dark/60 p-4">
        <div class="flex items-center gap-2 text-text-primary font-medium">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>${place} · ${escapeHtml(s.zip)}</span>
        </div>
        <div class="mt-1 text-sm text-text-primary">Climate: <span class="text-accent font-medium">${escapeHtml(s.regionLabel)}</span>${iecc}</div>
        ${designLine}
      </div>`;
  }

  let zipLookupAbort: AbortController | null = null;
  let zipLookupTimer: number | null = null;

  function setClimateFromZip(raw: string) {
    const zip = raw.replace(/\D/g, '').slice(0, 5);

    if (zipLookupAbort) { zipLookupAbort.abort(); zipLookupAbort = null; }
    if (zipLookupTimer !== null) { window.clearTimeout(zipLookupTimer); zipLookupTimer = null; }

    if (zip.length === 0) {
      climate = null;
      renderZipCard({ kind: 'empty' });
      zipFallback.classList.add('hidden');
      return;
    }
    if (zip.length < 5) {
      climate = null;
      renderZipCard({ kind: 'partial' });
      zipFallback.classList.add('hidden');
      return;
    }

    // 5 digits entered — sync lookup drives the calculation
    const lookup = lookupZip(zip);
    if (!lookup) {
      climate = null;
      renderZipCard({ kind: 'unrecognized' });
      zipFallback.classList.remove('hidden');
      return;
    }
    climate = lookup;
    zipFallback.classList.add('hidden');

    // Render what we know synchronously (no city, no IECC yet)
    renderZipCard({
      kind: 'resolved',
      zip,
      city: null,
      state: lookup.state,
      regionLabel: lookup.regionLabel,
    });

    // Debounced async enrichment via /api/zip-lookup
    zipLookupTimer = window.setTimeout(() => {
      zipLookupAbort = new AbortController();
      fetch(`/api/zip-lookup?zip=${zip}`, { signal: zipLookupAbort.signal })
        .then((r) => (r.ok ? r.json() : null))
        .then((data: any) => {
          if (!data || data.error) return;
          renderZipCard({
            kind: 'resolved',
            zip: data.zip,
            city: data.city ?? null,
            state: data.state,
            regionLabel: data.regionLabel,
            ieccZone: data.ieccZone,
            designCoolingDB: data.designCoolingDB,
            designHeatingDB: data.designHeatingDB,
          });
          (window as any).posthog?.capture('zip_resolved', {
            tool_slug: 'load-calculator',
            trade_slug: 'hvac',
            zip: data.zip,
            city: data.city,
            state: data.state,
            climate_region: data.region,
            iecc_zone: data.ieccZone,
          });
        })
        .catch(() => { /* aborted / network — sync card still visible */ });
    }, 250) as unknown as number;
  }
  zipInput.addEventListener('input', () => setClimateFromZip(zipInput.value));

  document.querySelectorAll<HTMLButtonElement>('.region-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      const region = btn.dataset.region as Region;
      climate = lookupRegion(region, zipInput.value, '');
      const meta = REGIONS[region];
      zipDisplay.innerHTML = `
        <div class="rounded-lg border border-border bg-bg-dark/60 p-4">
          <div class="text-text-primary font-medium">Manual region selection</div>
          <div class="mt-1 text-sm text-text-primary">Climate: <span class="text-accent font-medium">${escapeHtml(meta.label)}</span> <span class="text-text-primary">(ZIP not in our database)</span></div>
        </div>`;
      zipFallback.classList.add('hidden');
      document.querySelectorAll<HTMLButtonElement>('.region-pill').forEach(b => b.classList.remove('border-accent'));
      btn.classList.add('border-accent');
    });
  });

  let pendingResult: WholeHouseResult | null = null;
  let pendingInputs: WholeHouseInputs | null = null;
  // User self-identified segment: 'home' (homeowner) vs 'customer' (pro
  // sizing for a client). Captured between Calculate and the email gate.
  let segment: 'home' | 'customer' | null = null;
  // Home-path qualifying answers. Null for pro path (segment=customer).
  let isDiy: boolean | null = null;
  let contractorStage: 'not_yet' | 'has_estimates' | 'researching' | null = null;
  const calcBtn = document.getElementById('calculate-btn') as HTMLButtonElement;
  const calcHint = document.getElementById('calc-hint')!;

  function readInputs(): WholeHouseInputs | null {
    if (!climate) {
      calcHint.textContent = 'Please enter a valid ZIP code.';
      calcHint.classList.remove('hidden');
      return null;
    }
    calcHint.classList.add('hidden');
    return {
      climate,
      sqft: parseFloat((document.getElementById('sqft') as HTMLInputElement).value) || 2000,
      ceilingHeight: parseFloat((document.getElementById('ceiling') as HTMLSelectElement).value) || 8,
      insulation: (document.getElementById('insulation') as HTMLSelectElement).value as InsulationGrade,
      sun: (document.getElementById('sun') as HTMLSelectElement).value as SunExposure,
      windows: (document.getElementById('windows') as HTMLSelectElement).value as WindowAmount,
      tightness: (document.getElementById('tightness') as HTMLSelectElement).value as Tightness,
      occupants: parseInt((document.getElementById('occupants') as HTMLSelectElement).value) || 2,
      deviceWatts: parseInt((document.getElementById('devices') as HTMLSelectElement).value) || 0,
      kitchen: (document.getElementById('kitchen') as HTMLSelectElement).value === 'yes',
    };
  }

  calcBtn.addEventListener('click', () => {
    const inputs = readInputs();
    if (!inputs) return;
    pendingInputs = inputs;
    pendingResult = calcWholeHouse(inputs);
    segment = null;
    isDiy = null;
    contractorStage = null;
    document.getElementById('calc-btn-area')!.classList.add('hidden');
    document.getElementById('segment-gate')!.classList.remove('hidden');
    document.getElementById('diy-gate')!.classList.add('hidden');
    document.getElementById('contractor-gate')!.classList.add('hidden');
    (window as any).posthog?.capture('segment_shown', {
      tool_slug: 'load-calculator',
      trade_slug: 'hvac',
    });
  });

  // Centralize email-gate reveal. Called from three places:
  // 1. segment=customer (direct — pro path skips Q2/Q3)
  // 2. segment=home + diy=yes (skip Q3)
  // 3. segment=home + diy=no + any contractor_stage
  function openEmailGate() {
    document.getElementById('segment-gate')!.classList.add('hidden');
    document.getElementById('diy-gate')!.classList.add('hidden');
    document.getElementById('contractor-gate')!.classList.add('hidden');
    document.getElementById('email-gate')!.classList.remove('hidden');
    (document.getElementById('gate-email') as HTMLInputElement).focus();

    // A/B/C gate_shown — denominator for email-rate conversion.
    // Now carries qualifying answers for segmented analysis.
    (window as any).posthog?.capture('gate_shown', {
      experiment: AB_EXPERIMENT,
      ab_variant: abVariant,
      tool_slug: 'load-calculator',
      segment,
      is_diy: isDiy,
      contractor_stage: contractorStage,
    });
  }

  // Segment pill pick → home advances to Q2, pro goes straight to gate.
  document.querySelectorAll<HTMLButtonElement>('.segment-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      segment = (btn.dataset.segment || 'home') as 'home' | 'customer';

      (window as any).posthog?.capture('segment_picked', {
        tool_slug: 'load-calculator',
        trade_slug: 'hvac',
        segment,
      });

      if (segment === 'home') {
        // Home path → advance to Q2 (DIY check), NOT the email gate.
        document.getElementById('segment-gate')!.classList.add('hidden');
        document.getElementById('diy-gate')!.classList.remove('hidden');
        (window as any).posthog?.capture('diy_shown', {
          tool_slug: 'load-calculator',
          trade_slug: 'hvac',
        });
      } else {
        // Pro path → straight to email gate.
        openEmailGate();
      }
    });
  });

  // Q2: DIY check. Yes → skip Q3, open email gate. No → show Q3.
  document.querySelectorAll<HTMLButtonElement>('.diy-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      isDiy = btn.dataset.diy === 'yes';

      (window as any).posthog?.capture('diy_picked', {
        tool_slug: 'load-calculator',
        trade_slug: 'hvac',
        is_diy: isDiy,
      });

      if (isDiy) {
        openEmailGate();
      } else {
        document.getElementById('diy-gate')!.classList.add('hidden');
        document.getElementById('contractor-gate')!.classList.remove('hidden');
        (window as any).posthog?.capture('contractor_shown', {
          tool_slug: 'load-calculator',
          trade_slug: 'hvac',
        });
      }
    });
  });

  // Q3: Contractor stage. All three answers open the email gate.
  document.querySelectorAll<HTMLButtonElement>('.contractor-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      contractorStage = (btn.dataset.stage || null) as typeof contractorStage;

      (window as any).posthog?.capture('contractor_picked', {
        tool_slug: 'load-calculator',
        trade_slug: 'hvac',
        contractor_stage: contractorStage,
      });

      openEmailGate();
    });
  });

  const gateSubmit = document.getElementById('gate-submit') as HTMLButtonElement;
  const gateEmail = document.getElementById('gate-email') as HTMLInputElement;
  const gateError = document.getElementById('gate-error')!;

  function showResults(r: WholeHouseResult) {
    document.getElementById('r-cool')!.textContent = r.coolingBTU.toLocaleString() + ' BTU';
    document.getElementById('r-heat')!.textContent = r.heatingBTU.toLocaleString() + ' BTU';
    document.getElementById('r-tons')!.textContent = r.tonnage + ' ton';
    document.getElementById('results')!.classList.remove('hidden');
    document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  gateSubmit.addEventListener('click', async () => {
    const email = gateEmail.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      gateError.textContent = 'Please enter a valid email address.';
      gateError.classList.remove('hidden');
      return;
    }
    if (!pendingResult || !pendingInputs) return;
    gateError.classList.add('hidden');
    gateSubmit.disabled = true;
    gateSubmit.textContent = 'Sending...';

    try {
      const attrib = (window as any).__ntqAttribution || {};
      const res = await fetch('/api/email-capture', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          toolSlug: 'load-calculator',
          toolName: 'HVAC Load Calculator',
          tradeSlug: 'hvac',
          tradeName: 'HVAC',
          marketingConsent: true,
          sourceUrl: window.location.pathname,
          segment,          // 'home' | 'customer' — captured on the segment gate
          isDiy,            // true | false | null (null for pro path)
          contractorStage,  // 'not_yet' | 'has_estimates' | 'researching' | null
          abVariant,        // 'A' | 'B' | 'C' — email-gate copy experiment arm
          attribution: {
            gclid: attrib.gclid,
            utm_source: attrib.utm_source,
            utm_medium: attrib.utm_medium,
            utm_campaign: attrib.utm_campaign,
            utm_term: attrib.utm_term,
            utm_content: attrib.utm_content,
            landing_url: attrib.landing_url,
            referrer: attrib.referrer,
          },
          calculationResults: {
            mode: 'whole-house',
            // Results
            coolingBTU: pendingResult.coolingBTU,
            heatingBTU: pendingResult.heatingBTU,
            tonnage: pendingResult.tonnage,
            // Climate context
            zip: (document.getElementById('zip') as HTMLInputElement).value.trim(),
            state: pendingInputs.climate.state,
            region: pendingInputs.climate.regionLabel,
            // All raw inputs so the admin view can inspect what pros submitted
            sqft: pendingInputs.sqft,
            ceilingHeight: pendingInputs.ceilingHeight,
            insulation: pendingInputs.insulation,
            sun: pendingInputs.sun,
            windows: pendingInputs.windows,
            tightness: pendingInputs.tightness,
            occupants: pendingInputs.occupants,
            deviceWatts: pendingInputs.deviceWatts,
            kitchen: pendingInputs.kitchen,
          },
        }),
      });
      if (!res.ok) throw new Error('Failed to send');

      document.getElementById('email-gate')!.classList.add('hidden');
      showResults(pendingResult);

      const meta = (window as any).__ntqToolMeta;
      if ((window as any).posthog && meta) {
        (window as any).posthog.capture('email_captured', {
          tool_slug: meta.toolSlug,
          trade_slug: meta.tradeSlug,
          trade_name: meta.tradeName,
          tool_name: meta.toolName,
          tool_category: meta.category,
          marketing_consent: true,
          gated: true,
          mode: 'whole-house',
          segment,              // 'home' | 'customer'
          is_diy: isDiy,
          contractor_stage: contractorStage,
          // A/B/C tagging — pairs with gate_shown for per-arm conversion
          experiment: AB_EXPERIMENT,
          ab_variant: abVariant,
        });
      }
      if (typeof (window as any).gtag === 'function') {
        (window as any).gtag('event', 'conversion', { send_to: 'AW-17899660858/rqouCLin75gcELrMnNdC' });
      }
    } catch {
      gateError.textContent = 'Something went wrong. Please try again.';
      gateError.classList.remove('hidden');
      gateSubmit.disabled = false;
      gateSubmit.textContent = 'Send My Results';
    }
  });

  gateEmail.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') gateSubmit.click();
  });
</script>
