---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/electricalTools';

const tool = getToolBySlug('service-call-price-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much should I charge for an electrical service call?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most electrical service calls range from $150 to $500 total. This includes a diagnostic fee of $75-$150, labor at $85-$175 per hour, and marked-up materials. Your price depends on your market, overhead, and target profit margin. Use a service call price calculator to build the total from your actual costs and ensure you are hitting at least a 40-50% gross margin."
      }
    },
    {
      "@type": "Question",
      "name": "What markup should I put on electrical parts?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The industry standard is 200-400% markup on small parts like outlets, switches, and wire nuts, 100-200% on mid-range parts like breakers, GFCIs, and light fixtures, and 50-100% on major components like panels and sub-panels. This typically results in a 50-75% margin on materials, which is necessary to cover truck inventory, waste, and overhead."
      }
    },
    {
      "@type": "Question",
      "name": "Should I charge tax on electrical labor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In most US states, labor for repair and maintenance services is not subject to sales tax, but parts and materials are taxable. However, tax rules vary by state and locality. Some states tax all services, some tax none. Check your state's department of revenue for specific rules. When in doubt, consult a tax professional."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate profit margin on a service call?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Subtract your total costs from the customer total to get gross profit. Divide gross profit by the customer total and multiply by 100 for the margin percentage. For example, if you charge $380 and your costs are $155, your gross profit is $225 and your margin is 59%. A healthy electrical service call margin is 40-60%."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="service-calc">
    <!-- Service Details -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Service Details</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="diagnostic-fee">Diagnostic / Trip Fee ($)</label>
        <input type="number" id="diagnostic-fee" value="95" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="labor-hours">Labor Hours</label>
        <input type="number" id="labor-hours" value="1.5" min="0" step="0.25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="billable-rate">Billable Rate ($/hr)</label>
        <input type="number" id="billable-rate" value="115" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="loaded-wage">
          Your Loaded Wage ($/hr)
          <span class="inline-block ml-1 text-text-muted cursor-help" title="Your actual cost per hour including benefits, insurance, workers comp, payroll taxes">&#9432;</span>
        </label>
        <input type="number" id="loaded-wage" value="42" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Parts Section -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Materials &amp; Parts</h3>
    <div class="mb-2 text-sm text-text-muted">Add parts and materials used on this service call. Select a preset or enter custom values.</div>
    <div id="parts-table" class="space-y-3 mb-4">
      <!-- Part rows inserted here by JS -->
    </div>
    <button id="add-part-btn" class="bg-bg-dark border border-border rounded-lg px-5 py-2.5 text-sm text-text-secondary hover:border-accent hover:text-accent transition-colors cursor-pointer">
      + Add Part
    </button>

    <!-- Wire / Cable Section -->
    <h3 class="font-heading font-bold text-lg mt-8 mb-4 text-text-primary">Wire &amp; Cable (optional)</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wire-type">Wire Type</label>
        <select id="wire-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="none">None</option>
          <option value="nm14-2">14/2 NM-B (Romex)</option>
          <option value="nm12-2">12/2 NM-B (Romex)</option>
          <option value="nm10-3">10/3 NM-B (Romex)</option>
          <option value="thhn10">10 AWG THHN</option>
          <option value="thhn6">6 AWG THHN</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wire-feet">Feet Used</label>
        <input type="number" id="wire-feet" value="0" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wire-cost">Your Cost per ft ($)</label>
        <input type="number" id="wire-cost" value="0" min="0" step="0.01" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" disabled />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wire-price">Customer Price per ft ($)</label>
        <input type="number" id="wire-price" value="0" min="0" step="0.01" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" disabled />
      </div>
    </div>

    <!-- Other -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Other</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="permit-fee">Permit Fee ($)</label>
        <input type="number" id="permit-fee" value="0" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="tax-rate">
          Tax Rate (%)
        </label>
        <input type="number" id="tax-rate" value="0" min="0" max="20" step="0.1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        <p class="text-text-muted text-xs mt-1.5">Applied to parts and materials only &mdash; labor is typically not taxed.</p>
      </div>
    </div>


    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Customer Price Breakdown</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Customer Total</div>
          <div id="result-customer-total" class="font-heading font-extrabold text-3xl text-accent">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Parts Revenue</div>
          <div id="result-parts-revenue" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Labor Revenue</div>
          <div id="result-labor-revenue" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Wire/Cable Revenue</div>
          <div id="result-wire-revenue" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
      </div>

      <h3 class="font-heading font-bold text-xl mb-6">Your Profitability</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Gross Profit</div>
          <div id="result-gross-profit" class="font-heading font-extrabold text-3xl text-[#34D399]">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Profit Margin</div>
          <div id="result-profit-margin" class="font-heading font-extrabold text-3xl">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Your Total Cost</div>
          <div id="result-total-cost" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Profit per Hour</div>
          <div id="result-profit-per-hour" class="font-heading font-extrabold text-xl text-text-primary">&mdash;</div>
        </div>
      </div>

      <!-- Benchmark Bar -->
      <div class="bg-bg-dark rounded-xl p-5 mt-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Benchmark &mdash; Average Electrical Service Call: $150 &ndash; $500</h4>
        <div class="relative h-6 bg-bg-card rounded-full overflow-hidden border border-border">
          <div class="absolute inset-0 flex">
            <div class="w-1/3 bg-[rgba(52,211,153,0.15)] border-r border-border"></div>
            <div class="w-1/3 bg-[rgba(251,191,36,0.1)] border-r border-border"></div>
            <div class="w-1/3 bg-[rgba(239,68,68,0.1)]"></div>
          </div>
          <div id="benchmark-marker" class="absolute top-0 h-full w-1 bg-accent rounded transition-all" style="left: 0%"></div>
        </div>
        <div class="flex justify-between text-xs text-text-muted mt-2">
          <span>$0</span>
          <span>$150</span>
          <span>$350</span>
          <span>$500</span>
          <span>$700+</span>
        </div>
        <p id="benchmark-text" class="text-text-secondary text-sm mt-3">Your price: &mdash;</p>
      </div>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter your service details.</strong> Set your diagnostic or trip fee, estimated labor hours, your billable hourly rate, and your loaded wage (your true cost per hour including benefits, insurance, and workers comp).</p>
          <p><strong class="text-text-primary">2. Add parts and materials.</strong> Use the preset dropdown to quickly add common electrical parts with typical wholesale costs, or enter custom parts and costs. Set your markup percentage for each item individually.</p>
          <p><strong class="text-text-primary">3. Add wire or cable if applicable.</strong> Select the wire type and footage used. The calculator auto-fills typical cost and customer pricing for common Romex and THHN sizes.</p>
          <p><strong class="text-text-primary">4. Review the breakdown.</strong> The calculator shows the customer's total price, your total cost, gross profit, profit margin, and profit per hour. Compare your price to the industry benchmark range.</p>
        </div>
      </section>

      <!-- How Pricing Works -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How Service Call Pricing Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>An electrical service call price is built from four components: <strong class="text-text-primary">diagnostic fee, labor, parts/materials, and wire/cable</strong>. Each one contributes to revenue differently and has different margin characteristics.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm space-y-1">
            <p>Customer Total = Diagnostic + (Hours x Rate) + Parts Revenue + Wire Revenue + Permit + Tax</p>
            <p>Your Cost = (Hours x Loaded Wage) + Wholesale Parts + Wire Cost + Permit</p>
            <p>Gross Profit = Customer Total - Your Cost</p>
          </div>
          <p><strong class="text-text-primary">Why materials markup matters.</strong> Materials are often the highest-margin component of a service call. A 250% markup on a $3 GFCI outlet means you charge $10.50 and keep $7.50. That margin covers the cost of stocking the part on your truck, waste, and your diagnostic expertise in knowing which parts to use per NEC code.</p>
          <p><strong class="text-text-primary">Labor vs materials profitability.</strong> Labor revenue depends on how fast you work. If you bill 1.5 hours at $115/hr but the job takes 2 hours, your effective rate drops. Materials profit is locked in the moment you set the price. The most profitable electrical service companies maximize both: fast electricians with strong materials margins.</p>
          <p><strong class="text-text-primary">Tax treatment.</strong> In most US states, sales tax applies to parts and materials but not to labor for repair services. Wire and cable are typically taxable as materials. Always check your local tax rules because some states tax all services and some tax none.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">On-the-fly pricing in the field.</strong> You have diagnosed the problem, you know the parts needed, and you need to give the customer a price before you start work. Pull up this calculator on your phone, plug in the materials and labor, and present a confident total.</p>
          <p><strong class="text-text-primary">Training new electricians on pricing.</strong> New electricians often struggle with pricing because they do not see the full picture. Walk them through the calculator to show how trip fees, labor, materials markup, and wire all add up. Show them what happens to profit margin when they discount the diagnostic fee or undercharge on materials.</p>
          <p><strong class="text-text-primary">Comparing time-and-materials to flat rate.</strong> Enter a few common repair scenarios in this calculator and compare the totals to your flat rate price book. If your flat rate prices are consistently lower than what this calculator produces, you may be leaving money on the table.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much should I charge for an electrical service call?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most electrical service calls range from $150 to $500 total. This includes a diagnostic fee of $75-$150, labor at $85-$175 per hour, and marked-up materials. Your price depends on your market, overhead, and target profit margin. Use this calculator to build the total from your actual costs and ensure you are hitting at least a 40-50% gross margin.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What markup should I put on electrical parts?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">The industry standard is 200-400% markup on small parts like outlets, switches, and wire nuts, 100-200% on mid-range parts like breakers, GFCIs, and light fixtures, and 50-100% on major components like panels and sub-panels. This typically results in a 50-75% margin on materials.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should I charge tax on electrical labor?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">In most US states, labor for repair and maintenance services is not subject to sales tax, but parts and materials are taxable. However, tax rules vary by state and locality. Some states tax all services, some tax none. Check your state's department of revenue for specific rules.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I calculate profit margin on a service call?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Subtract your total costs from the customer total to get gross profit. Divide gross profit by the customer total and multiply by 100 for the margin percentage. For example, if you charge $380 and your costs are $155, your gross profit is $225 and your margin is 59%. A healthy electrical service call margin is 40-60%.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // Preset parts with wholesale costs - electrical specific
  const presetParts: Record<string, number> = {
    '20A Breaker': 8,
    'GFCI Outlet': 12,
    'Standard Outlet': 2,
    'Light Switch (Single-Pole)': 3,
    '3-Way Switch': 5,
    'Dimmer Switch': 18,
    'AFCI Breaker': 35,
    'GFCI Breaker': 40,
    'Junction Box': 4,
    'Light Fixture': 45,
    'Ceiling Fan': 85,
    'Disconnect Box': 28,
  };

  const wirePricing: Record<string, { cost: number; price: number }> = {
    'nm14-2': { cost: 0.35, price: 1.00 },
    'nm12-2': { cost: 0.50, price: 1.40 },
    'nm10-3': { cost: 1.10, price: 2.75 },
    'thhn10': { cost: 0.45, price: 1.25 },
    'thhn6': { cost: 1.20, price: 3.00 },
  };

  let partCounter = 0;

  function addPartRow(name = '', cost = 0, markup = 250) {
    const id = partCounter++;
    const table = document.getElementById('parts-table')!;
    const row = document.createElement('div');
    row.className = 'grid grid-cols-1 md:grid-cols-[1fr_1fr_120px_120px_40px] gap-3 items-end part-row';
    row.dataset.partId = String(id);

    const presetOptions = Object.entries(presetParts).map(([n, c]) =>
      `<option value="${n}" ${n === name ? 'selected' : ''}>${n} &mdash; $${c}</option>`
    ).join('');

    row.innerHTML = `
      <div>
        <label class="block text-xs font-medium text-text-muted mb-1">Part / Material</label>
        <select class="part-preset w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors">
          <option value="">Custom part...</option>
          ${presetOptions}
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-text-muted mb-1">Wholesale Cost ($)</label>
        <input type="number" class="part-cost w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" value="${cost}" min="0" step="0.01" />
      </div>
      <div>
        <label class="block text-xs font-medium text-text-muted mb-1">Markup %</label>
        <input type="number" class="part-markup w-full bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" value="${markup}" min="0" step="1" />
      </div>
      <div>
        <label class="block text-xs font-medium text-text-muted mb-1">Sell Price</label>
        <div class="part-sell-price bg-bg-dark border border-border rounded-lg px-3 py-2.5 text-accent text-sm font-medium">&mdash;</div>
      </div>
      <div>
        <button class="remove-part-btn mt-5 text-text-muted hover:text-red-400 transition-colors cursor-pointer text-lg leading-none" title="Remove part">&times;</button>
      </div>
    `;

    table.appendChild(row);

    // Preset dropdown change
    const presetSelect = row.querySelector('.part-preset') as HTMLSelectElement;
    const costInput = row.querySelector('.part-cost') as HTMLInputElement;

    presetSelect.addEventListener('change', () => {
      const selected = presetSelect.value;
      if (selected && presetParts[selected] !== undefined) {
        costInput.value = String(presetParts[selected]);
      }
      calculate();
    });

    // Input change listeners
    row.querySelectorAll('input').forEach(input => {
      input.addEventListener('input', calculate);
    });

    // Remove button
    row.querySelector('.remove-part-btn')!.addEventListener('click', () => {
      row.remove();
      calculate();
    });

    // If a name was passed and it matches a preset, auto-fill cost
    if (name && presetParts[name] !== undefined && cost === 0) {
      costInput.value = String(presetParts[name]);
    }

    updatePartSellPrice(row);
    calculate();
  }

  function updatePartSellPrice(row: Element) {
    const cost = parseFloat((row.querySelector('.part-cost') as HTMLInputElement).value) || 0;
    const markup = parseFloat((row.querySelector('.part-markup') as HTMLInputElement).value) || 0;
    const sellPrice = cost * (1 + markup / 100);
    (row.querySelector('.part-sell-price') as HTMLElement).textContent = `$${sellPrice.toFixed(2)}`;
  }

  function calculate() {
    // Service details
    const diagnosticFee = parseFloat((document.getElementById('diagnostic-fee') as HTMLInputElement).value) || 0;
    const laborHours = parseFloat((document.getElementById('labor-hours') as HTMLInputElement).value) || 0;
    const billableRate = parseFloat((document.getElementById('billable-rate') as HTMLInputElement).value) || 0;
    const loadedWage = parseFloat((document.getElementById('loaded-wage') as HTMLInputElement).value) || 0;

    // Labor calculations
    const laborRevenue = laborHours * billableRate;
    const laborCost = laborHours * loadedWage;

    // Parts calculations
    let partsRevenue = 0;
    let partsCost = 0;
    document.querySelectorAll('.part-row').forEach(row => {
      updatePartSellPrice(row);
      const cost = parseFloat((row.querySelector('.part-cost') as HTMLInputElement).value) || 0;
      const markup = parseFloat((row.querySelector('.part-markup') as HTMLInputElement).value) || 0;
      const sellPrice = cost * (1 + markup / 100);
      partsCost += cost;
      partsRevenue += sellPrice;
    });

    // Wire calculations
    const wireType = (document.getElementById('wire-type') as HTMLSelectElement).value;
    const wireFeet = parseFloat((document.getElementById('wire-feet') as HTMLInputElement).value) || 0;
    const wireCostPerFt = parseFloat((document.getElementById('wire-cost') as HTMLInputElement).value) || 0;
    const wirePricePerFt = parseFloat((document.getElementById('wire-price') as HTMLInputElement).value) || 0;
    const wireCost = wireFeet * wireCostPerFt;
    const wireRevenue = wireFeet * wirePricePerFt;

    // Other
    const permitFee = parseFloat((document.getElementById('permit-fee') as HTMLInputElement).value) || 0;
    const taxRate = parseFloat((document.getElementById('tax-rate') as HTMLInputElement).value) || 0;

    // Tax applies to parts and wire only
    const taxableAmount = partsRevenue + wireRevenue;
    const taxAmount = taxableAmount * (taxRate / 100);

    // Totals
    const customerTotal = diagnosticFee + laborRevenue + partsRevenue + wireRevenue + permitFee + taxAmount;
    const totalCost = laborCost + partsCost + wireCost + permitFee;
    const grossProfit = customerTotal - totalCost;
    const profitMargin = customerTotal > 0 ? (grossProfit / customerTotal) * 100 : 0;
    const profitPerHour = laborHours > 0 ? grossProfit / laborHours : 0;

    // Update customer side results
    document.getElementById('result-customer-total')!.textContent = `$${customerTotal.toFixed(0)}`;
    document.getElementById('result-parts-revenue')!.textContent = `$${partsRevenue.toFixed(0)}`;
    document.getElementById('result-labor-revenue')!.textContent = `$${(diagnosticFee + laborRevenue).toFixed(0)}`;
    document.getElementById('result-wire-revenue')!.textContent = `$${wireRevenue.toFixed(0)}`;

    // Update profitability results
    document.getElementById('result-gross-profit')!.textContent = `$${grossProfit.toFixed(0)}`;
    document.getElementById('result-total-cost')!.textContent = `$${totalCost.toFixed(0)}`;
    document.getElementById('result-profit-per-hour')!.textContent = `$${profitPerHour.toFixed(0)}/hr`;

    // Profit margin with color coding
    const marginEl = document.getElementById('result-profit-margin')!;
    marginEl.textContent = `${profitMargin.toFixed(1)}%`;
    marginEl.className = 'font-heading font-extrabold text-3xl';
    if (profitMargin < 30) {
      marginEl.classList.add('text-red-400');
    } else if (profitMargin < 50) {
      marginEl.classList.add('text-yellow-400');
    } else {
      marginEl.classList.add('text-[#34D399]');
    }

    // Benchmark bar (range $0 - $700+)
    const maxBenchmark = 700;
    const markerPct = Math.min((customerTotal / maxBenchmark) * 100, 100);
    const marker = document.getElementById('benchmark-marker')!;
    marker.style.left = `${markerPct}%`;

    let benchmarkNote = '';
    if (customerTotal < 150) {
      benchmarkNote = 'Below average range. Make sure your margins are healthy.';
    } else if (customerTotal <= 500) {
      benchmarkNote = 'Within the typical range for electrical service calls.';
    } else {
      benchmarkNote = 'Above average. Justified for panel work, new circuits, or complex troubleshooting.';
    }
    document.getElementById('benchmark-text')!.textContent = `Your price: $${customerTotal.toFixed(0)} \u2014 ${benchmarkNote}`;
  }

  // Wire type change handler
  document.getElementById('wire-type')?.addEventListener('change', () => {
    const wType = (document.getElementById('wire-type') as HTMLSelectElement).value;
    const costInput = document.getElementById('wire-cost') as HTMLInputElement;
    const priceInput = document.getElementById('wire-price') as HTMLInputElement;

    if (wType === 'none') {
      costInput.value = '0';
      priceInput.value = '0';
      costInput.disabled = true;
      priceInput.disabled = true;
      (document.getElementById('wire-feet') as HTMLInputElement).value = '0';
    } else {
      const pricing = wirePricing[wType];
      costInput.value = String(pricing.cost);
      priceInput.value = String(pricing.price);
      costInput.disabled = false;
      priceInput.disabled = false;
    }
    calculate();
  });

  // Add Part button
  document.getElementById('add-part-btn')?.addEventListener('click', () => addPartRow());

  // Auto-calculate on any input/select change within the calculator
  document.querySelectorAll('#service-calc > .grid input, #service-calc > .grid select, #service-calc input[id="permit-fee"], #service-calc input[id="tax-rate"]').forEach(el => {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  // Also listen on wire inputs
  document.getElementById('wire-feet')?.addEventListener('input', calculate);
  document.getElementById('wire-cost')?.addEventListener('input', calculate);
  document.getElementById('wire-price')?.addEventListener('input', calculate);

  // Initialize with one preset part row and run initial calculation
  addPartRow('GFCI Outlet', 12, 250);
  calculate();
</script>
