---
import BaseLayout from './BaseLayout.astro';
import { categoryColors, getRelatedTools, type HvacTool } from '../data/hvacTools';

interface Props {
  tool: HvacTool;
}

const { tool } = Astro.props;
const relatedTools = getRelatedTools(tool.slug);
const catColor = categoryColors[tool.category];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sendthebid.com/" },
    { "@type": "ListItem", "position": 2, "name": "HVAC Tools", "item": "https://sendthebid.com/hvac/" },
    { "@type": "ListItem", "position": 3, "name": tool.name }
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": tool.name,
  "description": tool.metaDescription,
  "url": `https://sendthebid.com/hvac/${tool.slug}`,
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "creator": {
    "@type": "Organization",
    "name": "SendTheBid"
  }
};
---

<BaseLayout
  title={tool.seoTitle}
  description={tool.metaDescription}
  currentPath={`/hvac/${tool.slug}`}
  schema={[breadcrumbSchema, webAppSchema]}
>
  <!-- Breadcrumb -->
  <nav class="max-w-[1080px] mx-auto px-6 md:px-12 pt-4 pb-2" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-text-muted">
      <li><a href="/" class="hover:text-text-secondary transition-colors no-underline">Home</a></li>
      <li class="before:content-['/'] before:mx-2"><a href="/hvac/" class="hover:text-text-secondary transition-colors no-underline">HVAC Tools</a></li>
      <li class="before:content-['/'] before:mx-2 text-text-secondary">{tool.shortName}</li>
    </ol>
  </nav>

  <!-- Tool header -->
  <div class="max-w-[1080px] mx-auto px-6 md:px-12 pt-6 pb-8">
    <div class="flex items-center gap-3 mb-4">
      <span class:list={["text-[11px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded", catColor.text, catColor.bg]}>
        {tool.categoryLabel}
      </span>
      <span class="text-text-muted text-xs">Free &middot; No login required</span>
    </div>
    <h1 class="font-heading font-extrabold text-3xl md:text-5xl tracking-tight mb-3">{tool.name}</h1>
    <p class="text-text-secondary text-lg max-w-2xl">{tool.description}</p>
  </div>

  <!-- Calculator area -->
  <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16">
    <div class="bg-bg-card border border-border rounded-2xl p-6 md:p-8">
      <slot />
    </div>
  </div>

  <!-- Content sections (How to Use, How It Works, etc.) -->
  <slot name="content" />

  <!-- Related Tools -->
  {relatedTools.length > 0 && (
    <section class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16">
      <h2 class="font-heading font-bold text-2xl mb-6">Related HVAC Tools</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {relatedTools.map(rt => {
          const rc = categoryColors[rt.category];
          return (
            <a href={`/hvac/${rt.slug}`} class="bg-bg-card border border-border rounded-xl p-5 no-underline hover:border-[#3A4755] hover:bg-bg-card-hover hover:-translate-y-0.5 transition-all">
              <span class:list={["text-[11px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded inline-block mb-2", rc.text, rc.bg]}>
                {rt.categoryLabel}
              </span>
              <h3 class="font-heading font-bold text-base text-text-primary mb-1">{rt.shortName}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{rt.shortDescription}</p>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- Back to hub CTA -->
  <div class="text-center py-12 border-t border-border max-w-[1080px] mx-auto">
    <a href="/hvac/" class="inline-flex items-center gap-2 text-accent font-semibold text-sm hover:gap-3 transition-all no-underline">
      &larr; View all 24 HVAC tools
    </a>
  </div>
</BaseLayout>
