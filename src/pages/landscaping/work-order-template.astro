---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/landscapingTools';

const tool = getToolBySlug('work-order-template')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should be on a landscaping work order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A complete landscaping work order includes dispatch info (date, crew lead, priority), customer details, property information (lawn area, bed area, tree count, irrigation zones), reported issue and scope of work, services performed, materials used, a site safety checklist, and crew lead signature with arrival and completion times."
      }
    },
    {
      "@type": "Question",
      "name": "Why do I need to record property measurements?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Property measurements like lawn square footage, bed area, tree and shrub count, and irrigation zone count document the scope of the property at the time of service. These measurements are critical for accurate estimating, tracking property changes over time, scheduling crew hours, and resolving disputes over what was serviced."
      }
    },
    {
      "@type": "Question",
      "name": "Is detailed documentation required for landscaping jobs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Maintaining detailed service records is a best practice for every landscaping job. Document all work performed, materials applied (fertilizer, mulch, seed), and any issues found like pest damage or irrigation leaks. Thorough records protect you during disputes, support warranty claims on plantings, and provide a service history that builds customer trust."
      }
    },
    {
      "@type": "Question",
      "name": "What documentation standards should I follow for landscaping?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Quality landscaping documentation should include before and after photos, detailed descriptions of services performed, materials and quantities used (mulch yards, fertilizer lbs, sod pallets), time spent on each task, and any recommendations for future work like tree trimming or irrigation repairs. This level of detail helps justify your pricing and builds a professional reputation."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="work-order-form">

    <!-- Section: Dispatch Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Dispatch Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-number">Work Order #</label>
        <input type="text" id="wo-number" value="WO-001" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-date">Date</label>
        <input type="date" id="wo-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-time">Time</label>
        <input type="time" id="wo-time" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="tech-name">Crew Lead</label>
        <input type="text" id="tech-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="truck-number">Truck #</label>
        <input type="text" id="truck-number" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="priority">Priority</label>
        <select id="priority" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Routine" selected>Routine</option>
          <option value="Urgent">Urgent</option>
          <option value="Emergency">Emergency</option>
        </select>
      </div>
    </div>

    <!-- Section: Customer Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Customer Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-name">Customer Name</label>
        <input type="text" id="cust-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-address">Address</label>
        <input type="text" id="cust-address" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-phone">Phone</label>
        <input type="text" id="cust-phone" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="access-instructions">Access Instructions</label>
        <input type="text" id="access-instructions" placeholder="Gate code, lockbox, etc." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Job Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Job Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-type">Service Type</label>
        <select id="equip-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Mow & Maintain">Mow & Maintain</option>
          <option value="Planting">Planting</option>
          <option value="Irrigation">Irrigation</option>
          <option value="Hardscape">Hardscape</option>
          <option value="Tree/Shrub Care">Tree/Shrub Care</option>
          <option value="Lawn Treatment">Lawn Treatment</option>
          <option value="Cleanup">Cleanup</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-make">Property Type</label>
        <input type="text" id="equip-make" placeholder="Residential, Commercial..." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-model">Lot Size</label>
        <input type="text" id="equip-model" placeholder="e.g., 0.25 acres" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-serial">Service Agreement #</label>
        <input type="text" id="equip-serial" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="install-date">Last Service Date</label>
        <input type="date" id="install-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="filter-size">Crew Size</label>
        <input type="text" id="filter-size" placeholder="e.g., 3 crew" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="refrigerant-type">Grass Type</label>
        <select id="refrigerant-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Bermuda" selected>Bermuda</option>
          <option value="Fescue">Fescue</option>
          <option value="Zoysia">Zoysia</option>
          <option value="St. Augustine">St. Augustine</option>
          <option value="Kentucky Bluegrass">Kentucky Bluegrass</option>
          <option value="Mixed">Mixed</option>
          <option value="Other">Other</option>
        </select>
      </div>
    </div>

    <!-- Section: Service Details -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Service Details</h3>
    <div class="space-y-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="reported-issue">Reported Issue</label>
        <textarea id="reported-issue" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="diagnosis">Assessment</label>
        <textarea id="diagnosis" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="work-performed">Work Performed</label>
        <textarea id="work-performed" rows="4" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
    </div>

    <!-- Section: Materials Used -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Materials Used</h3>
    <div class="mb-8">
      <div id="parts-table" class="space-y-3">
        <div class="grid grid-cols-[1fr_1fr_80px_40px] gap-3 items-end part-row">
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">Material Name</label>
            <input type="text" class="part-name w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">SKU / Type</label>
            <input type="text" class="part-number w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">Qty</label>
            <input type="number" value="1" min="1" class="part-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">&nbsp;</label>
            <button type="button" class="remove-part-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove material">&times;</button>
          </div>
        </div>
      </div>
      <button type="button" id="add-part-btn" class="mt-3 text-accent hover:text-accent-hover transition-colors cursor-pointer text-sm font-medium">+ Add Material</button>
    </div>

    <!-- Section: Material Log -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Material Log</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="ref-added">Mulch Used (yards)</label>
        <input type="number" id="ref-added" min="0" step="0.5" value="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="ref-recovered">Debris Removed (yards)</label>
        <input type="number" id="ref-recovered" min="0" step="0.5" value="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Property Measurements -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Property Measurements</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="lawn-area">Lawn Area (sq ft)</label>
        <input type="number" id="lawn-area" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="bed-area">Bed Area (sq ft)</label>
        <input type="number" id="bed-area" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="tree-count">Tree / Shrub Count</label>
        <input type="number" id="tree-count" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="irrigation-zones">Irrigation Zones</label>
        <input type="number" id="irrigation-zones" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="hedge-lf">Hedge / Edging (LF)</label>
        <input type="number" id="hedge-lf" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="hardscape-sqft">Hardscape (sq ft)</label>
        <input type="number" id="hardscape-sqft" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2">Total Property (sq ft)</label>
        <div id="total-property-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="mow-height">Mow Height (in)</label>
        <input type="number" id="mow-height" step="0.25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Safety Checklist -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Safety Checklist</h3>
    <div class="space-y-3 mb-8">
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-ppe" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-ppe" class="text-text-primary cursor-pointer">PPE Worn (eye, ear, gloves)</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-utilities" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-utilities" class="text-text-primary cursor-pointer">Underground Utilities Marked</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-equipment" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-equipment" class="text-text-primary cursor-pointer">Equipment Pre-Check Completed</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-debris" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-debris" class="text-text-primary cursor-pointer">Site Debris Cleared Before Mowing</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-irrigation" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-irrigation" class="text-text-primary cursor-pointer">Irrigation System Checked</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-cleanup" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-cleanup" class="text-text-primary cursor-pointer">Site Cleanup Completed</label>
      </div>
    </div>

    <!-- Section: Completion -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Completion</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="time-arrived">Time Arrived</label>
        <input type="time" id="time-arrived" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="time-completed">Time Completed</label>
        <input type="time" id="time-completed" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2">Total Hours</label>
        <div id="total-hours-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="tech-signature">Crew Lead Signature</label>
        <input type="text" id="tech-signature" placeholder="Type full name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Generate Button -->
    <button id="generate-btn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
      Generate Work Order &rarr;
    </button>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Template</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Fill in dispatch and customer info.</strong> Start with the work order number, date, and crew lead assignment. Add the customer's name, address, phone, and any access instructions like gate codes or lockbox combos.</p>
          <p><strong class="text-text-primary">2. Describe the job.</strong> Select the service type and enter property details. Record the lot size, grass type, and crew size so future visits have a complete picture.</p>
          <p><strong class="text-text-primary">3. Document the service.</strong> Write what the customer reported, your assessment, and exactly what work you performed. Be specific — vague notes cause problems during disputes and callbacks.</p>
          <p><strong class="text-text-primary">4. Record measurements and safety checks.</strong> Log property measurements like lawn area, bed area, and irrigation zones. Run through the safety checklist to confirm PPE was worn and the site was left clean.</p>
          <p><strong class="text-text-primary">5. Generate the work order.</strong> Hit the button to create a clean, printable work order. Have the customer review it, then use it for your records, service agreements, or office filing.</p>
        </div>
      </section>

      <!-- What Goes on a Work Order -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Goes on a Landscaping Work Order</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>A work order is the single document that proves what happened on a job. Every section exists for a reason.</p>
          <p><strong class="text-text-primary">Job identification</strong> — service type, property details, and lot information — ties the documentation to a specific service visit. This information is essential for recurring service agreements, follow-up visits, and customer records.</p>
          <p><strong class="text-text-primary">Property measurements</strong> document the scope of the property at the time of service. Lawn area, bed square footage, tree counts, and irrigation zone totals tell the full story. If a customer questions what was serviced or disputes the scope, your measurements prove exactly what was covered.</p>
          <p><strong class="text-text-primary">Material tracking</strong> is essential for every landscaping job. Recording mulch yards, fertilizer applied, seed spread, and sod installed protects you during billing disputes and helps with inventory management. Smart crews document everything regardless of job size.</p>
          <p><strong class="text-text-primary">The safety checklist</strong> is your liability shield. Documenting that PPE was worn, utilities were marked, equipment was pre-checked, and the site was cleaned up shows due diligence. If property damage or injury claims arise, that checklist is your first line of defense.</p>
          <p><strong class="text-text-primary">Materials used</strong> with quantities create a clear record for inventory management, customer billing, and accurate estimating on future jobs.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Regular maintenance visits.</strong> Every mow-and-maintain visit needs a work order. The crew lead fills it out on site — services performed, materials used, and property measurements. It becomes the permanent record of the visit and the basis for the invoice.</p>
          <p><strong class="text-text-primary">Seasonal projects.</strong> During spring cleanups, fall leaf removal, or mulch installations, the work order captures the full scope of work and materials used. Over multiple seasons, these records show property changes and help you plan future services more accurately.</p>
          <p><strong class="text-text-primary">Service agreement documentation.</strong> When a customer questions what was done, or when you need to verify recurring service history, the work order is your evidence. Complete work orders with measurements, materials, and signatures eliminate he-said-she-said situations.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should be on a landscaping work order?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A complete landscaping work order includes dispatch info (date, crew lead, priority), customer details, property information (lawn area, bed area, tree count, irrigation zones), reported issue and scope of work, services performed, materials used, a site safety checklist, and crew lead signature with arrival and completion times.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why do I need to record property measurements?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Property measurements like lawn square footage, bed area, tree and shrub count, and irrigation zone count document the scope of the property at the time of service. These measurements are critical for accurate estimating, tracking property changes over time, scheduling crew hours, and resolving disputes over what was serviced.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Is detailed documentation required for landscaping jobs?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Yes. Maintaining detailed service records is a best practice for every landscaping job. Document all work performed, materials applied (fertilizer, mulch, seed), and any issues found like pest damage or irrigation leaks. Thorough records protect you during disputes, support warranty claims on plantings, and provide a service history that builds customer trust.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What documentation standards should I follow for landscaping?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Quality landscaping documentation should include before and after photos, detailed descriptions of services performed, materials and quantities used (mulch yards, fertilizer lbs, sod pallets), time spent on each task, and any recommendations for future work like tree trimming or irrigation repairs. This level of detail helps justify your pricing and builds a professional reputation.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // --- Default date and time ---
  const now = new Date();
  const dateInput = document.getElementById('wo-date') as HTMLInputElement;
  const timeInput = document.getElementById('wo-time') as HTMLInputElement;
  if (dateInput && !dateInput.value) {
    dateInput.value = now.toISOString().slice(0, 10);
  }
  if (timeInput && !timeInput.value) {
    timeInput.value = now.toTimeString().slice(0, 5);
  }

  // --- Total Property auto-calculation ---
  function updateTotalProperty() {
    const lawn = parseFloat((document.getElementById('lawn-area') as HTMLInputElement).value) || 0;
    const bed = parseFloat((document.getElementById('bed-area') as HTMLInputElement).value) || 0;
    const hardscape = parseFloat((document.getElementById('hardscape-sqft') as HTMLInputElement).value) || 0;
    const display = document.getElementById('total-property-display')!;
    if (lawn > 0 || bed > 0 || hardscape > 0) {
      const total = lawn + bed + hardscape;
      display.textContent = total.toLocaleString() + ' sq ft';
      display.className = 'w-full bg-bg-dark border border-green-500/50 rounded-lg px-4 py-3 text-lg font-bold text-green-400';
    } else {
      display.textContent = '\u2014';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted';
    }
  }
  document.getElementById('lawn-area')?.addEventListener('input', updateTotalProperty);
  document.getElementById('bed-area')?.addEventListener('input', updateTotalProperty);
  document.getElementById('hardscape-sqft')?.addEventListener('input', updateTotalProperty);

  // --- Total Hours auto-calculation ---
  function updateTotalHours() {
    const arrived = (document.getElementById('time-arrived') as HTMLInputElement).value;
    const completed = (document.getElementById('time-completed') as HTMLInputElement).value;
    const display = document.getElementById('total-hours-display')!;
    if (arrived && completed) {
      const [ah, am] = arrived.split(':').map(Number);
      const [ch, cm] = completed.split(':').map(Number);
      let totalMinutes = (ch * 60 + cm) - (ah * 60 + am);
      if (totalMinutes < 0) totalMinutes += 24 * 60;
      const hours = Math.floor(totalMinutes / 60);
      const minutes = totalMinutes % 60;
      display.textContent = hours + 'h ' + minutes + 'm';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-primary';
    } else {
      display.textContent = '\u2014';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted';
    }
  }
  document.getElementById('time-arrived')?.addEventListener('input', updateTotalHours);
  document.getElementById('time-completed')?.addEventListener('input', updateTotalHours);

  // --- Dynamic Parts Table ---
  function addPartRow() {
    const table = document.getElementById('parts-table')!;
    const row = document.createElement('div');
    row.className = 'grid grid-cols-[1fr_1fr_80px_40px] gap-3 items-end part-row';
    row.innerHTML = `
      <div>
        <input type="text" class="part-name w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <input type="text" class="part-number w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <input type="number" value="1" min="1" class="part-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <button type="button" class="remove-part-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove material">&times;</button>
      </div>
    `;
    table.appendChild(row);
  }

  document.getElementById('add-part-btn')?.addEventListener('click', addPartRow);

  document.getElementById('parts-table')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('remove-part-btn')) {
      const row = target.closest('.part-row');
      const allRows = document.querySelectorAll('.part-row');
      if (allRows.length > 1 && row) {
        row.remove();
      }
    }
  });

  // --- Generate Work Order ---
  function getVal(id: string): string {
    const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
    return el ? el.value : '';
  }
  function getChecked(id: string): boolean {
    return (document.getElementById(id) as HTMLInputElement)?.checked || false;
  }

  function generateWorkOrder() {
    // Collect parts
    const partRows = document.querySelectorAll('.part-row');
    let partsHtml = '';
    partRows.forEach(row => {
      const name = (row.querySelector('.part-name') as HTMLInputElement)?.value || '';
      const num = (row.querySelector('.part-number') as HTMLInputElement)?.value || '';
      const qty = (row.querySelector('.part-qty') as HTMLInputElement)?.value || '';
      if (name || num) {
        partsHtml += `<tr><td style="border:1px solid #ddd;padding:6px 10px;">${name}</td><td style="border:1px solid #ddd;padding:6px 10px;">${num}</td><td style="border:1px solid #ddd;padding:6px 10px;text-align:center;">${qty}</td></tr>`;
      }
    });

    // Total property
    const lawnA = parseFloat(getVal('lawn-area')) || 0;
    const bedA = parseFloat(getVal('bed-area')) || 0;
    const hardA = parseFloat(getVal('hardscape-sqft')) || 0;
    const totalProp = lawnA + bedA + hardA;
    const totalPropStr = totalProp > 0 ? totalProp.toLocaleString() + ' sq ft' : '';

    // Total hours
    const arrived = getVal('time-arrived');
    const completed = getVal('time-completed');
    let totalHours = '';
    if (arrived && completed) {
      const [ah, am] = arrived.split(':').map(Number);
      const [ch, cm] = completed.split(':').map(Number);
      let totalMin = (ch * 60 + cm) - (ah * 60 + am);
      if (totalMin < 0) totalMin += 24 * 60;
      totalHours = Math.floor(totalMin / 60) + 'h ' + (totalMin % 60) + 'm';
    }

    // Safety checklist
    const safetyItems = [
      { id: 'chk-ppe', label: 'PPE Worn (eye, ear, gloves)', extra: '' },
      { id: 'chk-utilities', label: 'Underground Utilities Marked', extra: '' },
      { id: 'chk-equipment', label: 'Equipment Pre-Check Completed', extra: '' },
      { id: 'chk-debris', label: 'Site Debris Cleared Before Mowing', extra: '' },
      { id: 'chk-irrigation', label: 'Irrigation System Checked', extra: '' },
      { id: 'chk-cleanup', label: 'Site Cleanup Completed', extra: '' },
    ];
    let safetyHtml = '';
    safetyItems.forEach(item => {
      const checked = getChecked(item.id);
      const mark = checked ? '&#9745;' : '&#9744;';
      safetyHtml += `<div style="margin-bottom:4px;">${mark} ${item.label}${item.extra}</div>`;
    });

    const html = `<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Work Order ${getVal('wo-number')}</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color:#1a1a1a; padding:40px; max-width:850px; margin:0 auto; font-size:14px; line-height:1.5; }
  h1 { font-size:22px; margin-bottom:4px; }
  h2 { font-size:15px; color:#333; margin:20px 0 8px; padding-bottom:4px; border-bottom:2px solid #e5e5e5; text-transform:uppercase; letter-spacing:0.5px; }
  .header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:20px; padding-bottom:16px; border-bottom:3px solid #1a1a1a; }
  .header-left { }
  .header-right { text-align:right; font-size:13px; color:#555; }
  .grid2 { display:grid; grid-template-columns:1fr 1fr; gap:4px 24px; margin-bottom:6px; }
  .grid2 .label { font-weight:600; font-size:12px; color:#666; text-transform:uppercase; letter-spacing:0.3px; }
  .grid2 .value { font-size:14px; margin-bottom:6px; }
  .text-block { margin-bottom:12px; }
  .text-block .label { font-weight:600; font-size:12px; color:#666; text-transform:uppercase; letter-spacing:0.3px; margin-bottom:2px; }
  .text-block .value { font-size:14px; white-space:pre-wrap; background:#f9f9f9; padding:8px 10px; border-radius:4px; min-height:24px; }
  table { width:100%; border-collapse:collapse; margin-bottom:8px; }
  th { background:#f0f0f0; border:1px solid #ddd; padding:6px 10px; text-align:left; font-size:12px; text-transform:uppercase; letter-spacing:0.3px; }
  td { border:1px solid #ddd; padding:6px 10px; }
  .readings-table td { text-align:center; }
  .safety { font-size:14px; }
  .signature-block { display:grid; grid-template-columns:1fr 1fr; gap:40px; margin-top:40px; padding-top:16px; }
  .sig-line { border-top:1px solid #1a1a1a; padding-top:6px; font-size:12px; color:#666; text-transform:uppercase; }
  .sig-name { font-size:16px; font-weight:600; min-height:20px; }
  .priority-badge { display:inline-block; padding:2px 10px; border-radius:4px; font-size:12px; font-weight:600; text-transform:uppercase; }
  .priority-Routine { background:#e0f2e9; color:#166534; }
  .priority-Urgent { background:#fef3c7; color:#92400e; }
  .priority-Emergency { background:#fee2e2; color:#991b1b; }
  @media print { body { padding:20px; } }
</style>
</head><body>
<div class="header">
  <div class="header-left">
    <h1>Landscaping Work Order</h1>
    <div style="font-size:13px;color:#555;">Service Documentation</div>
  </div>
  <div class="header-right">
    <div style="font-size:20px;font-weight:700;">\${getVal('wo-number')}</div>
    <div>\${getVal('wo-date')}</div>
    <div>\${getVal('wo-time')}</div>
    <span class="priority-badge priority-\${getVal('priority')}">\${getVal('priority')}</span>
  </div>
</div>

<h2>Dispatch</h2>
<div class="grid2">
  <div><span class="label">Crew Lead:</span></div><div><span class="label">Truck #:</span></div>
  <div class="value">\${getVal('tech-name') || '\u2014'}</div><div class="value">\${getVal('truck-number') || '\u2014'}</div>
</div>

<h2>Customer</h2>
<div class="grid2">
  <div><span class="label">Name:</span></div><div><span class="label">Phone:</span></div>
  <div class="value">\${getVal('cust-name') || '\u2014'}</div><div class="value">\${getVal('cust-phone') || '\u2014'}</div>
  <div><span class="label">Address:</span></div><div><span class="label">Access:</span></div>
  <div class="value">\${getVal('cust-address') || '\u2014'}</div><div class="value">\${getVal('access-instructions') || '\u2014'}</div>
</div>

<h2>Job Info</h2>
<div class="grid2">
  <div><span class="label">Service Type:</span></div><div><span class="label">Property Type:</span></div>
  <div class="value">\${getVal('equip-type')}</div><div class="value">\${getVal('equip-make') || '\u2014'}</div>
  <div><span class="label">Lot Size:</span></div><div><span class="label">Agreement #:</span></div>
  <div class="value">\${getVal('equip-model') || '\u2014'}</div><div class="value">\${getVal('equip-serial') || '\u2014'}</div>
  <div><span class="label">Last Service:</span></div><div><span class="label">Crew Size:</span></div>
  <div class="value">\${getVal('install-date') || '\u2014'}</div><div class="value">\${getVal('filter-size') || '\u2014'}</div>
  <div><span class="label">Grass Type:</span></div><div></div>
  <div class="value">\${getVal('refrigerant-type')}</div><div></div>
</div>

<h2>Service Details</h2>
<div class="text-block"><div class="label">Reported Issue</div><div class="value">\${getVal('reported-issue') || '\u2014'}</div></div>
<div class="text-block"><div class="label">Assessment</div><div class="value">\${getVal('diagnosis') || '\u2014'}</div></div>
<div class="text-block"><div class="label">Work Performed</div><div class="value">\${getVal('work-performed') || '\u2014'}</div></div>

\${partsHtml ? \`<h2>Materials Used</h2>
<table><thead><tr><th>Material</th><th>SKU / Type</th><th style="text-align:center;">Qty</th></tr></thead><tbody>\${partsHtml}</tbody></table>\` : ''}

<h2>Material Log</h2>
<div class="grid2">
  <div><span class="label">Mulch Used:</span></div><div><span class="label">Debris Removed:</span></div>
  <div class="value">\${getVal('ref-added') || '0'} yards</div><div class="value">\${getVal('ref-recovered') || '0'} yards</div>
</div>

<h2>Property Measurements</h2>
<table class="readings-table">
  <thead><tr><th>Lawn Area</th><th>Bed Area</th><th>Trees/Shrubs</th><th>Irrigation Zones</th></tr></thead>
  <tbody><tr><td>\${getVal('lawn-area') ? getVal('lawn-area') + ' sq ft' : '\u2014'}</td><td>\${getVal('bed-area') ? getVal('bed-area') + ' sq ft' : '\u2014'}</td><td>\${getVal('tree-count') || '\u2014'}</td><td>\${getVal('irrigation-zones') || '\u2014'}</td></tr></tbody>
</table>
<table class="readings-table" style="margin-top:8px;">
  <thead><tr><th>Hedge/Edge LF</th><th>Hardscape</th><th>Total Property</th><th>Mow Height</th></tr></thead>
  <tbody><tr><td>\${getVal('hedge-lf') ? getVal('hedge-lf') + ' LF' : '\u2014'}</td><td>\${getVal('hardscape-sqft') ? getVal('hardscape-sqft') + ' sq ft' : '\u2014'}</td><td>\${totalPropStr || '\u2014'}</td><td>\${getVal('mow-height') ? getVal('mow-height') + ' in' : '\u2014'}</td></tr></tbody>
</table>

<h2>Safety Checklist</h2>
<div class="safety">\${safetyHtml}</div>

<h2>Completion</h2>
<div class="grid2">
  <div><span class="label">Time Arrived:</span></div><div><span class="label">Time Completed:</span></div>
  <div class="value">\${arrived || '\u2014'}</div><div class="value">\${completed || '\u2014'}</div>
  <div><span class="label">Total Hours:</span></div><div></div>
  <div class="value">\${totalHours || '\u2014'}</div><div></div>
</div>

<div class="signature-block">
  <div>
    <div class="sig-name">\${getVal('tech-signature') || ''}</div>
    <div class="sig-line">Crew Lead Signature</div>
  </div>
  <div>
    <div class="sig-name">&nbsp;</div>
    <div class="sig-line">Customer Signature</div>
  </div>
</div>

</body></html>`;

    const printWindow = window.open('', '_blank');
    if (printWindow) {
      printWindow.document.write(html);
      printWindow.document.close();
    }
  }

  document.getElementById('generate-btn')?.addEventListener('click', generateWorkOrder);
</script>
