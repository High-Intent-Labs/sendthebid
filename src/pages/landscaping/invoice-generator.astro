---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/landscapingTools';

const tool = getToolBySlug('invoice-generator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should be included on a Landscaping invoice?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A professional Landscaping invoice should include your company name, address, phone, and contractor license number. It should also list the customer's information, a description of work performed, service type, property size, plant list, materials used, itemized labor and materials, warranty terms, payment terms, and the invoice date and number."
      }
    },
    {
      "@type": "Question",
      "name": "How do I create a professional Landscaping invoice?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Use a dedicated Landscaping invoice generator that includes fields specific to the trade — service type, property size, plant list, materials used, and warranty terms. Fill in your company details, customer info, itemized line items with quantities and prices, applicable tax, and payment terms. Generate a PDF for a clean, professional document."
      }
    },
    {
      "@type": "Question",
      "name": "Should I charge tax on Landscaping labor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tax rules vary by state and municipality. In most states, Landscaping parts are taxable but labor is not. However, some states tax the entire invoice including labor when it is part of an installation. Check your state's department of revenue guidelines or consult your accountant for your specific jurisdiction."
      }
    },
    {
      "@type": "Question",
      "name": "What payment terms are standard for Landscaping?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For residential service calls and repairs, Due on Receipt or Net 15 is standard. For larger installations, many contractors require 50% deposit with the balance due on completion. Commercial work often uses Net 30. Always clearly state payment terms on the invoice to avoid collection issues."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="invoice-gen">
    <!-- Company Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Company Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="companyName">Company Name</label>
        <input type="text" id="companyName" placeholder="Your Landscaping Company" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="companyPhone">Phone</label>
        <input type="text" id="companyPhone" placeholder="(555) 123-4567" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="companyEmail">Email</label>
        <input type="text" id="companyEmail" placeholder="office@yourlandscaping.com" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="licenseNum">License #</label>
        <input type="text" id="licenseNum" placeholder="LAND-123456" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="invoiceNum">Invoice #</label>
        <input type="text" id="invoiceNum" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-2" for="invoiceDate">Invoice Date</label>
          <input type="date" id="invoiceDate" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-secondary mb-2" for="dueDate">Due Date</label>
          <input type="date" id="dueDate" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
        </div>
      </div>
    </div>

    <!-- Customer Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Customer Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customerName">Customer Name</label>
        <input type="text" id="customerName" placeholder="John Smith" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customerPhone">Customer Phone</label>
        <input type="text" id="customerPhone" placeholder="(555) 987-6543" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customerAddress">Customer Address</label>
        <input type="text" id="customerAddress" placeholder="123 Main St, Anytown, ST 12345" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Service Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Service Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equipmentType">Service Type</label>
        <select id="equipmentType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Lawn Maintenance">Lawn Maintenance</option>
          <option value="Landscape Design">Landscape Design</option>
          <option value="Hardscaping">Hardscaping</option>
          <option value="Irrigation">Irrigation</option>
          <option value="Tree Service">Tree Service</option>
          <option value="Seasonal Cleanup">Seasonal Cleanup</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equipMake">Property Size</label>
        <input type="text" id="equipMake" placeholder="e.g., 1/4 acre, 5,000 sq ft" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equipModel">Plant List / Scope</label>
        <input type="text" id="equipModel" placeholder="Plants, sod, mulch, pavers..." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equipSerial">Materials Used</label>
        <input type="text" id="equipSerial" placeholder="Mulch, topsoil, fertilizer..." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Line Items -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Line Items</h3>
    <div class="mb-3">
      <div class="hidden md:grid grid-cols-[1fr_80px_120px_120px_40px] gap-3 mb-2 px-1">
        <span class="text-text-muted text-xs font-medium uppercase tracking-wider">Description</span>
        <span class="text-text-muted text-xs font-medium uppercase tracking-wider">Qty</span>
        <span class="text-text-muted text-xs font-medium uppercase tracking-wider">Unit Price</span>
        <span class="text-text-muted text-xs font-medium uppercase tracking-wider">Total</span>
        <span></span>
      </div>
      <div id="line-items" class="space-y-3">
        <!-- Line items injected by JS -->
      </div>
    </div>

    <div class="flex flex-wrap gap-3 mb-8">
      <button id="add-line-btn" class="bg-bg-dark border border-border text-text-primary text-sm font-medium px-4 py-2 rounded-lg hover:border-accent hover:text-accent transition-colors cursor-pointer">
        + Add Line Item
      </button>
      <span class="text-text-muted text-xs self-center">Quick add:</span>
      <button data-quick="Site Visit / Consultation" data-price="75" class="quick-add-btn bg-bg-dark border border-border text-text-secondary text-xs px-3 py-2 rounded-lg hover:border-accent hover:text-accent transition-colors cursor-pointer">Site Visit ($75)</button>
      <button data-quick="Mowing (per visit)" data-price="55" class="quick-add-btn bg-bg-dark border border-border text-text-secondary text-xs px-3 py-2 rounded-lg hover:border-accent hover:text-accent transition-colors cursor-pointer">Mowing ($55)</button>
      <button data-quick="Mulch (per yard)" data-price="85" class="quick-add-btn bg-bg-dark border border-border text-text-secondary text-xs px-3 py-2 rounded-lg hover:border-accent hover:text-accent transition-colors cursor-pointer">Mulch / yard ($85)</button>
      <button data-quick="Shrub Trimming" data-price="150" class="quick-add-btn bg-bg-dark border border-border text-text-secondary text-xs px-3 py-2 rounded-lg hover:border-accent hover:text-accent transition-colors cursor-pointer">Shrub Trimming ($150)</button>
      <button data-quick="Seasonal Cleanup" data-price="250" class="quick-add-btn bg-bg-dark border border-border text-text-secondary text-xs px-3 py-2 rounded-lg hover:border-accent hover:text-accent transition-colors cursor-pointer">Seasonal Cleanup ($250)</button>
    </div>

    <!-- Bottom Section -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Invoice Settings</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="taxRate">Tax Rate (%)</label>
        <input type="number" id="taxRate" value="0" min="0" max="20" step="0.1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="paymentTerms">Payment Terms</label>
        <select id="paymentTerms" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Due on Receipt">Due on Receipt</option>
          <option value="Net 15">Net 15</option>
          <option value="Net 30" selected>Net 30</option>
        </select>
      </div>
      <div class="md:col-span-1">
        <!-- spacer for alignment -->
      </div>
      <div class="md:col-span-3">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="notes">Notes / Warranty</label>
        <textarea id="notes" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">Plant material: 1 yr warranty. Hardscape: 2 yr warranty. 30-day workmanship guarantee on all labor.</textarea>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Invoice Totals</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Subtotal</div>
          <div id="result-subtotal" class="font-heading font-extrabold text-3xl text-text-primary">$0.00</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Tax</div>
          <div id="result-tax" class="font-heading font-extrabold text-3xl text-text-primary">$0.00</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Total Due</div>
          <div id="result-total" class="font-heading font-extrabold text-3xl text-accent">$0.00</div>
        </div>
      </div>

      <!-- Generate PDF Button -->
      <button id="generate-pdf-btn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
        Generate PDF &rarr;
      </button>
      <p class="text-text-muted text-sm italic mt-3">Opens a print-ready invoice in a new window. Use your browser's print dialog to save as PDF.</p>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Generator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter your company details.</strong> Fill in your company name, phone, email, and contractor license number. These appear in the invoice header and build trust with customers.</p>
          <p><strong class="text-text-primary">2. Add customer and service info.</strong> Enter the customer's name, address, and phone. Then log the service type, property size, plant list, and materials used so every invoice ties back to the specific job you completed.</p>
          <p><strong class="text-text-primary">3. Build your line items.</strong> Add each material and labor charge individually, or use the quick-add buttons for common Landscaping items. Set quantities and unit prices, and the totals calculate automatically.</p>
          <p><strong class="text-text-primary">4. Set tax and payment terms.</strong> Enter your local tax rate and choose payment terms. Add warranty language or job notes in the notes field.</p>
          <p><strong class="text-text-primary">5. Generate the PDF.</strong> Click "Generate PDF" to open a clean, print-ready invoice in a new window. Use your browser's print function to save it as a PDF or send it directly to a printer.</p>
        </div>
      </section>

      <!-- What Makes a Professional Invoice -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Makes a Professional Landscaping Invoice</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>A professional Landscaping invoice goes beyond a basic receipt. It documents the entire service interaction and protects both you and the customer. At the top, you need your company name, license number, and contact information. Customers want to know who they paid and how to reach you if something goes wrong.</p>
          <p>The service details section is what separates a Landscaping invoice from a generic template. Logging the service type, property size, plant list, and materials used creates a service history for that property. When the customer calls back next season, you can see exactly what was planted and what materials were applied previously.</p>
          <p>Itemized line items with clear descriptions prevent disputes. Instead of writing "landscaping work - $500," break it out: site prep, mulch delivery, shrub installation, labor for planting. Customers respect transparency, and it makes warranty claims simpler if specific plants need replacement.</p>
          <p>Warranty terms on the invoice are legally important. Spell out what is covered, for how long, and any conditions. A common setup is a 1-year plant warranty, 2-year hardscape warranty, and a 30-day workmanship guarantee. Having it on the invoice means there is no ambiguity later.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">On-site after completing a job.</strong> You finish a landscaping project, pull up this tool on your phone or tablet, fill in what materials were used and the labor charges, and hand the customer a professional invoice before you leave. No more scribbling on carbon copies or promising to email something later.</p>
          <p><strong class="text-text-primary">Small crews without software.</strong> If you are a one-crew operation and do not want to pay for Jobber or LMN, this generator gives you a professional-looking invoice at no cost. It covers the Landscaping-specific fields that generic invoice templates miss.</p>
          <p><strong class="text-text-primary">Backup when your system is down.</strong> Software crashes happen. Internet goes out. When your dispatch or invoicing platform is unavailable, this tool works offline in your browser. Generate a clean invoice, save the PDF, and enter it into your system later when things are back online.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should be included on a Landscaping invoice?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A professional Landscaping invoice should include your company name, address, phone, and contractor license number. It should also list the customer's information, a description of work performed, service type, property size, plant list, materials used, itemized labor and materials, warranty terms, payment terms, and the invoice date and number.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I create a professional Landscaping invoice?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Use a dedicated Landscaping invoice generator that includes fields specific to the trade -- service type, property size, plant list, materials used, and warranty terms. Fill in your company details, customer info, itemized line items with quantities and prices, applicable tax, and payment terms. Generate a PDF for a clean, professional document.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should I charge tax on Landscaping labor?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Tax rules vary by state and municipality. In most states, Landscaping parts are taxable but labor is not. However, some states tax the entire invoice including labor when it is part of an installation. Check your state's department of revenue guidelines or consult your accountant for your specific jurisdiction.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What payment terms are standard for Landscaping?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">For residential service calls and repairs, Due on Receipt or Net 15 is standard. For larger installations, many contractors require 50% deposit with the balance due on completion. Commercial work often uses Net 30. Always clearly state payment terms on the invoice to avoid collection issues.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // --- Date and Invoice Number Defaults ---
  function initDefaults() {
    const today = new Date();
    const todayStr = today.toISOString().split('T')[0];
    const due = new Date(today);
    due.setDate(due.getDate() + 30);
    const dueStr = due.toISOString().split('T')[0];

    (document.getElementById('invoiceDate') as HTMLInputElement).value = todayStr;
    (document.getElementById('dueDate') as HTMLInputElement).value = dueStr;
    (document.getElementById('invoiceNum') as HTMLInputElement).value = 'INV-' + String(Math.floor(Math.random() * 9000) + 1000);
  }

  // --- Line Items ---
  interface LineItem {
    id: number;
    description: string;
    qty: number;
    price: number;
  }

  let lineItems: LineItem[] = [
    { id: 1, description: '', qty: 1, price: 0 }
  ];
  let nextId = 2;

  function renderLineItems() {
    const container = document.getElementById('line-items')!;
    container.innerHTML = '';

    lineItems.forEach((item, index) => {
      const row = document.createElement('div');
      row.className = 'grid grid-cols-1 md:grid-cols-[1fr_80px_120px_120px_40px] gap-3 items-center bg-bg-dark rounded-lg p-3 md:p-0 md:bg-transparent md:rounded-none';
      const total = (item.qty * item.price).toFixed(2);

      row.innerHTML = `
        <div>
          <label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Description</label>
          <input type="text" data-id="${item.id}" data-field="description" value="${escapeHtml(item.description)}" placeholder="Description" class="line-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Qty</label>
          <input type="number" data-id="${item.id}" data-field="qty" value="${item.qty}" min="1" class="line-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2 text-text-primary text-sm text-center focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Unit Price</label>
          <input type="number" data-id="${item.id}" data-field="price" value="${item.price}" min="0" step="0.01" class="line-input w-full bg-bg-dark border border-border rounded-lg px-3 py-2 text-text-primary text-sm text-right focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Total</label>
          <div class="text-text-primary text-sm font-medium text-right px-3 py-2">$${total}</div>
        </div>
        <div class="flex justify-end">
          ${lineItems.length > 1 ? `<button data-remove="${item.id}" class="remove-line-btn text-text-muted hover:text-red-400 transition-colors cursor-pointer text-lg leading-none" title="Remove">&times;</button>` : '<span></span>'}
        </div>
      `;

      container.appendChild(row);
    });

    // Attach events
    container.querySelectorAll('.line-input').forEach(input => {
      input.addEventListener('input', handleLineInput);
    });
    container.querySelectorAll('.remove-line-btn').forEach(btn => {
      btn.addEventListener('click', handleRemoveLine);
    });

    recalculate();
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function handleLineInput(e: Event) {
    const input = e.target as HTMLInputElement;
    const id = parseInt(input.dataset.id!);
    const field = input.dataset.field!;
    const item = lineItems.find(i => i.id === id);
    if (!item) return;

    if (field === 'description') {
      item.description = input.value;
    } else if (field === 'qty') {
      item.qty = parseFloat(input.value) || 0;
    } else if (field === 'price') {
      item.price = parseFloat(input.value) || 0;
    }

    // Update row total without full re-render
    const row = input.closest('.grid')!;
    const totalEl = row.querySelector('div:nth-child(4) div') as HTMLElement;
    if (totalEl) {
      totalEl.textContent = '$' + (item.qty * item.price).toFixed(2);
    }

    recalculate();
  }

  function handleRemoveLine(e: Event) {
    const btn = e.currentTarget as HTMLElement;
    const id = parseInt(btn.dataset.remove!);
    lineItems = lineItems.filter(i => i.id !== id);
    renderLineItems();
  }

  function addLineItem(description = '', price = 0) {
    lineItems.push({ id: nextId++, description, qty: 1, price });
    renderLineItems();
  }

  // --- Calculations ---
  function recalculate() {
    const subtotal = lineItems.reduce((sum, item) => sum + (item.qty * item.price), 0);
    const taxRate = parseFloat((document.getElementById('taxRate') as HTMLInputElement).value) || 0;
    const tax = subtotal * (taxRate / 100);
    const total = subtotal + tax;

    document.getElementById('result-subtotal')!.textContent = '$' + subtotal.toFixed(2);
    document.getElementById('result-tax')!.textContent = '$' + tax.toFixed(2);
    document.getElementById('result-total')!.textContent = '$' + total.toFixed(2);
  }

  // --- PDF Generation (print-ready HTML) ---
  function generatePDF() {
    const companyName = (document.getElementById('companyName') as HTMLInputElement).value || 'Landscaping Company';
    const companyPhone = (document.getElementById('companyPhone') as HTMLInputElement).value;
    const companyEmail = (document.getElementById('companyEmail') as HTMLInputElement).value;
    const licenseNum = (document.getElementById('licenseNum') as HTMLInputElement).value;
    const invoiceNum = (document.getElementById('invoiceNum') as HTMLInputElement).value;
    const invoiceDate = (document.getElementById('invoiceDate') as HTMLInputElement).value;
    const dueDate = (document.getElementById('dueDate') as HTMLInputElement).value;

    const customerName = (document.getElementById('customerName') as HTMLInputElement).value || 'Customer';
    const customerAddress = (document.getElementById('customerAddress') as HTMLInputElement).value;
    const customerPhone = (document.getElementById('customerPhone') as HTMLInputElement).value;

    const equipmentType = (document.getElementById('equipmentType') as HTMLSelectElement).value;
    const equipMake = (document.getElementById('equipMake') as HTMLInputElement).value;
    const equipModel = (document.getElementById('equipModel') as HTMLInputElement).value;
    const equipSerial = (document.getElementById('equipSerial') as HTMLInputElement).value;

    const taxRate = parseFloat((document.getElementById('taxRate') as HTMLInputElement).value) || 0;
    const paymentTerms = (document.getElementById('paymentTerms') as HTMLSelectElement).value;
    const notes = (document.getElementById('notes') as HTMLTextAreaElement).value;

    const subtotal = lineItems.reduce((sum, item) => sum + (item.qty * item.price), 0);
    const tax = subtotal * (taxRate / 100);
    const total = subtotal + tax;

    function formatDate(dateStr: string): string {
      if (!dateStr) return '';
      const d = new Date(dateStr + 'T00:00:00');
      return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    }

    const lineItemsHtml = lineItems
      .filter(item => item.description || item.price > 0)
      .map(item => `
        <tr>
          <td style="padding: 10px 12px; border-bottom: 1px solid #eee; text-align: left;">${escapeHtml(item.description)}</td>
          <td style="padding: 10px 12px; border-bottom: 1px solid #eee; text-align: center;">${item.qty}</td>
          <td style="padding: 10px 12px; border-bottom: 1px solid #eee; text-align: right;">$${item.price.toFixed(2)}</td>
          <td style="padding: 10px 12px; border-bottom: 1px solid #eee; text-align: right; font-weight: 600;">$${(item.qty * item.price).toFixed(2)}</td>
        </tr>
      `).join('');

    const systemInfoHtml = (equipmentType || equipMake || equipModel || equipSerial) ? `
      <div style="margin-bottom: 30px; padding: 15px; background: #f8f9fa; border-radius: 6px;">
        <div style="font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: #666; margin-bottom: 8px;">Service Information</div>
        <div style="display: flex; flex-wrap: wrap; gap: 20px; font-size: 14px; color: #333;">
          ${equipmentType ? `<div><span style="color: #888;">Service:</span> ${escapeHtml(equipmentType)}</div>` : ''}
          ${equipMake ? `<div><span style="color: #888;">Property Size:</span> ${escapeHtml(equipMake)}</div>` : ''}
          ${equipModel ? `<div><span style="color: #888;">Plant List / Scope:</span> ${escapeHtml(equipModel)}</div>` : ''}
          ${equipSerial ? `<div><span style="color: #888;">Materials:</span> ${escapeHtml(equipSerial)}</div>` : ''}
        </div>
      </div>
    ` : '';

    const html = `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Invoice ${escapeHtml(invoiceNum)}</title>
  <style>
    @media print {
      body { margin: 0; }
      .no-print { display: none; }
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #333; background: #fff; padding: 40px; max-width: 800px; margin: 0 auto; }
  </style>
</head>
<body>
  <!-- Header -->
  <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; padding-bottom: 20px; border-bottom: 3px solid #333;">
    <div>
      <div style="font-size: 28px; font-weight: 800; color: #111; margin-bottom: 4px;">${escapeHtml(companyName)}</div>
      ${companyPhone ? `<div style="font-size: 14px; color: #555;">${escapeHtml(companyPhone)}</div>` : ''}
      ${companyEmail ? `<div style="font-size: 14px; color: #555;">${escapeHtml(companyEmail)}</div>` : ''}
      ${licenseNum ? `<div style="font-size: 13px; color: #888; margin-top: 4px;">License: ${escapeHtml(licenseNum)}</div>` : ''}
    </div>
    <div style="text-align: right;">
      <div style="font-size: 36px; font-weight: 800; color: #111; letter-spacing: 0.04em;">INVOICE</div>
      <div style="font-size: 14px; color: #555; margin-top: 4px;">${escapeHtml(invoiceNum)}</div>
    </div>
  </div>

  <!-- Billing Details -->
  <div style="display: flex; justify-content: space-between; margin-bottom: 30px;">
    <div>
      <div style="font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: #888; margin-bottom: 6px;">Bill To</div>
      <div style="font-size: 16px; font-weight: 600; color: #111;">${escapeHtml(customerName)}</div>
      ${customerAddress ? `<div style="font-size: 14px; color: #555; margin-top: 2px;">${escapeHtml(customerAddress)}</div>` : ''}
      ${customerPhone ? `<div style="font-size: 14px; color: #555; margin-top: 2px;">${escapeHtml(customerPhone)}</div>` : ''}
    </div>
    <div style="text-align: right;">
      <div style="font-size: 14px; color: #555; margin-bottom: 4px;"><span style="color: #888;">Date:</span> ${formatDate(invoiceDate)}</div>
      <div style="font-size: 14px; color: #555; margin-bottom: 4px;"><span style="color: #888;">Due:</span> ${formatDate(dueDate)}</div>
      <div style="font-size: 14px; color: #555;"><span style="color: #888;">Terms:</span> ${escapeHtml(paymentTerms)}</div>
    </div>
  </div>

  <!-- System Info -->
  ${systemInfoHtml}

  <!-- Line Items Table -->
  <table style="width: 100%; border-collapse: collapse; margin-bottom: 30px;">
    <thead>
      <tr style="background: #333; color: #fff;">
        <th style="padding: 12px; text-align: left; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Description</th>
        <th style="padding: 12px; text-align: center; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; width: 70px;">Qty</th>
        <th style="padding: 12px; text-align: right; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; width: 110px;">Unit Price</th>
        <th style="padding: 12px; text-align: right; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; width: 110px;">Total</th>
      </tr>
    </thead>
    <tbody>
      ${lineItemsHtml}
    </tbody>
  </table>

  <!-- Totals -->
  <div style="display: flex; justify-content: flex-end; margin-bottom: 40px;">
    <div style="width: 280px;">
      <div style="display: flex; justify-content: space-between; padding: 8px 0; font-size: 14px; color: #555;">
        <span>Subtotal</span>
        <span>$${subtotal.toFixed(2)}</span>
      </div>
      ${taxRate > 0 ? `
      <div style="display: flex; justify-content: space-between; padding: 8px 0; font-size: 14px; color: #555; border-bottom: 1px solid #eee;">
        <span>Tax (${taxRate}%)</span>
        <span>$${tax.toFixed(2)}</span>
      </div>
      ` : ''}
      <div style="display: flex; justify-content: space-between; padding: 12px 0; font-size: 20px; font-weight: 800; color: #111; border-top: 2px solid #333;">
        <span>Total Due</span>
        <span>$${total.toFixed(2)}</span>
      </div>
    </div>
  </div>

  <!-- Notes -->
  ${notes ? `
  <div style="padding: 20px; background: #f8f9fa; border-radius: 6px; border-left: 4px solid #333;">
    <div style="font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: #888; margin-bottom: 6px;">Notes & Warranty</div>
    <div style="font-size: 13px; color: #555; line-height: 1.6; white-space: pre-wrap;">${escapeHtml(notes)}</div>
  </div>
  ` : ''}

  <div style="text-align: center; margin-top: 50px; padding-top: 20px; border-top: 1px solid #eee; font-size: 12px; color: #aaa;">
    Thank you for your business.
  </div>

  <script>window.onload = function() { window.print(); }<\/script>
</body>
</html>`;

    const printWindow = window.open('', '_blank');
    if (printWindow) {
      printWindow.document.write(html);
      printWindow.document.close();
    }
  }

  // --- Init ---
  initDefaults();
  renderLineItems();

  // Event listeners
  document.getElementById('add-line-btn')?.addEventListener('click', () => addLineItem());

  document.querySelectorAll('.quick-add-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const desc = el.dataset.quick || '';
      const price = parseFloat(el.dataset.price || '0');
      addLineItem(desc, price);
    });
  });

  document.getElementById('taxRate')?.addEventListener('input', recalculate);
  document.getElementById('generate-pdf-btn')?.addEventListener('click', generatePDF);
</script>
