---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/roofingTools';

const tool = getToolBySlug('flat-rate-price-builder')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I build a roofing flat rate price book?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start with your material costs and labor time for each repair type. Add your target markup to materials (30-45% is standard for roofing), multiply labor hours by your billable rate, and add overhead. Compare your calculated price to the national average range for that repair to make sure you are competitive but profitable. Build a library of your most common repairs and update prices quarterly."
      }
    },
    {
      "@type": "Question",
      "name": "What should a roofing flat rate include?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A roofing flat rate should include all materials at your marked-up price, all labor needed to complete the repair, disposal of old materials, travel time built into overhead, warranty on workmanship, and a margin for unexpected complications. The customer sees one clear price with no surprises."
      }
    },
    {
      "@type": "Question",
      "name": "How much should I charge for a roof leak repair?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A standard roof leak repair typically ranges from $300 to $500 depending on the source and severity. Simple shingle replacements or small sealant repairs fall on the lower end, while repairs involving flashing, valley work, or multiple penetration points push toward the higher end. Emergency or storm-related repairs may command premium pricing."
      }
    },
    {
      "@type": "Question",
      "name": "Is flat rate or time-and-materials better for roofing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Flat rate pricing is better for most roofing repair work because it gives the customer price certainty and rewards your crew for efficiency. A fast crew earns more per hour under flat rate. Time-and-materials works better for unknown-scope work like storm damage where you cannot predict the extent of repairs until tear-off. Many roofing companies use flat rate for standard repairs and T&M for investigation and complex restoration work."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="flat-rate-calc">
    <!-- Repair Type -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Repair Type</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="task-select">Quick Select &mdash; Common Roofing Repairs</label>
        <select id="task-select" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="">Custom repair...</option>
          <option value="inspection">Roof Inspection</option>
          <option value="leak-repair">Leak Repair (standard)</option>
          <option value="flashing-replace">Flashing Replacement (per 10 ft)</option>
          <option value="valley-repair">Valley Repair</option>
          <option value="ridge-vent">Ridge Vent Installation (per 10 ft)</option>
          <option value="emergency-tarp">Emergency Tarp / Board-Up</option>
          <option value="pipe-boot">Pipe Boot Replacement</option>
          <option value="shingle-repair">Shingle Repair (per bundle area)</option>
        </select>
      </div>
    </div>

    <!-- Cost Inputs -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Build Your Price</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="parts-cost">Materials Cost ($)</label>
        <input type="number" id="parts-cost" value="0" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="markup-pct">Materials Markup (%)</label>
        <input type="number" id="markup-pct" value="35" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="labor-hours">Labor Hours</label>
        <input type="number" id="labor-hours" value="1.5" min="0" step="0.25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="billable-rate">Billable Rate ($/hr)</label>
        <input type="number" id="billable-rate" value="75" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="misc-cost">Disposal / Misc ($)</label>
        <input type="number" id="misc-cost" value="0" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="loaded-wage">Your Loaded Wage ($/hr)</label>
        <input type="number" id="loaded-wage" value="35" min="0" step="1" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>


    <!-- Results -->
    <div id="results" class="mt-8 border-t border-border pt-8">
      <h3 class="font-heading font-bold text-xl mb-6">Your Flat Rate Price</h3>

      <!-- National Average Comparison -->
      <div class="bg-bg-dark rounded-xl p-6 mb-6">
        <div class="flex justify-between items-end mb-3">
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">National Low</div>
            <div id="avg-low" class="font-heading font-bold text-lg text-text-secondary">--</div>
          </div>
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Your Price</div>
            <div id="result-total" class="font-heading font-extrabold text-3xl text-accent">--</div>
          </div>
          <div class="text-center">
            <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-1">National High</div>
            <div id="avg-high" class="font-heading font-bold text-lg text-text-secondary">--</div>
          </div>
        </div>
        <div class="relative h-3 bg-bg-card rounded-full overflow-hidden mt-4">
          <div id="avg-range-bar" class="absolute inset-y-0 rounded-full bg-gradient-to-r from-accent/40 via-accent to-accent/40" style="left: 15%; right: 15%;"></div>
          <div id="price-marker" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 bg-accent rounded-full border-2 border-white shadow-lg"></div>
        </div>
        <p id="undercharge-warning" class="hidden text-yellow-400 text-sm font-medium mt-3">&#9888; Your price is below the national average low. Verify your margins before committing to this rate.</p>
      </div>

      <!-- Breakdown -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Materials Revenue</div>
          <div id="result-materials" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Labor Revenue</div>
          <div id="result-labor" class="font-heading font-extrabold text-xl text-text-primary">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Gross Profit</div>
          <div id="result-profit" class="font-heading font-extrabold text-xl text-[#34D399]">--</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Profit Margin</div>
          <div id="result-margin" class="font-heading font-extrabold text-xl">--</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Tool</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Select a repair type.</strong> Choose from common roofing repairs in the dropdown. The tool auto-fills typical material costs, labor hours, and markup. Or start from scratch with custom values.</p>
          <p><strong class="text-text-primary">2. Adjust for your market.</strong> Change the billable rate, markup percentage, and labor hours to match your company's pricing and efficiency. Add disposal or miscellaneous costs specific to the job.</p>
          <p><strong class="text-text-primary">3. Compare to the national average.</strong> The benchmark bar shows where your price falls relative to the national average range. If your price is below the low end, the tool warns you to check your margins.</p>
          <p><strong class="text-text-primary">4. Save your prices.</strong> Once you dial in your flat rate for each repair type, record it in your price book. Update quarterly as material costs change.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Why Flat Rate Pricing Works for Roofers</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>Flat rate pricing gives homeowners a clear, upfront price before any work begins. There are no surprises, no hourly clock ticking, and no disputes about how long the job took. The customer knows exactly what they are paying and can make a confident decision.</p>
          <p>For your crew, flat rate rewards speed and skill. A two-person team that finishes a flashing replacement in 45 minutes earns the same flat rate as a slower team that takes two hours. This incentivizes efficiency and directly improves your profit per hour.</p>
          <p>Flat rate also simplifies dispatching and estimating. Your office staff can quote common repairs over the phone without needing a site visit. Your technicians do not need to track time or calculate on the fly. The price is the price.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Building your price book.</strong> Go through every common repair your company performs and run it through this builder. Set your materials, labor, and markup to land within the national average range while maintaining your target margin.</p>
          <p><strong class="text-text-primary">Quoting standard repairs on the spot.</strong> When you identify a straightforward leak repair or pipe boot replacement on site, look up the flat rate in your book and present it immediately. No need to go back to the office to run numbers.</p>
          <p><strong class="text-text-primary">Sanity-checking your prices.</strong> If you are losing too many bids or your margins are shrinking, run your current flat rates through this tool. You may find you are undercharging on materials or underestimating labor time on certain repair types.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I build a roofing flat rate price book?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Start with your material costs and labor time for each repair type. Add your target markup to materials (30-45% is standard for roofing), multiply labor hours by your billable rate, and add overhead. Compare your calculated price to the national average range for that repair to make sure you are competitive but profitable. Build a library of your most common repairs and update prices quarterly.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should a roofing flat rate include?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A roofing flat rate should include all materials at your marked-up price, all labor needed to complete the repair, disposal of old materials, travel time built into overhead, warranty on workmanship, and a margin for unexpected complications. The customer sees one clear price with no surprises.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How much should I charge for a roof leak repair?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A standard roof leak repair typically ranges from $300 to $500 depending on the source and severity. Simple shingle replacements or small sealant repairs fall on the lower end, while repairs involving flashing, valley work, or multiple penetration points push toward the higher end. Emergency or storm-related repairs may command premium pricing.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Is flat rate or time-and-materials better for roofing?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Flat rate pricing is better for most roofing repair work because it gives the customer price certainty and rewards your crew for efficiency. A fast crew earns more per hour under flat rate. Time-and-materials works better for unknown-scope work like storm damage where you cannot predict the extent of repairs until tear-off. Many roofing companies use flat rate for standard repairs and T&M for investigation and complex restoration work.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // Task library with roofing-specific defaults
  interface TaskDef {
    partsCost: number;
    laborHours: number;
    markup: number;
    avgLow: number;
    avgHigh: number;
    misc: number;
    label: string;
  }

  const taskLibrary: Record<string, TaskDef> = {
    'inspection': { partsCost: 0, laborHours: 1, markup: 0, avgLow: 150, avgHigh: 300, misc: 0, label: 'Roof Inspection' },
    'leak-repair': { partsCost: 50, laborHours: 2, markup: 35, avgLow: 300, avgHigh: 500, misc: 25, label: 'Leak Repair' },
    'flashing-replace': { partsCost: 40, laborHours: 1.5, markup: 40, avgLow: 150, avgHigh: 350, misc: 15, label: 'Flashing Replacement (per 10 ft)' },
    'valley-repair': { partsCost: 80, laborHours: 3, markup: 35, avgLow: 400, avgHigh: 800, misc: 30, label: 'Valley Repair' },
    'ridge-vent': { partsCost: 50, laborHours: 1.5, markup: 35, avgLow: 200, avgHigh: 400, misc: 15, label: 'Ridge Vent Installation (per 10 ft)' },
    'emergency-tarp': { partsCost: 60, laborHours: 1.5, markup: 35, avgLow: 150, avgHigh: 400, misc: 20, label: 'Emergency Tarp / Board-Up' },
    'pipe-boot': { partsCost: 15, laborHours: 1, markup: 40, avgLow: 100, avgHigh: 250, misc: 10, label: 'Pipe Boot Replacement' },
    'shingle-repair': { partsCost: 40, laborHours: 1.5, markup: 35, avgLow: 200, avgHigh: 400, misc: 15, label: 'Shingle Repair (per bundle area)' },
  };

  let currentAvgLow = 0;
  let currentAvgHigh = 0;

  function calculate() {
    const partsCost = parseFloat((document.getElementById('parts-cost') as HTMLInputElement).value) || 0;
    const markupPct = parseFloat((document.getElementById('markup-pct') as HTMLInputElement).value) || 0;
    const laborHours = parseFloat((document.getElementById('labor-hours') as HTMLInputElement).value) || 0;
    const billableRate = parseFloat((document.getElementById('billable-rate') as HTMLInputElement).value) || 0;
    const miscCost = parseFloat((document.getElementById('misc-cost') as HTMLInputElement).value) || 0;
    const loadedWage = parseFloat((document.getElementById('loaded-wage') as HTMLInputElement).value) || 0;

    const materialsRevenue = partsCost * (1 + markupPct / 100);
    const laborRevenue = laborHours * billableRate;
    const totalPrice = materialsRevenue + laborRevenue + miscCost;

    const totalCost = partsCost + (laborHours * loadedWage) + miscCost;
    const grossProfit = totalPrice - totalCost;
    const profitMargin = totalPrice > 0 ? (grossProfit / totalPrice) * 100 : 0;

    document.getElementById('result-total')!.textContent = `$${totalPrice.toFixed(0)}`;
    document.getElementById('result-materials')!.textContent = `$${materialsRevenue.toFixed(0)}`;
    document.getElementById('result-labor')!.textContent = `$${laborRevenue.toFixed(0)}`;
    document.getElementById('result-profit')!.textContent = `$${grossProfit.toFixed(0)}`;

    const marginEl = document.getElementById('result-margin')!;
    marginEl.textContent = `${profitMargin.toFixed(1)}%`;
    marginEl.className = 'font-heading font-extrabold text-xl';
    if (profitMargin < 30) marginEl.classList.add('text-red-400');
    else if (profitMargin < 50) marginEl.classList.add('text-yellow-400');
    else marginEl.classList.add('text-[#34D399]');

    // Avg comparison
    const avgLowEl = document.getElementById('avg-low')!;
    const avgHighEl = document.getElementById('avg-high')!;

    if (currentAvgLow > 0 && currentAvgHigh > 0) {
      avgLowEl.textContent = `$${currentAvgLow}`;
      avgHighEl.textContent = `$${currentAvgHigh}`;

      const rangeMax = currentAvgHigh * 1.5;
      const lowPct = (currentAvgLow / rangeMax) * 100;
      const highPct = (currentAvgHigh / rangeMax) * 100;
      const pricePct = Math.min((totalPrice / rangeMax) * 100, 100);

      const rangeBar = document.getElementById('avg-range-bar') as HTMLElement;
      rangeBar.style.left = `${lowPct}%`;
      rangeBar.style.right = `${100 - highPct}%`;

      const priceMarker = document.getElementById('price-marker') as HTMLElement;
      priceMarker.style.left = `${pricePct}%`;

      const warning = document.getElementById('undercharge-warning')!;
      if (totalPrice < currentAvgLow && totalPrice > 0) {
        warning.classList.remove('hidden');
      } else {
        warning.classList.add('hidden');
      }
    } else {
      avgLowEl.textContent = '--';
      avgHighEl.textContent = '--';
      document.getElementById('undercharge-warning')!.classList.add('hidden');
    }
  }

  // Task select handler
  document.getElementById('task-select')?.addEventListener('change', () => {
    const taskKey = (document.getElementById('task-select') as HTMLSelectElement).value;
    if (taskKey && taskLibrary[taskKey]) {
      const task = taskLibrary[taskKey];
      (document.getElementById('parts-cost') as HTMLInputElement).value = String(task.partsCost);
      (document.getElementById('markup-pct') as HTMLInputElement).value = String(task.markup);
      (document.getElementById('labor-hours') as HTMLInputElement).value = String(task.laborHours);
      (document.getElementById('misc-cost') as HTMLInputElement).value = String(task.misc);
      currentAvgLow = task.avgLow;
      currentAvgHigh = task.avgHigh;
    } else {
      currentAvgLow = 0;
      currentAvgHigh = 0;
    }
    calculate();
  });

  // Auto-calculate on any input change
  document.querySelectorAll('#flat-rate-calc input, #flat-rate-calc select').forEach(el => {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  // Calculate on load
  calculate();
</script>
