      <!-- Benchmarks -->
      <div class="bg-bg-dark rounded-xl p-6">
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-4">Plumbing Overhead Benchmarks</h4>
        <div class="space-y-3">
