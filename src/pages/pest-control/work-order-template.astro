---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/pestControlTools';

const tool = getToolBySlug('work-order-template')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should be on a pest control work order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A complete pest control work order includes dispatch info (date, technician, priority), customer details, treatment area information (interior sqft, exterior perimeter, bait station count), target pest identification, products applied with EPA registration numbers, application rates, a safety checklist covering PPE and re-entry intervals, and technician signature with arrival and completion times."
      }
    },
    {
      "@type": "Question",
      "name": "Why do I need to record treatment data and measurements?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Treatment data like interior square footage treated, exterior perimeter linear feet, bait station count, and product application rates document what was done and where. These records are required by state pesticide regulations, critical for tracking treatment effectiveness over multiple visits, and protect your company from liability disputes about product usage."
      }
    },
    {
      "@type": "Question",
      "name": "Is pesticide application documentation legally required?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Most states require pest control operators to maintain detailed records of every pesticide application including the product name, EPA registration number, application rate, target pest, and area treated. These records must typically be kept for 3 to 7 years depending on the state. Failure to maintain proper records can result in license suspension and fines."
      }
    },
    {
      "@type": "Question",
      "name": "What safety information should be on a pest control work order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Safety documentation should include PPE worn during application, product SDS availability, re-entry interval communicated to the customer, bait station placement records, and any precautions for pets or children. This protects both the technician and the customer and is often required by state licensing boards."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="work-order-form">

    <!-- Section: Dispatch Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Dispatch Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-number">Work Order #</label>
        <input type="text" id="wo-number" value="WO-001" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-date">Date</label>
        <input type="date" id="wo-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-time">Time</label>
        <input type="time" id="wo-time" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="tech-name">Technician Name</label>
        <input type="text" id="tech-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="truck-number">Truck #</label>
        <input type="text" id="truck-number" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="priority">Priority</label>
        <select id="priority" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Routine" selected>Routine</option>
          <option value="Urgent">Urgent</option>
          <option value="Emergency">Emergency</option>
        </select>
      </div>
    </div>

    <!-- Section: Customer Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Customer Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-name">Customer Name</label>
        <input type="text" id="cust-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-address">Address</label>
        <input type="text" id="cust-address" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-phone">Phone</label>
        <input type="text" id="cust-phone" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="access-instructions">Access Instructions</label>
        <input type="text" id="access-instructions" placeholder="Gate code, lockbox, etc." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Job Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Job Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-type">Service Type</label>
        <select id="equip-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="General Pest">General Pest</option>
          <option value="Termite">Termite</option>
          <option value="Rodent">Rodent</option>
          <option value="Bed Bug">Bed Bug</option>
          <option value="Mosquito">Mosquito</option>
          <option value="Wildlife Exclusion">Wildlife Exclusion</option>
          <option value="Fumigation">Fumigation</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-make">Target Pest</label>
        <input type="text" id="equip-make" placeholder="e.g., German cockroach, Norway rat" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-model">Infestation Level</label>
        <input type="text" id="equip-model" placeholder="Light, Moderate, Heavy" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-serial">Service Agreement #</label>
        <input type="text" id="equip-serial" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="install-date">Last Treatment Date</label>
        <input type="date" id="install-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="filter-size">Property Sq Ft</label>
        <input type="text" id="filter-size" placeholder="e.g., 2,400 sq ft" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="refrigerant-type">Treatment Method</label>
        <select id="refrigerant-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Spray" selected>Spray</option>
          <option value="Bait">Bait</option>
          <option value="Dust">Dust</option>
          <option value="Gel">Gel</option>
          <option value="Trap">Trap</option>
          <option value="Fumigation">Fumigation</option>
          <option value="Other">Other</option>
        </select>
      </div>
    </div>

    <!-- Section: Service Details -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Service Details</h3>
    <div class="space-y-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="reported-issue">Reported Issue</label>
        <textarea id="reported-issue" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="diagnosis">Inspection Findings</label>
        <textarea id="diagnosis" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="work-performed">Treatment Performed</label>
        <textarea id="work-performed" rows="4" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
    </div>

    <!-- Section: Products Used -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Products Used</h3>
    <div class="mb-8">
      <div id="parts-table" class="space-y-3">
        <div class="grid grid-cols-[1fr_1fr_80px_40px] gap-3 items-end part-row">
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">Product Name</label>
            <input type="text" class="part-name w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">EPA Reg #</label>
            <input type="text" class="part-number w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">Qty</label>
            <input type="number" value="1" min="1" class="part-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">&nbsp;</label>
            <button type="button" class="remove-part-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove product">&times;</button>
          </div>
        </div>
      </div>
      <button type="button" id="add-part-btn" class="mt-3 text-accent hover:text-accent-hover transition-colors cursor-pointer text-sm font-medium">+ Add Product</button>
    </div>

    <!-- Section: Treatment Log -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Treatment Log</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="ref-added">Product Applied (oz)</label>
        <input type="number" id="ref-added" min="0" step="0.5" value="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="ref-recovered">Bait Stations Placed</label>
        <input type="number" id="ref-recovered" min="0" step="1" value="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Treatment Data -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Treatment Data</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="interior-sqft">Interior Treated (sq ft)</label>
        <input type="number" id="interior-sqft" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="exterior-lf">Exterior Perimeter (LF)</label>
        <input type="number" id="exterior-lf" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="bait-count">Bait Station Count</label>
        <input type="number" id="bait-count" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="trap-count">Trap Count</label>
        <input type="number" id="trap-count" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="entry-points">Entry Points Sealed</label>
        <input type="number" id="entry-points" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="activity-level">Activity Level (1-10)</label>
        <input type="number" id="activity-level" min="1" max="10" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2">Total Coverage (sq ft)</label>
        <div id="total-coverage-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="reentry-hours">Re-entry Interval (hrs)</label>
        <input type="number" id="reentry-hours" step="0.5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Safety Checklist -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Safety Checklist</h3>
    <div class="space-y-3 mb-8">
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-ppe" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-ppe" class="text-text-primary cursor-pointer">PPE Worn (gloves, respirator, goggles)</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-sds" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-sds" class="text-text-primary cursor-pointer">SDS Available On Site</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-reentry" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-reentry" class="text-text-primary cursor-pointer">Re-entry Interval Communicated</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-pets" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-pets" class="text-text-primary cursor-pointer">Pet / Child Precautions Noted</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-baitsecure" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-baitsecure" class="text-text-primary cursor-pointer">Bait Stations Secured / Tamper-Resistant</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-label" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-label" class="text-text-primary cursor-pointer">Applied Per Label Directions</label>
      </div>
    </div>

    <!-- Section: Completion -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Completion</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="time-arrived">Time Arrived</label>
        <input type="time" id="time-arrived" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="time-completed">Time Completed</label>
        <input type="time" id="time-completed" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2">Total Hours</label>
        <div id="total-hours-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="tech-signature">Technician Signature</label>
        <input type="text" id="tech-signature" placeholder="Type full name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Generate Button -->
    <button id="generate-btn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
      Generate Work Order &rarr;
    </button>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Template</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Fill in dispatch and customer info.</strong> Start with the work order number, date, and technician assignment. Add the customer's name, address, phone, and any access instructions like gate codes or lockbox combos.</p>
          <p><strong class="text-text-primary">2. Describe the job.</strong> Select the service type, identify the target pest, and note the infestation level. Record the treatment method and property square footage for accurate dosage calculations.</p>
          <p><strong class="text-text-primary">3. Document the service.</strong> Write what the customer reported, your inspection findings, and exactly what treatment was performed. Include specific areas treated and any exclusion work done.</p>
          <p><strong class="text-text-primary">4. Record treatment data and safety checks.</strong> Log interior treated area, exterior perimeter, bait station and trap counts. Run through the safety checklist — PPE, SDS availability, re-entry intervals, and pet/child precautions.</p>
          <p><strong class="text-text-primary">5. Generate the work order.</strong> Hit the button to create a clean, printable work order. Have the customer review it, then use it for your records, regulatory compliance, or office filing.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Goes on a Pest Control Work Order</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>A work order is the single document that proves what happened on a job. Every section exists for a reason.</p>
          <p><strong class="text-text-primary">Job identification</strong> — service type, target pest, and infestation level — ties the documentation to a specific service visit. This information is essential for tracking treatment effectiveness across multiple visits and meeting regulatory requirements.</p>
          <p><strong class="text-text-primary">Treatment data</strong> documents exactly what was applied and where. Interior square footage, exterior perimeter, bait station placement, and product application rates are required by state pesticide regulations. If a customer reports ongoing pest activity or an adverse reaction, your treatment data provides the full picture.</p>
          <p><strong class="text-text-primary">Product tracking</strong> is legally required. Every pesticide application must be logged with the product name, EPA registration number, application rate, and area treated. These records must be maintained for years and are subject to regulatory audits.</p>
          <p><strong class="text-text-primary">The safety checklist</strong> is your liability shield. Documenting PPE worn, SDS availability, re-entry intervals communicated, and pet/child precautions noted shows due diligence. If health concerns arise after treatment, that checklist is your first line of defense.</p>
          <p><strong class="text-text-primary">Products used</strong> with EPA registration numbers create a clear regulatory compliance record and help track inventory and reorder needs.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Routine treatment visits.</strong> Every pest control visit needs a work order. The technician fills it out on site — inspection findings, products applied, areas treated, and bait station placement. It becomes the permanent record and satisfies state pesticide documentation requirements.</p>
          <p><strong class="text-text-primary">Initial inspections and estimates.</strong> During first visits, the work order captures baseline activity levels, entry points found, and treatment recommendations. This creates a starting point for tracking treatment effectiveness over time.</p>
          <p><strong class="text-text-primary">Regulatory compliance and callbacks.</strong> When a state inspector asks for application records, or when a customer disputes what was done, the work order is your evidence. Complete work orders with products, rates, and safety documentation satisfy regulatory requirements and eliminate disputes.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should be on a pest control work order?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A complete pest control work order includes dispatch info (date, technician, priority), customer details, treatment area information (interior sqft, exterior perimeter, bait station count), target pest identification, products applied with EPA registration numbers, application rates, a safety checklist covering PPE and re-entry intervals, and technician signature with arrival and completion times.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why do I need to record treatment data and measurements?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Treatment data like interior square footage treated, exterior perimeter linear feet, bait station count, and product application rates document what was done and where. These records are required by state pesticide regulations, critical for tracking treatment effectiveness over multiple visits, and protect your company from liability disputes about product usage.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Is pesticide application documentation legally required?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Yes. Most states require pest control operators to maintain detailed records of every pesticide application including the product name, EPA registration number, application rate, target pest, and area treated. These records must typically be kept for 3 to 7 years depending on the state. Failure to maintain proper records can result in license suspension and fines.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What safety information should be on a pest control work order?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Safety documentation should include PPE worn during application, product SDS availability, re-entry interval communicated to the customer, bait station placement records, and any precautions for pets or children. This protects both the technician and the customer and is often required by state licensing boards.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  const now = new Date();
  const dateInput = document.getElementById('wo-date') as HTMLInputElement;
  const timeInput = document.getElementById('wo-time') as HTMLInputElement;
  if (dateInput && !dateInput.value) dateInput.value = now.toISOString().slice(0, 10);
  if (timeInput && !timeInput.value) timeInput.value = now.toTimeString().slice(0, 5);

  // --- Total Coverage auto-calculation ---
  function updateTotalCoverage() {
    const interior = parseFloat((document.getElementById('interior-sqft') as HTMLInputElement).value) || 0;
    const exterior = parseFloat((document.getElementById('exterior-lf') as HTMLInputElement).value) || 0;
    const display = document.getElementById('total-coverage-display')!;
    if (interior > 0 || exterior > 0) {
      display.textContent = interior.toLocaleString() + ' sq ft + ' + exterior.toLocaleString() + ' LF';
      display.className = 'w-full bg-bg-dark border border-green-500/50 rounded-lg px-4 py-3 text-lg font-bold text-green-400';
    } else {
      display.textContent = '\u2014';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted';
    }
  }
  document.getElementById('interior-sqft')?.addEventListener('input', updateTotalCoverage);
  document.getElementById('exterior-lf')?.addEventListener('input', updateTotalCoverage);

  function updateTotalHours() {
    const arrived = (document.getElementById('time-arrived') as HTMLInputElement).value;
    const completed = (document.getElementById('time-completed') as HTMLInputElement).value;
    const display = document.getElementById('total-hours-display')!;
    if (arrived && completed) {
      const [ah, am] = arrived.split(':').map(Number);
      const [ch, cm] = completed.split(':').map(Number);
      let totalMinutes = (ch * 60 + cm) - (ah * 60 + am);
      if (totalMinutes < 0) totalMinutes += 24 * 60;
      display.textContent = Math.floor(totalMinutes / 60) + 'h ' + (totalMinutes % 60) + 'm';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-primary';
    } else {
      display.textContent = '\u2014';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted';
    }
  }
  document.getElementById('time-arrived')?.addEventListener('input', updateTotalHours);
  document.getElementById('time-completed')?.addEventListener('input', updateTotalHours);

  function addPartRow() {
    const table = document.getElementById('parts-table')!;
    const row = document.createElement('div');
    row.className = 'grid grid-cols-[1fr_1fr_80px_40px] gap-3 items-end part-row';
    row.innerHTML = `<div><input type="text" class="part-name w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div><div><input type="text" class="part-number w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div><div><input type="number" value="1" min="1" class="part-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div><div><button type="button" class="remove-part-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove product">&times;</button></div>`;
    table.appendChild(row);
  }
  document.getElementById('add-part-btn')?.addEventListener('click', addPartRow);
  document.getElementById('parts-table')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('remove-part-btn')) {
      const row = target.closest('.part-row');
      if (document.querySelectorAll('.part-row').length > 1 && row) row.remove();
    }
  });

  function getVal(id: string): string {
    const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
    return el ? el.value : '';
  }
  function getChecked(id: string): boolean {
    return (document.getElementById(id) as HTMLInputElement)?.checked || false;
  }

  function generateWorkOrder() {
    const partRows = document.querySelectorAll('.part-row');
    let partsHtml = '';
    partRows.forEach(row => {
      const name = (row.querySelector('.part-name') as HTMLInputElement)?.value || '';
      const num = (row.querySelector('.part-number') as HTMLInputElement)?.value || '';
      const qty = (row.querySelector('.part-qty') as HTMLInputElement)?.value || '';
      if (name || num) partsHtml += `<tr><td style="border:1px solid #ddd;padding:6px 10px;">${name}</td><td style="border:1px solid #ddd;padding:6px 10px;">${num}</td><td style="border:1px solid #ddd;padding:6px 10px;text-align:center;">${qty}</td></tr>`;
    });

    const intSqft = parseFloat(getVal('interior-sqft')) || 0;
    const extLf = parseFloat(getVal('exterior-lf')) || 0;
    const totalCovStr = (intSqft > 0 || extLf > 0) ? intSqft.toLocaleString() + ' sq ft + ' + extLf.toLocaleString() + ' LF' : '';

    const arrived = getVal('time-arrived');
    const completed = getVal('time-completed');
    let totalHours = '';
    if (arrived && completed) {
      const [ah, am] = arrived.split(':').map(Number);
      const [ch, cm] = completed.split(':').map(Number);
      let totalMin = (ch * 60 + cm) - (ah * 60 + am);
      if (totalMin < 0) totalMin += 24 * 60;
      totalHours = Math.floor(totalMin / 60) + 'h ' + (totalMin % 60) + 'm';
    }

    const safetyItems = [
      { id: 'chk-ppe', label: 'PPE Worn (gloves, respirator, goggles)' },
      { id: 'chk-sds', label: 'SDS Available On Site' },
      { id: 'chk-reentry', label: 'Re-entry Interval Communicated' },
      { id: 'chk-pets', label: 'Pet / Child Precautions Noted' },
      { id: 'chk-baitsecure', label: 'Bait Stations Secured / Tamper-Resistant' },
      { id: 'chk-label', label: 'Applied Per Label Directions' },
    ];
    let safetyHtml = '';
    safetyItems.forEach(item => {
      safetyHtml += `<div style="margin-bottom:4px;">${getChecked(item.id) ? '&#9745;' : '&#9744;'} ${item.label}</div>`;
    });

    const html = `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Work Order ${getVal('wo-number')}</title>
<style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:#1a1a1a;padding:40px;max-width:850px;margin:0 auto;font-size:14px;line-height:1.5}h1{font-size:22px;margin-bottom:4px}h2{font-size:15px;color:#333;margin:20px 0 8px;padding-bottom:4px;border-bottom:2px solid #e5e5e5;text-transform:uppercase;letter-spacing:.5px}.header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;padding-bottom:16px;border-bottom:3px solid #1a1a1a}.header-right{text-align:right;font-size:13px;color:#555}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:4px 24px;margin-bottom:6px}.grid2 .label{font-weight:600;font-size:12px;color:#666;text-transform:uppercase;letter-spacing:.3px}.grid2 .value{font-size:14px;margin-bottom:6px}.text-block{margin-bottom:12px}.text-block .label{font-weight:600;font-size:12px;color:#666;text-transform:uppercase;letter-spacing:.3px;margin-bottom:2px}.text-block .value{font-size:14px;white-space:pre-wrap;background:#f9f9f9;padding:8px 10px;border-radius:4px;min-height:24px}table{width:100%;border-collapse:collapse;margin-bottom:8px}th{background:#f0f0f0;border:1px solid #ddd;padding:6px 10px;text-align:left;font-size:12px;text-transform:uppercase;letter-spacing:.3px}td{border:1px solid #ddd;padding:6px 10px}.readings-table td{text-align:center}.safety{font-size:14px}.signature-block{display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-top:40px;padding-top:16px}.sig-line{border-top:1px solid #1a1a1a;padding-top:6px;font-size:12px;color:#666;text-transform:uppercase}.sig-name{font-size:16px;font-weight:600;min-height:20px}.priority-badge{display:inline-block;padding:2px 10px;border-radius:4px;font-size:12px;font-weight:600;text-transform:uppercase}.priority-Routine{background:#e0f2e9;color:#166534}.priority-Urgent{background:#fef3c7;color:#92400e}.priority-Emergency{background:#fee2e2;color:#991b1b}@media print{body{padding:20px}}</style>
</head><body>
<div class="header"><div class="header-left"><h1>Pest Control Work Order</h1><div style="font-size:13px;color:#555;">Service Documentation</div></div><div class="header-right"><div style="font-size:20px;font-weight:700;">\${getVal('wo-number')}</div><div>\${getVal('wo-date')}</div><div>\${getVal('wo-time')}</div><span class="priority-badge priority-\${getVal('priority')}">\${getVal('priority')}</span></div></div>

<h2>Dispatch</h2><div class="grid2"><div><span class="label">Technician:</span></div><div><span class="label">Truck #:</span></div><div class="value">\${getVal('tech-name') || '\u2014'}</div><div class="value">\${getVal('truck-number') || '\u2014'}</div></div>

<h2>Customer</h2><div class="grid2"><div><span class="label">Name:</span></div><div><span class="label">Phone:</span></div><div class="value">\${getVal('cust-name') || '\u2014'}</div><div class="value">\${getVal('cust-phone') || '\u2014'}</div><div><span class="label">Address:</span></div><div><span class="label">Access:</span></div><div class="value">\${getVal('cust-address') || '\u2014'}</div><div class="value">\${getVal('access-instructions') || '\u2014'}</div></div>

<h2>Job Info</h2><div class="grid2"><div><span class="label">Service Type:</span></div><div><span class="label">Target Pest:</span></div><div class="value">\${getVal('equip-type')}</div><div class="value">\${getVal('equip-make') || '\u2014'}</div><div><span class="label">Infestation:</span></div><div><span class="label">Agreement #:</span></div><div class="value">\${getVal('equip-model') || '\u2014'}</div><div class="value">\${getVal('equip-serial') || '\u2014'}</div><div><span class="label">Last Treatment:</span></div><div><span class="label">Property Sq Ft:</span></div><div class="value">\${getVal('install-date') || '\u2014'}</div><div class="value">\${getVal('filter-size') || '\u2014'}</div><div><span class="label">Method:</span></div><div></div><div class="value">\${getVal('refrigerant-type')}</div><div></div></div>

<h2>Service Details</h2>
<div class="text-block"><div class="label">Reported Issue</div><div class="value">\${getVal('reported-issue') || '\u2014'}</div></div>
<div class="text-block"><div class="label">Inspection Findings</div><div class="value">\${getVal('diagnosis') || '\u2014'}</div></div>
<div class="text-block"><div class="label">Treatment Performed</div><div class="value">\${getVal('work-performed') || '\u2014'}</div></div>

\${partsHtml ? \`<h2>Products Used</h2><table><thead><tr><th>Product</th><th>EPA Reg #</th><th style="text-align:center;">Qty</th></tr></thead><tbody>\${partsHtml}</tbody></table>\` : ''}

<h2>Treatment Log</h2><div class="grid2"><div><span class="label">Product Applied:</span></div><div><span class="label">Bait Stations:</span></div><div class="value">\${getVal('ref-added') || '0'} oz</div><div class="value">\${getVal('ref-recovered') || '0'}</div></div>

<h2>Treatment Data</h2>
<table class="readings-table"><thead><tr><th>Interior Treated</th><th>Exterior Perimeter</th><th>Bait Stations</th><th>Traps</th></tr></thead><tbody><tr><td>\${getVal('interior-sqft') ? getVal('interior-sqft') + ' sq ft' : '\u2014'}</td><td>\${getVal('exterior-lf') ? getVal('exterior-lf') + ' LF' : '\u2014'}</td><td>\${getVal('bait-count') || '\u2014'}</td><td>\${getVal('trap-count') || '\u2014'}</td></tr></tbody></table>
<table class="readings-table" style="margin-top:8px;"><thead><tr><th>Entry Points Sealed</th><th>Activity Level</th><th>Total Coverage</th><th>Re-entry (hrs)</th></tr></thead><tbody><tr><td>\${getVal('entry-points') || '\u2014'}</td><td>\${getVal('activity-level') || '\u2014'}</td><td>\${totalCovStr || '\u2014'}</td><td>\${getVal('reentry-hours') ? getVal('reentry-hours') + ' hrs' : '\u2014'}</td></tr></tbody></table>

<h2>Safety Checklist</h2><div class="safety">\${safetyHtml}</div>

<h2>Completion</h2><div class="grid2"><div><span class="label">Time Arrived:</span></div><div><span class="label">Time Completed:</span></div><div class="value">\${arrived || '\u2014'}</div><div class="value">\${completed || '\u2014'}</div><div><span class="label">Total Hours:</span></div><div></div><div class="value">\${totalHours || '\u2014'}</div><div></div></div>

<div class="signature-block"><div><div class="sig-name">\${getVal('tech-signature') || ''}</div><div class="sig-line">Technician Signature</div></div><div><div class="sig-name">&nbsp;</div><div class="sig-line">Customer Signature</div></div></div>
</body></html>`;

    const printWindow = window.open('', '_blank');
    if (printWindow) { printWindow.document.write(html); printWindow.document.close(); }
  }

  document.getElementById('generate-btn')?.addEventListener('click', generateWorkOrder);
</script>
