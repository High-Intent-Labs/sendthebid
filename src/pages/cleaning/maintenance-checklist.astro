        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Empty trash and replace liner</span>
        </label>
      </div>
    </div>

    <!-- Bathrooms -->
    <div class="mb-8">
