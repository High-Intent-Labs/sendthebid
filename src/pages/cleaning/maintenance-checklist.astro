          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Wipe down electronics and screens (dry cloth)</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Fluff and straighten couch cushions and pillows</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Wipe light switches, door handles, and remotes</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Dust ceiling fan blades and light fixtures (reachable)</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Vacuum carpet or sweep and mop hard floors</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Vacuum area rugs and under furniture edges</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Empty trash and replace liner</span>
        </label>
      </div>
    </div>

    <!-- Laundry Room -->
    <div class="mb-8">
      <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Laundry Room
      </h3>
      <div class="space-y-3">
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Wipe exterior of washer and dryer</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Clean lint trap area and surrounding surfaces</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Wipe down counters, shelves, and folding area</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Clean laundry sink (if applicable)</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Sweep and mop floor</span>
        </label>
      </div>
    </div>

    <!-- Entryway / Hallways -->
    <div class="mb-8">
      <h3 class="font-heading font-bold text-lg text-text-primary mb-4 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Entryway &amp; Hallways
      </h3>
      <div class="space-y-3">
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Wipe front door, handle, and lockset</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Dust console table, shoe rack, and coat hooks</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Clean mirrors and wall art glass</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Wipe light switches, handrails, and banisters</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Vacuum or sweep hallway floors and entry mat</span>
        </label>
        <label class="flex items-start gap-3 cursor-pointer group">
          <input type="checkbox" class="cl-check mt-1 w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent shrink-0" />
          <span class="text-text-secondary group-hover:text-text-primary transition-colors">Dust stairway treads and risers</span>
        </label>
