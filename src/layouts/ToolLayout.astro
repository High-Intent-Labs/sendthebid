---
import BaseLayout from './BaseLayout.astro';
import AccountCreationCard from '../components/AccountCreationCard.astro';
import EmailCaptureCard from '../components/EmailCaptureCard.astro';
import { categoryColors, type Tool } from '../data/types';

interface Props {
  tool: Tool;
  extraSchema?: Record<string, unknown>[];
}

const { tool, extraSchema = [] } = Astro.props;

// Dynamic imports — resolve the trade's tool utilities at build time
const tradeModules: Record<string, () => Promise<{ getRelatedTools: (slug: string) => Tool[] }>> = {
  hvac: () => import('../data/hvacTools'),
  electrical: () => import('../data/electricalTools'),
  roofing: () => import('../data/roofingTools'),
  painting: () => import('../data/paintingTools'),
  landscaping: () => import('../data/landscapingTools'),
  gc: () => import('../data/gcTools'),
  handyman: () => import('../data/handymanTools'),
  'pest-control': () => import('../data/pestControlTools'),
  cleaning: () => import('../data/cleaningTools'),
  plumbing: () => import('../data/plumbingTools'),
};

let relatedTools: Tool[] = [];
const loader = tradeModules[tool.tradeSlug];
if (loader) {
  const mod = await loader();
  relatedTools = mod.getRelatedTools(tool.slug);
}

const catColor = categoryColors[tool.category];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://nailthequote.com/" },
    { "@type": "ListItem", "position": 2, "name": `${tool.tradeName} Tools`, "item": `https://nailthequote.com/${tool.tradeSlug}/` },
    { "@type": "ListItem", "position": 3, "name": tool.name }
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": tool.name,
  "description": tool.metaDescription,
  "url": `https://nailthequote.com/${tool.tradeSlug}/${tool.slug}`,
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "creator": {
    "@type": "Organization",
    "name": "NailTheQuote"
  }
};
---

<BaseLayout
  title={tool.seoTitle}
  description={tool.metaDescription}
  currentPath={`/${tool.tradeSlug}/${tool.slug}`}
  schema={[breadcrumbSchema, webAppSchema, ...extraSchema]}
>
  <!-- Breadcrumb -->
  <nav class="max-w-[1080px] mx-auto px-6 md:px-12 pt-4 pb-2" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-text-muted">
      <li><a href="/" class="hover:text-text-secondary transition-colors no-underline">Home</a></li>
      <li class="before:content-['/'] before:mx-2"><a href={`/${tool.tradeSlug}/`} class="hover:text-text-secondary transition-colors no-underline">{tool.tradeName} Tools</a></li>
      <li class="before:content-['/'] before:mx-2 text-text-secondary">{tool.shortName}</li>
    </ol>
  </nav>

  <!-- Tool header -->
  <div class="max-w-[1080px] mx-auto px-6 md:px-12 pt-6 pb-8">
    <div class="flex items-center gap-3 mb-4">
      <span class:list={["text-[11px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded", catColor.text, catColor.bg]}>
        {tool.categoryLabel}
      </span>
      <span class="text-text-muted text-xs">Free &middot; No login required</span>
    </div>
    <h1 class="font-heading font-extrabold text-3xl md:text-5xl tracking-tight mb-3">{tool.name}</h1>
    <p class="text-text-secondary text-lg max-w-2xl">{tool.description}</p>
  </div>

  <!-- Calculator area -->
  <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16">
    <div class="bg-bg-card border border-border rounded-2xl p-6 md:p-8">
      <slot />
    </div>
  </div>

  <!-- Account creation card -->
  <div class="max-w-[1080px] mx-auto px-6 md:px-12 -mt-8 pb-4">
    <AccountCreationCard
      toolName={tool.name}
      toolSlug={tool.slug}
      tradeSlug={tool.tradeSlug}
      tradeName={tool.tradeName}
      category={tool.category}
    />
  </div>

  <!-- Email capture card -->
  <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16">
    <EmailCaptureCard
      toolName={tool.name}
      toolSlug={tool.slug}
      tradeSlug={tool.tradeSlug}
      tradeName={tool.tradeName}
    />
  </div>

  <!-- Content sections (How to Use, How It Works, etc.) -->
  <slot name="content" />

  <!-- Related Tools -->
  {relatedTools.length > 0 && (
    <section class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16">
      <h2 class="font-heading font-bold text-2xl mb-6">Related {tool.tradeName} Tools</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {relatedTools.map(rt => {
          const rc = categoryColors[rt.category];
          return (
            <a href={`/${rt.tradeSlug}/${rt.slug}`} class="bg-bg-card border border-border rounded-xl p-5 no-underline hover:border-[#3A4755] hover:bg-bg-card-hover hover:-translate-y-0.5 transition-all">
              <span class:list={["text-[11px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded inline-block mb-2", rc.text, rc.bg]}>
                {rt.categoryLabel}
              </span>
              <h3 class="font-heading font-bold text-base text-text-primary mb-1">{rt.shortName}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{rt.shortDescription}</p>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- Back to hub CTA -->
  <div class="text-center py-12 border-t border-border max-w-[1080px] mx-auto">
    <a href={`/${tool.tradeSlug}/`} class="inline-flex items-center gap-2 text-accent font-semibold text-sm hover:gap-3 transition-all no-underline">
      &larr; View all {tool.tradeName} tools
    </a>
  </div>

  <!-- Restore inputs from URL parameters (runs before profile auto-fill) -->
  <script>
    (() => {
      try {
        const params = new URLSearchParams(window.location.search);
        if (params.size === 0) return;
        params.forEach((value, key) => {
          const el = document.getElementById(key) as HTMLInputElement | HTMLSelectElement | null
            || document.querySelector<HTMLInputElement | HTMLSelectElement>(`[name="${key}"]`);
          if (!el) return;
          // Skip inputs inside account/email cards
          if (el.closest('#email-capture-card') || el.closest('#signup-modal')) return;
          el.value = value;
          el.dispatchEvent(new Event('input', { bubbles: true }));
        });
      } catch { /* silent */ }
    })();
  </script>

  <!-- Auto-fill profile data for logged-in users -->
  <script>
    (async () => {
      try {
        const session = JSON.parse(localStorage.getItem('ntq_session') || '{}');
        if (!session.access_token) return;

        const res = await fetch('/api/auth/me', {
          headers: { Authorization: `Bearer ${session.access_token}` },
        });
        if (!res.ok) return;

        const { profile } = await res.json();
        if (!profile) return;

        // Map profile fields to common form field patterns
        const fieldMap: [string[], string][] = [
          [['company', 'business', 'company-name', 'business-name'], profile.business_name],
          [['owner', 'tech-name', 'owner-name', 'your-name'], profile.owner_name],
          [['phone', 'company-phone', 'your-phone'], profile.phone],
          [['email', 'company-email', 'your-email'], profile.email],
          [['license', 'license-number', 'license-num'], profile.license_number],
          [['hourly-rate', 'labor-rate', 'billable-rate', 'rate'], profile.default_hourly_rate],
          [['markup', 'parts-markup', 'materials-markup'], profile.default_markup],
        ];

        // Fill inputs by matching placeholder text, label text, name, or id
        const inputs = document.querySelectorAll<HTMLInputElement>('input[type="text"], input[type="tel"], input[type="email"], input[type="number"]');
        inputs.forEach(input => {
          // Skip if user already typed something or URL params pre-filled the value
          if (input.value && input.value !== input.defaultValue) return;

          // Skip email capture card and signup modal inputs
          if (input.closest('#email-capture-card') || input.closest('#signup-modal')) return;

          const label = input.closest('div')?.querySelector('label')?.textContent?.toLowerCase() || '';
          const id = (input.id || '').toLowerCase();
          const name = (input.name || '').toLowerCase();
          const dataField = (input.getAttribute('data-field') || '').toLowerCase();
          // Only use placeholder if it looks like a field hint, not an example email
          const placeholder = (input.placeholder || '').toLowerCase();
          const safePlaceholder = placeholder.includes('@') ? '' : placeholder;
          const searchStr = `${safePlaceholder} ${label} ${id} ${name} ${dataField}`;

          for (const [patterns, value] of fieldMap) {
            if (!value) continue;
            for (const pattern of patterns) {
              if (searchStr.includes(pattern)) {
                input.value = String(value);
                input.dispatchEvent(new Event('input', { bubbles: true }));
                return; // Only fill once per input
              }
            }
          }
        });
      } catch { /* silent — don't break the page */ }
    })();
  </script>
</BaseLayout>
