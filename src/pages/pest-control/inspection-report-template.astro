</table>

<h2>Activity Observations</h2>
<table>
  <thead><tr><th>Live Pests</th><th>Evidence Sites</th><th>Activity Level</th><th>Entry Points</th><th>Moisture (%)</th><th>Bait Activity</th></tr></thead>
  <tbody><tr>
    <td style="text-align:center;">${getVal('supply-temp') || '\u2014'}</td>
    <td style="text-align:center;">${getVal('return-temp') || '\u2014'}</td>
    <td style="text-align:center;font-weight:700;">${document.getElementById('temp-split-display')?.textContent || '\u2014'}</td>
    <td style="text-align:center;">${getVal('co-reading') || '\u2014'}</td>
    <td style="text-align:center;">${getVal('gas-pressure') ? getVal('gas-pressure') + '%' : '\u2014'}</td>
    <td style="text-align:center;">${getVal('static-pressure') || '\u2014'}</td>
  </tr></tbody>
</table>

${findingsHtml ? `<h2>Findings &amp; Recommendations</h2>
<table>
  <thead><tr><th>Description</th><th>Recommended Action</th><th style="text-align:right;">Est. Cost</th><th style="text-align:center;">Priority</th></tr></thead>
  <tbody>${findingsHtml}</tbody>
</table>` : ''}

<h2>Summary</h2>
<div class="summary-grid">
  <div class="summary-box">
    <div class="num" style="color:#16a34a;">${greenCount}</div>
    <div class="lbl">Good Condition</div>
  </div>
  <div class="summary-box">
    <div class="num" style="color:#ca8a04;">${yellowCount + redCount}</div>
    <div class="lbl">Needs Attention</div>
  </div>
  <div class="summary-box">
    <div class="num" style="color:#ea580c;">$${totalCost.toLocaleString()}</div>
    <div class="lbl">Total Repair Cost</div>
  </div>
  <div class="summary-box">
    <div class="assess-badge" style="background:${assessBg};color:${assessColor};">${assessment}</div>
    <div class="lbl" style="margin-top:8px;">Overall Assessment</div>
  </div>
</div>

${getVal('additional-notes') ? `<div style="margin-top:12px;"><span class="label">Additional Notes:</span><div class="value" style="background:#f9f9f9;padding:10px;border-radius:4px;white-space:pre-wrap;margin-top:4px;">${getVal('additional-notes')}</div></div>` : ''}

<div class="disclaimer">
