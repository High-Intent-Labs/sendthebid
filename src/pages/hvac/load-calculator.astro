---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/hvacTools';

const tool = getToolBySlug('load-calculator')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is this a Manual J calculation?",
      "acceptedAnswer": { "@type": "Answer", "text": "No — this is a simplified whole-house load estimator for pre-quote sanity checks. It's not permit-ready. For ACCA-stamped Manual J reports, use ACCA-accredited software. This tool gets you to within 15-20% of a full Manual J in 60 seconds, which is all most sales conversations need." }
    },
    {
      "@type": "Question",
      "name": "How accurate is this compared to a full load calculation?",
      "acceptedAnswer": { "@type": "Answer", "text": "Within 15-20% of a proper Manual J, typically. The main factors this tool doesn't capture are exact R-values, window SHGC ratings, duct losses, infiltration rate, and individual window orientations. Fine for sizing sanity checks. Not fine for permit applications." }
    },
    {
      "@type": "Question",
      "name": "Why do I need to enter a ZIP code?",
      "acceptedAnswer": { "@type": "Answer", "text": "Climate zone dramatically affects both cooling and heating loads. A 2,000 sqft home in Phoenix needs ~40% more cooling capacity than the same home in Seattle. Your ZIP maps to one of five climate regions (Hot / Warm / Mixed / Cool / Cold) that we use as a multiplier on the base load." }
    },
    {
      "@type": "Question",
      "name": "Does this work for mini-splits or ductless systems?",
      "acceptedAnswer": { "@type": "Answer", "text": "This tool sizes the whole-house load. For sizing an individual mini-split in a specific room, use our Mini-Split Sizing Calculator instead — it accounts for room dimensions, orientation, and exposed walls per-room, which matters a lot at the room level." }
    },
    {
      "@type": "Question",
      "name": "Why is heating BTU different from cooling BTU?",
      "acceptedAnswer": { "@type": "Answer", "text": "Cooling and heating loads are driven by different design conditions. In hot climates, cooling load dominates; in cold climates, heating load dominates. We apply a heating factor based on climate region to estimate the heating side — this matters especially for heat pump sizing where you need to know which load is bigger." }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]} hideCards>
  <div id="lc-calc">
    <!-- ZIP + climate display -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-text-secondary mb-2" for="zip">ZIP Code</label>
      <input type="text" id="zip" inputmode="numeric" maxlength="5" placeholder="e.g. 85001"
        class="w-full sm:max-w-[180px] bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      <!-- zip-display hosts one of four states injected by JS:
           empty / partial / resolved (pro card with city + state +
           climate + IECC zone + design temps) / unrecognized. -->
      <div id="zip-display" class="mt-3 text-text-secondary text-sm"></div>
      <div id="zip-fallback" class="hidden mt-3">
        <p class="text-text-muted text-xs mb-2">ZIP not found — pick your climate region:</p>
        <div class="flex flex-wrap gap-2">
          <button type="button" data-region="hot"   class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Hot</button>
          <button type="button" data-region="warm"  class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Warm</button>
          <button type="button" data-region="mixed" class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Mixed</button>
          <button type="button" data-region="cool"  class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Cool</button>
          <button type="button" data-region="cold"  class="region-pill bg-bg-dark border border-border rounded-lg px-3 py-1.5 text-sm hover:border-accent transition-colors">Cold</button>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="sqft">Square Footage</label>
        <div class="number-stepper flex items-stretch bg-bg-dark border border-border rounded-lg focus-within:border-accent transition-colors overflow-hidden">
          <button type="button" aria-label="Decrease square footage" class="stepper-minus px-4 text-text-secondary hover:text-accent text-2xl font-bold leading-none select-none">−</button>
          <input type="number" id="sqft" value="2000" min="200" max="20000" step="50"
            class="flex-1 bg-transparent text-text-primary text-lg text-center focus:outline-none min-w-0 py-3 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
          <button type="button" aria-label="Increase square footage" class="stepper-plus px-4 text-text-secondary hover:text-accent text-2xl font-bold leading-none select-none">+</button>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="ceiling">Ceiling Height (ft)</label>
        <div class="relative">
          <select id="ceiling"
            class="appearance-none w-full bg-bg-dark border border-border rounded-lg px-4 pr-10 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
            <option value="7">7 ft</option>
            <option value="8" selected>8 ft</option>
            <option value="9">9 ft</option>
            <option value="10">10 ft</option>
            <option value="11">11 ft</option>
            <option value="12">12 ft</option>
            <option value="13">13 ft</option>
            <option value="14">14 ft</option>
            <option value="15">15 ft</option>
            <option value="16">16 ft</option>
            <option value="17">17 ft</option>
            <option value="18">18 ft</option>
            <option value="19">19 ft</option>
            <option value="20">20 ft</option>
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-text-primary"
            fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="insulation">Insulation Quality</label>
        <select id="insulation" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="excellent">Excellent</option>
          <option value="better">Better than average</option>
          <option value="average" selected>Average</option>
          <option value="worse">Worse than average</option>
          <option value="bad">Bad</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="sun">Sun Exposure</label>
        <select id="sun" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="lots">A large amount</option>
          <option value="medium" selected>A medium amount</option>
          <option value="little">Little or none</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="windows">Amount of Windows</label>
        <select id="windows" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="standard" selected>Standard amount</option>
          <option value="many">Many (more than standard)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="tightness">Windows &amp; Doors Tightness</label>
        <select id="tightness" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="sealed">Sealed tight &amp; double-paned</option>
          <option value="typical" selected>Typical fit and seal</option>
          <option value="leaky">Not well-sealed &amp; single-paned</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="occupants">Occupants</label>
        <select id="occupants" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="2" selected>2 or less</option>
          <option value="3">3</option>
          <option value="4">4</option>
          <option value="5">5</option>
          <option value="6">6</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="devices">Extra Devices (heat-generating)</label>
        <select id="devices" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="0" selected>0</option>
          <option value="600">1</option>
          <option value="1200">2</option>
          <option value="1800">3</option>
          <option value="2400">4</option>
          <option value="3000">5</option>
          <option value="3600">6</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="kitchen">Kitchen?</label>
        <select id="kitchen" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="yes" selected>Yes</option>
          <option value="no">No</option>
        </select>
      </div>
    </div>

    <div id="calc-btn-area" class="mt-2">
      <button id="calculate-btn" type="button"
        class="w-full bg-accent hover:bg-accent-hover text-white font-heading font-bold text-lg px-8 py-4 rounded-xl transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
        Calculate My Load
      </button>
      <p id="calc-hint" class="hidden mt-3 text-sm text-[#EF4444]"></p>
    </div>

    <div id="email-gate" class="hidden mt-8 border-t border-border pt-8">
      <div class="max-w-lg mx-auto text-center">
        <div class="w-14 h-14 rounded-2xl bg-accent/15 flex items-center justify-center mx-auto mb-4">
          <svg width="28" height="28" viewBox="0 0 20 20" fill="none" class="text-accent">
            <path d="M2.5 6.667L9.025 11.05a1.667 1.667 0 001.95 0L17.5 6.667M4.167 15h11.666A1.667 1.667 0 0017.5 13.333V6.667A1.667 1.667 0 0015.833 5H4.167A1.667 1.667 0 002.5 6.667v6.666A1.667 1.667 0 004.167 15z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="font-heading font-bold text-xl text-text-primary mb-2">Your results are ready</h3>
        <p class="text-text-secondary text-sm mb-6">Enter your email to get your whole-house load calculation — cooling BTU, heating BTU, and system tonnage.</p>
        <div class="flex flex-col sm:flex-row gap-3 mb-3">
          <label for="gate-email" class="sr-only">Your work email</label>
          <input type="email" id="gate-email" placeholder="your email" required
            class="flex-1 bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-base focus:border-accent focus:outline-none transition-colors placeholder:text-text-muted" />
          <button id="gate-submit" type="button"
            class="bg-accent hover:bg-accent-hover text-white font-semibold px-6 py-3 rounded-lg transition-colors whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed">
            Send My Results
          </button>
        </div>
        <label class="flex items-center justify-center gap-2 cursor-pointer select-none">
          <input type="checkbox" id="gate-consent" checked class="w-4 h-4 rounded border-border bg-bg-dark accent-gray-500 opacity-70" />
          <span class="text-text-muted text-xs">Also send me free tools and tips for pros. Unsubscribe anytime.</span>
        </label>
        <div id="gate-error" class="hidden mt-3 text-sm text-[#EF4444]"></div>
      </div>
    </div>

    <div id="results" class="hidden mt-8 border-t border-border pt-8">
      <div class="mb-6 bg-[rgba(52,211,153,0.08)] border border-[rgba(52,211,153,0.25)] rounded-xl p-4 flex items-start gap-3">
        <div class="shrink-0 w-8 h-8 rounded-full bg-[rgba(52,211,153,0.15)] flex items-center justify-center">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" class="text-[#34D399]">
            <path d="M16.667 5L7.5 14.167 3.333 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <p class="text-text-primary font-semibold text-sm">Results also sent to your inbox</p>
          <p class="text-text-secondary text-xs mt-0.5">Don't see it? Check your Spam or Promotions folder.</p>
        </div>
      </div>

      <h3 class="font-heading font-bold text-xl mb-6">Your Load Calculation</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Cooling Load</div>
          <div id="r-cool" class="font-heading font-extrabold text-2xl text-accent">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Heating Load</div>
          <div id="r-heat" class="font-heading font-extrabold text-2xl text-text-primary">—</div>
        </div>
        <div class="bg-bg-dark rounded-xl p-5 text-center">
          <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">System Tonnage</div>
          <div id="r-tons" class="font-heading font-extrabold text-2xl text-text-primary">—</div>
        </div>
      </div>
      <p class="text-text-muted text-sm italic">Estimate only. For permit-ready Manual J, use ACCA-accredited software.</p>
    </div>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Calculator</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter a ZIP code.</strong> Auto-detects the climate region — a major factor in both cooling and heating load.</p>
          <p><strong class="text-text-primary">2. Add square footage and ceiling height.</strong> Total conditioned living space only. Exclude unfinished basements, garages, and unconditioned attics.</p>
          <p><strong class="text-text-primary">3. Rate insulation and window/door tightness.</strong> A 1980s retrofit with single-pane windows is "Bad" / "Not well-sealed." A 2020s tight envelope is "Excellent" / "Sealed tight."</p>
          <p><strong class="text-text-primary">4. Set sun, window count, and internal gains.</strong> South/west-facing homes with lots of glass take heavy cooling load. Each extra occupant adds ~600 BTU. Devices × 3.412 = BTU.</p>
          <p><strong class="text-text-primary">5. Click Calculate.</strong> Enter your email. We'll send the full results so you can reference them on-site or attach to a quote.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How the Calculation Works</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>We use a 20 BTU/sqft baseline with six adjustment factors (climate, insulation, sun, windows, tightness, ceiling height), then add internal gains for occupants, devices, and kitchen equipment.</p>
          <div class="bg-bg-card border border-border rounded-lg p-4 font-mono text-sm overflow-x-auto">
            <p>base = sqft × 20 × (ceiling / 8)</p>
            <p class="mt-2">modSum = climate + insulation + sun + windows + tightness</p>
            <p class="mt-2">coolingBTU = base × (1 + modSum) + occupants + devices + kitchen</p>
            <p class="mt-2">heatingBTU = coolingBTU × heatingFactor(region)</p>
            <p class="mt-2">tonnage = round(coolingBTU / 12,000, 0.5)</p>
          </div>
          <p>Climate regions range from +10% (Hot) to -10% (Cold). Heating factor ranges from 0.70 (Hot) to 1.45 (Cold) — so a home in Minneapolis will have a heating load roughly 1.5× the cooling load, while a home in Phoenix will have heating at ~70% of cooling.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When You Need a Full Manual J</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>This tool is a pre-quote sanity check. Accurate enough to keep you from badly oversizing or undersizing a system in a sales conversation, and to back up a quote with a defensible number.</p>
          <p>You need a full ACCA Manual J when:</p>
          <ul class="list-disc list-inside space-y-1 ml-2">
            <li>The job requires a permit (most new construction, many major replacements)</li>
            <li>The homeowner is pursuing ENERGY STAR certification or rebate programs</li>
            <li>A HERS rater or building department is involved</li>
            <li>Equipment warranties require a Manual J for the full capacity</li>
          </ul>
          <p>For those cases, use ACCA-accredited Manual J software — free options exist alongside the paid industry standards.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Is this a Manual J calculation?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">No. This is a simplified whole-house estimator for pre-quote sanity checks — not permit-ready. For ACCA-approved Manual J, use ACCA-accredited software.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How accurate is this compared to a full load calc?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Within 15-20% of a proper Manual J. Doesn't capture exact R-values, window SHGC, duct losses, infiltration, or per-wall window orientation. Fine for sanity checks. Not fine for permits.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why does the ZIP matter so much?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Climate dominates HVAC sizing. A 2,000 sqft home in Phoenix needs roughly 40% more cooling than the same home in Seattle. ZIP → one of five regions (Hot / Warm / Mixed / Cool / Cold) with its own multipliers.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Does this work for mini-splits?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">This is whole-house. For sizing an individual mini-split in a specific room, use our <a href="/hvac/mini-split-sizing-calculator/" class="text-accent hover:underline">Mini-Split Sizing Calculator</a>.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why is heating BTU different from cooling BTU?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Different design conditions. In hot climates, cooling dominates. In cold climates, heating dominates. Heat pump sizing especially requires knowing which load is bigger — you size for the bigger of the two.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  import { lookupZip, lookupRegion, REGIONS } from '../../lib/climate';
  import type { Region } from '../../lib/climate';
  import { calcWholeHouse } from '../../lib/hvac-calc';
  import type {
    WholeHouseInputs, InsulationGrade, SunExposure, WindowAmount, Tightness,
    WholeHouseResult,
  } from '../../lib/hvac-calc';
  import { initSteppers } from '../../lib/stepper';

  // Wire up +/- buttons on numeric inputs (mobile-friendly)
  initSteppers();

  let climate: ReturnType<typeof lookupZip> = null;
  const zipInput = document.getElementById('zip') as HTMLInputElement;
  const zipDisplay = document.getElementById('zip-display')!;
  const zipFallback = document.getElementById('zip-fallback')!;

  // ZIP card rendering + enrichment --------------------------------------
  // Sync path uses lookupZip for the climate region (drives the calc).
  // Async path hits /api/zip-lookup to enrich the card with city name,
  // IECC zone, and design temps — display only, never affects calculation.
  type ZipCardState = {
    kind: 'empty' | 'partial' | 'unrecognized' | 'manual';
  } | {
    kind: 'resolved';
    zip: string;
    city: string | null;
    state: string;
    regionLabel: string;
    ieccZone?: string;
    designCoolingDB?: number;
    designHeatingDB?: number;
  };

  function escapeHtml(s: string): string {
    return String(s).replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    } as Record<string, string>)[c]);
  }

  function renderZipCard(s: ZipCardState) {
    if (s.kind === 'empty') {
      zipDisplay.innerHTML = '';
      return;
    }
    if (s.kind === 'partial') {
      zipDisplay.innerHTML = '<span class="text-text-muted text-sm">Keep typing — 5 digits total.</span>';
      return;
    }
    if (s.kind === 'unrecognized') {
      zipDisplay.innerHTML = '<span class="text-text-muted text-sm">ZIP not recognized.</span>';
      return;
    }
    if (s.kind === 'manual') {
      // Set by the region-pill handler below with its own markup.
      return;
    }
    // resolved
    const place = s.city ? `${escapeHtml(s.city)}, ${escapeHtml(s.state)}` : escapeHtml(s.state);
    const iecc = s.ieccZone ? ` <span class="text-text-muted">(IECC ${escapeHtml(s.ieccZone)})</span>` : '';
    const designLine = (s.designCoolingDB != null && s.designHeatingDB != null)
      ? `<div class="text-sm text-text-muted mt-0.5">Design temp: ${s.designCoolingDB}°F cooling / ${s.designHeatingDB}°F heating</div>`
      : '';
    zipDisplay.innerHTML = `
      <div class="rounded-lg border border-border bg-bg-dark/60 p-4">
        <div class="flex items-center gap-2 text-text-primary font-medium">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>${place} · ${escapeHtml(s.zip)}</span>
        </div>
        <div class="mt-1 text-sm text-text-secondary">Climate: <span class="text-accent font-medium">${escapeHtml(s.regionLabel)}</span>${iecc}</div>
        ${designLine}
      </div>`;
  }

  let zipLookupAbort: AbortController | null = null;
  let zipLookupTimer: number | null = null;

  function setClimateFromZip(raw: string) {
    const zip = raw.replace(/\D/g, '').slice(0, 5);

    if (zipLookupAbort) { zipLookupAbort.abort(); zipLookupAbort = null; }
    if (zipLookupTimer !== null) { window.clearTimeout(zipLookupTimer); zipLookupTimer = null; }

    if (zip.length === 0) {
      climate = null;
      renderZipCard({ kind: 'empty' });
      zipFallback.classList.add('hidden');
      return;
    }
    if (zip.length < 5) {
      climate = null;
      renderZipCard({ kind: 'partial' });
      zipFallback.classList.add('hidden');
      return;
    }

    // 5 digits entered — sync lookup drives the calculation
    const lookup = lookupZip(zip);
    if (!lookup) {
      climate = null;
      renderZipCard({ kind: 'unrecognized' });
      zipFallback.classList.remove('hidden');
      return;
    }
    climate = lookup;
    zipFallback.classList.add('hidden');

    // Render what we know synchronously (no city, no IECC yet)
    renderZipCard({
      kind: 'resolved',
      zip,
      city: null,
      state: lookup.state,
      regionLabel: lookup.regionLabel,
    });

    // Debounced async enrichment via /api/zip-lookup
    zipLookupTimer = window.setTimeout(() => {
      zipLookupAbort = new AbortController();
      fetch(`/api/zip-lookup?zip=${zip}`, { signal: zipLookupAbort.signal })
        .then((r) => (r.ok ? r.json() : null))
        .then((data: any) => {
          if (!data || data.error) return;
          renderZipCard({
            kind: 'resolved',
            zip: data.zip,
            city: data.city ?? null,
            state: data.state,
            regionLabel: data.regionLabel,
            ieccZone: data.ieccZone,
            designCoolingDB: data.designCoolingDB,
            designHeatingDB: data.designHeatingDB,
          });
          (window as any).posthog?.capture('zip_resolved', {
            tool_slug: 'load-calculator',
            trade_slug: 'hvac',
            zip: data.zip,
            city: data.city,
            state: data.state,
            climate_region: data.region,
            iecc_zone: data.ieccZone,
          });
        })
        .catch(() => { /* aborted / network — sync card still visible */ });
    }, 250) as unknown as number;
  }
  zipInput.addEventListener('input', () => setClimateFromZip(zipInput.value));

  document.querySelectorAll<HTMLButtonElement>('.region-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      const region = btn.dataset.region as Region;
      climate = lookupRegion(region, zipInput.value, '');
      const meta = REGIONS[region];
      zipDisplay.innerHTML = `
        <div class="rounded-lg border border-border bg-bg-dark/60 p-4">
          <div class="text-text-primary font-medium">Manual region selection</div>
          <div class="mt-1 text-sm text-text-secondary">Climate: <span class="text-accent font-medium">${escapeHtml(meta.label)}</span> <span class="text-text-muted">(ZIP not in our database)</span></div>
        </div>`;
      zipFallback.classList.add('hidden');
      document.querySelectorAll<HTMLButtonElement>('.region-pill').forEach(b => b.classList.remove('border-accent'));
      btn.classList.add('border-accent');
    });
  });

  let pendingResult: WholeHouseResult | null = null;
  let pendingInputs: WholeHouseInputs | null = null;
  const calcBtn = document.getElementById('calculate-btn') as HTMLButtonElement;
  const calcHint = document.getElementById('calc-hint')!;

  function readInputs(): WholeHouseInputs | null {
    if (!climate) {
      calcHint.textContent = 'Please enter a valid ZIP code.';
      calcHint.classList.remove('hidden');
      return null;
    }
    calcHint.classList.add('hidden');
    return {
      climate,
      sqft: parseFloat((document.getElementById('sqft') as HTMLInputElement).value) || 2000,
      ceilingHeight: parseFloat((document.getElementById('ceiling') as HTMLSelectElement).value) || 8,
      insulation: (document.getElementById('insulation') as HTMLSelectElement).value as InsulationGrade,
      sun: (document.getElementById('sun') as HTMLSelectElement).value as SunExposure,
      windows: (document.getElementById('windows') as HTMLSelectElement).value as WindowAmount,
      tightness: (document.getElementById('tightness') as HTMLSelectElement).value as Tightness,
      occupants: parseInt((document.getElementById('occupants') as HTMLSelectElement).value) || 2,
      deviceWatts: parseInt((document.getElementById('devices') as HTMLSelectElement).value) || 0,
      kitchen: (document.getElementById('kitchen') as HTMLSelectElement).value === 'yes',
    };
  }

  calcBtn.addEventListener('click', () => {
    const inputs = readInputs();
    if (!inputs) return;
    pendingInputs = inputs;
    pendingResult = calcWholeHouse(inputs);
    document.getElementById('calc-btn-area')!.classList.add('hidden');
    document.getElementById('email-gate')!.classList.remove('hidden');
    (document.getElementById('gate-email') as HTMLInputElement).focus();
  });

  const gateSubmit = document.getElementById('gate-submit') as HTMLButtonElement;
  const gateEmail = document.getElementById('gate-email') as HTMLInputElement;
  const gateConsent = document.getElementById('gate-consent') as HTMLInputElement;
  const gateError = document.getElementById('gate-error')!;

  function showResults(r: WholeHouseResult) {
    document.getElementById('r-cool')!.textContent = r.coolingBTU.toLocaleString() + ' BTU';
    document.getElementById('r-heat')!.textContent = r.heatingBTU.toLocaleString() + ' BTU';
    document.getElementById('r-tons')!.textContent = r.tonnage + ' ton';
    document.getElementById('results')!.classList.remove('hidden');
    document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  gateSubmit.addEventListener('click', async () => {
    const email = gateEmail.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      gateError.textContent = 'Please enter a valid email address.';
      gateError.classList.remove('hidden');
      return;
    }
    if (!pendingResult || !pendingInputs) return;
    gateError.classList.add('hidden');
    gateSubmit.disabled = true;
    gateSubmit.textContent = 'Sending...';

    try {
      const res = await fetch('/api/email-capture', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          toolSlug: 'load-calculator',
          toolName: 'HVAC Load Calculator',
          tradeSlug: 'hvac',
          tradeName: 'HVAC',
          marketingConsent: gateConsent.checked,
          sourceUrl: window.location.pathname,
          calculationResults: {
            mode: 'whole-house',
            // Results
            coolingBTU: pendingResult.coolingBTU,
            heatingBTU: pendingResult.heatingBTU,
            tonnage: pendingResult.tonnage,
            // Climate context
            zip: (document.getElementById('zip') as HTMLInputElement).value.trim(),
            state: pendingInputs.climate.state,
            region: pendingInputs.climate.regionLabel,
            // All raw inputs so the admin view can inspect what pros submitted
            sqft: pendingInputs.sqft,
            ceilingHeight: pendingInputs.ceilingHeight,
            insulation: pendingInputs.insulation,
            sun: pendingInputs.sun,
            windows: pendingInputs.windows,
            tightness: pendingInputs.tightness,
            occupants: pendingInputs.occupants,
            deviceWatts: pendingInputs.deviceWatts,
            kitchen: pendingInputs.kitchen,
          },
        }),
      });
      if (!res.ok) throw new Error('Failed to send');

      document.getElementById('email-gate')!.classList.add('hidden');
      showResults(pendingResult);

      const meta = (window as any).__ntqToolMeta;
      if ((window as any).posthog && meta) {
        (window as any).posthog.capture('email_captured', {
          tool_slug: meta.toolSlug,
          trade_slug: meta.tradeSlug,
          trade_name: meta.tradeName,
          tool_name: meta.toolName,
          tool_category: meta.category,
          marketing_consent: gateConsent.checked,
          gated: true,
          mode: 'whole-house',
        });
      }
      if (typeof (window as any).gtag === 'function') {
        (window as any).gtag('event', 'conversion', { send_to: 'AW-17899660858/rqouCLin75gcELrMnNdC' });
      }
    } catch {
      gateError.textContent = 'Something went wrong. Please try again.';
      gateError.classList.remove('hidden');
      gateSubmit.disabled = false;
      gateSubmit.textContent = 'Send My Results';
    }
  });

  gateEmail.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') gateSubmit.click();
  });
</script>
