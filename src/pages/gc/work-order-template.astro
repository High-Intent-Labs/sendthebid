---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/gcTools';

const tool = getToolBySlug('work-order-template')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should be on a general contracting work order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A complete general contracting work order includes dispatch info (date, foreman, priority), customer details, project information (total sqft, affected area, materials quantity, demo area), scope of work and diagnosis, work performed, materials used, a jobsite safety checklist, and foreman signature with arrival and completion times."
      }
    },
    {
      "@type": "Question",
      "name": "Why do I need to record project measurements?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Project measurements like total square footage, affected area, materials quantities, and demo square footage document the scope of the project. These measurements are critical for accurate change order documentation, material takeoffs, progress tracking, verifying completed work against the contract, and resolving disputes about project scope."
      }
    },
    {
      "@type": "Question",
      "name": "Is detailed documentation required for GC work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Maintaining detailed work records is essential for every general contracting job. Document all work performed, materials used, subcontractor coordination, and any field conditions encountered. Thorough records protect you during disputes, support change orders, satisfy building inspector requirements, and provide a project history for warranty claims."
      }
    },
    {
      "@type": "Question",
      "name": "What documentation standards should a GC follow?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Quality GC documentation should include daily progress photos, detailed descriptions of work completed, materials delivered and installed, subcontractor activities, weather conditions, inspection results, and any deviations from plans. This level of detail protects against claims, supports payment applications, and demonstrates professional project management."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="work-order-form">

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Dispatch Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-number">Work Order #</label>
        <input type="text" id="wo-number" value="WO-001" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-date">Date</label>
        <input type="date" id="wo-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="wo-time">Time</label>
        <input type="time" id="wo-time" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="tech-name">Foreman Name</label>
        <input type="text" id="tech-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="truck-number">Truck #</label>
        <input type="text" id="truck-number" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="priority">Priority</label>
        <select id="priority" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Routine" selected>Routine</option>
          <option value="Urgent">Urgent</option>
          <option value="Emergency">Emergency</option>
        </select>
      </div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Customer Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-name">Customer Name</label>
        <input type="text" id="cust-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-address">Address</label>
        <input type="text" id="cust-address" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="cust-phone">Phone</label>
        <input type="text" id="cust-phone" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="access-instructions">Access Instructions</label>
        <input type="text" id="access-instructions" placeholder="Gate code, lockbox, etc." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Project Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-type">Project Type</label>
        <select id="equip-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="New Build">New Build</option>
          <option value="Addition">Addition</option>
          <option value="Remodel">Remodel</option>
          <option value="Renovation">Renovation</option>
          <option value="Restoration">Restoration</option>
          <option value="Repair">Repair</option>
          <option value="Demo">Demo</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-make">Property Type</label>
        <input type="text" id="equip-make" placeholder="Residential, Commercial..." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-model">Scope Summary</label>
        <input type="text" id="equip-model" placeholder="e.g., Kitchen remodel" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="equip-serial">Permit #</label>
        <input type="text" id="equip-serial" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="install-date">Project Start Date</label>
        <input type="date" id="install-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="filter-size">Crew Size</label>
        <input type="text" id="filter-size" placeholder="e.g., 4 crew + 2 subs" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="refrigerant-type">Phase</label>
        <select id="refrigerant-type" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Pre-Construction" selected>Pre-Construction</option>
          <option value="Demo">Demo</option>
          <option value="Rough-In">Rough-In</option>
          <option value="Drywall / Finish">Drywall / Finish</option>
          <option value="Final / Punch">Final / Punch</option>
          <option value="Other">Other</option>
        </select>
      </div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Service Details</h3>
    <div class="space-y-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="reported-issue">Reported Issue / Scope</label>
        <textarea id="reported-issue" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="diagnosis">Site Assessment</label>
        <textarea id="diagnosis" rows="3" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="work-performed">Work Performed</label>
        <textarea id="work-performed" rows="4" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Materials Used</h3>
    <div class="mb-8">
      <div id="parts-table" class="space-y-3">
        <div class="grid grid-cols-[1fr_1fr_80px_40px] gap-3 items-end part-row">
          <div><label class="block text-sm font-medium text-text-secondary mb-2">Material Name</label><input type="text" class="part-name w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
          <div><label class="block text-sm font-medium text-text-secondary mb-2">SKU / Spec</label><input type="text" class="part-number w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
          <div><label class="block text-sm font-medium text-text-secondary mb-2">Qty</label><input type="number" value="1" min="1" class="part-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
          <div><label class="block text-sm font-medium text-text-secondary mb-2">&nbsp;</label><button type="button" class="remove-part-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove">&times;</button></div>
        </div>
      </div>
      <button type="button" id="add-part-btn" class="mt-3 text-accent hover:text-accent-hover transition-colors cursor-pointer text-sm font-medium">+ Add Material</button>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Material Log</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="ref-added">Materials Delivered (units)</label>
        <input type="number" id="ref-added" min="0" step="1" value="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="ref-recovered">Debris Hauled (loads)</label>
        <input type="number" id="ref-recovered" min="0" step="1" value="0" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Project Measurements</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="total-sqft">Total Project (sq ft)</label>
        <input type="number" id="total-sqft" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="affected-area">Affected Area (sq ft)</label>
        <input type="number" id="affected-area" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="materials-qty">Materials Qty (units)</label>
        <input type="number" id="materials-qty" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="demo-sqft">Demo Area (sq ft)</label>
        <input type="number" id="demo-sqft" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="framing-lf">Framing (LF)</label>
        <input type="number" id="framing-lf" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="drywall-sheets">Drywall (sheets)</label>
        <input type="number" id="drywall-sheets" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2">% Complete</label>
        <div id="pct-complete-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="concrete-yards">Concrete (yards)</label>
        <input type="number" id="concrete-yards" step="0.5" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Safety Checklist</h3>
    <div class="space-y-3 mb-8">
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-ppe" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-ppe" class="text-text-primary cursor-pointer">PPE Worn (hard hat, safety glasses, boots)</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-permits" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-permits" class="text-text-primary cursor-pointer">Permits Posted / Current</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-utilities" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-utilities" class="text-text-primary cursor-pointer">Utilities Located / Marked</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-fall" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-fall" class="text-text-primary cursor-pointer">Fall Protection In Place</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-fire" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-fire" class="text-text-primary cursor-pointer">Fire Extinguisher On Site</label>
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="chk-cleanup" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <label for="chk-cleanup" class="text-text-primary cursor-pointer">Site Secured / Cleaned End of Day</label>
      </div>
    </div>

    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Completion</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="time-arrived">Time Arrived</label><input type="time" id="time-arrived" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="time-completed">Time Completed</label><input type="time" id="time-completed" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2">Total Hours</label><div id="total-hours-display" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted">&mdash;</div></div>
      <div><label class="block text-sm font-medium text-text-secondary mb-2" for="tech-signature">Foreman Signature</label><input type="text" id="tech-signature" placeholder="Type full name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div>
    </div>

    <button id="generate-btn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">Generate Work Order &rarr;</button>
  </div>

  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Template</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Fill in dispatch and customer info.</strong> Start with the work order number, date, and foreman assignment. Add the customer's name, address, phone, and any access instructions.</p>
          <p><strong class="text-text-primary">2. Describe the project.</strong> Select the project type and phase. Enter the scope summary, permit number, and crew size for complete project tracking.</p>
          <p><strong class="text-text-primary">3. Document the work.</strong> Write the scope, your site assessment, and exactly what work was performed. Be specific — vague notes cause problems during change order disputes and inspections.</p>
          <p><strong class="text-text-primary">4. Record measurements and safety checks.</strong> Log project area, affected area, demo area, and material quantities. Run through the safety checklist to confirm jobsite compliance.</p>
          <p><strong class="text-text-primary">5. Generate the work order.</strong> Hit the button to create a clean, printable work order for your records, payment applications, or inspector documentation.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Goes on a General Contracting Work Order</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>A work order is the single document that proves what happened on a job. Every section exists for a reason.</p>
          <p><strong class="text-text-primary">Project identification</strong> — project type, phase, permit number, and scope — ties the documentation to a specific project visit. This information is essential for change orders, payment applications, and building inspector records.</p>
          <p><strong class="text-text-primary">Project measurements</strong> document the scope of the work. Total square footage, affected area, demo area, and material quantities tell the full story. If a customer disputes change orders or a sub questions scope, your measurements are the definitive record.</p>
          <p><strong class="text-text-primary">Material tracking</strong> is essential for every GC job. Recording deliveries, materials installed, and debris hauled protects you during billing disputes and keeps inventory accurate. Smart GCs document every delivery and installation regardless of job size.</p>
          <p><strong class="text-text-primary">The safety checklist</strong> is your liability shield. Documenting PPE compliance, permits posted, utilities marked, and fall protection in place shows OSHA compliance. If an accident occurs on your jobsite, that checklist is your first line of defense.</p>
          <p><strong class="text-text-primary">Materials used</strong> with specs create a clear record for cost tracking, warranty documentation, and accurate progress billing.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Daily project documentation.</strong> Every day on a construction project needs a work order. The foreman fills it out — work completed, materials used, crew hours, and safety compliance. It becomes the daily log and basis for progress billing.</p>
          <p><strong class="text-text-primary">Service and repair calls.</strong> For smaller repair or renovation jobs, the work order captures the full scope from assessment through completion. It provides the permanent record of the visit and the basis for the invoice.</p>
          <p><strong class="text-text-primary">Change order and inspection documentation.</strong> When a building inspector requests proof of work, or when a change order needs documentation, the work order is your evidence. Complete records with measurements, materials, and safety compliance eliminate disputes.</p>
        </div>
      </section>

      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should be on a general contracting work order?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A complete general contracting work order includes dispatch info (date, foreman, priority), customer details, project information (total sqft, affected area, materials quantity, demo area), scope of work and diagnosis, work performed, materials used, a jobsite safety checklist, and foreman signature with arrival and completion times.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Why do I need to record project measurements?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Project measurements like total square footage, affected area, materials quantities, and demo square footage document the scope of the project. These measurements are critical for accurate change order documentation, material takeoffs, progress tracking, verifying completed work against the contract, and resolving disputes about project scope.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Is detailed documentation required for GC work?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Yes. Maintaining detailed work records is essential for every general contracting job. Document all work performed, materials used, subcontractor coordination, and any field conditions encountered. Thorough records protect you during disputes, support change orders, satisfy building inspector requirements, and provide a project history for warranty claims.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What documentation standards should a GC follow?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Quality GC documentation should include daily progress photos, detailed descriptions of work completed, materials delivered and installed, subcontractor activities, weather conditions, inspection results, and any deviations from plans. This level of detail protects against claims, supports payment applications, and demonstrates professional project management.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  const now = new Date();
  const dateInput = document.getElementById('wo-date') as HTMLInputElement;
  const timeInput = document.getElementById('wo-time') as HTMLInputElement;
  if (dateInput && !dateInput.value) dateInput.value = now.toISOString().slice(0, 10);
  if (timeInput && !timeInput.value) timeInput.value = now.toTimeString().slice(0, 5);

  function updatePctComplete() {
    const total = parseFloat((document.getElementById('total-sqft') as HTMLInputElement).value) || 0;
    const affected = parseFloat((document.getElementById('affected-area') as HTMLInputElement).value) || 0;
    const display = document.getElementById('pct-complete-display')!;
    if (total > 0 && affected > 0) {
      const pct = Math.min(100, (affected / total) * 100);
      display.textContent = pct.toFixed(0) + '%';
      display.className = pct >= 90 ? 'w-full bg-bg-dark border border-green-500/50 rounded-lg px-4 py-3 text-lg font-bold text-green-400' : 'w-full bg-bg-dark border border-yellow-500/50 rounded-lg px-4 py-3 text-lg font-bold text-yellow-400';
    } else {
      display.textContent = '\u2014';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted';
    }
  }
  document.getElementById('total-sqft')?.addEventListener('input', updatePctComplete);
  document.getElementById('affected-area')?.addEventListener('input', updatePctComplete);

  function updateTotalHours() {
    const arrived = (document.getElementById('time-arrived') as HTMLInputElement).value;
    const completed = (document.getElementById('time-completed') as HTMLInputElement).value;
    const display = document.getElementById('total-hours-display')!;
    if (arrived && completed) {
      const [ah, am] = arrived.split(':').map(Number);
      const [ch, cm] = completed.split(':').map(Number);
      let totalMinutes = (ch * 60 + cm) - (ah * 60 + am);
      if (totalMinutes < 0) totalMinutes += 24 * 60;
      display.textContent = Math.floor(totalMinutes / 60) + 'h ' + (totalMinutes % 60) + 'm';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-primary';
    } else {
      display.textContent = '\u2014';
      display.className = 'w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-lg font-bold text-text-muted';
    }
  }
  document.getElementById('time-arrived')?.addEventListener('input', updateTotalHours);
  document.getElementById('time-completed')?.addEventListener('input', updateTotalHours);

  function addPartRow() {
    const table = document.getElementById('parts-table')!;
    const row = document.createElement('div');
    row.className = 'grid grid-cols-[1fr_1fr_80px_40px] gap-3 items-end part-row';
    row.innerHTML = `<div><input type="text" class="part-name w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div><div><input type="text" class="part-number w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div><div><input type="number" value="1" min="1" class="part-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" /></div><div><button type="button" class="remove-part-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove">&times;</button></div>`;
    table.appendChild(row);
  }
  document.getElementById('add-part-btn')?.addEventListener('click', addPartRow);
  document.getElementById('parts-table')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('remove-part-btn')) {
      const row = target.closest('.part-row');
      if (document.querySelectorAll('.part-row').length > 1 && row) row.remove();
    }
  });

  function getVal(id: string): string { const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null; return el ? el.value : ''; }
  function getChecked(id: string): boolean { return (document.getElementById(id) as HTMLInputElement)?.checked || false; }

  function generateWorkOrder() {
    const partRows = document.querySelectorAll('.part-row');
    let partsHtml = '';
    partRows.forEach(row => {
      const name = (row.querySelector('.part-name') as HTMLInputElement)?.value || '';
      const num = (row.querySelector('.part-number') as HTMLInputElement)?.value || '';
      const qty = (row.querySelector('.part-qty') as HTMLInputElement)?.value || '';
      if (name || num) partsHtml += `<tr><td style="border:1px solid #ddd;padding:6px 10px;">${name}</td><td style="border:1px solid #ddd;padding:6px 10px;">${num}</td><td style="border:1px solid #ddd;padding:6px 10px;text-align:center;">${qty}</td></tr>`;
    });

    const totalSq = parseFloat(getVal('total-sqft')) || 0;
    const affectedSq = parseFloat(getVal('affected-area')) || 0;
    const pctStr = (totalSq > 0 && affectedSq > 0) ? Math.min(100, (affectedSq / totalSq) * 100).toFixed(0) + '%' : '';

    const arrived = getVal('time-arrived');
    const completed = getVal('time-completed');
    let totalHours = '';
    if (arrived && completed) {
      const [ah, am] = arrived.split(':').map(Number);
      const [ch, cm] = completed.split(':').map(Number);
      let totalMin = (ch * 60 + cm) - (ah * 60 + am);
      if (totalMin < 0) totalMin += 24 * 60;
      totalHours = Math.floor(totalMin / 60) + 'h ' + (totalMin % 60) + 'm';
    }

    const safetyItems = [
      { id: 'chk-ppe', label: 'PPE Worn (hard hat, safety glasses, boots)' },
      { id: 'chk-permits', label: 'Permits Posted / Current' },
      { id: 'chk-utilities', label: 'Utilities Located / Marked' },
      { id: 'chk-fall', label: 'Fall Protection In Place' },
      { id: 'chk-fire', label: 'Fire Extinguisher On Site' },
      { id: 'chk-cleanup', label: 'Site Secured / Cleaned End of Day' },
    ];
    let safetyHtml = '';
    safetyItems.forEach(item => { safetyHtml += `<div style="margin-bottom:4px;">${getChecked(item.id) ? '&#9745;' : '&#9744;'} ${item.label}</div>`; });

    const html = `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Work Order ${getVal('wo-number')}</title>
<style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:#1a1a1a;padding:40px;max-width:850px;margin:0 auto;font-size:14px;line-height:1.5}h1{font-size:22px;margin-bottom:4px}h2{font-size:15px;color:#333;margin:20px 0 8px;padding-bottom:4px;border-bottom:2px solid #e5e5e5;text-transform:uppercase;letter-spacing:.5px}.header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;padding-bottom:16px;border-bottom:3px solid #1a1a1a}.header-right{text-align:right;font-size:13px;color:#555}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:4px 24px;margin-bottom:6px}.grid2 .label{font-weight:600;font-size:12px;color:#666;text-transform:uppercase;letter-spacing:.3px}.grid2 .value{font-size:14px;margin-bottom:6px}.text-block{margin-bottom:12px}.text-block .label{font-weight:600;font-size:12px;color:#666;text-transform:uppercase;letter-spacing:.3px;margin-bottom:2px}.text-block .value{font-size:14px;white-space:pre-wrap;background:#f9f9f9;padding:8px 10px;border-radius:4px;min-height:24px}table{width:100%;border-collapse:collapse;margin-bottom:8px}th{background:#f0f0f0;border:1px solid #ddd;padding:6px 10px;text-align:left;font-size:12px;text-transform:uppercase;letter-spacing:.3px}td{border:1px solid #ddd;padding:6px 10px}.readings-table td{text-align:center}.safety{font-size:14px}.signature-block{display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-top:40px;padding-top:16px}.sig-line{border-top:1px solid #1a1a1a;padding-top:6px;font-size:12px;color:#666;text-transform:uppercase}.sig-name{font-size:16px;font-weight:600;min-height:20px}.priority-badge{display:inline-block;padding:2px 10px;border-radius:4px;font-size:12px;font-weight:600;text-transform:uppercase}.priority-Routine{background:#e0f2e9;color:#166534}.priority-Urgent{background:#fef3c7;color:#92400e}.priority-Emergency{background:#fee2e2;color:#991b1b}@media print{body{padding:20px}}</style>
</head><body>
<div class="header"><div class="header-left"><h1>General Contracting Work Order</h1><div style="font-size:13px;color:#555;">Project Documentation</div></div><div class="header-right"><div style="font-size:20px;font-weight:700;">\${getVal('wo-number')}</div><div>\${getVal('wo-date')}</div><div>\${getVal('wo-time')}</div><span class="priority-badge priority-\${getVal('priority')}">\${getVal('priority')}</span></div></div>

<h2>Dispatch</h2><div class="grid2"><div><span class="label">Foreman:</span></div><div><span class="label">Truck #:</span></div><div class="value">\${getVal('tech-name') || '\u2014'}</div><div class="value">\${getVal('truck-number') || '\u2014'}</div></div>
<h2>Customer</h2><div class="grid2"><div><span class="label">Name:</span></div><div><span class="label">Phone:</span></div><div class="value">\${getVal('cust-name') || '\u2014'}</div><div class="value">\${getVal('cust-phone') || '\u2014'}</div><div><span class="label">Address:</span></div><div><span class="label">Access:</span></div><div class="value">\${getVal('cust-address') || '\u2014'}</div><div class="value">\${getVal('access-instructions') || '\u2014'}</div></div>
<h2>Project Info</h2><div class="grid2"><div><span class="label">Project Type:</span></div><div><span class="label">Property:</span></div><div class="value">\${getVal('equip-type')}</div><div class="value">\${getVal('equip-make') || '\u2014'}</div><div><span class="label">Scope:</span></div><div><span class="label">Permit #:</span></div><div class="value">\${getVal('equip-model') || '\u2014'}</div><div class="value">\${getVal('equip-serial') || '\u2014'}</div><div><span class="label">Start Date:</span></div><div><span class="label">Crew Size:</span></div><div class="value">\${getVal('install-date') || '\u2014'}</div><div class="value">\${getVal('filter-size') || '\u2014'}</div><div><span class="label">Phase:</span></div><div></div><div class="value">\${getVal('refrigerant-type')}</div><div></div></div>

<h2>Service Details</h2>
<div class="text-block"><div class="label">Reported Issue / Scope</div><div class="value">\${getVal('reported-issue') || '\u2014'}</div></div>
<div class="text-block"><div class="label">Site Assessment</div><div class="value">\${getVal('diagnosis') || '\u2014'}</div></div>
<div class="text-block"><div class="label">Work Performed</div><div class="value">\${getVal('work-performed') || '\u2014'}</div></div>

\${partsHtml ? \`<h2>Materials Used</h2><table><thead><tr><th>Material</th><th>SKU / Spec</th><th style="text-align:center;">Qty</th></tr></thead><tbody>\${partsHtml}</tbody></table>\` : ''}

<h2>Material Log</h2><div class="grid2"><div><span class="label">Materials Delivered:</span></div><div><span class="label">Debris Hauled:</span></div><div class="value">\${getVal('ref-added') || '0'} units</div><div class="value">\${getVal('ref-recovered') || '0'} loads</div></div>

<h2>Project Measurements</h2>
<table class="readings-table"><thead><tr><th>Total Sq Ft</th><th>Affected Area</th><th>Materials Qty</th><th>Demo Area</th></tr></thead><tbody><tr><td>\${getVal('total-sqft') ? getVal('total-sqft') + ' sq ft' : '\u2014'}</td><td>\${getVal('affected-area') ? getVal('affected-area') + ' sq ft' : '\u2014'}</td><td>\${getVal('materials-qty') || '\u2014'}</td><td>\${getVal('demo-sqft') ? getVal('demo-sqft') + ' sq ft' : '\u2014'}</td></tr></tbody></table>
<table class="readings-table" style="margin-top:8px;"><thead><tr><th>Framing LF</th><th>Drywall</th><th>% Complete</th><th>Concrete</th></tr></thead><tbody><tr><td>\${getVal('framing-lf') ? getVal('framing-lf') + ' LF' : '\u2014'}</td><td>\${getVal('drywall-sheets') ? getVal('drywall-sheets') + ' sheets' : '\u2014'}</td><td>\${pctStr || '\u2014'}</td><td>\${getVal('concrete-yards') ? getVal('concrete-yards') + ' yards' : '\u2014'}</td></tr></tbody></table>

<h2>Safety Checklist</h2><div class="safety">\${safetyHtml}</div>
<h2>Completion</h2><div class="grid2"><div><span class="label">Time Arrived:</span></div><div><span class="label">Time Completed:</span></div><div class="value">\${arrived || '\u2014'}</div><div class="value">\${completed || '\u2014'}</div><div><span class="label">Total Hours:</span></div><div></div><div class="value">\${totalHours || '\u2014'}</div><div></div></div>
<div class="signature-block"><div><div class="sig-name">\${getVal('tech-signature') || ''}</div><div class="sig-line">Foreman Signature</div></div><div><div class="sig-name">&nbsp;</div><div class="sig-line">Customer Signature</div></div></div>
</body></html>`;

    const printWindow = window.open('', '_blank');
    if (printWindow) { printWindow.document.write(html); printWindow.document.close(); }
  }

  document.getElementById('generate-btn')?.addEventListener('click', generateWorkOrder);
</script>
