  <div><span class="label">Severity Level:</span></div><div><span class="label">Last Service Date:</span></div><div><span class="label">Time Since Service:</span></div>
  <div class="value">${getVal('equip-serial') || '\u2014'}</div><div class="value">${getVal('install-date') || '\u2014'}</div><div class="value">${equipAge}</div>
  <div><span class="label">Service Interval:</span></div><div><span class="label">Overall Condition:</span></div><div></div>
  <div class="value">${getVal('remaining-life') ? getVal('remaining-life') + ' months' : '\u2014'}</div><div class="value" style="color:${condColor};font-weight:700;">${condition}</div><div></div>
</div>

<h2>Area Ratings</h2>
<table>
  <thead><tr><th>Component</th><th style="text-align:center;">Rating</th><th>Notes</th></tr></thead>
