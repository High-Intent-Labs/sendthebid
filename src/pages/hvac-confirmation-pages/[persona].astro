---
// Solo persona view rendered inside the iframes on /hvac-confirmation-pages.
// Each variant matches the markup in src/pages/hvac/load-calculator.astro
// (results card + persona CTA card) so what the iframe shows is exactly what
// a real user sees post-submit. Mock BTU values stand in for the live calc
// output. Not linked from anywhere on the site; noindex.
import '../../styles/global.css';

// NB: getStaticPaths runs in an isolated scope at build time — frontmatter
// top-level vars are NOT visible inside it. Define the variants array inside
// the function and ship the per-persona data via `props` (consumed below).
export function getStaticPaths() {
  const variants = [
    {
      id: 'not_yet',
      label: 'Home + Hiring + Not Yet',
      cta: {
        headline: 'Ready to hire? Get quotes from Angi-vetted HVAC pros.',
        body: 'Share your zip, system size, and project scope, and Angi will connect you with background-checked pros near you who can quote the job.',
        button: 'Get My Free Quotes',
        href: 'https://request.angi.com/service-request/category/10211?utm_source=nailthequote&utm_medium=calculator&utm_campaign=load_calc&utm_content=home_hiring_not_yet',
      },
    },
    {
      id: 'has_estimates',
      label: 'Home + Hiring + Has Estimates',
      cta: {
        headline: "Before you pick a quote, make sure it's fair.",
        body: 'Quotes for the same HVAC job can vary a lot between contractors. The most reliable way to know yours is reasonable is to compare it with more quotes for the same job.',
        button: 'Get More Quotes',
        href: 'https://request.angi.com/service-request/category/10211?utm_source=nailthequote&utm_medium=calculator&utm_campaign=load_calc&utm_content=home_hiring_has_estimates',
      },
    },
    {
      id: 'researching',
      label: 'Home + Hiring + Researching',
      cta: {
        headline: 'Browse Angi-vetted HVAC pros in your area.',
        body: "See profiles, reviews, and typical project photos from local contractors. Request a quote only when you're ready.",
        button: 'Browse HVAC Pros',
        href: 'https://request.angi.com/service-request/category/10211?utm_source=nailthequote&utm_medium=calculator&utm_campaign=load_calc&utm_content=home_hiring_researching',
      },
    },
    {
      id: 'diy',
      label: 'Home + DIY',
      cta: {
        headline: 'Doing it yourself? The 240V hookup still needs a licensed electrician.',
        body: 'A new HVAC system requires a dedicated 240V circuit. Most states require a licensed electrician for the wiring, and most manufacturers require it for warranty validity.',
        button: 'Get a Free Electrician Quote',
        href: 'https://request.angi.com/service-request/category/12026?utm_source=nailthequote&utm_medium=calculator&utm_campaign=load_calc&utm_content=home_diy_electrical',
      },
    },
    {
      id: 'pro',
      label: 'Pro / Contractor',
      cta: {
        headline: 'Need more customers? Join Angi as a pro.',
        body: 'Angi is one of the largest networks connecting homeowners with local contractors. Join to receive homeowner leads in the trades and areas you serve.',
        button: 'Become an Angi Pro',
        href: 'https://signup.angi.com/pro?utm_source=nailthequote&utm_medium=calculator&utm_campaign=load_calc&utm_content=pro_signup',
      },
    },
  ];
  return variants.map((v) => ({
    params: { persona: v.id },
    props: { variant: v },
  }));
}

const { variant } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{variant.label} — preview</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-bg-dark text-text-primary min-h-screen">
  <div class="max-w-[1080px] mx-auto px-4 sm:px-6 md:px-12 py-6">
    <div class="bg-bg-card border border-border rounded-2xl p-6 md:p-8">

      <!-- Results card (mirrors #results > .rounded-2xl.border-2.border-accent in load-calculator.astro) -->
      <div class="rounded-2xl border-2 border-accent bg-accent/5 p-6 sm:p-8">
        <div class="mb-6 bg-[rgba(52,211,153,0.08)] border border-[rgba(52,211,153,0.25)] rounded-xl p-4 flex items-start gap-3">
          <div class="shrink-0 w-8 h-8 rounded-full bg-[rgba(52,211,153,0.15)] flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" class="text-[#34D399]">
              <path d="M16.667 5L7.5 14.167 3.333 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <p class="text-text-primary font-semibold text-sm">Results also sent to your inbox</p>
            <p class="text-text-primary text-xs mt-0.5">Don't see it? Check your Spam or Promotions folder.</p>
          </div>
        </div>

        <h3 class="font-heading font-bold text-xl mb-6">Your Load Calculation</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
          <div class="bg-bg-dark rounded-xl p-5 text-center">
            <div class="text-text-primary text-xs font-medium uppercase tracking-wider mb-2">Cooling Load</div>
            <div class="font-heading font-extrabold text-2xl text-accent">30,000 BTU</div>
          </div>
          <div class="bg-bg-dark rounded-xl p-5 text-center">
            <div class="text-text-primary text-xs font-medium uppercase tracking-wider mb-2">Heating Load</div>
            <div class="font-heading font-extrabold text-2xl text-text-primary">36,000 BTU</div>
          </div>
          <div class="bg-bg-dark rounded-xl p-5 text-center">
            <div class="text-text-primary text-xs font-medium uppercase tracking-wider mb-2">System Tonnage</div>
            <div class="font-heading font-extrabold text-2xl text-text-primary">2.5 tons</div>
          </div>
        </div>
        <p class="text-text-primary text-sm italic">Estimate only. For permit-ready Manual J, use ACCA-accredited software.</p>
      </div>

      <!-- Persona CTA card (mirrors #persona-cta variant for {variant.id}) -->
      <div class="mt-6">
        <div class="rounded-2xl border-2 border-accent bg-gradient-to-br from-accent/15 to-accent/5 p-6 sm:p-8">
          <h3 class="font-heading font-bold text-xl text-text-primary mb-2">{variant.cta.headline}</h3>
          <p class="text-text-primary text-sm mb-5">{variant.cta.body}</p>
          <a class="inline-flex items-center gap-2 bg-accent hover:bg-accent-hover text-white font-semibold px-6 py-3 rounded-lg transition-colors no-underline"
             href={variant.cta.href}
             target="_blank"
             rel="noopener">
            {variant.cta.button}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12h14m-6-6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>

    </div>
  </div>
</body>
</html>
