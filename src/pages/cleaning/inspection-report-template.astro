---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/cleaningTools';

const tool = getToolBySlug('inspection-report-template')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should a cleaning inspection report include?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A professional cleaning inspection report should include property identification (address, property type, inspection date), a room-by-room assessment with Pass/Fail/N/A ratings for floors, walls and baseboards, windows and sills, fixtures and hardware, appliances, and odor. It should also include a dynamic issues table listing specific findings with severity and recommendations, a summary with total pass/fail counts, and an overall property rating."
      }
    },
    {
      "@type": "Question",
      "name": "When should a cleaning inspection be performed?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cleaning inspections are commonly performed during move-in and move-out walkthroughs, after deep cleans or post-construction cleanups, as part of quality control for recurring cleaning contracts, and during property management turnover reviews. Regular inspections on commercial contracts help maintain standards and catch issues before they become complaints."
      }
    },
    {
      "@type": "Question",
      "name": "What is a Pass/Fail rating system for cleaning inspections?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A Pass/Fail/N/A system rates each area of each room on a simple three-point scale. Pass means the area meets the cleanliness standard. Fail means the area does not meet the standard and needs attention. N/A means the area is not applicable to that room, such as appliances in a bedroom. This system is fast to use on site and produces clear, objective documentation that clients and property managers understand immediately."
      }
    },
    {
      "@type": "Question",
      "name": "How do I write a professional cleaning inspection report?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start with complete property and inspector identification. Rate each area in each room using a standardized Pass/Fail/N/A scale. Document every issue found with the specific room, a description of the problem, a severity rating (minor, moderate, or major), and a recommended action. Include an overall assessment with total pass and fail counts. Generate a clean PDF report that can be shared with clients, property managers, or your own records."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="inspection-report-form">

    <!-- Section: Inspector & Property Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Inspector &amp; Property Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="company-name">Company Name</label>
        <input type="text" id="company-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="inspector-name">Inspector Name</label>
        <input type="text" id="inspector-name" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="inspector-phone">Phone</label>
        <input type="text" id="inspector-phone" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="report-number">Report #</label>
        <input type="text" id="report-number" value="IR-001" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="inspection-date">Inspection Date</label>
        <input type="date" id="inspection-date" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="inspection-reason">Reason for Inspection</label>
        <select id="inspection-reason" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="Move-In Walkthrough">Move-In Walkthrough</option>
          <option value="Move-Out Walkthrough">Move-Out Walkthrough</option>
          <option value="Post-Clean Quality Check" selected>Post-Clean Quality Check</option>
          <option value="Recurring Contract Review">Recurring Contract Review</option>
          <option value="Complaint Investigation">Complaint Investigation</option>
          <option value="Initial Property Assessment">Initial Property Assessment</option>
        </select>
      </div>
      <div class="md:col-span-2 lg:col-span-3">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="property-address">Property Address</label>
        <input type="text" id="property-address" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Section: Room-by-Room Assessment -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Room-by-Room Assessment</h3>
    <p class="text-text-muted text-sm mb-6">Rate each area as Pass, Fail, or N/A. The summary at the bottom updates automatically.</p>

    <div id="room-assessments" class="space-y-6 mb-8">
      <!-- Rooms are rendered by JS for DRY code -->
    </div>

    <!-- Section: Issues Found -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Issues Found</h3>
    <div class="mb-8">
      <div class="hidden md:grid grid-cols-[1fr_1fr_120px_1fr_40px] gap-3 mb-2 px-1">
        <span class="text-text-muted text-xs font-medium uppercase tracking-wider">Room</span>
        <span class="text-text-muted text-xs font-medium uppercase tracking-wider">Issue</span>
        <span class="text-text-muted text-xs font-medium uppercase tracking-wider">Severity</span>
        <span class="text-text-muted text-xs font-medium uppercase tracking-wider">Recommendation</span>
        <span></span>
      </div>
      <div id="issues-table" class="space-y-3">
        <!-- Issues added by JS -->
      </div>
      <button type="button" id="add-issue-btn" class="mt-3 text-accent hover:text-accent-hover transition-colors cursor-pointer text-sm font-medium">+ Add Issue</button>
    </div>

    <!-- Section: Summary -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Summary</h3>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
      <div class="bg-bg-dark rounded-xl p-5 text-center">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Pass</div>
        <div id="summary-pass" class="font-heading font-extrabold text-3xl text-[#34D399]">0</div>
      </div>
      <div class="bg-bg-dark rounded-xl p-5 text-center">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Fail</div>
        <div id="summary-fail" class="font-heading font-extrabold text-3xl text-[#EF4444]">0</div>
      </div>
      <div class="bg-bg-dark rounded-xl p-5 text-center">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">N/A</div>
        <div id="summary-na" class="font-heading font-extrabold text-3xl text-text-muted">0</div>
      </div>
      <div class="bg-bg-dark rounded-xl p-5 text-center">
        <div class="text-text-muted text-xs font-medium uppercase tracking-wider mb-2">Overall</div>
        <div id="summary-overall" class="font-heading font-extrabold text-3xl text-text-primary">--</div>
      </div>
    </div>

    <div class="mb-8">
      <label class="block text-sm font-medium text-text-secondary mb-2" for="overall-notes">Overall Notes / Recommendations</label>
      <textarea id="overall-notes" rows="3" placeholder="Summary of findings, recommended follow-up actions, next inspection date..." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
    </div>

    <!-- Generate Button -->
    <button id="generate-btn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
      Generate Inspection Report &rarr;
    </button>
    <p class="text-text-muted text-sm italic mt-3">Opens a print-ready inspection report in a new window. Use your browser's print dialog to save as PDF.</p>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Template</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Enter inspector and property info.</strong> Fill in your company name, inspector name, phone, and the property address. Set the report number and inspection date, and select the reason for the inspection.</p>
          <p><strong class="text-text-primary">2. Rate each room area.</strong> Walk through each room and rate the six standard areas: Floors, Walls and Baseboards, Windows and Sills, Fixtures and Hardware, Appliances, and Odor. Select Pass, Fail, or N/A for each area.</p>
          <p><strong class="text-text-primary">3. Log any issues found.</strong> For each problem you identify, add an issue with the room name, a description of the problem, the severity level (Minor, Moderate, or Major), and your recommended action.</p>
          <p><strong class="text-text-primary">4. Review the summary.</strong> The summary section automatically tallies your Pass, Fail, and N/A counts and calculates an overall rating. Add any final notes or recommendations.</p>
          <p><strong class="text-text-primary">5. Generate the report.</strong> Click the button to create a professional, print-ready inspection report. Save it as a PDF for your records or share it with the client or property manager.</p>
        </div>
      </section>

      <!-- What Makes a Good Inspection Report -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">What Makes a Professional Cleaning Inspection Report</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>A cleaning inspection report documents the condition of a property in a standardized, repeatable way. The goal is objectivity. Every inspector who walks the same property should produce a similar report because they are evaluating the same criteria using the same rating system.</p>
          <p>The room-by-room format ensures nothing gets skipped. Each room is evaluated on six areas that cover the full scope of a cleaning inspection: floors, walls, windows, fixtures, appliances, and odor. This consistency makes it easy to compare reports over time and identify recurring problem areas.</p>
          <p>The issues table is where the real value lives. Anyone can check Pass or Fail on a form. The difference between a basic inspection and a professional one is the detail in the findings. Describe the specific issue, rate its severity so the client knows what to prioritize, and provide a clear recommendation. This turns the report from a checklist into an action plan.</p>
          <p>The summary gives decision-makers what they need at a glance. A property manager reviewing ten inspection reports does not want to read every line item. The pass/fail counts and overall rating tell them immediately whether the property needs attention or meets the standard.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Move-in and move-out walkthroughs.</strong> Document the condition of every room before a tenant moves in or after they leave. This report becomes the baseline for security deposit disputes and cleaning charge justification. Take it room by room, photograph anything that fails, and attach the report to the lease file.</p>
          <p><strong class="text-text-primary">Post-clean quality checks.</strong> After a deep clean or post-construction cleanup, run this inspection before the client sees the property. Catching missed areas before the walkthrough prevents callbacks and protects your reputation. It also gives the client a professional document showing what was evaluated.</p>
          <p><strong class="text-text-primary">Recurring commercial contracts.</strong> For office buildings, medical facilities, and retail spaces, regular inspections keep your cleaning standards verifiable. Monthly or quarterly inspection reports show the property manager that you are maintaining the agreed-upon level of service and catching issues proactively.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should a cleaning inspection report include?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A professional cleaning inspection report should include property identification (address, property type, inspection date), a room-by-room assessment with Pass/Fail/N/A ratings for floors, walls and baseboards, windows and sills, fixtures and hardware, appliances, and odor. It should also include a dynamic issues table listing specific findings with severity and recommendations, a summary with total pass/fail counts, and an overall property rating.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">When should a cleaning inspection be performed?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Cleaning inspections are commonly performed during move-in and move-out walkthroughs, after deep cleans or post-construction cleanups, as part of quality control for recurring cleaning contracts, and during property management turnover reviews. Regular inspections on commercial contracts help maintain standards and catch issues before they become complaints.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What is a Pass/Fail rating system for cleaning inspections?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A Pass/Fail/N/A system rates each area of each room on a simple three-point scale. Pass means the area meets the cleanliness standard. Fail means the area does not meet the standard and needs attention. N/A means the area is not applicable to that room, such as appliances in a bedroom. This system is fast to use on site and produces clear, objective documentation that clients and property managers understand immediately.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I write a professional cleaning inspection report?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Start with complete property and inspector identification. Rate each area in each room using a standardized Pass/Fail/N/A scale. Document every issue found with the specific room, a description of the problem, a severity rating (minor, moderate, or major), and a recommended action. Include an overall assessment with total pass and fail counts. Generate a clean PDF report that can be shared with clients, property managers, or your own records.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // --- Config ---
    const ROOMS = [
      { id: 'kitchen', label: 'Kitchen' },
      { id: 'bathrooms', label: 'Bathrooms' },
      { id: 'bedrooms', label: 'Bedrooms' },
      { id: 'living', label: 'Living Areas' },
      { id: 'laundry', label: 'Laundry Room' },
      { id: 'entry', label: 'Exterior Entry' },
    ];
    const AREAS = [
      'Floors',
      'Walls & Baseboards',
      'Windows & Sills',
      'Fixtures & Hardware',
      'Appliances',
      'Odor',
    ];
    const RATINGS = ['Pass', 'Fail', 'N/A'];

    // --- Default date ---
    const dateInput = document.getElementById('inspection-date') as HTMLInputElement;
    if (dateInput && !dateInput.value) {
      dateInput.value = new Date().toISOString().slice(0, 10);
    }

    // --- Render Room Assessments ---
    const container = document.getElementById('room-assessments')!;
    ROOMS.forEach(room => {
      const section = document.createElement('div');
      section.className = 'bg-bg-dark rounded-lg p-4';
      let areasHtml = '';
      AREAS.forEach((area, aIdx) => {
        const baseName = `rating-${room.id}-${aIdx}`;
        areasHtml += `
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 py-2 ${aIdx < AREAS.length - 1 ? 'border-b border-border/50' : ''}">
            <span class="text-sm text-text-secondary font-medium">${area}</span>
            <div class="flex gap-2">
              ${RATINGS.map(r => `
                <label class="cursor-pointer">
                  <input type="radio" name="${baseName}" value="${r}" class="sr-only rating-radio" data-room="${room.id}" data-area="${aIdx}" />
                  <span class="inline-block px-3 py-1 rounded text-xs font-bold uppercase tracking-wider border transition-colors
                    ${r === 'Pass' ? 'border-[#34D399]/30 text-text-muted hover:bg-[#34D399]/20 hover:text-[#34D399] hover:border-[#34D399]/50' : ''}
                    ${r === 'Fail' ? 'border-[#EF4444]/30 text-text-muted hover:bg-[#EF4444]/20 hover:text-[#EF4444] hover:border-[#EF4444]/50' : ''}
                    ${r === 'N/A' ? 'border-border text-text-muted hover:bg-[rgba(255,255,255,0.05)] hover:text-text-secondary' : ''}
                  ">${r}</span>
                </label>
              `).join('')}
            </div>
          </div>
        `;
      });

      section.innerHTML = `
        <h4 class="font-heading font-bold text-sm uppercase tracking-wider text-text-muted mb-3">${room.label}</h4>
        ${areasHtml}
      `;
      container.appendChild(section);
    });

    // --- Rating radio styling ---
    container.addEventListener('change', (e) => {
      const radio = e.target as HTMLInputElement;
      if (!radio.classList.contains('rating-radio')) return;

      // Update visual state for all radios in same group
      const name = radio.name;
      document.querySelectorAll<HTMLInputElement>(`input[name="${name}"]`).forEach(r => {
        const span = r.nextElementSibling as HTMLElement;
        const val = r.value;
        if (r.checked) {
          span.classList.remove('border-[#34D399]/30', 'border-[#EF4444]/30', 'border-border', 'text-text-muted');
          if (val === 'Pass') {
            span.classList.add('bg-[#34D399]/20', 'text-[#34D399]', 'border-[#34D399]/50');
          } else if (val === 'Fail') {
            span.classList.add('bg-[#EF4444]/20', 'text-[#EF4444]', 'border-[#EF4444]/50');
          } else {
            span.classList.add('bg-[rgba(255,255,255,0.1)]', 'text-text-secondary', 'border-border');
          }
        } else {
          span.classList.remove('bg-[#34D399]/20', 'text-[#34D399]', 'border-[#34D399]/50',
            'bg-[#EF4444]/20', 'text-[#EF4444]', 'border-[#EF4444]/50',
            'bg-[rgba(255,255,255,0.1)]', 'text-text-secondary');
          if (val === 'Pass') {
            span.classList.add('border-[#34D399]/30', 'text-text-muted');
          } else if (val === 'Fail') {
            span.classList.add('border-[#EF4444]/30', 'text-text-muted');
          } else {
            span.classList.add('border-border', 'text-text-muted');
          }
        }
      });

      updateSummary();
    });

    // --- Summary Calculation ---
    function updateSummary() {
      let pass = 0, fail = 0, na = 0;
      document.querySelectorAll<HTMLInputElement>('.rating-radio:checked').forEach(r => {
        if (r.value === 'Pass') pass++;
        else if (r.value === 'Fail') fail++;
        else na++;
      });

      document.getElementById('summary-pass')!.textContent = String(pass);
      document.getElementById('summary-fail')!.textContent = String(fail);
      document.getElementById('summary-na')!.textContent = String(na);

      const rated = pass + fail;
      const overallEl = document.getElementById('summary-overall')!;
      if (rated > 0) {
        const pct = (pass / rated) * 100;
        overallEl.textContent = pct.toFixed(0) + '%';
        overallEl.classList.remove('text-[#34D399]', 'text-[#FBBF24]', 'text-[#EF4444]', 'text-text-primary');
        if (pct >= 90) overallEl.classList.add('text-[#34D399]');
        else if (pct >= 70) overallEl.classList.add('text-[#FBBF24]');
        else overallEl.classList.add('text-[#EF4444]');
      } else {
        overallEl.textContent = '--';
        overallEl.classList.remove('text-[#34D399]', 'text-[#FBBF24]', 'text-[#EF4444]');
        overallEl.classList.add('text-text-primary');
      }
    }

    // --- Dynamic Issues Table ---
    let issueId = 0;
    function addIssueRow() {
      issueId++;
      const table = document.getElementById('issues-table')!;
      const row = document.createElement('div');
      row.className = 'grid grid-cols-1 md:grid-cols-[1fr_1fr_120px_1fr_40px] gap-3 items-end issue-row bg-bg-dark rounded-lg p-3 md:p-0 md:bg-transparent md:rounded-none';
      row.innerHTML = `
        <div>
          <label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Room</label>
          <select class="issue-room w-full bg-bg-dark border border-border rounded-lg px-3 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors">
            ${ROOMS.map(r => `<option value="${r.label}">${r.label}</option>`).join('')}
          </select>
        </div>
        <div>
          <label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Issue</label>
          <input type="text" placeholder="Describe the issue" class="issue-desc w-full bg-bg-dark border border-border rounded-lg px-3 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div>
          <label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Severity</label>
          <select class="issue-severity w-full bg-bg-dark border border-border rounded-lg px-3 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors">
            <option value="Minor">Minor</option>
            <option value="Moderate">Moderate</option>
            <option value="Major">Major</option>
          </select>
        </div>
        <div>
          <label class="md:hidden block text-text-muted text-xs font-medium uppercase tracking-wider mb-1">Recommendation</label>
          <input type="text" placeholder="Recommended action" class="issue-rec w-full bg-bg-dark border border-border rounded-lg px-3 py-2 text-text-primary text-sm focus:border-accent focus:outline-none transition-colors" />
        </div>
        <div class="flex justify-end">
          <button type="button" class="remove-issue-btn text-text-muted hover:text-red-400 transition-colors cursor-pointer text-lg leading-none" title="Remove">&times;</button>
        </div>
      `;
      table.appendChild(row);
    }

    document.getElementById('add-issue-btn')?.addEventListener('click', addIssueRow);

    document.getElementById('issues-table')?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains('remove-issue-btn')) {
        const row = target.closest('.issue-row');
        if (row) row.remove();
      }
    });

    // Add one empty issue row by default
    addIssueRow();

    // --- Helper functions ---
    function getVal(id: string): string {
      const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
      return el ? el.value : '';
    }
    function escapeHtml(str: string): string {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // --- Generate Report ---
    function generateReport() {
      // Collect room ratings
      let roomRatingsHtml = '';
      ROOMS.forEach(room => {
        let rowsHtml = '';
        AREAS.forEach((area, aIdx) => {
          const checked = document.querySelector<HTMLInputElement>(`input[name="rating-${room.id}-${aIdx}"]:checked`);
          const val = checked ? checked.value : '\u2014';
          let color = '#666';
          if (val === 'Pass') color = '#16a34a';
          else if (val === 'Fail') color = '#dc2626';
          rowsHtml += `<tr><td style="border:1px solid #ddd;padding:6px 10px;font-size:13px;">${area}</td><td style="border:1px solid #ddd;padding:6px 10px;text-align:center;font-weight:700;color:${color};font-size:13px;">${val}</td></tr>`;
        });
        roomRatingsHtml += `
          <div style="margin-bottom:16px;">
            <div style="font-weight:700;font-size:14px;text-transform:uppercase;letter-spacing:0.5px;color:#333;margin-bottom:4px;">${room.label}</div>
            <table style="width:100%;border-collapse:collapse;"><tbody>${rowsHtml}</tbody></table>
          </div>
        `;
      });

      // Collect issues
      const issueRows = document.querySelectorAll('.issue-row');
      let issuesHtml = '';
      issueRows.forEach(row => {
        const room = (row.querySelector('.issue-room') as HTMLSelectElement)?.value || '';
        const desc = (row.querySelector('.issue-desc') as HTMLInputElement)?.value || '';
        const severity = (row.querySelector('.issue-severity') as HTMLSelectElement)?.value || '';
        const rec = (row.querySelector('.issue-rec') as HTMLInputElement)?.value || '';
        if (desc) {
          let sevColor = '#666';
          if (severity === 'Major') sevColor = '#dc2626';
          else if (severity === 'Moderate') sevColor = '#ca8a04';
          issuesHtml += `<tr>
            <td style="border:1px solid #ddd;padding:6px 10px;font-size:13px;">${escapeHtml(room)}</td>
            <td style="border:1px solid #ddd;padding:6px 10px;font-size:13px;">${escapeHtml(desc)}</td>
            <td style="border:1px solid #ddd;padding:6px 10px;font-size:13px;font-weight:700;color:${sevColor};">${escapeHtml(severity)}</td>
            <td style="border:1px solid #ddd;padding:6px 10px;font-size:13px;">${escapeHtml(rec)}</td>
          </tr>`;
        }
      });

      // Summary counts
      let pass = 0, fail = 0, na = 0;
      document.querySelectorAll<HTMLInputElement>('.rating-radio:checked').forEach(r => {
        if (r.value === 'Pass') pass++;
        else if (r.value === 'Fail') fail++;
        else na++;
      });
      const rated = pass + fail;
      const overallPct = rated > 0 ? ((pass / rated) * 100).toFixed(0) + '%' : 'N/A';
      let overallLabel = 'N/A';
      let overallColor = '#666';
      if (rated > 0) {
        const pct = (pass / rated) * 100;
        if (pct >= 90) { overallLabel = 'Excellent'; overallColor = '#16a34a'; }
        else if (pct >= 70) { overallLabel = 'Acceptable'; overallColor = '#ca8a04'; }
        else { overallLabel = 'Needs Attention'; overallColor = '#dc2626'; }
      }

      const html = `<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Inspection Report ${escapeHtml(getVal('report-number'))}</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color:#1a1a1a; padding:40px; max-width:850px; margin:0 auto; font-size:14px; line-height:1.5; }
  h1 { font-size:22px; margin-bottom:4px; }
  h2 { font-size:15px; color:#333; margin:20px 0 8px; padding-bottom:4px; border-bottom:2px solid #e5e5e5; text-transform:uppercase; letter-spacing:0.5px; }
  .header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:20px; padding-bottom:16px; border-bottom:3px solid #1a1a1a; }
  .grid2 { display:grid; grid-template-columns:1fr 1fr; gap:4px 24px; margin-bottom:6px; }
  .grid2 .label { font-weight:600; font-size:12px; color:#666; text-transform:uppercase; letter-spacing:0.3px; }
  .grid2 .value { font-size:14px; margin-bottom:6px; }
  table { width:100%; border-collapse:collapse; margin-bottom:8px; }
  th { background:#f0f0f0; border:1px solid #ddd; padding:6px 10px; text-align:left; font-size:12px; text-transform:uppercase; letter-spacing:0.3px; }
  .summary-box { display:inline-block; padding:8px 20px; border-radius:6px; font-weight:700; font-size:18px; margin-right:12px; }
  .text-block { margin-bottom:12px; }
  .text-block .label { font-weight:600; font-size:12px; color:#666; text-transform:uppercase; letter-spacing:0.3px; margin-bottom:2px; }
  .text-block .value { font-size:14px; white-space:pre-wrap; background:#f9f9f9; padding:8px 10px; border-radius:4px; min-height:24px; }
  @media print { body { padding:20px; } }
</style>
</head><body>
<div class="header">
  <div>
    <h1>Cleaning Inspection Report</h1>
    <div style="font-size:13px;color:#555;">Property Condition Assessment</div>
  </div>
  <div style="text-align:right;">
    <div style="font-size:20px;font-weight:700;">${escapeHtml(getVal('report-number'))}</div>
    <div style="font-size:13px;color:#555;">${getVal('inspection-date')}</div>
  </div>
</div>

<h2>Inspector &amp; Property</h2>
<div class="grid2">
  <div><span class="label">Company:</span></div><div><span class="label">Inspector:</span></div>
  <div class="value">${escapeHtml(getVal('company-name')) || '\u2014'}</div><div class="value">${escapeHtml(getVal('inspector-name')) || '\u2014'}</div>
  <div><span class="label">Phone:</span></div><div><span class="label">Reason:</span></div>
  <div class="value">${escapeHtml(getVal('inspector-phone')) || '\u2014'}</div><div class="value">${escapeHtml(getVal('inspection-reason'))}</div>
  <div><span class="label">Property Address:</span></div><div></div>
  <div class="value">${escapeHtml(getVal('property-address')) || '\u2014'}</div><div></div>
</div>

<h2>Room-by-Room Assessment</h2>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:0 24px;">
  ${roomRatingsHtml}
</div>

${issuesHtml ? `<h2>Issues Found</h2>
<table><thead><tr><th>Room</th><th>Issue</th><th>Severity</th><th>Recommendation</th></tr></thead><tbody>${issuesHtml}</tbody></table>` : ''}

<h2>Summary</h2>
<div style="margin-bottom:16px;">
  <span class="summary-box" style="background:#e0f2e9;color:#166534;">Pass: ${pass}</span>
  <span class="summary-box" style="background:#fee2e2;color:#991b1b;">Fail: ${fail}</span>
  <span class="summary-box" style="background:#f3f4f6;color:#666;">N/A: ${na}</span>
</div>
<div style="margin-bottom:16px;">
  <span style="font-size:14px;color:#666;">Overall Rating:</span>
  <span style="font-size:22px;font-weight:800;color:${overallColor};margin-left:8px;">${overallPct} - ${overallLabel}</span>
</div>

${getVal('overall-notes') ? `<div class="text-block"><div class="label">Notes / Recommendations</div><div class="value">${escapeHtml(getVal('overall-notes'))}</div></div>` : ''}

<div style="margin-top:40px;padding-top:16px;border-top:1px solid #1a1a1a;">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;">
    <div>
      <div style="font-size:16px;font-weight:600;min-height:20px;">${escapeHtml(getVal('inspector-name'))}</div>
      <div style="border-top:1px solid #1a1a1a;padding-top:6px;font-size:12px;color:#666;text-transform:uppercase;">Inspector Signature</div>
    </div>
    <div>
      <div style="font-size:16px;font-weight:600;min-height:20px;">&nbsp;</div>
      <div style="border-top:1px solid #1a1a1a;padding-top:6px;font-size:12px;color:#666;text-transform:uppercase;">Client / Property Manager Signature</div>
    </div>
  </div>
</div>

</body></html>`;

      const printWindow = window.open('', '_blank');
      if (printWindow) {
        printWindow.document.write(html);
        printWindow.document.close();
      }
    }

    document.getElementById('generate-btn')?.addEventListener('click', generateReport);
  });
</script>
