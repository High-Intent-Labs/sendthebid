---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getToolBySlug } from '../../data/handymanTools';

const tool = getToolBySlug('estimate-template')!;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should a handyman estimate include?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A professional handyman estimate should include your company name, phone, email, and license or registration number. List the customer's name and address, a clear project description with scope of work, itemized costs for labor and materials, optional add-ons, tax, deposit and balance amounts, warranty terms, payment methods accepted, and a validity period with expiration date."
      }
    },
    {
      "@type": "Question",
      "name": "How long should a handyman estimate be valid?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most handyman estimates are valid for 30 days. Material prices at home improvement stores are relatively stable within that window. During peak season or periods of supply chain disruption, some handymen shorten validity to 14 or 21 days. Always include a clear expiration date on the estimate so the customer knows the price is not open-ended."
      }
    },
    {
      "@type": "Question",
      "name": "Should I require a deposit before starting handyman work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For jobs over $500, requiring a 50% deposit is standard practice and protects both parties. The deposit covers your material costs and reserves your schedule. For smaller jobs under $500, most handymen collect full payment on completion. Always state the deposit amount and balance due on completion clearly on the estimate so there are no surprises."
      }
    },
    {
      "@type": "Question",
      "name": "How do I present optional add-ons on a handyman estimate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "List add-ons as separate optional line items below the main scope of work. Common handyman add-ons include paint touchup, haul-away and disposal, minor adjacent repairs, and extended cleanup. Presenting add-ons increases your average ticket by 15 to 25 percent because customers feel in control of the decision rather than being upsold during the job."
      }
    }
  ]
};
---

<ToolLayout tool={tool} extraSchema={[faqSchema]}>
  <div id="estimate-builder">
    <!-- Company Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Company Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="companyName">Company Name</label>
        <input type="text" id="companyName" placeholder="Your Handyman Co." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="companyPhone">Phone</label>
        <input type="text" id="companyPhone" placeholder="(555) 123-4567" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="companyEmail">Email</label>
        <input type="text" id="companyEmail" placeholder="info@yourhandyman.com" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="licenseNum">License / Registration #</label>
        <input type="text" id="licenseNum" placeholder="HM-12345" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="estimateNum">Estimate #</label>
        <input type="text" id="estimateNum" value="EST-001" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="estimateDate">Estimate Date</label>
        <input type="date" id="estimateDate" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="validDays">Valid For (days)</label>
        <select id="validDays" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="14">14 days</option>
          <option value="30" selected>30 days</option>
          <option value="60">60 days</option>
        </select>
      </div>
    </div>

    <!-- Customer Info -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Customer Info</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customerName">Customer Name</label>
        <input type="text" id="customerName" placeholder="John Smith" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customerPhone">Phone</label>
        <input type="text" id="customerPhone" placeholder="(555) 987-6543" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="customerAddress">Address</label>
        <input type="text" id="customerAddress" placeholder="123 Main St, Anytown, ST 12345" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Project Details -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Project Details</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="projectType">Project Type</label>
        <select id="projectType" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="General Repair">General Repair</option>
          <option value="Drywall Repair">Drywall Repair</option>
          <option value="Painting / Touchup">Painting / Touchup</option>
          <option value="Furniture Assembly">Furniture Assembly</option>
          <option value="Door / Window Repair">Door / Window Repair</option>
          <option value="Shelving / Mounting">Shelving / Mounting</option>
          <option value="Tile Repair">Tile Repair</option>
          <option value="Caulking / Weatherproofing">Caulking / Weatherproofing</option>
          <option value="Fixture Replacement">Fixture Replacement</option>
          <option value="Multi-Task Bundle">Multi-Task Bundle</option>
          <option value="Other">Other</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="projectLocation">Location in Home</label>
        <input type="text" id="projectLocation" placeholder="e.g., Kitchen, Master Bedroom" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-text-secondary mb-2" for="scopeDescription">Scope of Work</label>
        <textarea id="scopeDescription" rows="4" placeholder="Describe what work will be performed..." class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors resize-y"></textarea>
      </div>
    </div>

    <!-- Scope Checklist -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Scope Checklist</h3>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-8">
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" id="chk-remove" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <span class="text-text-primary text-sm">Remove existing</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" id="chk-prep" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <span class="text-text-primary text-sm">Prep / protect area</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" id="chk-install" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <span class="text-text-primary text-sm">Install / repair</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" id="chk-paint" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <span class="text-text-primary text-sm">Paint / finish</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" id="chk-cleanup" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <span class="text-text-primary text-sm">Cleanup / haul away</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" id="chk-materials" class="w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" />
        <span class="text-text-primary text-sm">Materials included</span>
      </label>
    </div>

    <!-- Cost Breakdown (Line Items) -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Cost Breakdown</h3>
    <div class="mb-4">
      <div class="flex flex-wrap gap-2 mb-4">
        <button type="button" class="quick-add-btn bg-accent/10 text-accent border border-accent/30 rounded-lg px-3 py-1.5 text-sm font-medium hover:bg-accent/20 transition-colors cursor-pointer" data-desc="Service Call" data-qty="1" data-price="75">+ Service Call $75</button>
        <button type="button" class="quick-add-btn bg-accent/10 text-accent border border-accent/30 rounded-lg px-3 py-1.5 text-sm font-medium hover:bg-accent/20 transition-colors cursor-pointer" data-desc="Labor (per hour)" data-qty="1" data-price="75">+ Labor/hr $75</button>
        <button type="button" class="quick-add-btn bg-accent/10 text-accent border border-accent/30 rounded-lg px-3 py-1.5 text-sm font-medium hover:bg-accent/20 transition-colors cursor-pointer" data-desc="Drywall Patch &amp; Repair" data-qty="1" data-price="125">+ Drywall Patch $125</button>
        <button type="button" class="quick-add-btn bg-accent/10 text-accent border border-accent/30 rounded-lg px-3 py-1.5 text-sm font-medium hover:bg-accent/20 transition-colors cursor-pointer" data-desc="Paint Touchup" data-qty="1" data-price="95">+ Paint Touchup $95</button>
        <button type="button" class="quick-add-btn bg-accent/10 text-accent border border-accent/30 rounded-lg px-3 py-1.5 text-sm font-medium hover:bg-accent/20 transition-colors cursor-pointer" data-desc="Furniture Assembly" data-qty="1" data-price="85">+ Assembly $85</button>
      </div>
      <div id="line-items" class="space-y-3">
        <div class="grid grid-cols-[1fr_60px_100px_40px] gap-3 items-end line-row">
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">Description</label>
            <input type="text" class="line-desc w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">Qty</label>
            <input type="number" value="1" min="1" class="line-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">Price ($)</label>
            <input type="number" value="0" min="0" step="5" class="line-price w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-2">&nbsp;</label>
            <button type="button" class="remove-line-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove">&times;</button>
          </div>
        </div>
      </div>
      <button type="button" id="add-line-btn" class="mt-3 text-accent hover:text-accent-hover transition-colors cursor-pointer text-sm font-medium">+ Add Line Item</button>
    </div>

    <!-- Optional Add-Ons -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Optional Add-Ons</h3>
    <div class="space-y-3 mb-8">
      <label class="flex items-center justify-between bg-bg-dark border border-border rounded-lg px-4 py-3 cursor-pointer hover:border-accent/50 transition-colors">
        <div class="flex items-center gap-3">
          <input type="checkbox" id="addon-paint" class="addon-check w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" data-price="150" />
          <span class="text-text-primary">Paint touchup (matching color)</span>
        </div>
        <span class="text-accent font-bold">$150</span>
      </label>
      <label class="flex items-center justify-between bg-bg-dark border border-border rounded-lg px-4 py-3 cursor-pointer hover:border-accent/50 transition-colors">
        <div class="flex items-center gap-3">
          <input type="checkbox" id="addon-haul" class="addon-check w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" data-price="75" />
          <span class="text-text-primary">Haul away / disposal</span>
        </div>
        <span class="text-accent font-bold">$75</span>
      </label>
      <label class="flex items-center justify-between bg-bg-dark border border-border rounded-lg px-4 py-3 cursor-pointer hover:border-accent/50 transition-colors">
        <div class="flex items-center gap-3">
          <input type="checkbox" id="addon-minor" class="addon-check w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" data-price="100" />
          <span class="text-text-primary">Minor adjacent repairs</span>
        </div>
        <span class="text-accent font-bold">$100</span>
      </label>
      <label class="flex items-center justify-between bg-bg-dark border border-border rounded-lg px-4 py-3 cursor-pointer hover:border-accent/50 transition-colors">
        <div class="flex items-center gap-3">
          <input type="checkbox" id="addon-cleanup" class="addon-check w-5 h-5 rounded border-border bg-bg-dark text-accent focus:ring-accent cursor-pointer" data-price="50" />
          <span class="text-text-primary">Extended cleanup</span>
        </div>
        <span class="text-accent font-bold">$50</span>
      </label>
    </div>

    <!-- Estimate Settings -->
    <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Estimate Settings</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="taxRate">Tax Rate (%)</label>
        <input type="number" id="taxRate" value="0" min="0" max="15" step="0.25" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="depositPct">Deposit (%)</label>
        <select id="depositPct" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="0">None</option>
          <option value="25">25%</option>
          <option value="50" selected>50%</option>
          <option value="100">100% upfront</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="warranty">Warranty</label>
        <select id="warranty" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors">
          <option value="30-day workmanship guarantee" selected>30-day workmanship</option>
          <option value="90-day workmanship guarantee">90-day workmanship</option>
          <option value="1-year workmanship guarantee">1-year workmanship</option>
          <option value="No warranty">No warranty</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-secondary mb-2" for="paymentMethods">Payment Methods</label>
        <input type="text" id="paymentMethods" value="Cash, Check, Venmo, Zelle" class="w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="bg-bg-dark border border-border rounded-xl p-6 mb-8">
      <h3 class="font-heading font-bold text-lg mb-4 text-text-primary">Estimate Summary</h3>
      <div class="space-y-3 text-lg">
        <div class="flex justify-between">
          <span class="text-text-secondary">Subtotal</span>
          <span id="r-subtotal" class="text-text-primary font-bold">$0.00</span>
        </div>
        <div class="flex justify-between">
          <span class="text-text-secondary">Add-Ons</span>
          <span id="r-addons" class="text-text-primary font-bold">$0.00</span>
        </div>
        <div class="flex justify-between">
          <span class="text-text-secondary">Tax</span>
          <span id="r-tax" class="text-text-primary font-bold">$0.00</span>
        </div>
        <div class="flex justify-between border-t border-border pt-3">
          <span class="text-text-primary font-bold text-xl">Total</span>
          <span id="r-total" class="text-accent font-extrabold text-2xl">$0.00</span>
        </div>
        <div class="flex justify-between mt-2">
          <span class="text-text-secondary">Deposit Due</span>
          <span id="r-deposit" class="text-text-primary font-bold">$0.00</span>
        </div>
        <div class="flex justify-between">
          <span class="text-text-secondary">Balance on Completion</span>
          <span id="r-balance" class="text-text-primary font-bold">$0.00</span>
        </div>
      </div>
    </div>

    <!-- Generate Button -->
    <button id="generate-btn" class="w-full md:w-auto bg-accent text-white font-heading font-bold text-base uppercase tracking-wider px-8 py-3.5 rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(255,107,43,0.3)] transition-all cursor-pointer">
      Generate Estimate PDF &rarr;
    </button>
  </div>

  <!-- Content sections -->
  <Fragment slot="content">
    <div class="max-w-[1080px] mx-auto px-6 md:px-12 pb-16 space-y-12">
      <!-- How to Use -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">How to Use This Estimate Template</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">1. Fill in your company and customer details.</strong> Start with your business name, phone, email, and license number. Add the customer's name, address, and phone. This information appears at the top of the PDF and establishes your professionalism before the customer reads a single line item.</p>
          <p><strong class="text-text-primary">2. Describe the project.</strong> Select the project type, note the location in the home, and write a clear scope of work. Use the scope checklist to confirm what is included — removal, prep, install, paint, cleanup, and whether materials are part of the price.</p>
          <p><strong class="text-text-primary">3. Add line items.</strong> Use the quick-add buttons for common handyman charges or add custom line items. Enter a description, quantity, and unit price for each line. The totals update automatically as you type.</p>
          <p><strong class="text-text-primary">4. Select add-ons and settings.</strong> Check any optional add-ons the customer might want. Set your tax rate, deposit percentage, warranty level, and accepted payment methods. The estimate summary recalculates in real time.</p>
          <p><strong class="text-text-primary">5. Generate the PDF.</strong> Hit the button to create a clean, print-ready estimate with your branding, itemized costs, deposit and balance amounts, warranty terms, and signature lines for both parties.</p>
        </div>
      </section>

      <!-- Why Estimates Matter -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Why Written Estimates Win More Jobs</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p>A verbal quote is forgotten before you leave the driveway. A written estimate lives on the customer's kitchen counter, gets forwarded to a spouse, and sits in an email inbox waiting for a decision. It keeps working for you after you walk away.</p>
          <p><strong class="text-text-primary">Itemized costs build trust.</strong> When customers see each charge broken out — service call, labor hours, materials, cleanup — they understand what they are paying for. Lump-sum quotes invite suspicion. Itemized estimates invite acceptance.</p>
          <p><strong class="text-text-primary">Add-ons increase your average ticket.</strong> Listing optional services like paint touchup, haul-away, and minor adjacent repairs gives customers a reason to spend more without feeling pressured. The customer decides which extras to include, and your revenue per job grows 15 to 25 percent.</p>
          <p><strong class="text-text-primary">Deposit and payment terms set expectations.</strong> A 50 percent deposit protects you from no-shows and covers material costs. Listing accepted payment methods — including Venmo and Zelle — eliminates the awkward conversation at the end of the job when the customer says they do not have a check.</p>
          <p><strong class="text-text-primary">Warranty language reduces callbacks.</strong> Stating a 30-day workmanship guarantee clearly on the estimate defines what is covered and for how long. Customers know what to expect, and you have documentation to reference if a dispute arises months later.</p>
        </div>
      </section>

      <!-- When To Use This -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">When To Use This</h2>
        <div class="text-text-secondary leading-relaxed space-y-3">
          <p><strong class="text-text-primary">Any job over $200.</strong> For small tasks that take less than an hour, a verbal price and a receipt after completion is fine. For anything more involved — drywall repairs, painting, assembly, shelving — a written estimate shows the customer you are professional and organized.</p>
          <p><strong class="text-text-primary">Multi-task bundles.</strong> When a customer has a list of five or six items they want done in a single visit, an estimate keeps everyone aligned on scope and price. It also makes it easy to show the savings of bundling tasks together versus separate service calls.</p>
          <p><strong class="text-text-primary">New customers.</strong> An estimate is your first impression. Repeat customers may be comfortable with a quick text message price, but new customers are comparing you to two or three other handymen. The one who sends a clean, professional estimate is the one who gets the job.</p>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-heading font-bold text-2xl mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">What should a handyman estimate include?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">A professional handyman estimate should include your company name, phone, email, and license or registration number. List the customer's name and address, a clear project description with scope of work, itemized costs for labor and materials, optional add-ons, tax, deposit and balance amounts, warranty terms, payment methods accepted, and a validity period with expiration date.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How long should a handyman estimate be valid?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">Most handyman estimates are valid for 30 days. Material prices at home improvement stores are relatively stable within that window. During peak season or periods of supply chain disruption, some handymen shorten validity to 14 or 21 days. Always include a clear expiration date on the estimate so the customer knows the price is not open-ended.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">Should I require a deposit before starting handyman work?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">For jobs over $500, requiring a 50% deposit is standard practice and protects both parties. The deposit covers your material costs and reserves your schedule. For smaller jobs under $500, most handymen collect full payment on completion. Always state the deposit amount and balance due on completion clearly on the estimate so there are no surprises.</div>
          </details>
          <details class="bg-bg-card border border-border rounded-lg">
            <summary class="px-5 py-4 cursor-pointer text-text-primary font-medium hover:text-accent transition-colors">How do I present optional add-ons on a handyman estimate?</summary>
            <div class="px-5 pb-4 text-text-secondary text-sm leading-relaxed">List add-ons as separate optional line items below the main scope of work. Common handyman add-ons include paint touchup, haul-away and disposal, minor adjacent repairs, and extended cleanup. Presenting add-ons increases your average ticket by 15 to 25 percent because customers feel in control of the decision rather than being upsold during the job.</div>
          </details>
        </div>
      </section>
    </div>
  </Fragment>
</ToolLayout>

<script>
  // --- Default dates ---
  const now = new Date();
  const dateInput = document.getElementById('estimateDate') as HTMLInputElement;
  if (dateInput && !dateInput.value) {
    dateInput.value = now.toISOString().slice(0, 10);
  }

  // --- Helpers ---
  function fmt(n: number): string {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  // --- Dynamic Line Items ---
  function addLineRow(desc = '', qty = '1', price = '0') {
    const table = document.getElementById('line-items')!;
    const row = document.createElement('div');
    row.className = 'grid grid-cols-[1fr_60px_100px_40px] gap-3 items-end line-row';
    row.innerHTML = `
      <div>
        <input type="text" value="${desc}" class="line-desc w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <input type="number" value="${qty}" min="1" class="line-qty w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <input type="number" value="${price}" min="0" step="5" class="line-price w-full bg-bg-dark border border-border rounded-lg px-4 py-3 text-text-primary text-lg focus:border-accent focus:outline-none transition-colors" />
      </div>
      <div>
        <button type="button" class="remove-line-btn w-full bg-red-900/30 text-red-400 rounded-lg py-3 hover:bg-red-900/50 transition-colors cursor-pointer text-lg font-bold" title="Remove">&times;</button>
      </div>
    `;
    table.appendChild(row);
    calculate();
  }

  document.getElementById('add-line-btn')?.addEventListener('click', () => addLineRow());

  // Quick-add buttons
  document.querySelectorAll('.quick-add-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      addLineRow(el.dataset.desc || '', el.dataset.qty || '1', el.dataset.price || '0');
    });
  });

  // Remove line item
  document.getElementById('line-items')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('remove-line-btn')) {
      const row = target.closest('.line-row');
      const allRows = document.querySelectorAll('.line-row');
      if (allRows.length > 1 && row) {
        row.remove();
        calculate();
      }
    }
  });

  // --- Calculate ---
  function calculate() {
    let subtotal = 0;
    document.querySelectorAll('.line-row').forEach(row => {
      const qty = parseFloat((row.querySelector('.line-qty') as HTMLInputElement)?.value) || 0;
      const price = parseFloat((row.querySelector('.line-price') as HTMLInputElement)?.value) || 0;
      subtotal += qty * price;
    });

    let addons = 0;
    document.querySelectorAll('.addon-check').forEach(chk => {
      const el = chk as HTMLInputElement;
      if (el.checked) {
        addons += parseFloat(el.dataset.price || '0');
      }
    });

    const taxRate = parseFloat((document.getElementById('taxRate') as HTMLInputElement).value) || 0;
    const tax = (subtotal + addons) * (taxRate / 100);
    const total = subtotal + addons + tax;

    const depositPct = parseFloat((document.getElementById('depositPct') as HTMLSelectElement).value) || 0;
    const deposit = total * (depositPct / 100);
    const balance = total - deposit;

    document.getElementById('r-subtotal')!.textContent = fmt(subtotal);
    document.getElementById('r-addons')!.textContent = fmt(addons);
    document.getElementById('r-tax')!.textContent = fmt(tax);
    document.getElementById('r-total')!.textContent = fmt(total);
    document.getElementById('r-deposit')!.textContent = fmt(deposit);
    document.getElementById('r-balance')!.textContent = fmt(balance);
  }

  // Attach listeners for auto-calculate
  document.getElementById('line-items')?.addEventListener('input', calculate);
  document.querySelectorAll('.addon-check').forEach(chk => chk.addEventListener('change', calculate));
  document.getElementById('taxRate')?.addEventListener('input', calculate);
  document.getElementById('depositPct')?.addEventListener('change', calculate);

  // Initial calculate
  calculate();

  // --- Generate Estimate PDF ---
  function getVal(id: string): string {
    const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
    return el ? el.value : '';
  }

  function generateEstimate() {
    const estDate = getVal('estimateDate');
    const validDays = parseInt(getVal('validDays')) || 30;
    let validUntil = '';
    if (estDate) {
      const d = new Date(estDate);
      d.setDate(d.getDate() + validDays);
      validUntil = d.toISOString().slice(0, 10);
    }

    const rows = document.querySelectorAll('.line-row');
    let lineItemsHtml = '';
    let subtotal = 0;
    rows.forEach(row => {
      const desc = (row.querySelector('.line-desc') as HTMLInputElement)?.value || '';
      const qty = parseFloat((row.querySelector('.line-qty') as HTMLInputElement)?.value) || 0;
      const price = parseFloat((row.querySelector('.line-price') as HTMLInputElement)?.value) || 0;
      const lineTotal = qty * price;
      subtotal += lineTotal;
      if (desc || price > 0) {
        lineItemsHtml += `<tr><td style="border:1px solid #ddd;padding:8px 12px;">${desc}</td><td style="border:1px solid #ddd;padding:8px 12px;text-align:center;">${qty}</td><td style="border:1px solid #ddd;padding:8px 12px;text-align:right;">${fmt(price)}</td><td style="border:1px solid #ddd;padding:8px 12px;text-align:right;">${fmt(lineTotal)}</td></tr>`;
      }
    });

    let addonsTotal = 0;
    let addonsHtml = '';
    document.querySelectorAll('.addon-check').forEach(chk => {
      const el = chk as HTMLInputElement;
      if (el.checked) {
        const price = parseFloat(el.dataset.price || '0');
        addonsTotal += price;
        const label = el.closest('label')?.querySelector('span.text-text-primary')?.textContent || '';
        addonsHtml += `<tr><td style="border:1px solid #ddd;padding:8px 12px;" colspan="3">${label} (add-on)</td><td style="border:1px solid #ddd;padding:8px 12px;text-align:right;">${fmt(price)}</td></tr>`;
      }
    });

    const taxRate = parseFloat(getVal('taxRate')) || 0;
    const tax = (subtotal + addonsTotal) * (taxRate / 100);
    const total = subtotal + addonsTotal + tax;
    const depositPct = parseFloat(getVal('depositPct')) || 0;
    const deposit = total * (depositPct / 100);
    const balance = total - deposit;

    const scopeItems = [
      { id: 'chk-remove', label: 'Remove existing' },
      { id: 'chk-prep', label: 'Prep / protect area' },
      { id: 'chk-install', label: 'Install / repair' },
      { id: 'chk-paint', label: 'Paint / finish' },
      { id: 'chk-cleanup', label: 'Cleanup / haul away' },
      { id: 'chk-materials', label: 'Materials included' },
    ];
    let scopeHtml = '';
    scopeItems.forEach(item => {
      const checked = (document.getElementById(item.id) as HTMLInputElement)?.checked;
      if (checked) {
        scopeHtml += `<span style="display:inline-block;background:#f0f9f0;color:#166534;padding:2px 10px;border-radius:4px;font-size:12px;margin:2px 4px 2px 0;">&#10003; ${item.label}</span>`;
      }
    });

    const html = `<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Estimate ${getVal('estimateNum')}</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color:#1a1a1a; padding:40px; max-width:850px; margin:0 auto; font-size:14px; line-height:1.5; }
  h1 { font-size:24px; margin-bottom:4px; }
  h2 { font-size:15px; color:#333; margin:24px 0 10px; padding-bottom:4px; border-bottom:2px solid #e5e5e5; text-transform:uppercase; letter-spacing:0.5px; }
  .header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:24px; padding-bottom:16px; border-bottom:3px solid #1a1a1a; }
  .grid2 { display:grid; grid-template-columns:1fr 1fr; gap:4px 24px; }
  .label { font-weight:600; font-size:12px; color:#666; text-transform:uppercase; letter-spacing:0.3px; }
  .value { font-size:14px; margin-bottom:6px; }
  table { width:100%; border-collapse:collapse; margin-bottom:8px; }
  th { background:#f0f0f0; border:1px solid #ddd; padding:8px 12px; text-align:left; font-size:12px; text-transform:uppercase; letter-spacing:0.3px; }
  td { border:1px solid #ddd; padding:8px 12px; }
  .totals { width:300px; margin-left:auto; margin-top:12px; }
  .totals td { border:none; padding:4px 8px; }
  .totals .total-row td { border-top:2px solid #1a1a1a; font-weight:700; font-size:16px; padding-top:8px; }
  .signature-block { display:grid; grid-template-columns:1fr 1fr; gap:40px; margin-top:50px; padding-top:16px; }
  .sig-line { border-top:1px solid #1a1a1a; padding-top:6px; font-size:12px; color:#666; text-transform:uppercase; }
  .footer { margin-top:30px; padding-top:12px; border-top:1px solid #e5e5e5; font-size:11px; color:#888; text-align:center; }
  @media print { body { padding:20px; } }
</style>
</head><body>
<div class="header">
  <div>
    <h1>${getVal('companyName') || 'Your Handyman Co.'}</h1>
    <div style="font-size:13px;color:#555;">${getVal('companyPhone')}${getVal('companyEmail') ? ' | ' + getVal('companyEmail') : ''}</div>
    ${getVal('licenseNum') ? '<div style="font-size:12px;color:#888;">License: ' + getVal('licenseNum') + '</div>' : ''}
  </div>
  <div style="text-align:right;">
    <div style="font-size:12px;color:#666;text-transform:uppercase;letter-spacing:0.5px;">Estimate</div>
    <div style="font-size:22px;font-weight:700;">${getVal('estimateNum')}</div>
    <div style="font-size:13px;color:#555;">Date: ${estDate}</div>
    <div style="font-size:13px;color:#555;">Valid until: ${validUntil}</div>
  </div>
</div>

<h2>Customer</h2>
<div class="grid2">
  <div><span class="label">Name:</span></div><div><span class="label">Phone:</span></div>
  <div class="value">${getVal('customerName') || '\u2014'}</div><div class="value">${getVal('customerPhone') || '\u2014'}</div>
  <div><span class="label">Address:</span></div><div></div>
  <div class="value">${getVal('customerAddress') || '\u2014'}</div><div></div>
</div>

<h2>Project Details</h2>
<div class="grid2">
  <div><span class="label">Project Type:</span></div><div><span class="label">Location:</span></div>
  <div class="value">${getVal('projectType')}</div><div class="value">${getVal('projectLocation') || '\u2014'}</div>
</div>
${getVal('scopeDescription') ? '<div style="margin-top:8px;"><span class="label">Scope of Work:</span><div class="value" style="background:#f9f9f9;padding:8px 10px;border-radius:4px;margin-top:4px;white-space:pre-wrap;">' + getVal('scopeDescription') + '</div></div>' : ''}
${scopeHtml ? '<div style="margin-top:8px;">' + scopeHtml + '</div>' : ''}

<h2>Cost Breakdown</h2>
<table>
  <thead><tr><th>Description</th><th style="text-align:center;">Qty</th><th style="text-align:right;">Unit Price</th><th style="text-align:right;">Amount</th></tr></thead>
  <tbody>${lineItemsHtml}${addonsHtml}</tbody>
</table>

<table class="totals">
  <tr><td style="text-align:right;color:#666;">Subtotal:</td><td style="text-align:right;">${fmt(subtotal)}</td></tr>
  ${addonsTotal > 0 ? '<tr><td style="text-align:right;color:#666;">Add-Ons:</td><td style="text-align:right;">' + fmt(addonsTotal) + '</td></tr>' : ''}
  ${tax > 0 ? '<tr><td style="text-align:right;color:#666;">Tax (' + taxRate + '%):</td><td style="text-align:right;">' + fmt(tax) + '</td></tr>' : ''}
  <tr class="total-row"><td style="text-align:right;">TOTAL:</td><td style="text-align:right;">${fmt(total)}</td></tr>
  ${depositPct > 0 && depositPct < 100 ? '<tr><td style="text-align:right;color:#666;font-size:12px;">Deposit (' + depositPct + '%):</td><td style="text-align:right;font-size:12px;">' + fmt(deposit) + '</td></tr><tr><td style="text-align:right;color:#666;font-size:12px;">Balance on completion:</td><td style="text-align:right;font-size:12px;">' + fmt(balance) + '</td></tr>' : ''}
</table>

<h2>Terms</h2>
<div class="grid2">
  <div><span class="label">Warranty:</span></div><div><span class="label">Payment Methods:</span></div>
  <div class="value">${getVal('warranty')}</div><div class="value">${getVal('paymentMethods')}</div>
</div>

<div class="signature-block">
  <div>
    <div style="min-height:40px;">&nbsp;</div>
    <div class="sig-line">Customer Signature &amp; Date</div>
  </div>
  <div>
    <div style="min-height:40px;">&nbsp;</div>
    <div class="sig-line">Contractor Signature &amp; Date</div>
  </div>
</div>

<div class="footer">
  This estimate is valid for ${validDays} days from the date shown above. Prices may change after the expiration date. Customer signature constitutes acceptance of the scope, pricing, and terms described in this document.
</div>

</body></html>`;

    const printWindow = window.open('', '_blank');
    if (printWindow) {
      printWindow.document.write(html);
      printWindow.document.close();
    }
  }

  document.getElementById('generate-btn')?.addEventListener('click', generateEstimate);
</script>
