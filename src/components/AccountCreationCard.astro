---
interface Props {
  toolName: string;
  toolSlug: string;
  tradeSlug: string;
  tradeName: string;
  category: 'technical' | 'business' | 'template' | 'sales';
}

const { toolName, toolSlug, tradeSlug, tradeName, category } = Astro.props;

// Contextual messaging for logged-out users
const signupMessaging: Record<string, { icon: string; title: string; description: string }> = {
  technical: {
    icon: '📊',
    title: 'Save this calculation to your account',
    description: 'Create a free account to save your results, compare sizing options side by side, and download a branded PDF you can attach to a quote.',
  },
  business: {
    icon: '📊',
    title: 'Save this calculation to your account',
    description: 'Create a free account to save your results, track your numbers over time, and download a branded PDF you can share with your accountant.',
  },
  template: {
    icon: '📄',
    title: `Save this ${toolName.toLowerCase().includes('invoice') ? 'invoice' : toolName.toLowerCase().includes('estimate') ? 'estimate' : toolName.toLowerCase().includes('agreement') ? 'agreement' : 'document'} to your account`,
    description: 'Create a free account to save your documents, pre-fill your business details next time, and access everything from any device.',
  },
  sales: {
    icon: '📥',
    title: 'Download a branded PDF of these results',
    description: 'Create a free account to download a professional PDF with your company logo and license number — ready to share with a customer.',
  },
};

// Contextual messaging for logged-in users
const saveMessaging: Record<string, { icon: string; title: string }> = {
  technical: { icon: '📊', title: 'Save this calculation to your account' },
  business: { icon: '📊', title: 'Save this calculation to your account' },
  template: { icon: '📄', title: `Save this ${toolName.toLowerCase().includes('invoice') ? 'invoice' : toolName.toLowerCase().includes('estimate') ? 'estimate' : toolName.toLowerCase().includes('agreement') ? 'agreement' : 'document'} to your account` },
  sales: { icon: '📥', title: 'Download a branded PDF' },
};

const signupMsg = signupMessaging[category] || signupMessaging.technical;
const saveMsg = saveMessaging[category] || saveMessaging.technical;
---

<!-- Logged-out state: signup prompt -->
<div
  id="account-creation-card"
  data-tool-slug={toolSlug}
  data-trade-slug={tradeSlug}
  data-tool-name={toolName}
  data-trade-name={tradeName}
  class="bg-bg-card border border-border rounded-2xl p-6 md:p-8 relative overflow-hidden flex flex-col sm:flex-row items-start sm:items-center gap-5 hover:border-[#3A4755] transition-colors"
>
  <div class="absolute left-0 top-0 bottom-0 w-1 bg-accent"></div>

  <div class="shrink-0 w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center text-2xl">
    {signupMsg.icon}
  </div>

  <!-- Logged-out body -->
  <div id="card-signup-body" class="flex-1 min-w-0">
    <h3 class="font-heading font-bold text-base md:text-lg text-text-primary mb-1">{signupMsg.title}</h3>
    <p class="text-text-secondary text-sm leading-relaxed">{signupMsg.description}</p>
  </div>

  <!-- Logged-in body (hidden by default) -->
  <div id="card-save-body" class="hidden flex-1 min-w-0">
    <h3 class="font-heading font-bold text-base md:text-lg text-text-primary">{saveMsg.title}</h3>
  </div>

  <!-- Logged-out CTA -->
  <div id="card-signup-cta" class="shrink-0 flex flex-col items-center">
    <button
      id="account-card-cta"
      type="button"
      class="bg-accent hover:bg-accent-hover text-white font-bold px-6 py-2.5 rounded-lg transition-colors whitespace-nowrap text-sm"
    >
      Sign Up Free
    </button>
    <button
      id="account-card-dismiss"
      type="button"
      class="mt-1.5 text-text-muted text-xs hover:text-text-secondary transition-colors bg-transparent border-none cursor-pointer"
    >
      Maybe later
    </button>
  </div>

  <!-- Logged-in CTA (hidden by default) -->
  <div id="card-save-cta" class="hidden shrink-0">
    <button
      id="account-card-save"
      type="button"
      class="bg-accent hover:bg-accent-hover text-white font-bold px-6 py-2.5 rounded-lg transition-colors whitespace-nowrap text-sm flex items-center gap-2"
    >
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none" class="text-white">
        <path d="M5 10l3 3 7-7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" id="save-check" class="hidden"/>
        <path d="M3 5a2 2 0 012-2h8.586a1 1 0 01.707.293l2.414 2.414a1 1 0 01.293.707V15a2 2 0 01-2 2H5a2 2 0 01-2-2V5z" stroke="currentColor" stroke-width="1.5" id="save-icon"/>
        <path d="M7 3v4h6V3M7 17v-5h6v5" stroke="currentColor" stroke-width="1.5" id="save-icon2"/>
      </svg>
      <span id="save-btn-text">Save</span>
    </button>
  </div>
</div>

<script>
  const card = document.getElementById('account-creation-card');
  const hasAccount = localStorage.getItem('ntq_has_account');

  if (hasAccount && card) {
    // Switch to logged-in save mode
    document.getElementById('card-signup-body')?.classList.add('hidden');
    document.getElementById('card-signup-cta')?.classList.add('hidden');
    document.getElementById('card-save-body')?.classList.remove('hidden');
    document.getElementById('card-save-cta')?.classList.remove('hidden');

    // Save button handler
    document.getElementById('account-card-save')?.addEventListener('click', async () => {
      const btn = document.getElementById('account-card-save') as HTMLButtonElement;
      const btnText = document.getElementById('save-btn-text')!;
      const saveIcon = document.getElementById('save-icon');
      const saveIcon2 = document.getElementById('save-icon2');
      const checkIcon = document.getElementById('save-check');

      btn.disabled = true;
      btnText.textContent = 'Saving...';

      try {
        let session = JSON.parse(localStorage.getItem('ntq_session') || '{}');
        let token = session.access_token;

        if (!token) throw new Error('No session');

        // Collect calculator inputs from the page
        const inputs: Record<string, string> = {};
        document.querySelectorAll<HTMLInputElement | HTMLSelectElement>(
          'input[type="number"], input[type="text"], select'
        ).forEach(el => {
          // Skip inputs inside account/email cards
          if (el.closest('#email-capture-card') || el.closest('#signup-modal')) return;
          const label = el.closest('div')?.querySelector('label')?.textContent?.trim()
            || el.getAttribute('data-field')
            || el.name
            || el.id;
          if (label && el.value) inputs[label] = el.value;
        });

        // Collect calculator outputs from the page
        const outputs: Record<string, string> = {};
        document.querySelectorAll('[id*="result"], [id*="output"], [class*="result"]').forEach(el => {
          const label = el.querySelector('[class*="muted"], [class*="label"], [class*="uppercase"]')?.textContent?.trim();
          const value = el.querySelector('[class*="accent"], [class*="primary"], [class*="bold"]')?.textContent?.trim();
          if (label && value) outputs[label] = value;
        });

        const payload = JSON.stringify({
          toolSlug: card.dataset.toolSlug,
          trade: card.dataset.tradeSlug,
          label: card.dataset.toolName,
          inputs: Object.keys(inputs).length > 0 ? inputs : { url: window.location.href },
          outputs: Object.keys(outputs).length > 0 ? outputs : {},
        });

        let res = await fetch('/api/dashboard/save-calculation', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: payload,
        });

        // If token expired, try refreshing and retry once
        if (res.status === 401 && session.refresh_token) {
          const refreshRes = await fetch('/api/auth/refresh', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ refresh_token: session.refresh_token }),
          });
          if (refreshRes.ok) {
            const newTokens = await refreshRes.json();
            session = { ...session, ...newTokens };
            try { localStorage.setItem('ntq_session', JSON.stringify(session)); } catch {}
            token = newTokens.access_token;
            res = await fetch('/api/dashboard/save-calculation', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
              body: payload,
            });
          }
        }

        if (!res.ok) {
          const errBody = await res.json().catch(() => ({}));
          throw new Error(errBody.detail || errBody.error || `HTTP ${res.status}`);
        }

        btnText.textContent = 'Saved';
        saveIcon?.classList.add('hidden');
        saveIcon2?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');
        btn.classList.remove('bg-accent', 'hover:bg-accent-hover');
        btn.classList.add('bg-[#059669]');
      } catch (e: any) {
        btnText.textContent = `Failed — ${e?.message || 'try again'}`;
        btn.disabled = false;
        btn.classList.remove('bg-[#059669]');
        btn.classList.add('bg-accent', 'hover:bg-accent-hover');
        setTimeout(() => { btnText.textContent = 'Save'; }, 3000);
      }
    });
  } else {
    // Logged-out: signup CTA
    document.getElementById('account-card-cta')?.addEventListener('click', () => {
      (window as any).openSignupModal?.('tier1_upsell');
    });

    // Dismiss
    document.getElementById('account-card-dismiss')?.addEventListener('click', () => {
      if (card) {
        card.style.transition = 'opacity 0.2s, margin 0.2s, padding 0.2s, max-height 0.3s';
        card.style.opacity = '0';
        card.style.maxHeight = '0';
        card.style.overflow = 'hidden';
        card.style.marginBottom = '0';
        card.style.paddingTop = '0';
        card.style.paddingBottom = '0';
        setTimeout(() => card.remove(), 300);
        try { sessionStorage.setItem('ntq_account_card_dismissed', '1'); } catch {}
      }
    });

    // Hide if dismissed this session
    try {
      if (sessionStorage.getItem('ntq_account_card_dismissed') === '1') {
        card?.remove();
      }
    } catch {}
  }
</script>
